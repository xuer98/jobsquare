on=\"SF\", url=\"u\", department=\"Eng\").content_hash\n        assert base.content_hash != make_job(title=\"A\", location=\"NYC\", url=\"u2\", department=\"Eng\").content_hash\n        assert base.content_hash != make_job(title=\"A\", location=\"NYC\", url=\"u\", department=\"Ops\").content_hash\n\n    def test_content_hash_ignores_non_material_fields(self):\n        # Documents current behavior: salary/posted_at/employment_type changes\n        # do NOT trigger store.diff's \"changed\" detection.\n        a = make_job(salary_range=\"$100k\", posted_at=\"2024-01-01\", employment_type=\"FT\")\n        b = make_job(salary_range=\"$200k\", posted_at=\"2025-01-01\", employment_type=\"PT\")\n        assert a.content_hash == b.content_hash\n\n    def test_to_row_excludes_raw_and_adds_derived_fields(self):\n        j = make_job(raw={\"secret\": \"blob\"})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash\n        assert row[\"title\"] == j.title\n```\n\n---\n\n",
