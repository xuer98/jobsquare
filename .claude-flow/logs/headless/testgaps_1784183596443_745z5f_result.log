        "code": "# tests/test_fetchers_async.py\nimport asyncio\nimport httpx\nimport pytest\nimport fetchers as f\n\n\ndef run(coro):\n    return asyncio.run(coro)\n\n\n@pytest.fixture(autouse=True)\ndef no_real_sleep(monkeypatch):\n    async def fast_sleep(_):\n        return None\n    monkeypatch.setattr(f.asyncio, \"sleep\", fast_sleep)\n\n\nclass TestRequestRetry:\n    def test_retries_transient_5xx_then_succeeds(self):\n        calls = {\"n\": 0}\n        def handler(request):\n            calls[\"n\"] += 1\n            if calls[\"n\"] < 3:\n                return httpx.Response(500)\n            return httpx.Response(200, json={\"ok\": True})\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        r = run(f._request(client, \"https://x.test/y\"))\n        assert r.status_code == 200 and calls[\"n\"] == 3\n\n    def test_exhausts_retries_raises_runtime_error(self):\n        client = httpx.AsyncClient(\n            transport=httpx.MockTransport(lambda req: httpx.Response(503)))\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            run(f._request(client, \"https://x.test/y\", retries=2))\n\n    def test_permanent_4xx_is_still_retried_up_to_limit(self):\n        # Documents current behavior: raise_for_status() raises HTTPStatusError\n        # for ANY non-2xx, which the except clause catches generically — so a\n        # permanent 404 gets retried `retries` times just like a 503 would,\n        # even though only 429/500/502/503/504 are the intended \"retryable\" set.\n        calls = {\"n\": 0}\n        def handler(request):\n            calls[\"n\"] += 1\n            return httpx.Response(404)\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        with pytest.raises(RuntimeError):\n            run(f._request(client, \"https://x.test/y\", retries=3))\n        assert calls[\"n\"] == 3  # not 1 — worth revisiting in the implementation\n\n\nclass TestFetchSource:\n    def test_unknown_ats_raises_value_error(self):\n        client = httpx.AsyncClient(transport=httpx.MockTransport(lambda r: httpx.Response(200)))\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            run(f.fetch_source(client, {\"ats\": \"not-a-real-ats\"}))\n\n\nclass TestFetchAll:\n    def test_aggregates_across_sources(self):\n        def handler(request):\n            return httpx.Response(200, json={\"jobs\": [\n                {\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"https://x/1\"}]})\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        sources = [{\"ats\": \"greenhouse\", \"company\": \"a\"},\n                   {\"ats\": \"greenhouse\", \"company\": \"b\"}]\n        jobs = run(f.fetch_all(sources, client=client))\n        assert len(jobs) == 2\n\n    def test_one_failing_source_does_not_abort_the_run(self, capsys):\n        def handler(request):\n            if \"boards-api\" in str(request.url):\n                return httpx.Response(500)\n            return httpx.Response(200, json=[])\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        sources = [{\"ats\": \"greenhouse\", \"company\": \"broken\"},\n                   {\"ats\": \"lever\", \"company\": \"ok\"}]\n        jobs = run(f.fetch_all(sources, client=client))\n        assert jobs == []  # lever returns [] too, but crucially: no exception raised\n        assert \"failed\" in capsys.readouterr().out\n\n\nclass TestFetchAshby:\n    def test_uses_posting_api_when_available(self):\n        def handler(request):\n            assert \"posting-api\" in str(request.url)\n            return httpx.Response(200, json={\"jobs\": [{\"id\": \"1\", \"title\": \"SWE\"}]})\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        jobs = run(f.fetch_ashby(client, {\"company\": \"acme\"}))\n        assert len(jobs) == 1\n\n    def test_falls_back_to_hosted_page_on_404(self):\n        app_data = {\"jobBoard\": {\"jobPostings\": [{\"id\": \"1\", \"title\": \"SWE\"}]}}\n        import json as _json\n        def handler(request):\n            if \"posting-api\" in str(request.url):\n                return httpx.Response(404)\n            html = f\"<script>window.__appData = {_json.dumps(app_data)};</script>\"\n            return httpx.Response(200, text=html)\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        jobs = run(f.fetch_ashby(client, {\"company\": \"acme\"}))\n        assert len(jobs) == 1\n\n    def test_no_posting_api_and_no_app_data_raises(self):\n        def handler(request):\n            if \"posting-api\" in str(request.url):\n                return httpx.Response(404)\n            return httpx.Response(200, text=\"<html>nothing</html>\")\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        with pytest.raises(RuntimeError, match=\"no posting-api\"):\n            run(f.fetch_ashby(client, {\"company\": \"acme\"}))\n\n\nclass TestFetchWorkday:\n    def test_stops_pagination_when_total_reached(self):\n        def handler(request):\n            return httpx.Response(200, json={\n                \"jobPostings\": [{\"title\": \"SWE\", \"externalPath\": \"/j/1\",\n                                  \"bulletFields\": [\"REQ1\"]}],\n                \"total\": 1})\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        jobs = run(f.fetch_workday(client, {\"host\": \"x.wd5.myworkdayjobs.com\",\n                                             \"tenant\": \"x\", \"site\": \"Site\"}))\n        assert len(jobs) == 1\n\n    def test_stops_pagination_on_empty_postings(self):\n        def handler(request):\n            return httpx.Response(200, json={\"jobPostings\": [], \"total\": 100})\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        jobs = run(f.fetch_workday(client, {\"host\": \"x.wd5.myworkdayjobs.com\",\n                                             \"tenant\": \"x\", \"site\": \"Site\"}))\n        assert jobs == []\n\n\nclass TestFetchMeta:\n    def test_graphql_error_surfaces_as_runtime_error(self):\n        def handler(request):\n            if request.url.path == \"/jobs\":\n                return httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok\"}]')\n            return httpx.Response(200, text=(\n                'for (;;);' + __import__(\"json\").dumps(\n                    {\"errors\": [{\"message\": \"doc_id not found\"}]})))\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        with pytest.raises(RuntimeError, match=\"doc_id not found\"):\n            run(f.fetch_meta(client, {}))"
