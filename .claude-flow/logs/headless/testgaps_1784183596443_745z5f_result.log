        "code": "# tests/test_agent.py\nimport json\nimport yaml\nimport agent\nfrom store import Store\nfrom conftest import make_job\n\n\ndef write_sources_yaml(tmp_path, db_path):\n    path = tmp_path / \"sources.yaml\"\n    path.write_text(yaml.dump({\"sources\": [], \"db\": str(db_path)}))\n    return path\n\n\nclass TestDbNew:\n    def test_first_run_uses_since_days_window(self, tmp_path, capsys):\n        db = tmp_path / \"jobs.db\"\n        cfg = write_sources_yaml(tmp_path, db)\n        with Store(db) as store:\n            store.diff([make_job(external_id=\"1\")])\n        agent.cmd_db_new([\"-c\", str(cfg)])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n        assert out[\"count\"] == 1\n\n    def test_posted_days_drops_old_keeps_undated(self, tmp_path, capsys):\n        from datetime import datetime, timedelta, timezone\n        db = tmp_path / \"jobs.db\"\n        cfg = write_sources_yaml(tmp_path, db)\n        old_ts = (datetime.now(timezone.utc) - timedelta(days=30)).isoformat()\n        with Store(db) as store:\n            store.diff([\n                make_job(external_id=\"1\", posted_at=old_ts),   # too old\n                make_job(external_id=\"2\", posted_at=\"\"),       # undated -> kept\n                make_job(external_id=\"3\", posted_at=datetime.now(timezone.utc).isoformat()),\n            ])\n        agent.cmd_db_new([\"-c\", str(cfg), \"--posted-days\", \"1\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"dropped_old\"] == 1\n        assert out[\"undated_kept\"] == 1\n        assert out[\"count\"] == 2\n\n    def test_dated_only_drops_undated(self, tmp_path, capsys):\n        db = tmp_path / \"jobs.db\"\n        cfg = write_sources_yaml(tmp_path, db)\n        with Store(db) as store:\n            store.diff([make_job(external_id=\"1\", posted_at=\"\")])\n        agent.cmd_db_new([\"-c\", str(cfg), \"--dated-only\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"undated_dropped\"] == 1\n        assert out[\"count\"] == 0\n\n    def test_truncation_never_splits_a_first_seen_group(self, tmp_path, capsys):\n        # Insert two batches (two distinct first_seen timestamps via two diff() calls),\n        # each containing 2 jobs; limit=3 should keep the whole first group (2) and\n        # stop before taking a partial second group — not truncate mid-group.\n        db = tmp_path / \"jobs.db\"\n        cfg = write_sources_yaml(tmp_path, db)\n        with Store(db) as store:\n            store.diff([make_job(external_id=\"1\"), make_job(external_id=\"2\")])\n            store.diff([make_job(external_id=\"3\"), make_job(external_id=\"4\")])\n        agent.cmd_db_new([\"-c\", str(cfg), \"--limit\", \"3\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"count\"] % 2 == 0  # never a partial group\n        assert out[\"truncated\"] is True\n\n\nclass TestDbMark:\n    def test_rejects_non_iso_watermark(self, tmp_path, capsys):\n        db = tmp_path / \"jobs.db\"\n        cfg = write_sources_yaml(tmp_path, db)\n        rc = agent.cmd_db_mark([\"not-a-timestamp\", \"-c\", str(cfg)])\n        assert rc == 2\n\n    def test_now_flag_sets_current_marker(self, tmp_path):\n        db = tmp_path / \"jobs.db\"\n        cfg = write_sources_yaml(tmp_path, db)\n        rc = agent.cmd_db_mark([\"--now\", \"-c\", str(cfg)])\n        assert rc == 0\n        with Store(db) as store:\n            assert store.get_meta(\"last_scan\") is not None\n\n    def test_requires_watermark_or_now(self, tmp_path, capsys):\n        db = tmp_path / \"jobs.db\"\n        cfg = write_sources_yaml(tmp_path, db)\n        rc = agent.cmd_db_mark([\"-c\", str(cfg)])\n        assert rc == 2\n\n\nclass TestReportNum:\n    def test_increments_across_calls(self, tmp_path, capsys):\n        db = tmp_path / \"jobs.db\"\n        cfg = write_sources_yaml(tmp_path, db)\n        agent.cmd_report_num([\"-c\", str(cfg)])\n        first = capsys.readouterr().out.strip()\n        agent.cmd_report_num([\"-c\", str(cfg)])\n        second = capsys.readouterr().out.strip()\n        assert first == \"001\" and second == \"002\"\n\n\nclass TestNormalizeAts:\n    def test_replaces_smart_quotes_in_body_text(self):\n        html, counts = agent._normalize_ats(\"<p>\\u201cHello\\u201d</p>\")\n        assert html == '<p>\"Hello\"</p>'\n        assert counts[\"smart-double-quote\"] == 2\n\n    def test_does_not_touch_content_inside_tags(self):\n        html, counts = agent._normalize_ats('<div data-x=\"\\u2014\"><p>ok</p></div>')\n        assert '\\u2014' in html  # attribute value untouched\n        assert \"em-dash\" not in counts\n\n    def test_does_not_touch_style_or_script_blocks(self):\n        src = '<style>.x::before{content:\"\\u2014\"}</style><p>\\u2014</p>'\n        html, counts = agent._normalize_ats(src)\n        assert '.x::before{content:\"\\u2014\"}' in html  # untouched inside <style>\n        assert counts.get(\"em-dash\") == 1  # only the <p> occurrence counted\n\n    def test_no_replacements_needed_returns_empty_counts(self):\n        html, counts = agent._normalize_ats(\"<p>plain ascii</p>\")\n        assert counts == {}"
