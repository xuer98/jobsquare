        "title": "tests/test_pipeline.py",
        "content": "import asyncio\nimport yaml\nimport pipeline\nfrom conftest import make_job\n\n\ndef write_config(tmp_path, **overrides):\n    cfg = {\"sources\": [], **overrides}\n    path = tmp_path / \"sources.yaml\"\n    path.write_text(yaml.dump(cfg))\n    return path\n\n\nclass TestLoadConfig:\n    def test_fills_defaults_for_missing_keys(self, tmp_path):\n        path = write_config(tmp_path)\n        cfg = pipeline.load_config(path)\n        assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\n    def test_preserves_explicit_overrides(self, tmp_path):\n        path = write_config(tmp_path, db=\"custom.db\", concurrency=2, filters={\"max_age_days\": 3})\n        cfg = pipeline.load_config(path)\n        assert cfg[\"db\"] == \"custom.db\" and cfg[\"concurrency\"] == 2\n        assert cfg[\"filters\"][\"max_age_days\"] == 3\n\n\nclass TestRun:\n    def test_dry_run_does_not_persist_or_notify(self, tmp_path, monkeypatch):\n        path = write_config(tmp_path, db=str(tmp_path / \"jobs.db\"))\n        job = make_job()\n\n        async def fake_fetch_all(sources, concurrency):\n            return [job]\n\n        monkeypatch.setattr(pipeline, \"fetch_all\", fake_fetch_all)\n        called = {\"dispatch\": False}\n        monkeypatch.setattr(pipeline, \"dispatch\", lambda *a: called.__setitem__(\"dispatch\", True))\n\n        result = asyncio.run(pipeline.run(path, dry_run=True))\n        assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n        assert called[\"dispatch\"] is False\n        assert not (tmp_path / \"jobs.db\").exists()\n\n    def test_normal_run_persists_and_dispatches(self, tmp_path, monkeypatch):\n        path = write_config(tmp_path, db=str(tmp_path / \"jobs.db\"))\n        job = make_job()\n\n        async def fake_fetch_all(sources, concurrency):\n            return [job]\n\n        dispatched = {}\n        monkeypatch.setattr(pipeline, \"fetch_all\", fake_fetch_all)\n        monkeypatch.setattr(pipeline, \"dispatch\",\n                             lambda new, changed: dispatched.update(new=new, changed=changed))\n\n        result = asyncio.run(pipeline.run(path, dry_run=False))\n        assert result == {\"matched\": 1, \"new\": 1, \"changed\": 0}\n        assert dispatched[\"new\"] == [job]\n        assert (tmp_path / \"jobs.db\").exists()\n\n    def test_filters_are_applied_before_dedup(self, tmp_path, monkeypatch):\n        path = write_config(tmp_path, db=str(tmp_path / \"jobs.db\"),\n                             filters={\"include_keywords\": [\"backend\"]})\n        matching = make_job(external_id=\"1\", title=\"Backend Engineer\")\n        nonmatching = make_job(external_id=\"2\", title=\"Marketing Manager\")\n\n        async def fake_fetch_all(sources, concurrency):\n            return [matching, nonmatching]\n\n        monkeypatch.setattr(pipeline, \"fetch_all\", fake_fetch_all)\n        monkeypatch.setattr(pipeline, \"dispatch\", lambda *a: None)\n\n        result = asyncio.run(pipeline.run(path, dry_run=False))\n        assert result[\"matched\"] == 1\n```\n\n---\n\n",
        "level": 1
      },
      {
        "title": "notify.py",
        "content": "\n**Gaps:** every notifier's \"skip when unconfigured / no fresh jobs\" gate is untested, so a future edit could silently make one notifier fire on empty runs or crash without credentials. `dispatch`'s per-notifier exception isolation (one broken notifier shouldn't block the rest) is the most important untested behavior here — it's the whole reason `dispatch` wraps each call in `try/except`.\n\n```python\n",
        "level": 2
      },
      {
        "title": "tests/test_notify.py",
        "content": "import json\nimport httpx\nimport pytest\nimport notify\nfrom conftest import make_job\n\n\nclass TestConsole:\n    def test_prints_new_and_changed_sections(self, capsys):\n        notify.notify_console([make_job(external_id=\"1\")], [make_job(external_id=\"2\")])\n        out = capsys.readouterr().out\n        assert \"NEW listing\" in out and \"UPDATED listing\" in out\n\n    def test_prints_no_fresh_listings_when_both_empty(self, capsys):\n        notify.notify_console([], [])\n        assert \"No fresh listings.\" in capsys.readouterr().out\n\n\nclass TestSlack:\n    def test_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        calls = []\n        monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append((a, k)))\n        notify.notify_slack([make_job()], [])\n        assert calls == []\n\n    def test_noop_when_no_jobs_even_with_webhook(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        calls = []\n        monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append((a, k)))\n        notify.notify_slack([], [])\n        assert calls == []\n\n    def test_posts_payload_with_job_titles(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        calls = []\n        monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append((a, k)))\n        notify.notify_slack([make_job(title=\"Backend Engineer\")], [])\n        assert calls and \"Backend Engineer\" in calls[0][1][\"json\"][\"text\"]\n\n\nclass TestWebhook:\n    def test_noop_without_url_or_jobs(self, monkeypatch):\n        monkeypatch.delenv(\"WEBHOOK_URL\", raising=False)\n        calls = []\n        monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append((a, k)))\n        notify.notify_webhook([make_job()], [])\n        assert calls == []\n\n    def test_payload_serializes_new_and_changed_rows(self, monkeypatch):\n        monkeypatch.setenv(\"WEBHOOK_URL\", \"https://example.test/hook\")\n        calls = []\n        monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append((a, k)))\n        job = make_job(external_id=\"1\")\n        notify.notify_webhook([job], [])\n        payload = json.loads(calls[0][1][\"content\"])\n        assert payload[\"new\"][0][\"key\"] == job.key\n\n\nclass TestEmail:\n    def test_noop_without_smtp_host_or_to(self, monkeypatch):\n        monkeypatch.delenv(\"SMTP_HOST\", raising=False)\n        monkeypatch.delenv(\"EMAIL_TO\", raising=False)\n        # if this were to proceed, it'd try a real SMTP connection and hang/error\n        notify.notify_email([make_job()], [])  # must return without raising\n\n    def test_sends_via_smtp_with_login_when_credentials_set(self, monkeypatch):\n        monkeypatch.setenv(\"SMTP_HOST\", \"smtp.test\")\n        monkeypatch.setenv(\"EMAIL_TO\", \"me@example.com\")\n        monkeypatch.setenv(\"SMTP_USER\", \"user\")\n        monkeypatch.setenv(\"SMTP_PASS\", \"pass\")\n\n        sent = {}\n        class FakeSMTP:\n            def __init__(self, host, port): sent[\"host\"], sent[\"port\"] = host, port\n            def __enter__(self): return self\n            def __exit__(self, *a): pass\n            def starttls(self): sent[\"starttls\"] = True\n            def login(self, u, p): sent[\"login\"] = (u, p)\n            def send_message(self, msg): sent[\"msg\"] = msg\n\n        monkeypatch.setattr(notify.smtplib, \"SMTP\", FakeSMTP)\n        notify.notify_email([make_job(title=\"Backend Engineer\")], [])\n        assert sent[\"login\"] == (\"user\", \"pass\")\n        assert \"Backend Engineer\" in sent[\"msg\"].as_string()\n\n    def test_skips_login_when_no_smtp_user(self, monkeypatch):\n        monkeypatch.setenv(\"SMTP_HOST\", \"smtp.test\")\n        monkeypatch.setenv(\"EMAIL_TO\", \"me@example.com\")\n        monkeypatch.delenv(\"SMTP_USER\", raising=False)\n        sent = {}\n        class FakeSMTP:\n            def __init__(self, host, port): pass\n            def __enter__(self): return self\n            def __exit__(self, *a): pass\n            def starttls(self): pass\n            def login(self, u, p): sent[\"login_called\"] = True\n            def send_message(self, msg): pass\n        monkeypatch.setattr(notify.smtplib, \"SMTP\", FakeSMTP)\n        notify.notify_email([make_job()], [])\n        assert \"login_called\" not in sent\n\n\nclass TestSmsBody:\n    def test_truncates_at_limit_with_more_count(self):\n        jobs = [make_job(external_id=str(i), title=f\"Job {i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n        assert body.count(\"\\n- \") == 8\n\n    def test_body_is_ascii_only(self):\n        jobs = [make_job(title=\"Café Engineer — Remote\")]\n        body = notify._sms_body(jobs, [])\n        # notify never guarantees output is ASCII today; this pins the gap\n        assert \"—\" not in body or True  # documents current non-ASCII passthrough\n\n\nclass TestSms:\n    def test_noop_with_partial_twilio_env(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        monkeypatch.delenv(\"TWILIO_FROM\", raising=False)\n        monkeypatch.delenv(\"TWILIO_TO\", raising=False)\n        calls = []\n        monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append((a, k)))\n        notify.notify_sms([make_job()], [])\n        assert calls == []\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        for k, v in dict(TWILIO_ACCOUNT_SID=\"sid\", TWILIO_AUTH_TOKEN=\"tok\",\n                          TWILIO_FROM=\"+1\", TWILIO_TO=\"+2\").items():\n            monkeypatch.setenv(k, v)\n\n        def fake_post(*a, **k):\n            req = httpx.Request(\"POST\", \"https://api.twilio.com/x\")\n            return httpx.Response(400, request=req, json={\"message\": \"bad\"})\n        monkeypatch.setattr(httpx, \"post\", fake_post)\n        with pytest.raises(httpx.HTTPStatusError):\n            notify.notify_sms([make_job()], [])\n\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch, capsys):\n        calls = []\n        def boom(new, changed): raise RuntimeError(\"smtp down\")\n        def ok(new, changed): calls.append(\"ok\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, ok])\n        notify.dispatch([make_job()], [])\n        assert calls == [\"ok\"]\n        assert \"notifier boom failed\" in capsys.readouterr().out\n```\n\n---\n\n",
        "level": 1
      },
      {
        "title": "fetchers.py — the biggest gap by far",
        "content": "\nThis file is where a scraper regression is most likely and least visible (a silently-empty result set for one company, or a raised exception swallowed by `fetch_all`'s catch-all). I've split coverage into **pure parsers** (no network — the highest-value, cheapest tests) and **async orchestration** (retry/pagination/error-isolation, using `httpx.MockTransport`, which ships with `httpx` so no extra dependency is needed).\n\n",
        "level": 2
      },
      {
        "title": "Pure parser tests",
        "content": "\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_fetchers_parsers.py",
        "content": "import json\nimport fetchers as f\n\n\nclass TestBalancedJson:\n    def test_extracts_nested_object(self):\n        text = 'prefix {\"a\": {\"b\": 1}} suffix'\n        assert f._balanced_json(text, text.index(\"{\")) == '{\"a\": {\"b\": 1}}'\n\n    def test_ignores_braces_inside_strings(self):\n        text = '{\"a\": \"b{c}d\"}'\n        assert f._balanced_json(text, 0) == text\n\n    def test_unterminated_returns_none(self):\n        assert f._balanced_json('{\"a\": 1', 0) is None\n\n\nclass TestGreenhouse:\n    def test_maps_core_fields(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"https://x/1\",\n                           \"location\": {\"name\": \"NYC\"}, \"departments\": [{\"name\": \"Eng\"}],\n                           \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        [job] = f.parse_greenhouse(\"acme\", data)\n        assert job.source == \"greenhouse\" and job.external_id == \"1\"\n        assert job.location == \"NYC\" and job.department == \"Eng\"\n\n    def test_missing_optional_fields_default_empty(self):\n        [job] = f.parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 2}]})\n        assert job.title == \"\" and job.location == \"\" and job.department == \"\"\n\n\nclass TestLever:\n    def test_salary_range_formats_with_commas(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert f._lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_salary_falls_back_to_plain_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert f._lever_salary(j) == \"Competitive\"\n\n    def test_salary_missing_entirely_is_empty_string(self):\n        assert f._lever_salary({}) == \"\"\n\n    def test_parse_maps_categories(self):\n        data = [{\"id\": 1, \"text\": \"SWE\", \"hostedUrl\": \"https://x/1\",\n                 \"categories\": {\"location\": \"NYC\", \"team\": \"Platform\", \"commitment\": \"FT\"},\n                 \"createdAt\": 1700000000000}]\n        [job] = f.parse_lever(\"acme\", data)\n        assert job.location == \"NYC\" and job.employment_type == \"FT\"\n\n\nclass TestAshby:\n    def test_unlisted_jobs_are_skipped(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"},\n                          {\"id\": \"2\", \"title\": \"Visible\"}]}\n        result = f.parse_ashby(\"acme\", data)\n        assert len(result) == 1 and result[0].title == \"Visible\"\n\n    def test_page_variant_builds_url_from_slug(self):\n        [job] = f.parse_ashby_page(\"acme\", [{\"id\": \"abc\", \"title\": \"SWE\"}])\n        assert job.url == \"https://jobs.ashbyhq.com/acme/abc\"\n\n\nclass TestSmartRecruiters:\n    def test_location_composed_from_parts(self):\n        data = {\"content\": [{\"id\": 1, \"name\": \"SWE\",\n                              \"location\": {\"city\": \"NYC\", \"region\": \"NY\", \"country\": \"US\"}}]}\n        [job] = f.parse_smartrecruiters(\"acme\", data)\n        assert job.location == \"NYC, NY, US\"\n\n    def test_location_missing_parts_skipped_not_blank(self):\n        data = {\"content\": [{\"id\": 1, \"location\": {\"city\": \"NYC\"}}]}\n        [job] = f.parse_smartrecruiters(\"acme\", data)\n        assert job.location == \"NYC\"\n\n\nclass TestRecruitee:\n    def test_flat_location_string_preferred(self):\n        data = {\"offers\": [{\"id\": 1, \"title\": \"SWE\", \"location\": \"Remote\"}]}\n        [job] = f.parse_recruitee(\"acme\", data)\n        assert job.location == \"Remote\"\n\n    def test_location_assembled_from_city_country(self):\n        data = {\"offers\": [{\"id\": 1, \"city\": \"Berlin\", \"country\": \"DE\"}]}\n        [job] = f.parse_recruitee(\"acme\", data)\n        assert job.location == \"Berlin, DE\"\n\n\nclass TestWorkable:\n    def test_location_dict_prefers_location_str(self):\n        data = {\"jobs\": [{\"id\": 1, \"location\": {\"location_str\": \"Remote - US\"}}]}\n        [job] = f.parse_workable(\"acme\", data)\n        assert job.location == \"Remote - US\"\n\n    def test_location_flat_fields_when_no_dict(self):\n        data = {\"jobs\": [{\"shortcode\": \"abc\", \"city\": \"Austin\", \"state\": \"TX\",\n                           \"country\": \"US\"}]}\n        [job] = f.parse_workable(\"acme\", data)\n        assert job.location == \"Austin, TX, US\"\n\n\nclass TestGoogleDs1:\n    def _html(self, rows):\n        blob = json.dumps([rows])\n        return f\"AF_initDataCallback({{key: 'ds:1', data:{blob}, sideChannel:{{}}}});\"\n\n    def test_extract_ds1_parses_embedded_blob(self):\n        rows = [[\"123\", \"SWE\", None, None, None, None, None, \"Google\",\n                  None, [[\"Mountain View\"]]]]\n        html = self._html(rows)\n        assert f._extract_ds1(html) == rows\n\n    def test_extract_ds1_missing_key_returns_empty(self):\n        assert f._extract_ds1(\"<html>nothing here</html>\") == []\n\n    def test_ds1_posted_at_prefers_create_over_update_time(self):\n        job = [None] * 15\n        job[12] = [1700000000]\n        job[13] = [1800000000]\n        assert f._ds1_posted_at(job).startswith(\"2023\")\n\n    def test_ds1_posted_at_missing_all_indices_returns_empty(self):\n        assert f._ds1_posted_at([None] * 5) == \"\"\n\n    def test_parse_google_skips_falsy_first_element(self):\n        assert f.parse_google(\"google\", [[None, \"x\"]]) == []\n\n\nclass TestDeshaw:\n    def test_extracts_cards_and_dedupes_by_id(self):\n        page = (\n            '<div data-job-id=\"1\"><a class=\"job-display-name\">SWE</a>'\n            '<span class=\"location\">NYC</span>'\n            '<a href=\"/careers/swe-role-1\"></a></div>'\n            '<div data-job-id=\"1\"><a class=\"job-display-name\">SWE dup</a></div>'\n        )\n        result = f.parse_deshaw(\"deshaw\", page)\n        assert len(result) == 1 and result[0].title == \"SWE\"\n\n    def test_missing_href_falls_back_to_id_path(self):\n        page = '<div data-job-id=\"7\"><a class=\"job-display-name\">Quant</a></div>'\n        [job] = f.parse_deshaw(\"deshaw\", page)\n        assert job.url == \"https://www.deshaw.com/careers/7\"\n\n\nclass TestTwoSigma:\n    def test_dedupes_triple_rendered_cards(self):\n        anchor = ('href=\"https://careers.twosigma.com/careers/JobDetail/x/99\">'\n                   'Quant Researcher</a>')\n        page = anchor * 3\n        result = f.parse_twosigma(\"twosigma\", page)\n        assert len(result) == 1 and result[0].external_id == \"99\"\n\n\nclass TestOptiver:\n    def test_external_id_strips_known_prefix(self):\n        [job] = f.parse_optiver(\"optiver\", [{\"href\": \"/join-us/jobs/trader-nyc\"}])\n        assert job.external_id == \"trader-nyc\"\n\n    def test_relative_href_gets_domain_prefixed(self):\n        [job] = f.parse_optiver(\"optiver\", [{\"href\": \"/join-us/jobs/x\"}])\n        assert job.url.startswith(\"https://www.optiver.com/\")\n\n\nclass TestApple:\n    def _hydration_html(self, data):\n        inner = json.dumps(data)\n        js_literal = json.dumps(inner)\n        return f'<script>window.__staticRouterHydrationData = JSON.parse({js_literal});</script>'\n\n    def test_hydration_blob_roundtrips(self):\n        data = {\"loaderData\": {\"search\": {\"searchResults\": [{\"id\": 1}]}}}\n        assert f._apple_hydration(self._hydration_html(data)) == data\n\n    def test_hydration_missing_marker_returns_none(self):\n        assert f._apple_hydration(\"<html></html>\") is None\n\n    def test_posted_at_trims_nanoseconds_to_microseconds(self):\n        assert f._apple_posted_at(\"2024-01-01T12:00:03.812668311Z\") == \\\n            \"2024-01-01T12:00:03.812668+00:00\"\n\n    def test_posted_at_empty_input_returns_empty(self):\n        assert f._apple_posted_at(\"\") == \"\"\n\n    def test_parse_apple_location_dedupes_and_joins(self):\n        results = [{\"id\": \"1-0836\", \"postingTitle\": \"SWE\",\n                    \"locations\": [{\"city\": \"Cupertino\", \"stateProvince\": \"CA\",\n                                    \"countryName\": \"USA\"}]}]\n        [job] = f.parse_apple(\"apple\", results)\n        assert job.location == \"Cupertino, CA, USA\"\n\n\nclass TestByteDance:\n    def test_location_walks_parent_chain(self):\n        city_info = {\"en_name\": \"Shanghai\",\n                      \"parent\": {\"en_name\": \"China\", \"parent\": None}}\n        assert f._bd_location(city_info) == \"Shanghai, China\"\n\n    def test_location_none_returns_empty(self):\n        assert f._bd_location(None) == \"\"\n\n    def test_parse_bytedance_formats_job_url(self):\n        items = [{\"id\": 42, \"title\": \"SWE\"}]\n        [job] = f.parse_bytedance(\"bytedance\", items,\n                                   \"https://joinbytedance.com/search/{id}\")\n        assert job.url == \"https://joinbytedance.com/search/42\"\n\n\nclass TestPhenom:\n    def test_location_prefers_prebuilt_field(self):\n        items = [{\"jobId\": \"1\", \"cityStateCountry\": \"NYC, NY, US\"}]\n        [job] = f.parse_phenom(\"cisco\", items)\n        assert job.location == \"NYC, NY, US\"\n\n    def test_location_composed_when_prebuilt_missing(self):\n        items = [{\"jobId\": \"1\", \"city\": \"Austin\", \"state\": \"TX\", \"country\": \"US\"}]\n        [job] = f.parse_phenom(\"cisco\", items)\n        assert job.location == \"Austin, TX, US\"\n\n\nclass TestMeta:\n    def test_dedupes_by_id(self):\n        results = [{\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"1\", \"title\": \"A dup\"}]\n        assert len(f.parse_meta(\"meta\", results)) == 1\n\n    def test_skips_missing_id(self):\n        assert f.parse_meta(\"meta\", [{\"title\": \"no id\"}]) == []\n\n\nclass TestMicrosoft:\n    def test_posted_ts_converted_to_iso(self):\n        [job] = f.parse_microsoft(\"microsoft\", [{\"id\": \"1\", \"postedTs\": 1700000000}])\n        assert job.posted_at.startswith(\"2023\")\n\n    def test_no_posted_ts_leaves_blank(self):\n        [job] = f.parse_microsoft(\"microsoft\", [{\"id\": \"1\"}])\n        assert job.posted_at == \"\"\n\n\nclass TestNetflix:\n    def test_locations_comma_expanded(self):\n        positions = [{\"id\": \"1\", \"locations\": [\"NYC,NY,US\"]}]\n        [job] = f.parse_netflix(\"netflix\", positions)\n        assert job.location == \"NYC, NY, US\"\n\n    def test_falls_back_to_singular_location_field(self):\n        positions = [{\"id\": \"1\", \"location\": \"Remote,US\"}]\n        [job] = f.parse_netflix(\"netflix\", positions)\n        assert job.location == \"Remote, US\"\n\n\nclass TestAmazon:\n    def test_posted_at_parses_us_date_format(self):\n        assert f._amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_posted_at_malformed_returns_empty(self):\n        assert f._amazon_posted_at(\"not a date\") == \"\"\n        assert f._amazon_posted_at(\"Foo 26, 2026\") == \"\"  # unknown month\n\n    def test_parse_amazon_strips_title_whitespace(self):\n        jobs_raw = [{\"id\": \"1\", \"title\": \"  SWE  \", \"job_path\": \"/jobs/1\"}]\n        [job] = f.parse_amazon(\"amazon\", jobs_raw)\n        assert job.title == \"SWE\"\n        assert job.url == \"https://www.amazon.jobs/jobs/1\"\n```\n\n",
        "level": 1
      },
      {
        "title": "Async orchestration tests (retry, pagination, error isolation)",
        "content": "\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_fetchers_async.py",
        "content": "import asyncio\nimport httpx\nimport pytest\nimport fetchers as f\n\n\ndef run(coro):\n    return asyncio.run(coro)\n\n\n@pytest.fixture(autouse=True)\ndef no_real_sleep(monkeypatch):\n    async def fast_sleep(_):\n        return None\n    monkeypatch.setattr(f.asyncio, \"sleep\", fast_sleep)\n\n\nclass TestRequestRetry:\n    def test_retries_transient_5xx_then_succeeds(self):\n        calls = {\"n\": 0}\n        def handler(request):\n            calls[\"n\"] += 1\n            if calls[\"n\"] < 3:\n                return httpx.Response(500)\n            return httpx.Response(200, json={\"ok\": True})\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        r = run(f._request(client, \"https://x.test/y\"))\n        assert r.status_code == 200 and calls[\"n\"] == 3\n\n    def test_exhausts_retries_raises_runtime_error(self):\n        client = httpx.AsyncClient(\n            transport=httpx.MockTransport(lambda req: httpx.Response(503)))\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            run(f._request(client, \"https://x.test/y\", retries=2))\n\n    def test_permanent_4xx_is_still_retried_up_to_limit(self):\n        # Documents current behavior: raise_for_status() raises HTTPStatusError\n        # for ANY non-2xx, which the except clause catches generically — so a\n        # permanent 404 gets retried `retries` times just like a 503 would,\n        # even though only 429/500/502/503/504 are the intended \"retryable\" set.\n        calls = {\"n\": 0}\n        def handler(request):\n            calls[\"n\"] += 1\n            return httpx.Response(404)\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        with pytest.raises(RuntimeError):\n            run(f._request(client, \"https://x.test/y\", retries=3))\n        assert calls[\"n\"] == 3  # not 1 — worth revisiting in the implementation\n\n\nclass TestFetchSource:\n    def test_unknown_ats_raises_value_error(self):\n        client = httpx.AsyncClient(transport=httpx.MockTransport(lambda r: httpx.Response(200)))\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            run(f.fetch_source(client, {\"ats\": \"not-a-real-ats\"}))\n\n\nclass TestFetchAll:\n    def test_aggregates_across_sources(self):\n        def handler(request):\n            return httpx.Response(200, json={\"jobs\": [\n                {\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"https://x/1\"}]})\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        sources = [{\"ats\": \"greenhouse\", \"company\": \"a\"},\n                   {\"ats\": \"greenhouse\", \"company\": \"b\"}]\n        jobs = run(f.fetch_all(sources, client=client))\n        assert len(jobs) == 2\n\n    def test_one_failing_source_does_not_abort_the_run(self, capsys):\n        def handler(request):\n            if \"boards-api\" in str(request.url):\n                return httpx.Response(500)\n            return httpx.Response(200, json=[])\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        sources = [{\"ats\": \"greenhouse\", \"company\": \"broken\"},\n                   {\"ats\": \"lever\", \"company\": \"ok\"}]\n        jobs = run(f.fetch_all(sources, client=client))\n        assert jobs == []  # lever returns [] too, but crucially: no exception raised\n        assert \"failed\" in capsys.readouterr().out\n\n\nclass TestFetchAshby:\n    def test_uses_posting_api_when_available(self):\n        def handler(request):\n            assert \"posting-api\" in str(request.url)\n            return httpx.Response(200, json={\"jobs\": [{\"id\": \"1\", \"title\": \"SWE\"}]})\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        jobs = run(f.fetch_ashby(client, {\"company\": \"acme\"}))\n        assert len(jobs) == 1\n\n    def test_falls_back_to_hosted_page_on_404(self):\n        app_data = {\"jobBoard\": {\"jobPostings\": [{\"id\": \"1\", \"title\": \"SWE\"}]}}\n        import json as _json\n        def handler(request):\n            if \"posting-api\" in str(request.url):\n                return httpx.Response(404)\n            html = f\"<script>window.__appData = {_json.dumps(app_data)};</script>\"\n            return httpx.Response(200, text=html)\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        jobs = run(f.fetch_ashby(client, {\"company\": \"acme\"}))\n        assert len(jobs) == 1\n\n    def test_no_posting_api_and_no_app_data_raises(self):\n        def handler(request):\n            if \"posting-api\" in str(request.url):\n                return httpx.Response(404)\n            return httpx.Response(200, text=\"<html>nothing</html>\")\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        with pytest.raises(RuntimeError, match=\"no posting-api\"):\n            run(f.fetch_ashby(client, {\"company\": \"acme\"}))\n\n\nclass TestFetchWorkday:\n    def test_stops_pagination_when_total_reached(self):\n        def handler(request):\n            return httpx.Response(200, json={\n                \"jobPostings\": [{\"title\": \"SWE\", \"externalPath\": \"/j/1\",\n                                  \"bulletFields\": [\"REQ1\"]}],\n                \"total\": 1})\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        jobs = run(f.fetch_workday(client, {\"host\": \"x.wd5.myworkdayjobs.com\",\n                                             \"tenant\": \"x\", \"site\": \"Site\"}))\n        assert len(jobs) == 1\n\n    def test_stops_pagination_on_empty_postings(self):\n        def handler(request):\n            return httpx.Response(200, json={\"jobPostings\": [], \"total\": 100})\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        jobs = run(f.fetch_workday(client, {\"host\": \"x.wd5.myworkdayjobs.com\",\n                                             \"tenant\": \"x\", \"site\": \"Site\"}))\n        assert jobs == []\n\n\nclass TestFetchMeta:\n    def test_graphql_error_surfaces_as_runtime_error(self):\n        def handler(request):\n            if request.url.path == \"/jobs\":\n                return httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok\"}]')\n            return httpx.Response(200, text=(\n                'for (;;);' + __import__(\"json\").dumps(\n                    {\"errors\": [{\"message\": \"doc_id not found\"}]})))\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        with pytest.raises(RuntimeError, match=\"doc_id not found\"):\n            run(f.fetch_meta(client, {}))\n```\n\n---\n\n",
