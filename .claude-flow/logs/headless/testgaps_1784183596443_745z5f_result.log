        "language": "python",
        "code": "# tests/test_store.py\nimport sqlite3\nfrom store import Store\nfrom conftest import make_job\n\n\nclass TestMigration:\n    def test_adds_salary_range_column_to_pre_existing_db(self, tmp_path):\n        path = tmp_path / \"old.db\"\n        conn = sqlite3.connect(str(path))\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (\n                key TEXT PRIMARY KEY, source TEXT NOT NULL, company TEXT NOT NULL,\n                external_id TEXT NOT NULL, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT NOT NULL, last_seen TEXT NOT NULL\n            );\n            CREATE TABLE meta (k TEXT PRIMARY KEY, v TEXT NOT NULL);\n        \"\"\")\n        conn.commit()\n        conn.close()\n\n        with Store(path) as store:\n            cols = {r[\"name\"] for r in store.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n            # and the store is actually usable post-migration\n            store.diff([make_job()])\n            assert store.count() == 1\n\n    def test_fresh_db_is_idempotent_to_reopen(self, tmp_path):\n        path = tmp_path / \"new.db\"\n        with Store(path):\n            pass\n        with Store(path) as store:  # second open must not error on existing schema\n            assert store.count() == 0\n\n\nclass TestDiff:\n    def test_new_job_reported_and_persisted(self, tmp_path):\n        with Store(tmp_path / \"jobs.db\") as store:\n            new, changed = store.diff([make_job(external_id=\"1\")])\n            assert len(new) == 1 and changed == []\n            assert store.count() == 1\n\n    def test_unchanged_job_reseen_not_reported(self, tmp_path):\n        with Store(tmp_path / \"jobs.db\") as store:\n            job = make_job(external_id=\"1\")\n            store.diff([job])\n            new, changed = store.diff([job])\n            assert new == [] and changed == []\n            assert store.count() == 1  # no duplicate row\n\n    def test_content_change_reported_and_row_updated(self, tmp_path):\n        with Store(tmp_path / \"jobs.db\") as store:\n            store.diff([make_job(external_id=\"1\", title=\"Old Title\")])\n            new, changed = store.diff([make_job(external_id=\"1\", title=\"New Title\")])\n            assert new == [] and len(changed) == 1\n            row = store.conn.execute(\"SELECT title FROM jobs WHERE key=?\",\n                                      (changed[0].key,)).fetchone()\n            assert row[\"title\"] == \"New Title\"\n\n    def test_last_seen_advances_on_reseen(self, tmp_path):\n        with Store(tmp_path / \"jobs.db\") as store:\n            job = make_job(external_id=\"1\")\n            store.diff([job])\n            row1 = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n            store.diff([job])\n            row2 = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n            assert row2[\"last_seen\"] >= row1[\"last_seen\"]\n\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, tmp_path):\n        with Store(tmp_path / \"jobs.db\") as store:\n            assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_roundtrip_and_overwrite(self, tmp_path):\n        with Store(tmp_path / \"jobs.db\") as store:\n            store.set_meta(\"last_scan\", \"2024-01-01T00:00:00\")\n            assert store.get_meta(\"last_scan\") == \"2024-01-01T00:00:00\"\n            store.set_meta(\"last_scan\", \"2024-02-01T00:00:00\")\n            assert store.get_meta(\"last_scan\") == \"2024-02-01T00:00:00\"\n\n\nclass TestNextSeq:\n    def test_starts_at_one_and_increments(self, tmp_path):\n        with Store(tmp_path / \"jobs.db\") as store:\n            assert store.next_seq(\"report_seq\") == 1\n            assert store.next_seq(\"report_seq\") == 2\n            assert store.next_seq(\"report_seq\") == 3\n\n    def test_independent_counters_per_key(self, tmp_path):\n        with Store(tmp_path / \"jobs.db\") as store:\n            assert store.next_seq(\"a\") == 1\n            assert store.next_seq(\"b\") == 1\n            assert store.next_seq(\"a\") == 2\n\n\nclass TestAddedSince:\n    def test_strict_inequality_boundary(self, tmp_path):\n        with Store(tmp_path / \"jobs.db\") as store:\n            store.diff([make_job(external_id=\"1\")])\n            row = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()\n            ts = row[\"first_seen\"]\n            assert store.added_since(ts) == []          # not > ts\n            assert len(store.added_since(\"2000-01-01T00:00:00\")) == 1\n\n    def test_ordered_by_first_seen_then_company_then_title(self, tmp_path):\n        with Store(tmp_path / \"jobs.db\") as store:\n            store.diff([\n                make_job(external_id=\"1\", company=\"zeta\", title=\"A\"),\n                make_job(external_id=\"2\", company=\"alpha\", title=\"B\"),\n            ])\n            rows = store.added_since(\"2000-01-01T00:00:00\")\n            companies = [r[\"company\"] for r in rows]\n            assert companies == sorted(companies)"
