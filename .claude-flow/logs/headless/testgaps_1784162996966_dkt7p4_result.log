        "code": "# tests/test_fetchers_fetch.py\nimport httpx\nimport pytest\nfrom fetchers import (\n    _request, fetch_source, fetch_all, fetch_meta, fetch_workday,\n)\n\ndef mock_client(handler):\n    return httpx.AsyncClient(transport=httpx.MockTransport(handler))\n\nclass TestRequestRetry:\n    async def test_retries_on_503_then_succeeds(self):\n        calls = {\"n\": 0}\n        def handler(request):\n            calls[\"n\"] += 1\n            if calls[\"n\"] < 3:\n                return httpx.Response(503)\n            return httpx.Response(200, json={\"ok\": True})\n        async with mock_client(handler) as client:\n            r = await _request(client, \"https://x/y\", retries=4)\n        assert r.json() == {\"ok\": True} and calls[\"n\"] == 3\n\n    async def test_exhausts_retries_and_raises(self):\n        async with mock_client(lambda r: httpx.Response(500)) as client:\n            with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n                await _request(client, \"https://x/y\", retries=2)\n\n    async def test_non_retryable_4xx_fails_fast(self):\n        calls = {\"n\": 0}\n        def handler(request):\n            calls[\"n\"] += 1\n            return httpx.Response(404)\n        async with mock_client(handler) as client:\n            with pytest.raises(RuntimeError):\n                await _request(client, \"https://x/y\", retries=4)\n        assert calls[\"n\"] == 1  # no retry on non-retryable status\n\nclass TestFetchSource:\n    async def test_unknown_ats_raises_value_error(self):\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(ValueError, match=\"unknown ATS\"):\n                await fetch_source(client, {\"ats\": \"bogus\"})\n\nclass TestFetchAll:\n    async def test_one_source_failing_does_not_fail_others(self):\n        def handler(request):\n            if \"greenhouse\" in str(request.url):\n                return httpx.Response(500)\n            return httpx.Response(200, json={\"jobs\": []})\n        async with mock_client(handler) as client:\n            jobs = await fetch_all(\n                [{\"ats\": \"greenhouse\", \"company\": \"a\"},\n                 {\"ats\": \"greenhouse\", \"company\": \"b\"}],\n                client=client,\n            )\n        assert jobs == []  # both empty, but call didn't raise\n\nclass TestFetchMeta:\n    async def test_strips_jsonp_guard_and_parses(self):\n        def handler(request):\n            if request.method == \"POST\":\n                body = 'for (;;);' + '{\"data\":{\"job_search_with_featured_jobs_v2\":{\"all_jobs\":[]}}}'\n                return httpx.Response(200, text=body)\n            return httpx.Response(200, text='\"LSD\",[],{\"token\":\"tok\"} \"__spin_r\":1')\n        async with mock_client(handler) as client:\n            jobs = await fetch_meta(client, {})\n        assert jobs == []\n\n    async def test_graphql_errors_raise_runtime_error(self):\n        def handler(request):\n            if request.method == \"POST\":\n                return httpx.Response(200, json={\"errors\": [{\"message\": \"doc_id invalid\"}]})\n            return httpx.Response(200, text=\"\")\n        async with mock_client(handler) as client:\n            with pytest.raises(RuntimeError, match=\"meta graphql\"):\n                await fetch_meta(client, {})\n\nclass TestFetchWorkday:\n    async def test_stops_at_offset_total(self):\n        def handler(request):\n            return httpx.Response(200, json={\"jobPostings\": [], \"total\": 0})\n        async with mock_client(handler) as client:\n            jobs = await fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\"})\n        assert jobs == []\n\n    async def test_pagination_advances_and_stops(self):\n        pages = {\"n\": 0}\n        def handler(request):\n            pages[\"n\"] += 1\n            if pages[\"n\"] == 1:\n                return httpx.Response(200, json={\n                    \"jobPostings\": [{\"title\": \"A\", \"externalPath\": \"/a\",\n                                     \"bulletFields\": [\"REQ1\"]}],\n                    \"total\": 1})\n            return httpx.Response(200, json={\"jobPostings\": [], \"total\": 1})\n        async with mock_client(handler) as client:\n            jobs = await fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\"})\n        assert len(jobs) == 1"
      },
