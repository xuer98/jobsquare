        "code": "# tests/test_fetchers_parsers.py\nfrom fetchers import (\n    parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n    _extract_ds1, _ds1_posted_at, parse_google, parse_deshaw,\n    _apple_hydration, _apple_posted_at, parse_apple, parse_meta,\n    parse_microsoft, parse_netflix, _amazon_posted_at, parse_amazon,\n)\n\nclass TestParseGreenhouse:\n    def test_missing_location_and_departments(self):\n        jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1, \"title\": \"Eng\"}]})\n        assert jobs[0].location == \"\" and jobs[0].department == \"\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\nclass TestLeverSalary:\n    def test_min_max_present(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000â€“150,000\"\n\n    def test_falls_back_to_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\nclass TestParseAshby:\n    def test_unlisted_jobs_excluded(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"},\n                          {\"id\": \"2\", \"title\": \"Visible\"}]}\n        jobs = parse_ashby(\"acme\", data)\n        assert [j.external_id for j in jobs] == [\"2\"]\n\nclass TestExtractDs1:\n    def test_no_match_returns_empty_list(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_fallback_pattern_when_sidechannel_moves(self):\n        html = \"key: 'ds:1', ..., data:[[1,2]] });\"\n        assert _extract_ds1(html) == [1, 2]\n\n    def test_malformed_json_returns_empty(self):\n        html = \"key: 'ds:1', data:[not valid json], sideChannel\"\n        assert _extract_ds1(html) == []\n\nclass TestDs1PostedAt:\n    def test_no_timestamp_fields_returns_empty(self):\n        assert _ds1_posted_at([None] * 12) == \"\"\n\n    def test_uses_first_available_index(self):\n        job = [None] * 13 + [[1700000000, 0]]\n        assert _ds1_posted_at(job).startswith(\"2023\")\n\nclass TestAppleHydration:\n    def test_missing_marker_returns_none(self):\n        assert _apple_hydration(\"<html></html>\") is None\n\n    def test_escaped_quotes_in_payload(self):\n        html = 'window.__staticRouterHydrationData = JSON.parse(\"{\\\\\"a\\\\\":1}\");'\n        assert _apple_hydration(html) == {\"a\": 1}\n\nclass TestApplePostedAt:\n    def test_nanosecond_precision_truncated(self):\n        result = _apple_posted_at(\"2024-01-15T10:00:03.812668311Z\")\n        assert result == \"2024-01-15T10:00:03.812668+00:00\"\n\n    def test_empty_input(self):\n        assert _apple_posted_at(\"\") == \"\"\n\n    def test_no_fractional_seconds(self):\n        assert _apple_posted_at(\"2024-01-15T10:00:03Z\") == \"2024-01-15T10:00:03+00:00\"\n\nclass TestParseMeta:\n    def test_duplicate_ids_deduped(self):\n        results = [{\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"1\", \"title\": \"A dup\"}]\n        assert len(parse_meta(\"meta\", results)) == 1\n\n    def test_missing_id_skipped(self):\n        assert parse_meta(\"meta\", [{\"title\": \"No id\"}]) == []\n\nclass TestAmazonPostedAt:\n    def test_valid_date(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_date_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_empty_string(self):\n        assert _amazon_posted_at(\"\") == \"\"\n\nclass TestParseAmazon:\n    def test_falls_back_to_id_icims(self):\n        jobs = parse_amazon(\"amazon\", [{\"id_icims\": \"123\", \"title\": \"Eng\", \"job_path\": \"/x\"}])\n        assert jobs[0].external_id == \"123\"\n\n    def test_no_id_at_all(self):\n        jobs = parse_amazon(\"amazon\", [{\"title\": \"Eng\"}])\n        assert jobs[0].external_id == \"\""
