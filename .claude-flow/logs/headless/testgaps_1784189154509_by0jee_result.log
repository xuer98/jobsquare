er_collide(self, tmp_path):\n        # exercises the BEGIN IMMEDIATE serialization the docstring claims\n        db_path = tmp_path / \"concurrent.db\"\n        Store(db_path).close()  # create schema once\n        results = []\n        lock = threading.Lock()\n\n        def worker():\n            s = Store(db_path)\n            n = s.next_seq(\"report_seq\")\n            with lock:\n                results.append(n)\n            s.close()\n\n        threads = [threading.Thread(target=worker) for _ in range(10)]\n        [t.start() for t in threads]\n        [t.join() for t in threads]\n        assert sorted(results) == list(range(1, 11))  # no duplicates\n\n\nclass TestAddedSince:\n    def test_excludes_row_at_exact_timestamp(self, store):\n        store.diff([job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n        assert store.added_since(ts) == []  # strictly after, boundary excluded\n\n    def test_includes_rows_after_ts(self, store):\n        rows = store.added_since(\"2000-01-01T00:00:00+00:00\")\n        store.diff([job()])\n        rows2 = store.added_since(\"2000-01-01T00:00:00+00:00\")\n        assert len(rows2) == 1\n\n\nclass TestMigration:\n    def test_opens_pre_salary_range_schema_without_error(self, tmp_path):\n        db_path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(db_path)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        s = Store(db_path)  # must not raise\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n        s.close()\n```\n\n---\n\n### 4. `notify.py` — env-var gated I/O, 