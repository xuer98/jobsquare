        "code": "# tests/test_models.py\nimport pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_returns_none(self):\n        assert parse_posted_at(\"\") is None\n\n    def test_ms_epoch(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt.tzinfo is timezone.utc\n\n    def test_sec_epoch_boundary_just_under_1e12(self):\n        dt = parse_posted_at(\"999999999999\")  # 12 digits, seconds\n        assert dt.year < 2100  # not misread as ms\n\n    def test_iso_with_trailing_z(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_naive_iso_gets_utc_attached(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_unparseable_string_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_negative_numeric_string(self):\n        # documents current behavior — decide if this should raise/None instead\n        result = parse_posted_at(\"-100\")\n        assert result is not None or result is None  # replace with actual expectation\n\n\nclass TestJob:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"Engineer\", url=\"https://x/1\")\n        return Job(**{**base, **overrides})\n\n    def test_key_stable_across_title_change(self):\n        j1, j2 = self._job(title=\"Engineer I\"), self._job(title=\"Engineer II\")\n        assert j1.key == j2.key\n\n    def test_content_hash_changes_on_title(self):\n        j1, j2 = self._job(title=\"A\"), self._job(title=\"B\")\n        assert j1.content_hash != j2.content_hash\n\n    def test_content_hash_ignores_posted_at_and_salary(self):\n        j1 = self._job(posted_at=\"2024-01-01\", salary_range=\"100k\")\n        j2 = self._job(posted_at=\"2024-06-01\", salary_range=\"200k\")\n        assert j1.content_hash == j2.content_hash\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self):\n        row = self._job(raw={\"secret\": 1}).to_row()\n        assert \"raw\" not in row\n        assert \"key\" in row and \"content_hash\" in row"
