unittest.mock import AsyncMock, patch\nfrom pipeline import load_config, run\nfrom models import Job\n\ndef test_load_config_applies_defaults(tmp_path):\n    cfg_file = tmp_path / \"cfg.yaml\"\n    cfg_file.write_text(\"sources: []\\n\")\n    cfg = load_config(cfg_file)\n    assert cfg[\"db\"] == \"jobs.db\"\n    assert cfg[\"concurrency\"] == 8\n    assert cfg[\"filters\"] == {}\n\ndef test_load_config_missing_file_raises(tmp_path):\n    with pytest.raises(FileNotFoundError):\n        load_config(tmp_path / \"nope.yaml\")\n\n@pytest.mark.asyncio\nasync def test_dry_run_does_not_touch_store(tmp_path):\n    cfg_file = tmp_path / \"cfg.yaml\"\n    cfg_file.write_text(f\"sources: []\\ndb: {tmp_path / 'x.db'}\\n\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[\n        Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Eng\", url=\"u\")\n    ])), patch(\"pipeline.Store\") as MockStore:\n        result = await run(cfg_file, dry_run=True)\n        MockStore.assert_not_called()\n        assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n```\n\n---\n\n### 6. `agent.py` — CLI + business logic, 0% covered\n\nHighest-value pure-logic targets:\n\n| Gap |\n|---|\n| `cmd_db_new`: first run (no marker) uses `since_days` window |\n| `cmd_db_new`: `--posted-days` drops old, keeps undated (default) |\n| `cmd_db_new`: `--dated-only` drops undated too |\n| `cmd_db_new`: truncation **only at `first_seen` group boundaries** — a group must never be split (this is a documented invariant with a subtle off-by-one risk: `if jobs and len(jobs) + len(g) > a.limit`) |\n| `cmd_db_new`: `watermark` in output equals the last **included** group's timestamp, not `since` |\n| `cmd_db_mark`: `--now` vs explicit watermark vs neither (exit code 2) |\n| `cmd_db_mark`: invalid ISO watermark rejected with exit code 2 |\n| `cmd_report_num`: delegates to `store.next_seq` |\n| `_normalize_ats`: smart quotes/dashes/ellipsis/nbsp replaced in body text |\n| `_normalize_