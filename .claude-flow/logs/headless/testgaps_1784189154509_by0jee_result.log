        "code": "# tests/test_notify.py\nimport pytest\nimport httpx\nimport respx\nfrom notify import notify_slack, notify_sms, notify_webhook, _sms_body, dispatch\nfrom models import Job\n\ndef job(title=\"Engineer\", company=\"Acme\"):\n    return Job(source=\"s\", company=company, external_id=\"1\", title=title, url=\"u\")\n\nclass TestSlack:\n    def test_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        notify_slack([job()], [])  # must not raise / must not attempt network\n\n    @respx.mock\n    def test_posts_when_configured(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        route = respx.post(\"https://hooks.slack.test/x\").mock(\n            return_value=httpx.Response(200))\n        notify_slack([job()], [])\n        assert route.called\n\n    def test_noop_when_no_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        notify_slack([], [])  # should return before any network call\n\n\nclass TestSmsBody:\n    def test_truncates_at_limit_with_more_count(self):\n        jobs = [job(title=f\"J{i}\") for i in range(12)]\n        body = _sms_body(jobs, [], limit=8)\n        assert \"+4 more\" in body\n        assert body.count(\"\\n- \") == 8\n\n    def test_ascii_only_output(self):\n        body = _sms_body([job(title=\"Engineer — Backend\")], [])\n        assert \"—\" not in body  # non-GSM char should not survive\n\n\nclass TestDispatch:\n    def test_one_failing_notifier_does_not_block_others(self, monkeypatch, capsys):\n        import notify\n        def boom(new, changed): raise RuntimeError(\"smtp down\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, notify.notify_console])\n        dispatch([job()], [])\n        out = capsys.readouterr().out\n        assert \"boom\" not in out  # sanity\n        assert \"! notifier boom failed\" in out or \"smtp down\" in out\n        assert \"NEW listing\" in out  # console notifier still ran"
