        "code": "# tests/test_filters.py\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef job(**kw):\n    base = dict(source=\"s\", company=\"c\", external_id=\"1\", title=\"Software Engineer\",\n                url=\"u\", location=\"Remote, USA\", department=\"Eng\")\n    return Job(**{**base, **kw})\n\ndef test_include_word_boundary_excludes_substring_match():\n    # \"go\" as an include keyword must not match \"gopher\" in the title\n    assert match(job(title=\"Gopher Wrangler\"), include=[\"go\"]) is False\n\ndef test_exclude_wins_over_include():\n    j = job(title=\"Senior Manager\")\n    assert match(j, include=[\"manager\"], exclude=[\"manager\"]) is False\n\ndef test_location_substring_case_insensitive():\n    assert match(job(location=\"San Francisco, CA\"), locations=[\"san francisco\"]) is True\n\ndef test_location_no_match_excludes():\n    assert match(job(location=\"London\"), locations=[\"Remote\"]) is False\n\ndef test_cutoff_keeps_unparseable_posted_at():\n    j = job()\n    j.posted_at = \"Posted 3 Days Ago\"  # unparseable\n    cutoff = datetime.now(timezone.utc) + timedelta(days=365)  # far future\n    assert match(j, cutoff=cutoff) is True  # not nuked despite being \"before\" cutoff\n\ndef test_cutoff_drops_old_parseable_job():\n    j = job()\n    j.posted_at = (datetime.now(timezone.utc) - timedelta(days=30)).isoformat()\n    cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n    assert match(j, cutoff=cutoff) is False\n\ndef test_filter_jobs_applies_max_age_days():\n    old = job(external_id=\"old\")\n    old.posted_at = (datetime.now(timezone.utc) - timedelta(days=10)).isoformat()\n    fresh = job(external_id=\"new\")\n    fresh.posted_at = datetime.now(timezone.utc).isoformat()\n    result = filter_jobs([old, fresh], {\"max_age_days\": 5})\n    assert [j.external_id for j in result] == [\"new\"]\n\ndef test_filter_jobs_empty_rules_keeps_everything():\n    jobs = [job(external_id=\"1\"), job(external_id=\"2\")]\n    assert filter_jobs(jobs, {}) == jobs"
