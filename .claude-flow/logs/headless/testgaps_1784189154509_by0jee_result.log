        "code": "# tests/test_store.py\nimport pytest\nimport sqlite3\nimport threading\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"test.db\")\n    yield s\n    s.close()\n\ndef job(external_id=\"1\", title=\"Engineer\", **kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=external_id,\n                title=title, url=\"u\")\n    return Job(**{**base, **kw})\n\nclass TestDiff:\n    def test_new_job_reported_and_persisted(self, store):\n        new, changed = store.diff([job()])\n        assert len(new) == 1 and len(changed) == 0\n        assert store.count() == 1\n\n    def test_unchanged_job_not_reported_but_last_seen_updates(self, store):\n        store.diff([job()])\n        new, changed = store.diff([job()])\n        assert new == [] and changed == []\n\n    def test_changed_content_reported_as_changed_not_duplicated(self, store):\n        store.diff([job(title=\"Engineer I\")])\n        new, changed = store.diff([job(title=\"Engineer II\")])\n        assert new == []\n        assert len(changed) == 1\n        assert store.count() == 1  # updated in place, not a second row\n\n    def test_empty_input(self, store):\n        assert store.diff([]) == ([], [])\n\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta(self, store):\n        store.set_meta(\"k\", \"v1\")\n        assert store.get_meta(\"k\") == \"v1\"\n\n    def test_set_meta_overwrites(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n\nclass TestNextSeq:\n    def test_increments(self, store):\n        assert [store.next_seq(\"x\") for _ in range(3)] == [1, 2, 3]\n\n    def test_concurrent_callers_never_collide(self, tmp_path):\n        # exercises the BEGIN IMMEDIATE serialization the docstring claims\n        db_path = tmp_path / \"concurrent.db\"\n        Store(db_path).close()  # create schema once\n        results = []\n        lock = threading.Lock()\n\n        def worker():\n            s = Store(db_path)\n            n = s.next_seq(\"report_seq\")\n            with lock:\n                results.append(n)\n            s.close()\n\n        threads = [threading.Thread(target=worker) for _ in range(10)]\n        [t.start() for t in threads]\n        [t.join() for t in threads]\n        assert sorted(results) == list(range(1, 11))  # no duplicates\n\n\nclass TestAddedSince:\n    def test_excludes_row_at_exact_timestamp(self, store):\n        store.diff([job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n        assert store.added_since(ts) == []  # strictly after, boundary excluded\n\n    def test_includes_rows_after_ts(self, store):\n        rows = store.added_since(\"2000-01-01T00:00:00+00:00\")\n        store.diff([job()])\n        rows2 = store.added_since(\"2000-01-01T00:00:00+00:00\")\n        assert len(rows2) == 1\n\n\nclass TestMigration:\n    def test_opens_pre_salary_range_schema_without_error(self, tmp_path):\n        db_path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(db_path)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        s = Store(db_path)  # must not raise\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n        s.close()"
