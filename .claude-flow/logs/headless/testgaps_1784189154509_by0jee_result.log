ff=cutoff) is True  # not nuked despite being \"before\" cutoff\n\ndef test_cutoff_drops_old_parseable_job():\n    j = job()\n    j.posted_at = (datetime.now(timezone.utc) - timedelta(days=30)).isoformat()\n    cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n    assert match(j, cutoff=cutoff) is False\n\ndef test_filter_jobs_applies_max_age_days():\n    old = job(external_id=\"old\")\n    old.posted_at = (datetime.now(timezone.utc) - timedelta(days=10)).isoformat()\n    fresh = job(external_id=\"new\")\n    fresh.posted_at = datetime.now(timezone.utc).isoformat()\n    result = filter_jobs([old, fresh], {\"max_age_days\": 5})\n    assert [j.external_id for j in result] == [\"new\"]\n\ndef test_filter_jobs_empty_rules_keeps_everything():\n    jobs = [job(external_id=\"1\"), job(external_id=\"2\")]\n    assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n### 3. `store.py` — SQLite dedup, 0% covered; use `Store(\":memory:\")` or tmp_path\n\n| Gap |\n|---|\n| `diff`: new job → appears in `new`, row inserted |\n| `diff`: same job re-fetched, unchanged hash → not in `new` or `changed`, but `last_seen` updates |\n| `diff`: same key, changed content_hash → appears in `changed`, row updated (not duplicated) |\n| `diff`: empty jobs list |\n| `_migrate`: opening a DB file created before `salary_range` existed (schema migration path — **currently impossible to test without hand-crafting a pre-migration DB**) |\n| `get_meta`/`set_meta`: missing key returns `None`; upsert overwrites |\n| `next_seq`: sequential calls increment (1, 2, 3...) |\n| `next_seq`: **concurrency claim in the docstring is untested** — the whole point of `BEGIN IMMEDIATE` is to serialize concurrent writers; there's no test proving two threads/processes don't get the same sequence number |\n| `added_since`: string-comparison ordering assumption (rows with `first_seen` after `ts`, ordered by `first_seen, company, title`) |\n| `added_since`: boundary — row with `first_seen == ts` excluded (`>` not `>=`)