        "code": "import pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\ndef _job(ext_id=\"1\", title=\"Engineer\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id, title=title, url=\"u\")\n\ndef test_diff_classifies_new_changed_unchanged(store):\n    new, changed = store.diff([_job()])\n    assert len(new) == 1 and not changed\n\n    new2, changed2 = store.diff([_job()])  # same content\n    assert not new2 and not changed2\n\n    new3, changed3 = store.diff([_job(title=\"Senior Engineer\")])  # content changed\n    assert not new3 and len(changed3) == 1\n\ndef test_last_seen_bumps_on_unchanged_row(store):\n    store.diff([_job()])\n    before = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()[\"last_seen\"]\n    import time; time.sleep(1)\n    store.diff([_job()])\n    after = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()[\"last_seen\"]\n    assert after >= before\n\ndef test_migrate_adds_salary_range_to_legacy_schema(tmp_path):\n    import sqlite3\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n        external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n        employment_type TEXT, posted_at TEXT, content_hash TEXT,\n        first_seen TEXT, last_seen TEXT)\"\"\")  # no salary_range column\n    conn.commit(); conn.close()\n    with Store(path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\ndef test_next_seq_increments_atomically(store):\n    assert store.next_seq(\"report_seq\") == 1\n    assert store.next_seq(\"report_seq\") == 2\n\ndef test_next_seq_concurrent_writers_do_not_collide(tmp_path):\n    # regression guard for the parallel-worker-collision failure mode\n    import threading\n    path = tmp_path / \"concurrent.db\"\n    results = []\n    def worker():\n        with Store(path) as s:\n            results.append(s.next_seq(\"report_seq\"))\n    threads = [threading.Thread(target=worker) for _ in range(10)]\n    [t.start() for t in threads]; [t.join() for t in threads]\n    assert sorted(results) == list(range(1, 11))  # no duplicates\n\ndef test_added_since_excludes_ts_itself(store):\n    store.diff([_job()])\n    ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[\"first_seen\"]\n    assert store.added_since(ts) == []       # strictly after, not >=\n    assert len(store.added_since(\"2000-01-01T00:00:00+00:00\")) == 1\n\ndef test_set_meta_upserts(store):\n    store.set_meta(\"k\", \"v1\")\n    store.set_meta(\"k\", \"v2\")\n    assert store.get_meta(\"k\") == \"v2\""
