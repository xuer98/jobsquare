        "content": "\n**Gaps:** `parse_posted_at` edge cases (empty, negative epoch, ms-vs-seconds boundary at 1e12, malformed ISO, no-timezone ISO, trailing `Z`), `Job.key` stability, `content_hash` sensitivity/insensitivity to field changes, `to_row` excludes `raw`.\n\n```python\nimport pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\n@pytest.mark.parametrize(\"value,expected_year\", [\n    (\"\", None),\n    (None, None),\n    (\"not-a-date\", None),\n    (\"1643241332430\", 2022),      # ms epoch (13 digits)\n    (\"1643241332\", 2022),         # seconds epoch\n    (\"2024-01-15T00:00:00Z\", 2024),\n    (\"2024-01-15T00:00:00+00:00\", 2024),\n    (\"2024-01-15T00:00:00\", 2024),  # naive -> assumed UTC\n])\ndef test_parse_posted_at(value, expected_year):\n    dt = parse_posted_at(value)\n    if expected_year is None:\n        assert dt is None\n    else:\n        assert dt.year == expected_year\n        assert dt.tzinfo is not None\n\ndef test_epoch_boundary_999_billion_treated_as_seconds():\n    # just under 1e12 -> seconds, not ms\n    dt = parse_posted_at(\"999999999999\")\n    assert dt.year < 2100  # would be absurd if misread as ms\n\ndef test_job_key_stable_across_field_edits():\n    j1 = Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\", title=\"A\")\n    j2 = Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\", title=\"B changed\")\n    assert j1.key == j2.key\n\ndef test_content_hash_changes_on_material_field(job_factory):\n    j1 = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Eng\", location=\"NY\", url=\"u\")\n    j2 = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Eng II\", location=\"NY\", url=\"u\")\n    assert j1.content_hash != j2.content_hash\n\ndef test_content_hash_stable_when_irrelevant_field_changes():\n    j1 = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Eng\", posted_at=\"2024-01-01\")\n    j2 = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Eng\", posted_at=\"2024-06-01\")\n    assert j1.content_hash == j2.content_hash  # posted_at not in the hash blob\n\ndef test_to_row_excludes_raw_and_adds_key_and_hash():\n    j = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", raw={\"secret\": 1})\n    row = j.to_row()\n    assert \"raw\" not in row\n    assert row[\"key\"] == j.key\n    assert row[\"content_hash\"] == j.content_hash\n```\n\n",
        "level": 3
      },
      {
        "title": "2. `filters.py`",
        "content": "\n**Gaps:** word-boundary matching (substring false positives, e.g. `\"eng\"` shouldn't match `\"engineering manager\"` — actually it should via `\\b`, but check hyphenated words like `\"co-op\"` don't break regex), include+exclude interaction, `cutoff` \"keep if unparseable\" behavior, empty rule dict.\n\n```python\nfrom datetime import datetime, timedelta, timezone\nfrom filters import match, filter_jobs\nfrom models import Job\n\ndef _job(**kw):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Software Engineer\",\n               department=\"Platform\", location=\"Remote - USA\", **kw)\n\ndef test_exclude_takes_precedence_over_include():\n    j = _job(title=\"Senior Software Engineer (Contract)\")\n    assert not match(j, include=[\"software\"], exclude=[\"contract\"])\n\ndef test_word_boundary_avoids_partial_match():\n    j = _job(title=\"Engagement Manager\")\n    assert not match(j, include=[\"engineer\"])  # \"engineer\" shouldn't match \"engagement\"\n\ndef test_locations_is_substring_case_insensitive():\n    j = _job(location=\"Remote - USA\")\n    assert match(j, locations=[\"usa\"])\n    assert not match(j, locations=[\"canada\"])\n\ndef test_cutoff_drops_only_confirmed_old_postings():\n    cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n    old = _job(); old.posted_at = (cutoff - timedelta(days=1)).isoformat()\n    unparseable = _job(); unparseable.posted_at = \"Posted recently\"\n    assert not match(old, cutoff=cutoff)\n    assert match(unparseable, cutoff=cutoff)  # kept, not nuked\n\ndef test_filter_jobs_respects_max_age_days(monkeypatch):\n    jobs = [_job()]\n    assert filter_jobs(jobs, {\"max_age_days\": 30}) == jobs\n\ndef test_filter_jobs_empty_rules_returns_all():\n    jobs = [_job(), _job()]\n    assert filter_jobs(jobs, {}) == jobs\n```\n\n",
        "level": 3
      },
      {
        "title": "3. `store.py` — the dedup source of truth, needs the most rigor",
        "content": "\n**Gaps:** new vs. changed vs. unchanged classification, `last_seen` bump on unchanged rows, `_migrate()` additive-column path (old DB missing `salary_range`), `next_seq` atomicity under concurrent writers (this project's own memory notes *\"parallel worker collisions\"* — worth a real concurrency test), `added_since` ordering/boundary (`>` not `>=`), `get_meta`/`set_meta` upsert.\n\n```python\nimport pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\ndef _job(ext_id=\"1\", title=\"Engineer\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id, title=title, url=\"u\")\n\ndef test_diff_classifies_new_changed_unchanged(store):\n    new, changed = store.diff([_job()])\n    assert len(new) == 1 and not changed\n\n    new2, changed2 = store.diff([_job()])  # same content\n    assert not new2 and not changed2\n\n    new3, changed3 = store.diff([_job(title=\"Senior Engineer\")])  # content changed\n    assert not new3 and len(changed3) == 1\n\ndef test_last_seen_bumps_on_unchanged_row(store):\n    store.diff([_job()])\n    before = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()[\"last_seen\"]\n    import time; time.sleep(1)\n    store.diff([_job()])\n    after = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()[\"last_seen\"]\n    assert after >= before\n\ndef test_migrate_adds_salary_range_to_legacy_schema(tmp_path):\n    import sqlite3\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n        external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n        employment_type TEXT, posted_at TEXT, content_hash TEXT,\n        first_seen TEXT, last_seen TEXT)\"\"\")  # no salary_range column\n    conn.commit(); conn.close()\n    with Store(path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\ndef test_next_seq_increments_atomically(store):\n    assert store.next_seq(\"report_seq\") == 1\n    assert store.next_seq(\"report_seq\") == 2\n\ndef test_next_seq_concurrent_writers_do_not_collide(tmp_path):\n    # regression guard for the parallel-worker-collision failure mode\n    import threading\n    path = tmp_path / \"concurrent.db\"\n    results = []\n    def worker():\n        with Store(path) as s:\n            results.append(s.next_seq(\"report_seq\"))\n    threads = [threading.Thread(target=worker) for _ in range(10)]\n    [t.start() for t in threads]; [t.join() for t in threads]\n    assert sorted(results) == list(range(1, 11))  # no duplicates\n\ndef test_added_since_excludes_ts_itself(store):\n    store.diff([_job()])\n    ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[\"first_seen\"]\n    assert store.added_since(ts) == []       # strictly after, not >=\n    assert len(store.added_since(\"2000-01-01T00:00:00+00:00\")) == 1\n\ndef test_set_meta_upserts(store):\n    store.set_meta(\"k\", \"v1\")\n    store.set_meta(\"k\", \"v2\")\n    assert store.get_meta(\"k\") == \"v2\"\n```\n\n",
        "level": 3
      },
      {
        "title": "4. `fetchers.py` — biggest gap by volume (~1,150 lines, 30 functions, 3 new this branch)",
        "content": "\nEvery `parse_*` function is pure (dict/list in, `Job`s out) — these are the cheapest, highest-value tests to write and currently have **zero** coverage. Priority order:\n\n**a) New-to-this-branch parsers (Microsoft/Netflix/Amazon) — should block merge until covered:**\n```python\nfrom fetchers import parse_microsoft, parse_netflix, parse_amazon, _amazon_posted_at\n\ndef test_parse_microsoft_builds_apply_careers_url_not_jobs_careers():\n    jobs = parse_microsoft(\"microsoft\", [{\"id\": \"123\", \"name\": \"SWE\",\n        \"standardizedLocations\": [\"Redmond, WA\"], \"postedTs\": 1700000000}])\n    assert jobs[0].url == \"https://apply.careers.microsoft.com/careers/job/123\"\n    assert jobs[0].posted_at  # real timestamp converts\n\ndef test_parse_microsoft_missing_id_yields_empty_url():\n    jobs = parse_microsoft(\"microsoft\", [{\"name\": \"SWE\"}])\n    assert jobs[0].url == \"\"\n\ndef test_parse_netflix_prefers_locations_list_over_singular():\n    jobs = parse_netflix(\"netflix\", [{\"id\": \"1\", \"name\": \"SWE\",\n        \"locations\": [\"Los Gatos,CA,USA\"], \"location\": \"ignored\"}])\n    assert jobs[0].location == \"Los Gatos, CA, USA\"  # comma-spacing fixup\n\ndef test_parse_netflix_falls_back_to_singular_location():\n    jobs = parse_netflix(\"netflix\", [{\"id\": \"1\", \"name\": \"SWE\", \"location\": \"Remote,USA\"}])\n    assert jobs[0].location == \"Remote, USA\"\n\ndef test_parse_netflix_prefers_t_create_over_t_update():\n    jobs = parse_netflix(\"netflix\", [{\"id\": \"1\", \"t_create\": 1600000000, \"t_update\": 1700000000}])\n    assert \"2020\" in jobs[0].posted_at  # from t_create, not t_update\n\n@pytest.mark.parametrize(\"value,expected\", [\n    (\"June 26, 2026\", \"2026-06-26T00:00:00+00:00\"),\n    (\"December 1, 2024\", \"2024-12-01T00:00:00+00:00\"),\n    (\"\", \"\"),\n    (\"garbage\", \"\"),\n    (\"Jan 5 2024\", \"\"),   # missing comma -> split() gives 3 tokens but wrong format\n])\ndef test_amazon_posted_at_parsing(value, expected):\n    assert _amazon_posted_at(value) == expected\n\ndef test_parse_amazon_falls_back_to_id_icims():\n    jobs = parse_amazon(\"amazon\", [{\"id_icims\": \"999\", \"title\": \" SWE \", \"job_path\": \"/x\"}])\n    assert jobs[0].external_id == \"999\"\n    assert jobs[0].title == \"SWE\"  # stripped\n```\n\n**b) Existing parsers — sample the pattern (apply identically to `parse_lever`, `parse_ashby`, `parse_smartrecruiters`, `parse_recruitee`, `parse_workable`, `parse_eightfold`, `parse_phenom`, `parse_bytedance`):**\n```python\nfrom fetchers import parse_greenhouse, _lever_salary, parse_ashby, _extract_ds1, _balanced_json\n\ndef test_parse_greenhouse_joins_multiple_departments():\n    jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1, \"title\": \"SWE\",\n        \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Platform\"}]}]})\n    assert jobs[0].department == \"Eng, Platform\"\n\ndef test_lever_salary_prefers_range_over_description():\n    assert _lever_salary({\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}) \\\n        == \"USD 100,000–150,000\"\n\ndef test_lever_salary_falls_back_to_description_plain():\n    assert _lever_salary({\"salaryDescriptionPlain\": \"Competitive\"}) == \"Competitive\"\n\ndef test_parse_ashby_skips_unlisted_jobs():\n    jobs = parse_ashby(\"acme\", {\"jobs\": [{\"id\": 1, \"isListed\": False, \"title\": \"Hidden\"}]})\n    assert jobs == []\n\ndef test_balanced_json_handles_nested_braces_and_escaped_quotes():\n    text = 'prefix {\"a\": {\"b\": \"c\\\\\"}d\"}, \"e\": 1} suffix'\n    result = _balanced_json(text, text.index(\"{\"))\n    assert result == '{\"a\": {\"b\": \"c\\\\\"}d\"}, \"e\": 1}'\n\ndef test_balanced_json_unterminated_returns_none():\n    assert _balanced_json('prefix {\"a\": 1', 7) is None\n```\n\n**c) Retry/backoff — `_request` currently has zero tests despite being the resilience backbone for every fetcher:**\n```python\nimport respx, httpx, pytest\nfrom fetchers import _request\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_request_retries_on_503_then_succeeds():\n    route = respx.get(\"https://x/y\").mock(side_effect=[\n        httpx.Response(503), httpx.Response(200, json={\"ok\": True})])\n    async with httpx.AsyncClient() as client:\n        r = await _request(client, \"https://x/y\", retries=3)\n    assert r.status_code == 200\n    assert route.call_count == 2\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_request_exhausts_retries_and_raises():\n    respx.get(\"https://x/y\").mock(return_value=httpx.Response(500))\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(client, \"https://x/y\", retries=2)\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_request_does_not_retry_on_404():\n    respx.get(\"https://x/y\").mock(return_value=httpx.Response(404))\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(RuntimeError):\n            await _request(client, \"https://x/y\", retries=3)\n    # assert only 1 call was made (no wasted retries on a non-retryable 4xx)\n```\n\n**d) Pagination-stopping logic** (the `fresh = [...]; if not fresh: break` pattern repeats in ~8 fetchers — worth one shared parametrized integration test with a mocked client, e.g. `fetch_optiver`/`fetch_twosigma` returning 2 pages then an empty page):\n```python\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_optiver_stops_when_page_returns_no_fresh_items():\n    respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(side_effect=[\n        httpx.Response(200, json={\"items\": [{\"href\": \"/a\", \"title\": \"A\"}]}),\n        httpx.Response(200, json={\"items\": []}),\n    ])\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_optiver(client, {\"max_pages\": 5})\n    assert len(jobs) == 1\n```\n\n**e) Dispatcher + concurrency — no tests at all:**\n```python\nfrom fetchers import fetch_source, fetch_all\n\n@pytest.mark.asyncio\nasync def test_fetch_source_unknown_ats_raises():\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            await fetch_source(client, {\"ats\": \"bogus\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_all_isolates_one_source_failure(respx_mock, monkeypatch):\n    # one source raises, the other succeeds — fetch_all must return the good one, not blow up\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_all_respects_concurrency_semaphore():\n    # spawn N sources with a fetcher that tracks concurrent-call high-water-mark;\n    # assert it never exceeds `concurrency`\n    ...\n```\n\n",
