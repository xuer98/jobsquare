        "title": "tests/test_filters.py",
        "content": "import pytest\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(**kw):\n    defaults = dict(source=\"s\", company=\"c\", external_id=\"1\", title=\"Backend Engineer\",\n                     url=\"u\", location=\"Remote - US\", department=\"Engineering\")\n    return Job(**{**defaults, **kw})\n\ndef test_include_keyword_word_boundary_no_substring_match():\n    # \"eng\" should not match \"Engineering\" as a substring per word-boundary regex\n    assert match(_job(title=\"Engineering Manager\"), include=[\"eng\"]) is True  # \\bENG\\b in \"Engineering\"? verify boundary behavior\n    assert match(_job(title=\"Design\"), include=[\"eng\"]) is False\n\ndef test_exclude_takes_precedence_over_include():\n    j = _job(title=\"Senior Backend Engineer (Intern)\")\n    assert match(j, include=[\"engineer\"], exclude=[\"intern\"]) is False\n\ndef test_locations_case_insensitive_substring():\n    assert match(_job(location=\"San Francisco, CA\"), locations=[\"san francisco\"]) is True\n    assert match(_job(location=\"Remote\"), locations=[\"san francisco\"]) is False\n\ndef test_locations_empty_list_job_location_matches_nothing():\n    assert match(_job(location=\"\"), locations=[\"nyc\"]) is False\n\ndef test_cutoff_drops_old_confirmed_date():\n    old = _job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n    assert match(old, cutoff=datetime.now(timezone.utc) - timedelta(days=7)) is False\n\ndef test_cutoff_keeps_unparseable_posted_at():\n    j = _job(posted_at=\"Posted 3 Days Ago\")  # Workday prose, currently unparsed\n    assert match(j, cutoff=datetime.now(timezone.utc) - timedelta(days=1)) is True\n\ndef test_filter_jobs_max_age_days_builds_cutoff(monkeypatch):\n    fresh = _job(external_id=\"1\", posted_at=datetime.now(timezone.utc).isoformat())\n    stale = _job(external_id=\"2\", posted_at=(datetime.now(timezone.utc) - timedelta(days=10)).isoformat())\n    result = filter_jobs([fresh, stale], {\"max_age_days\": 1})\n    assert result == [fresh]\n\ndef test_filter_jobs_no_rules_returns_all():\n    jobs = [_job(external_id=str(i)) for i in range(3)]\n    assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n",
