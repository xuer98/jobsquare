        "title": "tests/test_store.py",
        "content": "import pytest\nfrom models import Job\nfrom store import Store\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\ndef _job(ext_id=\"1\", title=\"Eng\", **kw):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id, title=title, url=\"u\", **kw)\n\ndef test_diff_first_seen_is_new(store):\n    new, changed = store.diff([_job()])\n    assert len(new) == 1 and changed == []\n    assert store.count() == 1\n\ndef test_diff_unchanged_job_reappears_in_neither_list(store):\n    store.diff([_job()])\n    new, changed = store.diff([_job()])   # same content, second run\n    assert new == [] and changed == []\n\ndef test_diff_changed_content_hash_flags_changed(store):\n    store.diff([_job(title=\"Eng I\")])\n    new, changed = store.diff([_job(title=\"Eng II\")])  # same key, different title -> different hash\n    assert new == [] and len(changed) == 1\n\ndef test_diff_persists_across_store_instances(tmp_path):\n    path = tmp_path / \"persist.db\"\n    with Store(path) as s1:\n        s1.diff([_job()])\n    with Store(path) as s2:\n        new, _ = s2.diff([_job()])\n        assert new == []  # still known on reopen\n\ndef test_migrate_adds_salary_range_to_legacy_schema(tmp_path):\n    import sqlite3\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.executescript(\"\"\"\n        CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n            external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n            employment_type TEXT, posted_at TEXT, content_hash TEXT,\n            first_seen TEXT, last_seen TEXT);\n        CREATE TABLE meta (k TEXT PRIMARY KEY, v TEXT NOT NULL);\n    \"\"\")\n    conn.commit(); conn.close()\n    with Store(path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\ndef test_meta_get_set_roundtrip_and_upsert(store):\n    assert store.get_meta(\"last_scan\") is None\n    store.set_meta(\"last_scan\", \"2024-01-01T00:00:00+00:00\")\n    assert store.get_meta(\"last_scan\") == \"2024-01-01T00:00:00+00:00\"\n    store.set_meta(\"last_scan\", \"2024-02-01T00:00:00+00:00\")  # overwrite path\n    assert store.get_meta(\"last_scan\") == \"2024-02-01T00:00:00+00:00\"\n\ndef test_added_since_excludes_exact_timestamp_boundary(store):\n    store.diff([_job()])\n    ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n    assert store.added_since(ts) == []          # strictly-after semantics\n    assert len(store.added_since(\"2000-01-01T00:00:00+00:00\")) == 1\n\ndef test_added_since_orders_by_first_seen_company_title(store):\n    store.diff([_job(ext_id=\"2\", title=\"Z Role\")])\n    store.diff([_job(ext_id=\"1\", title=\"A Role\")])  # separate diff call -> later first_seen\n    rows = store.added_since(\"2000-01-01T00:00:00+00:00\")\n    assert [r[\"title\"] for r in rows] == [\"Z Role\", \"A Role\"]\n```\n\n---\n\n",
