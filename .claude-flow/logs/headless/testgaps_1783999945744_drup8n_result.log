        "code": "# tests/test_models.py\nimport pytest\nfrom datetime import datetime, timezone\nfrom models import Job, parse_posted_at\n\n@pytest.mark.parametrize(\"value,expected_epoch_s\", [\n    (\"1643241332430\", 1643241332),   # Lever ms epoch\n    (\"1643241332\", 1643241332),      # plain seconds epoch\n    (\"-5\", -5),                      # negative numeric edge case\n])\ndef test_parse_posted_at_numeric(value, expected_epoch_s):\n    dt = parse_posted_at(value)\n    assert dt.timestamp() == expected_epoch_s\n\ndef test_parse_posted_at_iso_with_z():\n    dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n    assert dt == datetime(2024, 1, 15, 10, 0, tzinfo=timezone.utc)\n\ndef test_parse_posted_at_iso_naive_assumes_utc():\n    dt = parse_posted_at(\"2024-01-15T10:00:00\")\n    assert dt.tzinfo == timezone.utc\n\n@pytest.mark.parametrize(\"value\", [\"\", None, \"Posted 3 Days Ago\", \"not-a-date\"])\ndef test_parse_posted_at_unparseable_returns_none(value):\n    assert parse_posted_at(value) is None\n\ndef test_job_key_is_stable_identity():\n    j = Job(source=\"lever\", company=\"acme\", external_id=\"123\", title=\"Eng\", url=\"u\")\n    assert j.key == \"lever:acme:123\"\n\ndef test_job_content_hash_changes_on_title_but_not_on_id():\n    base = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Eng\", url=\"u\", location=\"NY\")\n    same_id_diff_title = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Sr Eng\", url=\"u\", location=\"NY\")\n    diff_id_same_fields = Job(source=\"s\", company=\"c\", external_id=\"2\", title=\"Eng\", url=\"u\", location=\"NY\")\n    assert base.content_hash != same_id_diff_title.content_hash\n    assert base.content_hash == diff_id_same_fields.content_hash  # hash excludes external_id\n\ndef test_job_to_row_excludes_raw_and_adds_key_and_hash():\n    j = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"t\", url=\"u\", raw={\"x\": 1})\n    row = j.to_row()\n    assert \"raw\" not in row\n    assert row[\"key\"] == j.key\n    assert row[\"content_hash\"] == j.content_hash"
