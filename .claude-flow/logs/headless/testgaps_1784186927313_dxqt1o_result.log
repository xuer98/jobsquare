with expected bounds (needs `asyncio.sleep` mocked, not real sleep — currently would make tests slow/flaky if untested this way).\n\n```python\nimport httpx, pytest\nimport fetchers\n\n@pytest.mark.asyncio\nasync def test_request_retries_on_503_then_succeeds(monkeypatch):\n    monkeypatch.setattr(fetchers.asyncio, \"sleep\", lambda *_: None)\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        if calls[\"n\"] < 3:\n            return httpx.Response(503)\n        return httpx.Response(200, json={\"ok\": True})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    r = await fetchers._request(client, \"https://x/test\")\n    assert r.status_code == 200 and calls[\"n\"] == 3\n\n@pytest.mark.asyncio\nasync def test_request_does_not_retry_404(monkeypatch):\n    monkeypatch.setattr(fetchers.asyncio, \"sleep\", lambda *_: None)\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        return httpx.Response(404)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    with pytest.raises(RuntimeError):\n        await fetchers._request(client, \"https://x/test\")\n    assert calls[\"n\"] == 1\n\n@pytest.mark.asyncio\nasync def test_request_exhausts_retries_raises_runtime_error(monkeypatch):\n    monkeypatch.setattr(fetchers.asyncio, \"sleep\", lambda *_: None)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(lambda r: httpx.Response(500)))\n    with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n        await fetchers._request(client, \"https://x/test\", retries=2)\n```\n\n#### 6d. Paginated `fetch_*` — pagination-stop logic is subtle and entirely untested\n\nEvery paginated fetcher (`fetch_twosigma`, `fetch_optiver`, `fetch_apple`, `fetch_eightfold`, `fetch_bytedance`, `fetch_phenom`, `fetch_workday`, `fetch_google`, `fetch_microsoft`, `fetch_netflix`, `fetch_amazon`) shares the \"stop when a page yields no *fresh* IDs\" pattern — but each has a different stop condition (empty `items`, `len(jobs) >= total`, `offset > 5000` safety cap for Workday). None tested. Highest-risk: an off-by-one here causes either infinite pagination against a live API or silently truncated results.\n\n```python\nimport httpx, pytest\nimport fetchers\n\n@pytest.mark.asyncio\nasync def test_fetch_optiver_stops_on_empty_items(monkeypatch):\n    pages = [{\"items\": [{\"href\": \"/join-us/jobs/a\", \"title\": \"A\"}]}, {\"items\": []}]\n    calls = {\"n\": 0}\n    def handler(request):\n        resp = pages[calls[\"n\"]]; calls[\"n\"] += 1\n        return httpx.Response(200, json=resp)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetchers.fetch_optiver(client, {\"company\": \"optiver\"}, )\n    # patch client injection point as needed; verifies single fetch, stop on empty page\n    assert calls[\"n\"] == 2\n\n@pytest.mark.asyncio\nasync def test_fetch_workday_respects_5000_offset_safety_cap(monkeypatch):\n    # mock a tenant that always returns `total` larger than reality — assert\n    # the loop terminates at offset > 5000 rather than looping forever\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_ashby_falls_back_to_hosted_page_on_404():\n    def handler(request):\n        if \"posting-api\" in str(request.url):\n            return httpx.Response(404)\n        html = \"window.__appData = {\\\"jobBoard\\\":{\\\"jobPostings\\\":[{\\\"id\\\":\\\"1\\\",\\\"title\\\":\\\"T\\\"}]}};\"\n        return httpx.Response(200, text=html)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetchers.fetch_ashby(client, {\"company\": \"acme\"})\n    assert jobs[0].external_id == \"1\"\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_raises_on_graphql_errors_field(monkeypatch):\n    monkeypatch.setattr(fetchers, \"_get_text\", async_stub_returning_error_payload)\n    with pytest.raises(RuntimeError, match=\"meta graphql\"):\n        await fetchers.fetch_meta(client_stub, {\"company\": \"meta\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_strips_for_loop_prefix():\n    # response text starts with \"for (;;);\" — verify it's stripped before json.loads\n    ...\n```\n\n#### 6e. `fetch_source` / `fetch_all` — dispatcher and fault isolation, untested\n\n```python\nimport pytest\nfrom fetchers import fetch_source, fetch_all\n\n@pytest.mark.asyncio\nasync def test_fetch_source_unknown_ats_raises_value_error():\n    with pytest.raises(ValueError, match=\"unknown ATS\"):\n        await fetch_source(None, {\"ats\": \"not-a-real-ats\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_all_isolates_one_source_failure(monkeypatch, capsys):\n    async def good(client, src): return [job_stub]\n    async def bad(client, src): raise RuntimeError(\"network down\")\n    monkeypatch.setitem(fetchers.FETCHERS, \"greenhouse\", good)\n    monkeypatch.setitem(fetchers.FETCHERS, \"lever\", bad)\n    jobs = await fetch_all([{\"ats\": \"greenhouse\", \"company\": \"a\"},\n                             {\"ats\": \"lever\", \"company\": \"b\"}])\n    assert len(jobs) == 1\n    assert \"lever:b failed\" in capsys.readouterr().out\n\n@pytest.mark.asyncio\nasync def test_fetch_all_respects_concurrency_semaphore(monkeypatch):\n    # inject a fetcher that records max concurrent in-flight calls; assert <= concurrency\n    ...\n```\n\n---\n\n### 7. `agent.py` — deterministic CLI helpers (fully untestable-in-practice today; no tests exist)\n\n**Gaps:**\n- `cmd_db_new`: first-run window fallback, watermark advances only to the last *complete* `first_seen` group (never mid-group — this is a subtle correctness guarantee explicitly called out in a comment and has zero test backing it), `--posted-days` + `--dated-only` interactions (4-way matrix: dated/undated × within/outside window), `--limit` truncation exactness.\n- `cmd_db_mark`: rejects non-ISO watermark, requires either `watermark` or `--now`.\n- `_normalize_ats`: replacements skip `<style>`/`<script>` content and tag attributes, only touch body text; counts dict correctness; nested/adjacent tags.\n- `_chrome_bin`: `CHROME_PATH` env override, PATH lookup, macOS `.app` fallback, exits when none found.\n- `run_claude` / `main`: mode-word vs. flag-passthrough splitting logic (`words[:i]` / `words[i:]` split point), bare invocation → interactive REPL.\n\n```python\nimport pytest\nfrom agent import cmd_db_new, cmd_db_mark, _normalize_ats\n\ndef test_normalize_ats_skips_style_and_script_blocks():\n    html = '<style>content: \"\\u2014\";</style><p>em\\u2014dash</p><script>var x=\"\\u2014\";</script>'\n    out, counts = _normalize_ats(html)\n    assert 'content: \"\\u2014\"' in out          # untouched inside <style>\n    assert 'var x=\"\\u2014\"' in out              # untouched inside <script>\n    assert \"em-dash\" in out                     # replaced in body text\n    assert counts[\"em-dash\"] == 1\n\ndef test_normalize_ats_skips_tag_attributes():\n    html = '<a title=\"em\\u2014dash\">visible\\u2014text</a>'\n    out, counts = _normalize_ats(html)\n    assert 'title=\"em\\u2014dash\"' in out         # attribute untouched\n    assert \"visible-text\" in out                 # body text replaced\n    assert counts[\"em-dash\"] == 1\n\ndef test_db_mark_rejects_non_iso_watermark(capsys):\n    rc = cmd_db_mark([\"not-a-timestamp\"])\n    assert rc == 2\n    assert \"not an ISO timestamp\" in capsys.readouterr().err\n\ndef test_db_mark_requires_watermark_or_now(capsys):\n    rc = cmd_db_mark([])\n    assert rc == 2\n\ndef test_db_new_first_run_uses_since_days_window(tmp_store_config, capsys):\n    rc = cmd_db_new([\"-c\", tmp_store_config, \"--since-days\", \"3\"])\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"first_run\"] is True\n\ndef test_db_new_truncation_stops_at_group_boundary(populated_store_config, capsys):\n    # seed two first_seen groups where group sizes straddle --limit;\n    # assert watermark == the LAST fully-included group's timestamp,\n    # never a timestamp from within a partially-dropped group\n    rc = cmd_db_new([\"-c\", populated_store_config, \"--limit\", \"1\"])\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"truncated\"] is True\n\ndef test_db_new_dated_only_drops_undated(populated_store_config, capsys):\n    rc = cmd_db_new([\"-c\", populated_store_config, \"--dated-only\"])\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"undated_dropped\"] > 0 and out[\"undated_kept\"] == 0\n```\n\n---\n\n### Integration test gaps (no end-to-end coverage at all)\n\n1. **Full pipeline happy path**: YAML config → mocked multi-source fetch → filter → `Store.diff` → `dispatch` → assert DB rows + notifier calls, using a real `tmp_path` SQLite file (not mocked) to catch schema/SQL bugs mocks would hide.\n2. **Idempotent re-run**: running `run()` twice against the same DB with unchanged upstream data yields `new=0, changed=0` both times — the core \"don't spam duplicate notifications\" guarantee.\n3. **Cross-module posted_at propagation**: a fetcher-specific date format (Amazon's `\"June 26, 2026\"`, Workday's `\"Posted 3 Days Ago\"` — which currently has **no parser path in `parse_posted_at` at all** and will silently always be treated as `None`/kept) flowing through `filters.max_age_days` end-to-end.\n4. **`agent.py db-new` ↔ `pipeline.py` handoff**: pipeline writes rows, then `db-new` reads them back via `added_since` — no test exercises this producer/consumer contract together.\n5. **Concurrent pipeline workers**: your own memory notes ([[jobsquare-parallel-worker-collisions]]) flag shared scratchpad/report-filename collisions across parallel runs — `Store.next_seq`'s `BEGIN IMMEDIATE` locking claim is completely unverified under actual concurrent access (e.g. `ThreadPoolExecutor` hammering the same DB file).\n\n---\n\n### Missing error-handling tests (explicit gaps in exception paths)\n\n| Location | Untested failure mode |\n|---|---|\n| `fetchers._request` | Retry exhaustion → `RuntimeError`; non-retryable status short-circuits |\n| `fetchers.fetch_meta` | `data.get(\"errors\")` → `RuntimeError` on rotated `doc_id` |\n| `fetchers.fetch_ashby` | Non-404, non-200 status → `raise_for_status()` propagates; `__appData` blob absent → `RuntimeError` |\n| `notify.dispatch` | Any notifier exception is caught+logged, never propagates |\n| `notify.notify_sms` | `raise_for_status()` on bad Twilio creds — only caught one level up in `dispatch` |\n| `agent.cmd_db_mark` | Invalid ISO string → exit code 2, not a crash |\n| `agent._chrome_bin` | No Chrome found → `sys.exit()` (currently untested, would silently pass in CI without display) |\n| `agent.cmd_pdf_render` | Chrome subprocess produces non-PDF output → exit code 1 + stderr tail |\n| `pipeline.load_config` | Malformed YAML / missing file — no test for either |\n\n---\n\n**Priority order if implementing incrementally:**\n1. `models.parse_posted_at` + `store.Store` (correctness-critical, cheap to test, no network)\n2. `filters.match` (cheap, catches silent over/under-matching)\n3. `fetchers.py` pure `parse_*` functions (no network needed, largest function count)\n4. `fetchers._request` retry logic + `_balanced_json`/`_extract_ds1`/`_apple_hydration` (highest bug-density code in the repo)\n5. `notify.dispatch` isolation + env-gating\n6. Paginated `fetch_*` stop-conditions via `httpx.MockTransport`\n7. `agent.py` CLI helpers\n8. End-to-end `pipeline.run` integration tests last, once units are solid underneath them\n",
