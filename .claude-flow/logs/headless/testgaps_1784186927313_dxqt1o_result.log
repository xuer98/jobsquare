        "title": "3. `store.py` — `Store` (dedup is the correctness-critical core; entirely untested)",
        "content": "\n**Gaps:** new-vs-changed-vs-unchanged classification, `last_seen` bump on unchanged row, migration path (`salary_range` column added to a pre-existing DB missing it), `next_seq` concurrency/atomicity, `added_since` ordering + strict `>` boundary, `count()`.\n\n```python\nimport sqlite3\nimport pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\ndef job(ext_id=\"1\", title=\"T\", **kw):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id, title=title, url=\"u\", **kw)\n\ndef test_diff_classifies_new(store):\n    new, changed = store.diff([job()])\n    assert len(new) == 1 and changed == []\n    assert store.count() == 1\n\ndef test_diff_second_run_same_job_is_neither_new_nor_changed(store):\n    store.diff([job()])\n    new, changed = store.diff([job()])\n    assert new == [] and changed == []\n\ndef test_diff_detects_content_change(store):\n    store.diff([job(title=\"Old Title\")])\n    new, changed = store.diff([job(title=\"New Title\")])\n    assert new == [] and len(changed) == 1\n\ndef test_diff_unchanged_row_bumps_last_seen(store):\n    store.diff([job()])\n    cur = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n    store.diff([job()])\n    cur2 = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n    assert cur2[\"last_seen\"] >= cur[\"last_seen\"]\n\ndef test_migration_adds_salary_range_to_legacy_db(tmp_path):\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.executescript(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n        external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n        employment_type TEXT, posted_at TEXT, content_hash TEXT,\n        first_seen TEXT, last_seen TEXT);\n        CREATE TABLE meta (k TEXT PRIMARY KEY, v TEXT);\"\"\")\n    conn.commit(); conn.close()\n    with Store(path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\ndef test_next_seq_increments(store):\n    assert store.next_seq(\"k\") == 1\n    assert store.next_seq(\"k\") == 2\n\ndef test_added_since_boundary_is_strict(store):\n    store.diff([job()])\n    ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[\"first_seen\"]\n    assert store.added_since(ts) == []          # strictly-after excludes equal ts\n    assert len(store.added_since(\"2000-01-01T00:00:00+00:00\")) == 1\n```\n\n---\n\n",
