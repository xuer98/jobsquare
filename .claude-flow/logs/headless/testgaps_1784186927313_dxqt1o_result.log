        "title": "6a. Pure parsers — `parse_greenhouse`, `parse_lever`, `parse_ashby`, `parse_ashby_page`, `parse_smartrecruiters`, `parse_recruitee`, `parse_workable`, `parse_google`, `parse_deshaw`, `parse_twosigma`, `parse_optiver`, `parse_apple`, `parse_eightfold`, `parse_bytedance`, `parse_phenom`, `parse_microsoft`, `parse_netflix`, `parse_amazon`",
        "content": "\nThese take plain data, no network — cheapest, highest-ROI tests to add. None exist. Each needs: (1) a minimal realistic fixture, (2) a missing/null-field fixture to check defensive `.get()` fallbacks don't crash, (3) source-specific quirks below.\n\n```python\nfrom fetchers import parse_greenhouse, parse_lever, parse_ashby, parse_amazon, _amazon_posted_at\n\ndef test_parse_greenhouse_basic():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"https://x/1\",\n                       \"location\": {\"name\": \"NYC\"}, \"departments\": [{\"name\": \"Eng\"}],\n                       \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n    jobs = parse_greenhouse(\"acme\", data)\n    assert jobs[0].key == \"greenhouse:acme:1\"\n    assert jobs[0].department == \"Eng\"\n\ndef test_parse_greenhouse_missing_optional_fields_does_not_crash():\n    jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1}]})\n    assert jobs[0].title == \"\" and jobs[0].location == \"\"\n\ndef test_parse_lever_salary_range_formatting():\n    j = {\"id\": \"1\", \"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n    assert \"100,000\" in parse_lever(\"acme\", [j])[0].salary_range\n\ndef test_parse_lever_salary_falls_back_to_plain_description():\n    j = {\"id\": \"1\", \"salaryDescriptionPlain\": \"Competitive\"}\n    assert parse_lever(\"acme\", [j])[0].salary_range == \"Competitive\"\n\ndef test_parse_ashby_skips_unlisted():\n    data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False}, {\"id\": \"2\", \"isListed\": True, \"title\": \"T\"}]}\n    out = parse_ashby(\"acme\", data)\n    assert len(out) == 1 and out[0].external_id == \"2\"\n\n@pytest.mark.parametrize(\"value,expected\", [\n    (\"June 26, 2026\", \"2026-06-26T00:00:00+00:00\"),\n    (\"\", \"\"),\n    (\"Not A Date\", \"\"),\n    (\"Frebruary 1, 2024\", \"\"),   # typo'd month -> KeyError path\n])\ndef test_amazon_posted_at(value, expected):\n    assert _amazon_posted_at(value) == expected\n\ndef test_parse_amazon_dedupes_id_fallback_to_icims():\n    j = [{\"id_icims\": \"999\", \"job_path\": \"/x\", \"title\": \" SWE \"}]\n    out = parse_amazon(\"amazon\", j)\n    assert out[0].external_id == \"999\" and out[0].title == \"SWE\"  # strip() check\n```\n\n",
