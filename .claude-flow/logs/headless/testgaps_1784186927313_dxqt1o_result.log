        "content": "\n**Gaps:** every notifier's env-var gating (missing var → no-op, no crash), `dispatch`'s try/except isolation (one notifier throwing must not block the rest), Slack payload shape, SMS truncation at `limit`, SMS non-GSM char avoidance, email `EMAIL_FROM` fallback to `EMAIL_TO`, `notify_sms` propagating `raise_for_status()` — caught only at `dispatch` level.\n\n```python\nimport notify\nfrom models import Job\nfrom unittest.mock import patch\n\ndef job(**kw): return Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\", **kw)\n\ndef test_notify_slack_noop_without_env(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    with patch(\"httpx.post\") as p:\n        notify.notify_slack([job()], [])\n        p.assert_not_called()\n\ndef test_notify_slack_posts_when_configured(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n    with patch(\"httpx.post\") as p:\n        notify.notify_slack([job()], [])\n        p.assert_called_once()\n\ndef test_dispatch_isolates_failing_notifier(monkeypatch, capsys):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n    with patch(\"notify.notify_slack\", side_effect=RuntimeError(\"boom\")), \\\n         patch(\"notify.notify_console\") as console:\n        notify.dispatch([job()], [])\n        console.assert_called_once()\n    assert \"notifier notify_slack failed\" in capsys.readouterr().out\n\ndef test_sms_body_truncates_and_counts_overflow():\n    jobs = [job(title=f\"T{i}\") for i in range(10)]\n    body = notify._sms_body(jobs, [], limit=8)\n    assert \"+2 more\" in body\n\ndef test_email_from_falls_back_to_email_to(monkeypatch):\n    monkeypatch.setenv(\"SMTP_HOST\", \"smtp\"); monkeypatch.setenv(\"EMAIL_TO\", \"a@b.com\")\n    monkeypatch.delenv(\"EMAIL_FROM\", raising=False)\n    with patch(\"smtplib.SMTP\"):\n        notify.notify_email([job()], [])\n    # assert constructed MIMEText[\"From\"] == \"a@b.com\" (needs SMTP mock introspection)\n\ndef test_notify_sms_raises_on_bad_credentials(monkeypatch):\n    for k, v in [(\"TWILIO_ACCOUNT_SID\",\"x\"),(\"TWILIO_AUTH_TOKEN\",\"y\"),\n                 (\"TWILIO_FROM\",\"+1\"),(\"TWILIO_TO\",\"+2\")]:\n        monkeypatch.setenv(k, v)\n    with patch(\"httpx.post\") as p:\n        p.return_value.raise_for_status.side_effect = Exception(\"401\")\n        with pytest.raises(Exception):\n            notify.notify_sms([job()], [])\n```\n\n---\n\n",
