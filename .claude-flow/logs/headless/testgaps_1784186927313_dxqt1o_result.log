   (\"1643241332\", datetime(2022, 1, 26, 20, 55, 32, tzinfo=timezone.utc)),      # s epoch\n    (\"2024-01-01T00:00:00Z\", datetime(2024, 1, 1, tzinfo=timezone.utc)),\n    (\"2024-01-01T00:00:00\", datetime(2024, 1, 1, tzinfo=timezone.utc)),          # naive -> UTC\n    (\"-5\", None),  # or whatever the intended behavior is for negative epochs — currently untested\n])\ndef test_parse_posted_at(value, expected):\n    assert parse_posted_at(value) == expected\n\ndef test_content_hash_ignores_posted_at_and_salary():\n    j1 = Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\", posted_at=\"a\")\n    j2 = Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\", posted_at=\"b\", salary_range=\"$1\")\n    assert j1.content_hash == j2.content_hash\n\ndef test_content_hash_changes_on_title():\n    j1 = Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"T1\", url=\"u\")\n    j2 = Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"T2\", url=\"u\")\n    assert j1.content_hash != j2.content_hash\n\ndef test_key_ignores_title_change():\n    j1 = Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"Old\", url=\"u\")\n    j2 = Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"New\", url=\"u\")\n    assert j1.key == j2.key\n\ndef test_to_row_excludes_raw_includes_key_and_hash():\n    j = Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\", raw={\"secret\": 1})\n    row = j.to_row()\n    assert \"raw\" not in row\n    assert row[\"key\"] == j.key and row[\"content_hash\"] == j.content_hash\n```\n\n---\n\n### 2. `filters.py` — `match`, `filter_jobs`\n\n**Gaps:** word-boundary regex false-positive/negative (e.g. `include=[\"ai\"]` shouldn't match \"email\" but should match \"AI Engineer\"), exclude taking priority over include, empty rule sets returning True (no filters = pass-through), case-insensitive location substring match, cutoff behavior on unparseable `posted_at` (must be *kept*, per the comment), `max_age_days` as a float string.\n\n```python\nfrom datetime import datetime, timedelta, timezone\nfrom filters import match, filter_jobs\nfrom models import Job\n\ndef job(**kw):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Backend Engineer\",\n               url=\"u\", location=\"Remote, USA\", department=\"Eng\", **kw)\n\ndef test_exclude_wins_over_include():\n    j = job(title=\"Staff AI Engineer (Contract)\")\n    assert match(j, include=[\"engineer\"], exclude=[\"contract\"]) is False\n\ndef test_include_word_boundary_no_substring_match():\n    j = job(title=\"Email Marketing Specialist\")\n    assert match(j, include=[\"ai\"]) is False   # \"ai\" inside \"Email\" must NOT match\n\ndef test_no_rules_passes():\n    assert match(job()) is True\n\ndef test_location_case_insensitive_substring():\n    assert match(job(location=\"Seattle, WA\"), locations=[\"seattle\"]) is True\n\ndef test_cutoff_keeps_unparseable_posted_at():\n    j = job(posted_at=\"garbage\")\n    cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n    assert match(j, cutoff=cutoff) is True\n\ndef test_cutoff_drops_stale_parseable_posted_at():\n    j = job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n    cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n    assert match(j, cutoff=cutoff) is False\n\ndef test_filter_jobs_max_age_days_builds_cutoff():\n    old = job(posted_at=(datetime.now(timezone.utc) - timedelta(days=10)).isoformat())\n    new = job(posted_at=datetime.now(timezone.utc).isoformat())\n    out = filter_jobs([old, new], {\"max_age_days\": 1})\n    assert out == [new]\n```\n\n---\n\n### 3. `store.py` — `Store` (dedup is the correctness-critical core; entirely untested)\n\n**Gaps:** new-vs-changed-vs-unchanged classification, `last_seen` bump on unchanged row, migration path (`salary_range` column added to a pre-existing DB missing it), `next_seq` concurrency/atomicity, `added_since` ordering + strict `>` boundary, `count()`.\n\n```python\nimport sqlite3\nimport pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\ndef job(ext_id=\"1\", title=\"T\", **kw):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id, title=title, url=\"u\", **kw)\n\ndef test_diff_classifies_new(store):\n    new, changed = store.diff([job()])\n    assert len(new) == 1 and changed == []\n    assert store.count() == 1\n\ndef test_diff_second_run_same_job_is_neither_new_nor_changed(store):\n    store.diff([job()])\n    new, changed = store.diff([job()])\n    assert new == [] and changed == []\n\ndef test_diff_detects_content_change(store):\n    store.diff([job(title=\"Old Title\")])\n    new, changed = store.diff([job(title=\"New Title\")])\n    assert new == [] and len(changed) == 1\n\ndef test_diff_unchanged_row_bumps_last_seen(store):\n    store.diff([job()])\n    cur = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n    store.diff([job()])\n    cur2 = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n    assert cur2[\"last_seen\"] >= cur[\"last_seen\"]\n\ndef test_migration_adds_salary_range_to_legacy_db(tmp_path):\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.executescript(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n        external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n        employment_type TEXT, posted_at TEXT, content_hash TEXT,\n        first_seen TEXT, last_seen TEXT);\n        CREATE TABLE meta (k TEXT PRIMARY KEY, v TEXT);\"\"\")\n    conn.commit(); conn.close()\n    with Store(path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\ndef test_next_seq_increments(store):\n    assert store.next_seq(\"k\") == 1\n    assert store.next_seq(\"k\") =