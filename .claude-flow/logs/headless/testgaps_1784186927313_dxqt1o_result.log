ssert \"+2 more\" in body\n\ndef test_email_from_falls_back_to_email_to(monkeypatch):\n    monkeypatch.setenv(\"SMTP_HOST\", \"smtp\"); monkeypatch.setenv(\"EMAIL_TO\", \"a@b.com\")\n    monkeypatch.delenv(\"EMAIL_FROM\", raising=False)\n    with patch(\"smtplib.SMTP\"):\n        notify.notify_email([job()], [])\n    # assert constructed MIMEText[\"From\"] == \"a@b.com\" (needs SMTP mock introspection)\n\ndef test_notify_sms_raises_on_bad_credentials(monkeypatch):\n    for k, v in [(\"TWILIO_ACCOUNT_SID\",\"x\"),(\"TWILIO_AUTH_TOKEN\",\"y\"),\n                 (\"TWILIO_FROM\",\"+1\"),(\"TWILIO_TO\",\"+2\")]:\n        monkeypatch.setenv(k, v)\n    with patch(\"httpx.post\") as p:\n        p.return_value.raise_for_status.side_effect = Exception(\"401\")\n        with pytest.raises(Exception):\n            notify.notify_sms([job()], [])\n```\n\n---\n\n### 5. `pipeline.py` — `run`, `load_config`\n\n**Gaps:** config defaults (`sources`, `filters`, `db`, `concurrency`) applied when omitted from YAML; `dry_run=True` never touches `Store`/`dispatch`; full happy-path integration wiring fetch→filter→dedup→notify.\n\n```python\nimport pytest\nfrom pipeline import load_config, run\n\ndef test_load_config_defaults(tmp_path):\n    f = tmp_path / \"min.yaml\"\n    f.write_text(\"sources: []\\n\")\n    cfg = load_config(f)\n    assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\n@pytest.mark.asyncio\nasync def test_run_dry_run_skips_store_and_notify(tmp_path, monkeypatch):\n    cfg_path = tmp_path / \"c.yaml\"\n    cfg_path.write_text(f\"sources: []\\ndb: {tmp_path/'x.db'}\\n\")\n    monkeypatch.setattr(\"pipeline.fetch_all\", lambda *a, **k: [])\n    called = {\"store\": False, \"dispatch\": False}\n    monkeypatch.setattr(\"pipeline.Store\", lambda *a, **k: (_ for _ in ()).throw(AssertionError))\n    result = await run(cfg_path, dry_run=True)\n    assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n\n@pytest.mark.asyncio\nasyn