        "code": "import pytest\nfrom agent import cmd_db_new, cmd_db_mark, _normalize_ats\n\ndef test_normalize_ats_skips_style_and_script_blocks():\n    html = '<style>content: \"\\u2014\";</style><p>em\\u2014dash</p><script>var x=\"\\u2014\";</script>'\n    out, counts = _normalize_ats(html)\n    assert 'content: \"\\u2014\"' in out          # untouched inside <style>\n    assert 'var x=\"\\u2014\"' in out              # untouched inside <script>\n    assert \"em-dash\" in out                     # replaced in body text\n    assert counts[\"em-dash\"] == 1\n\ndef test_normalize_ats_skips_tag_attributes():\n    html = '<a title=\"em\\u2014dash\">visible\\u2014text</a>'\n    out, counts = _normalize_ats(html)\n    assert 'title=\"em\\u2014dash\"' in out         # attribute untouched\n    assert \"visible-text\" in out                 # body text replaced\n    assert counts[\"em-dash\"] == 1\n\ndef test_db_mark_rejects_non_iso_watermark(capsys):\n    rc = cmd_db_mark([\"not-a-timestamp\"])\n    assert rc == 2\n    assert \"not an ISO timestamp\" in capsys.readouterr().err\n\ndef test_db_mark_requires_watermark_or_now(capsys):\n    rc = cmd_db_mark([])\n    assert rc == 2\n\ndef test_db_new_first_run_uses_since_days_window(tmp_store_config, capsys):\n    rc = cmd_db_new([\"-c\", tmp_store_config, \"--since-days\", \"3\"])\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"first_run\"] is True\n\ndef test_db_new_truncation_stops_at_group_boundary(populated_store_config, capsys):\n    # seed two first_seen groups where group sizes straddle --limit;\n    # assert watermark == the LAST fully-included group's timestamp,\n    # never a timestamp from within a partially-dropped group\n    rc = cmd_db_new([\"-c\", populated_store_config, \"--limit\", \"1\"])\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"truncated\"] is True\n\ndef test_db_new_dated_only_drops_undated(populated_store_config, capsys):\n    rc = cmd_db_new([\"-c\", populated_store_config, \"--dated-only\"])\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"undated_dropped\"] > 0 and out[\"undated_kept\"] == 0"
