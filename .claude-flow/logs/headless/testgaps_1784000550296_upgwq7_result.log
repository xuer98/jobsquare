        "language": "python",
        "code": "# tests/test_models.py\nimport pytest\nfrom datetime import datetime, timezone\nfrom models import Job, parse_posted_at\n\n\nclass TestParsePostedAt:\n    def test_empty_returns_none(self):\n        assert parse_posted_at(\"\") is None\n\n    def test_none_like_returns_none(self):\n        assert parse_posted_at(None) is None  # value: str but callers pass \"\"/None\n\n    @pytest.mark.parametrize(\"raw,expected_epoch\", [\n        (\"1643241332430\", 1643241332),   # Lever ms\n        (\"1643241332\", 1643241332),      # plain seconds\n        (\"-1\", None),                    # negative epoch: lstrip(\"-\").isdigit() path\n    ])\n    def test_numeric_epoch(self, raw, expected_epoch):\n        dt = parse_posted_at(raw)\n        if expected_epoch is None:\n            assert dt is not None  # documents current behavior; confirm intent\n        else:\n            assert dt == datetime.fromtimestamp(expected_epoch, tz=timezone.utc)\n\n    def test_iso8601_with_z_suffix(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00Z\")\n        assert dt.tzinfo is not None\n\n    def test_iso8601_naive_gets_utc(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_workday_prose_is_unparseable(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_garbage_string_returns_none(self):\n        assert parse_posted_at(\"not-a-date\") is None\n\n\nclass TestJob:\n    def _job(self, **kw):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                    title=\"Engineer\", url=\"https://x/1\")\n        base.update(kw)\n        return Job(**base)\n\n    def test_key_is_stable_across_field_changes(self):\n        j1 = self._job(title=\"Engineer I\")\n        j2 = self._job(title=\"Engineer II\")\n        assert j1.key == j2.key\n\n    def test_content_hash_ignores_raw(self):\n        j1 = self._job(raw={\"a\": 1})\n        j2 = self._job(raw={\"a\": 2})\n        assert j1.content_hash == j2.content_hash\n\n    def test_content_hash_changes_on_title_location_url_department(self):\n        base = self._job()\n        assert base.content_hash != self._job(title=\"Other\").content_hash\n        assert base.content_hash != self._job(location=\"Remote\").content_hash\n        assert base.content_hash != self._job(url=\"https://x/2\").content_hash\n        assert base.content_hash != self._job(department=\"Eng\").content_hash\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self):\n        row = self._job(raw={\"secret\": \"payload\"}).to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == self._job().key\n        assert row[\"content_hash\"] == self._job().content_hash\n\n    def test_posted_dt_none_when_unparseable(self):\n        assert self._job(posted_at=\"bogus\").posted_dt is None"
