        "code": "# tests/test_filters.py\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Data Engineer\", url=\"https://x/1\", location=\"Remote, US\",\n                department=\"Engineering\")\n    base.update(kw)\n    return Job(**base)\n\n\nclass TestMatch:\n    def test_no_filters_matches_everything(self):\n        assert match(make_job())\n\n    def test_exclude_beats_include(self):\n        j = make_job(title=\"Senior Data Engineer\")\n        assert not match(j, include=[\"engineer\"], exclude=[\"senior\"])\n\n    def test_word_boundary_avoids_substring_false_positive(self):\n        j = make_job(title=\"Database Administrator\")\n        assert not match(j, include=[\"data\"])  # \"data\" shouldn't match \"Database\"\n\n    def test_case_insensitive(self):\n        assert match(make_job(title=\"ENGINEER\"), include=[\"engineer\"])\n\n    def test_location_substring_match_is_case_insensitive(self):\n        assert match(make_job(location=\"Remote, US\"), locations=[\"remote\"])\n\n    def test_location_no_match_excludes(self):\n        assert not match(make_job(location=\"Berlin\"), locations=[\"us\", \"remote\"])\n\n    def test_cutoff_drops_older_job(self):\n        cutoff = datetime.now(timezone.utc)\n        old = make_job(posted_at=(cutoff - timedelta(days=5)).isoformat())\n        assert not match(old, cutoff=cutoff)\n\n    def test_cutoff_keeps_unparseable_posted_at(self):\n        cutoff = datetime.now(timezone.utc)\n        j = make_job(posted_at=\"Posted 3 Days Ago\")  # Workday-style prose\n        assert match(j, cutoff=cutoff)\n\n    def test_cutoff_keeps_job_exactly_at_boundary_or_newer(self):\n        cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n        j = make_job(posted_at=datetime.now(timezone.utc).isoformat())\n        assert match(j, cutoff=cutoff)\n\n\nclass TestFilterJobs:\n    def test_max_age_days_as_string_from_yaml(self):\n        jobs = [make_job(posted_at=datetime.now(timezone.utc).isoformat())]\n        out = filter_jobs(jobs, {\"max_age_days\": \"7\"})\n        assert out == jobs\n\n    def test_empty_rules_returns_all(self):\n        jobs = [make_job()]\n        assert filter_jobs(jobs, {}) == jobs"
