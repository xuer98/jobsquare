  "output": "## Test Coverage Analysis — jobsquare\n\n**Current state: zero test files exist anywhere in the repo.** No `pytest`, `pytest-asyncio`, `respx`, or `freezegun` in `requirements.txt` or the venv either. Everything below is a gap; I've prioritized by blast radius (data-correctness bugs that would silently corrupt the dedup DB or drop jobs) and included skeletons using `pytest` + `pytest-asyncio` + `respx` (for mocking `httpx`) + `freezegun` (for time-dependent logic). I recommend adding those four as dev dependencies before writing any of this.\n\n---\n\n### 1. `models.py` — highest priority (everything else depends on `Job` being correct)\n\n**Untested:** `parse_posted_at`, `Job.key`, `Job.posted_dt`, `Job.content_hash`, `Job.to_row`.\n\n**Edge cases not covered:**\n- Lever millisecond-epoch vs second-epoch ambiguity (the `>= 1e12` heuristic) — a job posted right at the boundary, or a negative/zero epoch.\n- ISO-8601 with `Z` suffix vs explicit offset vs naive (no tzinfo).\n- Garbage/empty/whitespace `posted_at` strings.\n- `content_hash` stability — same job, different `raw` dict, should still hash equal (raw is excluded).\n- `to_row()` must never leak `raw` (it can contain large/sensitive payloads) and must include computed `key`/`content_hash`.\n\n```python\n# tests/test_models.py\nimport pytest\nfrom datetime import datetime, timezone\nfrom models import Job, parse_posted_at\n\n\nclass TestParsePostedAt:\n    def test_empty_returns_none(self):\n        assert parse_posted_at(\"\") is None\n\n    def test_none_like_returns_none(self):\n        assert parse_posted_at(None) is None  # value: str but callers pass \"\"/None\n\n    @pytest.mark.parametrize(\"raw,expected_epoch\", [\n        (\"1643241332430\", 1643241332),   # Lever ms\n        (\"1643241332\", 1643241332),      # plain seconds\n        (\"-1\", None),                    # negative epoch: lstrip(\"-\").isdigit() path\n    ])\n    def test_numeric_epoch(self, raw, expected_epoch):\n        dt = parse_posted_at(raw)\n        if expected_epoch is None:\n            assert dt is not None  # documents current behavior; confirm intent\n        else:\n            assert dt == datetime.fromtimestamp(expected_epoch, tz=timezone.utc)\n\n    def test_iso8601_with_z_suffix(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00Z\")\n        assert dt.tzinfo is not None\n\n    def test_iso8601_naive_gets_utc(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_workday_prose_is_unparseable(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_garbage_string_returns_none(self):\n        assert parse_posted_at(\"not-a-date\") is None\n\n\nclass TestJob:\n    def _job(self, **kw):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                    title=\"Engineer\", url=\"https://x/1\")\n        base.update(kw)\n        return Job(**base)\n\n    def test_key_is_stable_across_field_changes(self):\n        j1 = self._job(title=\"Engineer I\")\n        j2 = self._job(title=\"Engineer II\")\n        assert j1.key == j2.key\n\n    def test_content_hash_ignores_raw(self):\n        j1 = self._job(raw={\"a\": 1})\n        j2 = self._job(raw={\"a\": 2})\n        assert j1.content_hash == j2.content_hash\n\n    def test_content_hash_changes_on_title_location_url_department(self):\n        base = self._job()\n        assert base.content_hash != self._job(title=\"Other\").content_hash\n        assert base.content_hash != self._job(location=\"Remote\").content_hash\n        assert base.content_hash != self._job(url=\"https://x/2\").content_hash\n        assert base.content_hash != self._job(department=\"Eng\").content_hash\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self):\n        row = self._job(raw={\"secret\": \"payload\"}).to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == self._job().key\n        assert row[\"content_hash\"] == self._job().content_hash\n\n    def test_posted_dt_none_when_unparseable(self):\n        assert self._job(posted_at=\"bogus\").posted_dt is None\n```\n\n---\n\n### 2. `filters.py`\n\n**Untested:** `_compile`, `match`, `filter_jobs` entirely.\n\n**Edge cases not covered:**\n- Word-boundary regex matching (`\\b`) — should match \"Data Engineer\" on include=`[\"data\"]` but must NOT match \"Database Engineer\" as a substring false-positive... actually verify: does `\\bdata\\b` match inside \"Database\"? No — worth a test proving that boundary.\n- Empty/`None` include/exclude/locations lists (falsy → skip filter).\n- `exclude` takes precedence over `include` (a job in both lists should be excluded).\n- Case-insensitivity.\n- `cutoff` with an unparseable `posted_at` → job is **kept**, not dropped (documented behavior, easy to break in a refactor).\n- `max_age_days` as a string from YAML (`\"7\"`) vs float/int.\n\n```python\n# tests/test_filters.py\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Data Engineer\", url=\"https://x/1\", location=\"Remote, US\",\n                department=\"Engineering\")\n    base.update(kw)\n    return Job(**base)\n\n\nclass TestMatch:\n    def test_no_filters_matches_everything(self):\n        assert match(make_job())\n\n    def test_exclude_beats_include(self):\n        j = make_job(title=\"Senior Data Engineer\")\n        assert not match(j, include=[\"engineer\"], exclude=[\"senior\"])\n\n    def test_word_boundary_avoids_substring_false_positive(self):\n        j = make_job(title=\"Database Administrator\")\n        assert not match(j, include=[\"data\"])  # \"data\" shouldn't match \"Database\"\n\n    def test_case_insensitive(self):\n        assert match(make_job(title=\"ENGINEER\"), include=[\"engineer\"])\n\n    def test_location_substring_match_is_case_insensitive(self):\n        assert match(make_job(location=\"Remote, US\"), locations=[\"remote\"])\n\n    def test_location_no_match_excludes(self):\n        assert not match(make_job(location=\"Berlin\"), locations=[\"us\", \"remote\"])\n\n    def test_cutoff_drops_older_job(self):\n        cutoff = datetime.now(timezone.utc)\n        old = make_job(posted_at=(cutoff - timedelta(days=5)).isoformat())\n        assert not match(old, cutoff=cutoff)\n\n    def test_cutoff_keeps_unparseable_posted_at(self):\n        cutoff = datetime.now(timezone.utc)\n        j = make_job(posted_at=\"Posted 3 Days Ago\")  # Workday-style prose\n        assert match(j, cutoff=cutoff)\n\n    def test_cutoff_keeps_job_exactly_at_boundary_or_newer(self):\n        cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n        j = make_job(posted_at=datetime.now(timezone.utc).isoformat())\n        assert match(j, cutoff=cutoff)\n\n\nclass TestFilterJobs:\n    def test_max_age_days_as_string_from_yaml(self):\n        jobs = [make_job(posted_at=datetime.now(timezone.utc).isoformat())]\n        out = filter_jobs(jobs, {\"max_age_days\": \"7\"})\n        assert out == jobs\n\n    def test_empty_rules_returns_all(self):\n        jobs = [make_job()]\n        assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n### 3. `store.py` — dedup correctness is the core value proposition of this app\n\n**Untested:** the entire `Store` class.\n\n**Edge cases / integration gaps not covered:**\n- Fresh DB schema creation (`_SCHEMA`).\n- `_migrate()` — adding `salary_range` to a DB created **before** that column existed. This is an additive-migration path that will silently never be tested again once everyone's local DB has the column.\n- `diff()` three-way branching: new job / changed content_hash / unchanged (just touches `last_seen`).\n- `diff()` idempotency — running the same batch twice produces `(new=[], changed=[])` the second time.\n- `added_since()` string-comparison correctness relies on identical ISO formatting — test with jobs from two separate `diff()` calls.\n- `get_meta`/`set_meta` upsert (`ON CONFLICT DO UPDATE`) — set twice, confirm the second wins, not a duplicate row.\n- `count()`.\n- Context manager (`__enter__`/`__exit__`) closes connection.\n\n```python\n# tests/test_store.py\nimport pytest\nimport sqlite3\nfrom datetime import datetime, timezone\nfrom models import Job\nfrom store import Store\n\n\ndef make_job(external_id=\"1\", **kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=external_id,\n                title=\"Engineer\", url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\n\nclass TestDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([make_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_on_second_run_is_neither(self, store):\n        store.diff([make_job()])\n        new, changed = store.diff([make_job()])\n        assert new == [] and changed == []\n\n    def test_changed_title_marks_as_changed(self, store):\n        store.diff([make_job(title=\"Engineer I\")])\n        new, changed = store.diff([make_job(title=\"Engineer II\")])\n        assert new == [] and len(changed) == 1\n\n    def test_different_company_same_source_is_separate_row(self, store):\n        store.diff([make_job()])\n        new, _ = store.diff([make_job(source=\"greenhouse\")], )\n        # same source/company/external_id => same key, no duplicate\n        assert store.count() == 1\n\n    def test_diff_persists_across_reopen(self, tmp_path):\n        path = tmp_path / \"persist.db\"\n        with Store(path) as s:\n            s.diff([make_job()])\n        with Store(path) as s2:\n            assert s2.count() == 1\n\n\nclass TestMigration:\n    def test_migrates_db_missing_salary_range_column(self, tmp_path):\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(str(path))\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit()\n        conn.close()\n        with Store(path) as s:  # must not raise\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\n\nclass TestMeta:\n    def test_set_meta_upserts_not_duplicates(self, store):\n        store.set_meta(\"last_scan\", \"2026-01-01T00:00:00+00:00\")\n        store.set_meta(\"last_scan\", \"2026-01-02T00:00:00+00:00\")\n        assert store.get_meta(\"last_scan\") == \"2026-01-02T00:00:00+00:00\"\n\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n\nclass TestAddedSince:\n    def test_returns_only_rows_strictly_after_ts(self, store):\n        store.diff([make_job(external_id=\"1\")])\n        ts = datetime.now(timezone.utc).isoformat(timespec=\"seconds\")\n        store.diff([make_job(external_id=\"2\")])\n        rows = store.added_since(ts)\n        assert {r[\"external_id\"] for r in rows} == {\"2\"} or rows == []\n        # NOTE: same-second writes are indistinguishable — worth flagging (see gaps below)\n```\n\n> **Gap worth flagging to the team:** `added_since` uses second-resolution ISO timestamps for a strict `>` comparison. Two `diff()` calls within the same wall-clock second (realistic in tests, and possible in a fast CI run) are indistinguishable, so a \"new since last scan\" boundary test needs `freezegun` or a manual timestamp injection rather than relying on real clock ticks.\n\n---\n\n### 4. `pipeline.py` — no integration test exists for the orchestration path at all\n\n**Untested:** `load_config` defaults, `run()` end-to-end, `dry_run` branch, `run_sync`.\n\n**Edge cases:**\n- `load_config` default-filling (`sources`, `filters`, `db`, `concurrency`) when the YAML omits them.\n- `dry_run=True` must not touch the `Store` (no dedup writes) and must return `{\"new\": 0, \"changed\": 0}` even when jobs matched.\n- Non-dry-run path must call `dispatch(new, changed)` — a regression here means silent notification loss.\n\n```python\n# tests/test_pipeline.py\nimport pytest\nfrom unittest.mock import AsyncMock, patch\nfrom models import Job\nimport pipeline\n\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\n\nclass TestLoadConfig:\n    def test_fills_defaults(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(\"sources: []\\n\")\n        cfg = pipeline.load_config(cfg_path)\n        assert cfg[\"db\"] == \"jobs.db\"\n        assert cfg[\"concurrency\"] == 8\n        assert cfg[\"filters\"] == {}\n\n    def test_preserves_explicit_values(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(\"db: custom.db\\nconcurrency: 2\\n\")\n        cfg = pipeline.load_config(cfg_path)\n        assert cfg[\"db\"] == \"custom.db\"\n        assert cfg[\"concurrency\"] == 2\n\n\nclass TestRun:\n    @pytest.mark.asyncio\n    async def test_dry_run_does_not_persist_or_notify(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(f\"db: {tmp_path / 'jobs.db'}\\nsources: []\\n\")\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[make_job()])), \\\n             patch(\"pipeline.dispatch\") as mock_dispatch:\n            result = await pipeline.run(cfg_path, dry_run=True)\n        assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n        mock_dispatch.assert_not_called()\n\n    @pytest.mark.asyncio\n    async def test_real_run_persists_and_dispatches(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(f\"db: {tmp_path / 'jobs.db'}\\nsources: []\\n\")\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[make_job()])), \\\n             patch(\"pipeline.dispatch\") as mock_dispatch:\n            result = await pipeline.run(cfg_path)\n        assert result[\"new\"] == 1\n        mock_dispatch.assert_called_once()\n\n    @pytest.mark.asyncio\n    async def test_filters_are_applied_before_dedup(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(\n            f\"db: {tmp_path / 'jobs.db'}\\nsources: []\\n\"\n            \"filters:\\n  exclude_keywords: [engineer]\\n\")\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[make_job()])):\n            result = await pipeline.run(cfg_path, dry_run=True)\n        assert result[\"matched\"] == 0\n```\n\n---\n\n### 5. `notify.py`\n\n**Untested:** everything. This module has real error-handling logic in `dispatch()` (catch-and-continue per notifier) that's completely unverified.\n\n**Edge cases / missing error-handling tests:**\n- Each notifier's \"activate only if env vars set\" guard — untested for partial env var sets (e.g., `TWILIO_ACCOUNT_SID` set but `TWILIO_TO` missing → must no-op, not crash on `auth=(sid, token)` with `None`).\n- `dispatch()` must continue to the next notifier when one throws (this is the whole point of the try/except, and it's unverified — a regression that removes the try/except would go unnoticed).\n- `notify_sms` calls `resp.raise_for_status()` — an HTTP 400 from Twilio must be caught by `dispatch`, not propagate and abort remaining notifiers.\n- `_sms_body` truncation at `limit=8` and the \"+N more\" line.\n- Empty `new`/`changed` → no-op for slack/webhook/email/sms (must not fire network calls), but console prints \"No fresh listings.\"\n\n```python\n# tests/test_notify.py\nimport pytest\nimport httpx\nimport respx\nfrom models import Job\nimport notify\n\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\n\nclass TestNotifySlack:\n    def test_noop_without_webhook_url(self, monkeypatch, capsys):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        notify.notify_slack([make_job()], [])  # must not raise / not attempt network\n\n    @respx.mock\n    def test_posts_when_configured(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        route = respx.post(\"https://hooks.slack.test/x\").mock(\n            return_value=httpx.Response(200))\n        notify.notify_slack([make_job()], [])\n        assert route.called\n\n    def test_noop_when_no_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        # no respx mock registered -> would raise if a request were attempted\n        notify.notify_slack([], [])\n\n\nclass TestNotifySms:\n    def test_noop_with_partial_env_vars(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        monkeypatch.delenv(\"TWILIO_FROM\", raising=False)\n        monkeypatch.delenv(\"TWILIO_TO\", raising=False)\n        notify.notify_sms([make_job()], [])  # must not raise\n\n    @respx.mock\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        for k, v in dict(TWILIO_ACCOUNT_SID=\"sid\", TWILIO_AUTH_TOKEN=\"tok\",\n                          TWILIO_FROM=\"+10000000000\", TWILIO_TO=\"+10000000001\").items():\n            monkeypatch.setenv(k, v)\n        respx.post(url__regex=r\".*/Messages\\.json\").mock(\n            return_value=httpx.Response(400, json={\"message\": \"bad request\"}))\n        with pytest.raises(httpx.HTTPStatusError):\n            notify.notify_sms([make_job()], [])\n\n    def test_sms_body_truncates_at_limit(self):\n        jobs = [make_job(external_id=str(i), title=f\"Job {i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n        assert body.count(\"Job\") == 8  # only 8 listed, not 10\n\n\nclass TestDispatch:\n    def test_continues_past_a_failing_notifier(self, monkeypatch, capsys):\n        def boom(new, changed):\n            raise RuntimeError(\"smtp down\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, notify.notify_console])\n        notify.dispatch([make_job()], [])\n        out = capsys.readouterr().out\n        assert \"notifier boom failed\" in out\n        assert \"NEW listing\" in out  # console notifier still ran\n```\n\n---\n\n### 6. `fetchers.py` — largest file, largest gap, highest risk of silent breakage\n\nThis is the module most likely to break silently (ATS payload shape drift) and it has **zero** tests protecting any parser. Two categories of gaps:\n\n**(a) Retry/transport logic** — `_request` (backoff, retryable status codes, exhaustion) is completely unverified:\n\n```python\n# tests/test_fetchers_request.py\nimport httpx, pytest, respx\nfrom fetchers import _request\n\n\nclass TestRequestRetry:\n    @respx.mock\n    @pytest.mark.asyncio\n    async def test_retries_on_503_then_succeeds(self, monkeypatch):\n        monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)  # skip real backoff\n        route = respx.get(\"https://x.test/j\").mock(side_effect=[\n            httpx.Response(503), httpx.Response(200, json={\"ok\": True})])\n        async with httpx.AsyncClient() as client:\n            r = await _request(client, \"https://x.test/j\", retries=3)\n        assert r.status_code == 200\n        assert route.call_count == 2\n\n    @respx.mock\n    @pytest.mark.asyncio\n    async def test_exhausts_retries_and_raises(self, monkeypatch):\n        monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)\n        respx.get(\"https://x.test/j\").mock(return_value=httpx.Response(500))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n                await _request(client, \"https://x.test/j\", retries=2)\n\n    @respx.mock\n    @pytest.mark.asyncio\n    async def test_non_retryable_4xx_raises_immediately(self, monkeypatch):\n        monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)\n        route = respx.get(\"https://x.test/j\").mock(return_value=httpx.Response(404))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError):\n                await _request(client, \"https://x.test/j\", retries=3)\n        assert route.call_count == 1  # no retry on a plain 404\n```\n\n**(b) Parser functions** — every `parse_*` needs a \"happy path\" test plus at least one \"hostile/missing-field payload\" test, since these ATS APIs are undocumented/positional (`parse_google`, `parse_deshaw`, `parse_twosigma` regex-scrape HTML — these are the most fragile and least tested):\n\n```python\n# tests/test_fetchers_parsers.py\nfrom fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       parse_smartrecruiters, parse_recruitee, parse_workable,\n                       parse_google, _extract_ds1, _ds1_posted_at, parse_deshaw,\n                       parse_twosigma, parse_optiver, parse_meta, parse_microsoft,\n                       parse_netflix, parse_amazon, _amazon_posted_at)\n\n\nclass TestParseGreenhouse:\n    def test_happy_path(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"https://x/1\",\n                           \"location\": {\"name\": \"Remote\"},\n                           \"departments\": [{\"name\": \"Eng\"}], \"updated_at\": \"2026-01-01\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].title == \"SWE\" and jobs[0].location == \"Remote\"\n\n    def test_missing_optional_fields_defaults_empty(self):\n        jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1}]})\n        assert jobs[0].title == \"\" and jobs[0].location == \"\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_jobs_key(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\n\nclass TestLeverSalary:\n    def test_formats_range_with_commas(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_falls_back_to_plain_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestAshbyIsListedFilter:\n    def test_unlisted_jobs_are_skipped(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"},\n                          {\"id\": \"2\", \"isListed\": True, \"title\": \"Visible\"}]}\n        jobs = parse_ashby(\"acme\", data)\n        assert len(jobs) == 1 and jobs[0].title == \"Visible\"\n\n\nclass TestGoogleDs1Extraction:\n    def test_extracts_data_array_from_callback(self):\n        html = \"AF_initDataCallback({key: 'ds:1', data:[[['j1']]], sideChannel: {}});\"\n        assert _extract_ds1(html) == [['j1']]\n\n    def test_missing_ds1_key_returns_empty(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_malformed_json_returns_empty(self):\n        html = \"AF_initDataCallback({key: 'ds:1', data:[[bad json, sideChannel: {}});\"\n        assert _extract_ds1(html) == []\n\n    def test_falls_back_to_alt_pattern_when_sidechannel_missing(self):\n        html = \"AF_initDataCallback({key: 'ds:1', data:[[['j1']]]});\"\n        assert _extract_ds1(html) == [['j1']]\n\n\nclass TestDs1PostedAt:\n    def test_prefers_create_time_index_12(self):\n        job = [None] * 15\n        job[12] = [1700000000]\n        job[13] = [1800000000]\n        assert _ds1_posted_at(job) == \\\n            __import__(\"datetime\").datetime.fromtimestamp(\n                1700000000, __import__(\"datetime\").timezone.utc\n            ).isoformat(timespec=\"seconds\")\n\n    def test_short_array_no_index_error(self):\n        assert _ds1_posted_at([1, 2]) == \"\"\n\n\nclass TestParseDeshawDedup:\n    def test_dedups_repeated_job_id_cards(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">A</span></div>'\n                '<div data-job-id=\"1\"><span class=\"job-display-name\">A</span></div>')\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert len(jobs) == 1\n\n    def test_smart_quotes_unescaped_in_title(self):\n        page = '<div data-job-id=\"1\"><span class=\"job-display-name\">Senior &amp; Lead</span></div>'\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert jobs[0].title == \"Senior & Lead\"\n\n\nclass TestAmazonPostedAt:\n    def test_parses_us_format_date(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_garbage_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_unknown_month_returns_empty(self):\n        assert _amazon_posted_at(\"Junuary 1, 2026\") == \"\"\n```\n\n**(c) Pagination loop integration tests** — `fetch_twosigma`, `fetch_optiver`, `fetch_google`, `fetch_workday`, `fetch_microsoft`, `fetch_netflix`, `fetch_amazon` all share a \"stop when a page returns nothing new\" pattern that's never been exercised, including the `max_pages` safety cap:\n\n```python\n# tests/test_fetchers_pagination.py\nimport httpx, pytest, respx\nfrom fetchers import fetch_optiver\n\n\nclass TestFetchOptiverPagination:\n    @respx.mock\n    @pytest.mark.asyncio\n    async def test_stops_when_page_returns_no_new_items(self):\n        respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(side_effect=[\n            httpx.Response(200, json={\"items\": [{\"href\": \"/a\", \"title\": \"A\"}]}),\n            httpx.Response(200, json={\"items\": []}),\n        ])\n        jobs = await fetch_optiver(None if False else httpx.AsyncClient(),\n                                    {\"company\": \"optiver\"})\n        assert len(jobs) == 1\n\n    @respx.mock\n    @pytest.mark.asyncio\n    async def test_respects_max_pages_cap(self):\n        respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n            return_value=httpx.Response(200, json={\n                \"items\": [{\"href\": \"/x\", \"title\": \"Same\"}]}))  # never-ending \"new\" page\n        async with httpx.AsyncClient() as client:\n            jobs = await fetch_optiver(client, {\"company\": \"optiver\", \"max_pages\": 2})\n        assert len(jobs) <= 2  # bounded, doesn't loop forever\n```\n*(Same shape applies to `fetch_workday`'s `offset >= total or offset > 5000` cap, `fetch_google`'s empty-page stop condition, and the Meta `doc_id`-rotation error path — `fetch_meta` raising `RuntimeError` on a GraphQL `errors` payload is untested and is explicitly called out in the module's own comment as the failure mode to expect.)*\n\n**(d) Registry/dispatch:**\n\n```python\nclass TestFetchSource:\n    @pytest.mark.asyncio\n    async def test_unknown_ats_raises_valueerror(self):\n        from fetchers import fetch_source\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            await fetch_source(None, {\"ats\": \"bogus_ats\"})\n\n\nclass TestFetchAll:\n    @respx.mock\n    @pytest.mark.asyncio\n    async def test_one_source_failing_does_not_abort_others(self):\n        respx.get(\"https://boards-api.greenhouse.io/v1/boards/broken/jobs?content=false\") \\\n            .mock(return_value=httpx.Response(500))\n        respx.get(\"https://boards-api.greenhouse.io/v1/boards/ok/jobs?content=false\") \\\n            .mock(return_value=httpx.Response(200, json={\"jobs\": [{\"id\": 1, \"title\": \"X\"}]}))\n        from fetchers import fetch_all\n        jobs = await fetch_all([{\"ats\": \"greenhouse\", \"company\": \"broken\"},\n                                 {\"ats\": \"greenhouse\", \"company\": \"ok\"}])\n        assert len(jobs) == 1  # broken source logged+skipped, not fatal\n```\n\n---\n\n### 7. `agent.py`\n\n**Untested:** `cmd_db_new` (watermark/truncation logic — this has a subtle grouping invariant that's easy to break), `cmd_db_mark`, `_normalize_ats`, `cmd_pdf_render`, `_chrome_bin`, `main`'s argv routing.\n\n**Highest-value gap:** the `cmd_db_new` truncation logic groups rows by `first_seen` and only truncates at group boundaries \"so a pipeline run's rows aren't split.\" This invariant is subtle and completely unverified:\n\n```python\n# tests/test_agent.py\nimport json\nfrom datetime import datetime, timezone\nfrom unittest.mock import patch\nfrom store import Store\nfrom models import Job\nimport agent\n\n\ndef make_job(external_id, **kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=external_id,\n                title=f\"Job {external_id}\", url=f\"https://x/{external_id}\")\n    base.update(kw)\n    return Job(**base)\n\n\nclass TestCmdDbNew:\n    def test_first_run_uses_since_days_window(self, tmp_path, capsys):\n        db = tmp_path / \"jobs.db\"\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {db}\\n\")\n        with Store(db) as s:\n            s.diff([make_job(\"1\")])\n        agent.cmd_db_new([\"-c\", str(cfg), \"--since-days\", \"7\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n        assert out[\"count\"] == 1\n\n    def test_truncates_only_at_first_seen_group_boundary(self, tmp_path, capsys):\n        db = tmp_path / \"jobs.db\"\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {db}\\n\")\n        with Store(db) as s:\n            s.set_meta(\"last_scan\", \"2020-01-01T00:00:00+00:00\")\n            s.diff([make_job(\"1\"), make_job(\"2\")])  # group A: same first_seen\n            s.diff([make_job(\"3\")])                  # group B\n        agent.cmd_db_new([\"-c\", str(cfg), \"--limit\", \"2\"])\n        out = json.loads(capsys.readouterr().out)\n        # limit=2 lands mid-group-B; must not split group A off partially either\n        assert out[\"count\"] == 2\n        assert out[\"truncated\"] is False or out[\"count\"] % 2 == 0\n\n    def test_never_advances_marker(self, tmp_path):\n        db = tmp_path / \"jobs.db\"\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {db}\\n\")\n        with Store(db) as s:\n            s.diff([make_job(\"1\")])\n        agent.cmd_db_new([\"-c\", str(cfg)])\n        with Store(db) as s:\n            assert s.get_meta(\"last_scan\") is None\n\n\nclass TestCmdDbMark:\n    def test_rejects_non_iso_watermark(self, tmp_path, capsys):\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {tmp_path / 'jobs.db'}\\n\")\n        rc = agent.cmd_db_mark([\"not-a-timestamp\", \"-c\", str(cfg)])\n        assert rc == 2\n\n    def test_no_args_returns_error(self, tmp_path):\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {tmp_path / 'jobs.db'}\\n\")\n        assert agent.cmd_db_mark([\"-c\", str(cfg)]) == 2\n\n    def test_now_flag_sets_current_time(self, tmp_path):\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {tmp_path / 'jobs.db'}\\n\")\n        agent.cmd_db_mark([\"--now\", \"-c\", str(cfg)])\n        with Store(tmp_path / \"jobs.db\") as s:\n            assert s.get_meta(\"last_scan\") is not None\n\n\nclass TestNormalizeAts:\n    def test_replaces_smart_quotes_and_dashes_in_body_text(self):\n        html = \"<p>It\\u2019s a \\u201cgreat\\u201d role \\u2014 apply now\\u2026</p>\"\n        out, counts = agent._normalize_ats(html)\n        assert \"'\" in out and '\"' in out and \"-\" in out and \"...\" in out\n\n    def test_does_not_touch_style_or_script_blocks(self):\n        html = '<style>.x{content:\"\\u2014\"}</style><p>text\\u2014here</p>'\n        out, _ = agent._normalize_ats(html)\n        assert \"\\u2014\" in out.split(\"</style>\")[0]  # untouched inside <style>\n        assert \"-\" in out.split(\"</style>\")[1]        # replaced outside\n\n    def test_does_not_touch_tag_attributes(self):\n        html = '<a title=\"em\\u2014dash\">text</a>'\n        out, _ = agent._normalize_ats(html)\n        assert 'title=\"em\\u2014dash\"' in out  # attribute preserved verbatim\n\n    def test_returns_zero_counts_when_nothing_to_fix(self):\n        _, counts = agent._normalize_ats(\"<p>plain ascii</p>\")\n        assert counts == {}\n\n\nclass TestMainRouting:\n    def test_db_new_subcommand_dispatches(self):\n        with patch.object(agent, \"cmd_db_new\", return_value=0) as m:\n            with patch.object(agent, \"sys\") as _:\n                pass  # patch sys.argv instead, shown for brevity\n        import sys\n        old = sys.argv\n        try:\n            sys.argv = [\"agent.py\", \"db-new\", \"--limit\", \"5\"]\n            with patch.object(agent, \"cmd_db_new\", return_value=0) as m:\n                agent.main()\n            m.assert_called_once_with([\"--limit\", \"5\"])\n        finally:\n            sys.argv = old\n\n    def test_bare_invocation_is_interactive(self):\n        with patch.object(agent, \"run_claude\") as m:\n            import sys\n            old = sys.argv\n            try:\n                sys.argv = [\"agent.py\"]\n                agent.main()\n                m.assert_called_once_with([], True, [])\n            finally:\n                sys.argv = old\n```\n\n`cmd_pdf_render`/`_chrome_bin` need a Chrome binary or a mocked `subprocess.run`; lower