        "code": "# tests/test_agent.py\nimport json\nfrom datetime import datetime, timezone\nfrom unittest.mock import patch\nfrom store import Store\nfrom models import Job\nimport agent\n\n\ndef make_job(external_id, **kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=external_id,\n                title=f\"Job {external_id}\", url=f\"https://x/{external_id}\")\n    base.update(kw)\n    return Job(**base)\n\n\nclass TestCmdDbNew:\n    def test_first_run_uses_since_days_window(self, tmp_path, capsys):\n        db = tmp_path / \"jobs.db\"\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {db}\\n\")\n        with Store(db) as s:\n            s.diff([make_job(\"1\")])\n        agent.cmd_db_new([\"-c\", str(cfg), \"--since-days\", \"7\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n        assert out[\"count\"] == 1\n\n    def test_truncates_only_at_first_seen_group_boundary(self, tmp_path, capsys):\n        db = tmp_path / \"jobs.db\"\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {db}\\n\")\n        with Store(db) as s:\n            s.set_meta(\"last_scan\", \"2020-01-01T00:00:00+00:00\")\n            s.diff([make_job(\"1\"), make_job(\"2\")])  # group A: same first_seen\n            s.diff([make_job(\"3\")])                  # group B\n        agent.cmd_db_new([\"-c\", str(cfg), \"--limit\", \"2\"])\n        out = json.loads(capsys.readouterr().out)\n        # limit=2 lands mid-group-B; must not split group A off partially either\n        assert out[\"count\"] == 2\n        assert out[\"truncated\"] is False or out[\"count\"] % 2 == 0\n\n    def test_never_advances_marker(self, tmp_path):\n        db = tmp_path / \"jobs.db\"\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {db}\\n\")\n        with Store(db) as s:\n            s.diff([make_job(\"1\")])\n        agent.cmd_db_new([\"-c\", str(cfg)])\n        with Store(db) as s:\n            assert s.get_meta(\"last_scan\") is None\n\n\nclass TestCmdDbMark:\n    def test_rejects_non_iso_watermark(self, tmp_path, capsys):\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {tmp_path / 'jobs.db'}\\n\")\n        rc = agent.cmd_db_mark([\"not-a-timestamp\", \"-c\", str(cfg)])\n        assert rc == 2\n\n    def test_no_args_returns_error(self, tmp_path):\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {tmp_path / 'jobs.db'}\\n\")\n        assert agent.cmd_db_mark([\"-c\", str(cfg)]) == 2\n\n    def test_now_flag_sets_current_time(self, tmp_path):\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {tmp_path / 'jobs.db'}\\n\")\n        agent.cmd_db_mark([\"--now\", \"-c\", str(cfg)])\n        with Store(tmp_path / \"jobs.db\") as s:\n            assert s.get_meta(\"last_scan\") is not None\n\n\nclass TestNormalizeAts:\n    def test_replaces_smart_quotes_and_dashes_in_body_text(self):\n        html = \"<p>It\\u2019s a \\u201cgreat\\u201d role \\u2014 apply now\\u2026</p>\"\n        out, counts = agent._normalize_ats(html)\n        assert \"'\" in out and '\"' in out and \"-\" in out and \"...\" in out\n\n    def test_does_not_touch_style_or_script_blocks(self):\n        html = '<style>.x{content:\"\\u2014\"}</style><p>text\\u2014here</p>'\n        out, _ = agent._normalize_ats(html)\n        assert \"\\u2014\" in out.split(\"</style>\")[0]  # untouched inside <style>\n        assert \"-\" in out.split(\"</style>\")[1]        # replaced outside\n\n    def test_does_not_touch_tag_attributes(self):\n        html = '<a title=\"em\\u2014dash\">text</a>'\n        out, _ = agent._normalize_ats(html)\n        assert 'title=\"em\\u2014dash\"' in out  # attribute preserved verbatim\n\n    def test_returns_zero_counts_when_nothing_to_fix(self):\n        _, counts = agent._normalize_ats(\"<p>plain ascii</p>\")\n        assert counts == {}\n\n\nclass TestMainRouting:\n    def test_db_new_subcommand_dispatches(self):\n        with patch.object(agent, \"cmd_db_new\", return_value=0) as m:\n            with patch.object(agent, \"sys\") as _:\n                pass  # patch sys.argv instead, shown for brevity\n        import sys\n        old = sys.argv\n        try:\n            sys.argv = [\"agent.py\", \"db-new\", \"--limit\", \"5\"]\n            with patch.object(agent, \"cmd_db_new\", return_value=0) as m:\n                agent.main()\n            m.assert_called_once_with([\"--limit\", \"5\"])\n        finally:\n            sys.argv = old\n\n    def test_bare_invocation_is_interactive(self):\n        with patch.object(agent, \"run_claude\") as m:\n            import sys\n            old = sys.argv\n            try:\n                sys.argv = [\"agent.py\"]\n                agent.main()\n                m.assert_called_once_with([], True, [])\n            finally:\n                sys.argv = old"
      }
