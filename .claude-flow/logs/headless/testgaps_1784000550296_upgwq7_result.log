      {
        "title": "tests/test_pipeline.py",
        "content": "import pytest\nfrom unittest.mock import AsyncMock, patch\nfrom models import Job\nimport pipeline\n\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\n\nclass TestLoadConfig:\n    def test_fills_defaults(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(\"sources: []\\n\")\n        cfg = pipeline.load_config(cfg_path)\n        assert cfg[\"db\"] == \"jobs.db\"\n        assert cfg[\"concurrency\"] == 8\n        assert cfg[\"filters\"] == {}\n\n    def test_preserves_explicit_values(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(\"db: custom.db\\nconcurrency: 2\\n\")\n        cfg = pipeline.load_config(cfg_path)\n        assert cfg[\"db\"] == \"custom.db\"\n        assert cfg[\"concurrency\"] == 2\n\n\nclass TestRun:\n    @pytest.mark.asyncio\n    async def test_dry_run_does_not_persist_or_notify(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(f\"db: {tmp_path / 'jobs.db'}\\nsources: []\\n\")\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[make_job()])), \\\n             patch(\"pipeline.dispatch\") as mock_dispatch:\n            result = await pipeline.run(cfg_path, dry_run=True)\n        assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n        mock_dispatch.assert_not_called()\n\n    @pytest.mark.asyncio\n    async def test_real_run_persists_and_dispatches(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(f\"db: {tmp_path / 'jobs.db'}\\nsources: []\\n\")\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[make_job()])), \\\n             patch(\"pipeline.dispatch\") as mock_dispatch:\n            result = await pipeline.run(cfg_path)\n        assert result[\"new\"] == 1\n        mock_dispatch.assert_called_once()\n\n    @pytest.mark.asyncio\n    async def test_filters_are_applied_before_dedup(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(\n            f\"db: {tmp_path / 'jobs.db'}\\nsources: []\\n\"\n            \"filters:\\n  exclude_keywords: [engineer]\\n\")\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[make_job()])):\n            result = await pipeline.run(cfg_path, dry_run=True)\n        assert result[\"matched\"] == 0\n```\n\n---\n\n",
