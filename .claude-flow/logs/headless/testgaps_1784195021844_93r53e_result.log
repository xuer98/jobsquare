  "output": "## Test Coverage Analysis — jobsquare\n\n**Current state: 0%.** No test files exist anywhere in the repo (only matches under `.venv/`), no `pytest`/`pytest-asyncio`/`respx` in `requirements.txt`, no `tests/` dir, no CI test job under `.github/`. Every one of the ~50 functions across 8 modules is unexercised. Before anything else, add to `requirements.txt` (dev-only):\n\n```\npytest>=8.0\npytest-asyncio>=0.24\nrespx>=0.21        # mocks httpx for the fetchers\nfreezegun>=1.5      # freezes datetime.now() for models/filters/store timestamp tests\n```\n\nBelow is a per-module breakdown, ranked by risk (bug-proneness × blast radius), with concrete gaps and runnable skeletons.\n\n---\n\n### 1. `models.py` — highest risk, smallest file\n\n`parse_posted_at` is the load-bearing function for every recency filter (`filters.py`, `agent.py db-new`), and it silently swallows bad input by returning `None`. A regression here doesn't crash — it just makes jobs vanish or stick around forever.\n\n**Untested:** `parse_posted_at`, `Job.key`, `Job.posted_dt`, `Job.content_hash`, `Job.to_row`.\n\n**Gaps:**\n- Millisecond-vs-second epoch boundary (`999_999_999_999` vs `1_000_000_000_000`) — off-by-one could silently produce a date in 1970 or 33658.\n- Negative epoch strings (`\"-5\"` — `lstrip(\"-\").isdigit()` accepts these; does `fromtimestamp` accept negative?).\n- ISO string missing tz vs with `Z` vs with explicit offset.\n- Garbage string (`\"Posted 3 Days Ago\"` — Workday's actual format) → must return `None`, not raise.\n- Empty string / `None` input.\n- `content_hash` stability: same fields → same hash across two `Job` instances; changing `title`/`location`/`url`/`department` changes it; changing `posted_at`/`salary_range` does **not** (that's the intent — verify it, since a future editor could easily break it by adding a field to the tuple).\n- `key` uniqueness/stability across mutation of non-identity fields.\n- `to_row` excludes `raw`, includes computed `key`/`content_hash`.\n\n```python\n# tests/test_models.py\nimport pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\n\nclass TestParsePostedAt:\n    def test_empty_and_none_return_none(self):\n        assert parse_posted_at(\"\") is None\n        assert parse_posted_at(None) is None\n\n    def test_garbage_string_returns_none_not_raise(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    @pytest.mark.parametrize(\"epoch_ms,expected_year\", [\n        (\"1643241332430\", 2022),   # lever-style ms epoch\n    ])\n    def test_millisecond_epoch_detected(self, epoch_ms, expected_year):\n        dt = parse_posted_at(epoch_ms)\n        assert dt.year == expected_year\n        assert dt.tzinfo is not None\n\n    def test_second_epoch_boundary_not_misread_as_ms(self):\n        # 999_999_999_999 (12 digits) is just under the 1e12 threshold\n        dt = parse_posted_at(\"999999999999\")\n        assert dt is not None\n        # if this ever gets misclassified the year will be absurd\n        assert 1970 <= dt.year <= 2100\n\n    def test_negative_epoch_string(self):\n        # lstrip(\"-\").isdigit() accepts \"-5\"; document actual behavior\n        result = parse_posted_at(\"-5\")\n        assert result is None or isinstance(result, __import__(\"datetime\").datetime)\n\n    def test_iso_with_z_suffix(self):\n        dt = parse_posted_at(\"2024-01-15T10:30:00Z\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_naive_gets_utc_assumed(self):\n        dt = parse_posted_at(\"2024-01-15T10:30:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_with_explicit_offset_preserved(self):\n        dt = parse_posted_at(\"2024-01-15T10:30:00+05:00\")\n        assert dt.utcoffset().total_seconds() == 5 * 3600\n\n    def test_malformed_iso_returns_none(self):\n        assert parse_posted_at(\"not-a-date\") is None\n\n\nclass TestJob:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"42\",\n                    title=\"Engineer\", url=\"https://x/42\")\n        base.update(overrides)\n        return Job(**base)\n\n    def test_key_is_stable_composite(self):\n        j = self._job()\n        assert j.key == \"greenhouse:acme:42\"\n\n    def test_content_hash_changes_on_title_change(self):\n        a, b = self._job(), self._job(title=\"Senior Engineer\")\n        assert a.content_hash != b.content_hash\n\n    def test_content_hash_stable_on_salary_or_posted_at_change(self):\n        a = self._job()\n        b = self._job(salary_range=\"$100k\", posted_at=\"2024-01-01\")\n        assert a.content_hash == b.content_hash  # not part of the identity blob\n\n    def test_content_hash_changes_on_location_department_url(self):\n        a = self._job()\n        for field, val in [(\"location\", \"Remote\"), (\"department\", \"Eng\"),\n                            (\"url\", \"https://x/999\")]:\n            b = self._job(**{field: val})\n            assert a.content_hash != b.content_hash, field\n\n    def test_to_row_excludes_raw_includes_computed_fields(self):\n        j = self._job(raw={\"secret\": 1})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash\n\n    def test_posted_dt_none_when_unparseable(self):\n        assert self._job(posted_at=\"garbage\").posted_dt is None\n```\n\n---\n\n### 2. `filters.py`\n\n**Untested:** `_compile`, `match`, `filter_jobs` entirely.\n\n**Gaps:**\n- Word-boundary regex: `include=[\"ai\"]` should NOT match \"said\" or \"aim\" as substrings but the `\\b` boundary means \"AI/ML\" title should still match \"ai\" case-insensitively — verify both directions.\n- Exclude takes priority over include (a job matching both should be dropped).\n- Empty/`None` `include`/`exclude`/`locations` lists (falsy) should be no-ops, not \"match nothing.\"\n- `locations` matching is substring/lower-case, not word-boundary — a location filter of `\"NY\"` would match \"Wyoming\"? No — `\"ny\" in \"wyoming\"` is actually False, but `\"la\"` would match \"Atlanta\". Worth a regression test for this false-positive.\n- `cutoff` behavior: job newer than cutoff kept; older dropped; **unparseable `posted_at` is kept** (explicit design choice per the comment) — this is exactly the kind of intentional-but-surprising behavior that needs a locked-in test.\n- Special regex characters in include/exclude words (e.g. `\"C++\"`) must not raise — verify `re.escape` is actually protecting this.\n\n```python\n# tests/test_filters.py\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\n\ndef _job(title=\"\", department=\"\", location=\"\", posted_at=\"\"):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=title,\n               url=\"u\", department=department, location=location, posted_at=posted_at)\n\n\nclass TestMatch:\n    def test_no_filters_matches_everything(self):\n        assert match(_job(title=\"Anything\")) is True\n\n    def test_include_word_boundary_not_substring(self):\n        # \"ai\" should not match inside \"said\" but should match \"AI Engineer\"\n        assert match(_job(title=\"Said Something\"), include=[\"ai\"]) is False\n        assert match(_job(title=\"AI Engineer\"), include=[\"ai\"]) is True\n\n    def test_include_case_insensitive(self):\n        assert match(_job(title=\"Software ENGINEER\"), include=[\"engineer\"]) is True\n\n    def test_exclude_overrides_include(self):\n        j = _job(title=\"Senior Intern Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"intern\"]) is False\n\n    def test_special_regex_chars_in_keyword_do_not_raise(self):\n        assert match(_job(title=\"C++ Developer\"), include=[\"C++\"]) is True\n\n    def test_locations_substring_false_positive_regression(self):\n        # documents current substring-matching behavior (not a boundary match)\n        assert match(_job(location=\"Atlanta, GA\"), locations=[\"la\"]) is True\n\n    def test_locations_no_match(self):\n        assert match(_job(location=\"Remote - US\"), locations=[\"Berlin\"]) is False\n\n    def test_cutoff_drops_old_dated_job(self):\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        old = _job(posted_at=(cutoff - timedelta(days=1)).isoformat())\n        assert match(old, cutoff=cutoff) is False\n\n    def test_cutoff_keeps_recent_dated_job(self):\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        recent = _job(posted_at=(cutoff + timedelta(days=1)).isoformat())\n        assert match(recent, cutoff=cutoff) is True\n\n    def test_cutoff_keeps_undated_job(self):\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(_job(posted_at=\"\"), cutoff=cutoff) is True\n\n\nclass TestFilterJobs:\n    def test_max_age_days_builds_cutoff(self):\n        recent = _job(title=\"a\", posted_at=datetime.now(timezone.utc).isoformat())\n        old = _job(title=\"b\", posted_at=\"2000-01-01T00:00:00+00:00\")\n        result = filter_jobs([recent, old], {\"max_age_days\": 30})\n        assert recent in result and old not in result\n\n    def test_no_rules_returns_all(self):\n        jobs = [_job(title=\"a\"), _job(title=\"b\")]\n        assert filter_jobs(jobs, {}) == jobs\n\n    def test_empty_jobs_list(self):\n        assert filter_jobs([], {\"include_keywords\": [\"x\"]}) == []\n```\n\n---\n\n### 3. `store.py` — dedup correctness is the whole point of the app\n\n**Untested:** `Store.__init__`/schema creation, `_migrate`, `diff` (new/changed/unchanged branches), `get_meta`/`set_meta`, `next_seq`, `added_since`, `count`, context-manager protocol.\n\n**Gaps:**\n- `diff` three-way branch: brand-new key → `new`; existing key with different `content_hash` → `changed` + row updated; existing key with same hash → neither list, but `last_seen` still bumped (currently **untested and easy to silently break** — nothing asserts `last_seen` actually advances on a no-op re-seen job).\n- `_migrate` — schema created without `salary_range` column, then `Store` re-opened should backfill it without data loss. This is the only migration path and it's completely unverified.\n- `next_seq` concurrency: sequential calls must strictly increment, and it must work with a fresh (no existing `meta` row) key.\n- `added_since` ordering (`first_seen, company, title`) and the strict `>` boundary (a row with `first_seen == ts` must NOT come back).\n- Reopening a `Store` on the same path preserves previously written rows (persistence across connections — this is the actual behavior the whole app depends on across pipeline runs).\n- `to_row()`/upsert round-trip: a `Job` with unicode / SQL-special characters in title shouldn't break the parameterized query (low risk given `?`-params, but worth one smoke test).\n\n```python\n# tests/test_store.py\nimport sqlite3\nimport pytest\nfrom store import Store\nfrom models import Job\n\n\ndef _job(external_id=\"1\", title=\"Engineer\", company=\"acme\"):\n    return Job(source=\"greenhouse\", company=company, external_id=external_id,\n               title=title, url=\"https://x\")\n\n\n@pytest.fixture\ndef db_path(tmp_path):\n    return tmp_path / \"jobs.db\"\n\n\nclass TestDiff:\n    def test_new_job_goes_to_new_list(self, db_path):\n        with Store(db_path) as s:\n            new, changed = s.diff([_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_reseen_unchanged_job_is_neither_new_nor_changed(self, db_path):\n        with Store(db_path) as s:\n            s.diff([_job()])\n            new, changed = s.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_reseen_unchanged_job_bumps_last_seen(self, db_path):\n        with Store(db_path) as s:\n            s.diff([_job()])\n            row_before = s.conn.execute(\n                \"SELECT last_seen FROM jobs WHERE key=?\", (_job().key,)).fetchone()\n            s.diff([_job()])\n            row_after = s.conn.execute(\n                \"SELECT last_seen FROM jobs WHERE key=?\", (_job().key,)).fetchone()\n        assert row_after[\"last_seen\"] >= row_before[\"last_seen\"]\n\n    def test_changed_content_hash_goes_to_changed_list(self, db_path):\n        with Store(db_path) as s:\n            s.diff([_job(title=\"Engineer\")])\n            new, changed = s.diff([_job(title=\"Senior Engineer\")])\n        assert new == [] and len(changed) == 1\n        assert changed[0].title == \"Senior Engineer\"\n\n    def test_persists_across_store_reopen(self, db_path):\n        with Store(db_path) as s:\n            s.diff([_job()])\n        with Store(db_path) as s2:\n            assert s2.count() == 1\n\n\nclass TestMigration:\n    def test_old_schema_without_salary_range_gets_backfilled(self, db_path):\n        conn = sqlite3.connect(str(db_path))\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit()\n        conn.close()\n        with Store(db_path) as s:\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\n\nclass TestMetaAndSeq:\n    def test_get_meta_missing_key_returns_none(self, db_path):\n        with Store(db_path) as s:\n            assert s.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta_roundtrip(self, db_path):\n        with Store(db_path) as s:\n            s.set_meta(\"last_scan\", \"2024-01-01T00:00:00+00:00\")\n            assert s.get_meta(\"last_scan\") == \"2024-01-01T00:00:00+00:00\"\n\n    def test_next_seq_starts_at_one_and_increments(self, db_path):\n        with Store(db_path) as s:\n            assert s.next_seq(\"report_seq\") == 1\n            assert s.next_seq(\"report_seq\") == 2\n            assert s.next_seq(\"report_seq\") == 3\n\n\nclass TestAddedSince:\n    def test_strict_greater_than_excludes_boundary_ts(self, db_path):\n        with Store(db_path) as s:\n            s.diff([_job()])\n            ts = s.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n            assert s.added_since(ts) == []          # boundary excluded\n            assert len(s.added_since(\"2000-01-01T00:00:00+00:00\")) == 1\n\n    def test_ordering_by_first_seen_company_title(self, db_path):\n        with Store(db_path) as s:\n            s.diff([_job(external_id=\"2\", title=\"B\", company=\"z\"),\n                     _job(external_id=\"1\", title=\"A\", company=\"a\")])\n            rows = s.added_since(\"2000-01-01T00:00:00+00:00\")\n        assert [r[\"company\"] for r in rows] == [\"a\", \"z\"]\n```\n\n---\n\n### 4. `notify.py` — fault isolation is the critical property\n\n**Untested:** every notifier function, `_line`, `_sms_body`, and — most importantly — `dispatch`'s exception-isolation guarantee.\n\n**Gaps:**\n- `dispatch` must run every notifier even if an earlier one raises (currently the *entire reason* `dispatch` wraps each call in try/except) — **this is the single highest-value missing test in the file**: a bug that removes the try/except would silently break Slack notifications any time email is misconfigured, and nothing would catch it.\n- Every env-gated notifier (`notify_slack`, `notify_webhook`, `notify_email`, `notify_sms`) must **no-op** when its env var(s) are unset, and no-op when `new`/`changed` are both empty even if configured (avoid spamming empty notifications).\n- `notify_sms` requires **all four** Twilio env vars — partial configuration (3 of 4 set) must still no-op, not raise on a `None` credential.\n- `_sms_body` truncation at `limit` and the `+N more` line; ASCII-only comment — verify no bullet (`•`) leaks into SMS body (would double GSM segment cost — this is a real cost-affecting behavior, not cosmetic).\n- `notify_email` SMTP auth only attempted when `SMTP_USER` set (mock `smtplib.SMTP`).\n- HTTP-call notifiers should use a mocked transport (`respx`) rather than hitting real Slack/webhook/Twilio endpoints.\n\n```python\n# tests/test_notify.py\nimport pytest\nimport httpx\nimport respx\nfrom models import Job\nimport notify\n\n\ndef _job(title=\"Engineer\", company=\"acme\", salary=\"\", location=\"\"):\n    return Job(source=\"s\", company=company, external_id=\"1\", title=title,\n               url=\"https://x\", salary_range=salary, location=location)\n\n\nclass TestDispatchFaultIsolation:\n    def test_one_notifier_raising_does_not_block_others(self, monkeypatch):\n        calls = []\n        def boom(new, changed): raise RuntimeError(\"misconfigured\")\n        def ok(new, changed): calls.append(\"ok\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, ok])\n        notify.dispatch([_job()], [])\n        assert calls == [\"ok\"]\n\n    def test_dispatch_calls_every_notifier(self, monkeypatch):\n        seen = []\n        fns = [lambda n, c, i=i: seen.append(i) for i in range(3)]\n        monkeypatch.setattr(notify, \"NOTIFIERS\", fns)\n        notify.dispatch([], [])\n        assert seen == [0, 1, 2]\n\n\nclass TestEnvGating:\n    def test_slack_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        notify.notify_slack([_job()], [])  # must not raise / must not call httpx\n\n    def test_slack_noop_when_no_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        notify.notify_slack([], [])  # respx not mocked -> would error if it tried to POST\n\n    @respx.mock\n    def test_slack_posts_when_configured_and_has_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        route = respx.post(\"https://hooks.slack.test/x\").mock(\n            return_value=httpx.Response(200))\n        notify.notify_slack([_job()], [])\n        assert route.called\n\n    def test_sms_noop_with_partial_twilio_env(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.setenv(\"TWILIO_AUTH_TOKEN\", \"tok\")\n        monkeypatch.delenv(\"TWILIO_FROM\", raising=False)\n        monkeypatch.delenv(\"TWILIO_TO\", raising=False)\n        notify.notify_sms([_job()], [])  # must not raise on missing sender/to\n\n    @respx.mock\n    def test_sms_raises_on_twilio_4xx_so_dispatch_can_log_it(self, monkeypatch):\n        for k, v in {\"TWILIO_ACCOUNT_SID\": \"sid\", \"TWILIO_AUTH_TOKEN\": \"tok\",\n                     \"TWILIO_FROM\": \"+1\", \"TWILIO_TO\": \"+2\"}.items():\n            monkeypatch.setenv(k, v)\n        respx.post(url__startswith=\"https://api.twilio.com\").mock(\n            return_value=httpx.Response(401))\n        with pytest.raises(httpx.HTTPStatusError):\n            notify.notify_sms([_job()], [])\n\n\nclass TestSmsBody:\n    def test_truncates_at_limit_with_more_count(self):\n        jobs = [_job(title=f\"Job {i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n        assert body.count(\"Job\") == 8 + body.count(\"Job 9\")  # only 8 line items shown\n\n    def test_no_non_ascii_bullet_characters(self):\n        body = notify._sms_body([_job()], [])\n        assert \"•\" not in body and \"…\" not in body\n\n\nclass TestEmailAuth:\n    def test_smtp_login_only_called_when_user_env_set(self, monkeypatch):\n        monkeypatch.setenv(\"SMTP_HOST\", \"smtp.test\")\n        monkeypatch.setenv(\"EMAIL_TO\", \"me@test.com\")\n        monkeypatch.delenv(\"SMTP_USER\", raising=False)\n        calls = []\n        class FakeSMTP:\n            def __init__(self, *a, **k): pass\n            def __enter__(self): return self\n            def __exit__(self, *a): pass\n            def starttls(self): pass\n            def login(self, *a): calls.append(\"login\")\n            def send_message(self, *a): pass\n        monkeypatch.setattr(notify.smtplib, \"SMTP\", FakeSMTP)\n        notify.notify_email([_job()], [])\n        assert calls == []\n```\n\n---\n\n### 5. `fetchers.py` — largest surface, mostly parsers + one shared retry/pagination pattern\n\nThis file is 1146 lines but structurally repetitive: ~20 `parse_*` functions (pure, `dict/list -> list[Job]`, trivially unit-testable with fixture payloads) and ~10 `fetch_*` functions (async, need `respx` or an injected `httpx.MockTransport`). Priority order:\n\n**5a. `_request` retry wrapper — untested, and it's shared by every fetcher.**\n- Retries on `429/500/502/503/504`, does NOT retry on `404`/`401`/other 4xx.\n- Exhausts `retries` and raises `RuntimeError` wrapping the last exception.\n- Succeeds on the Nth attempt after N-1 failures (verify backoff doesn't block forever — mock `asyncio.sleep`).\n\n```python\n# tests/test_fetchers_request.py\nimport httpx\nimport pytest\nimport respx\nfrom fetchers import _request\n\npytestmark = pytest.mark.asyncio\n\n\n@respx.mock\nasync def test_retries_on_503_then_succeeds(monkeypatch):\n    monkeypatch.setattr(\"fetchers.asyncio.sleep\", lambda *_: None)  # no real delay\n    route = respx.get(\"https://x.test/j\").mock(side_effect=[\n        httpx.Response(503), httpx.Response(200, json={\"ok\": True}),\n    ])\n    async with httpx.AsyncClient() as client:\n        r = await _request(client, \"https://x.test/j\")\n    assert r.status_code == 200\n    assert route.call_count == 2\n\n\n@respx.mock\nasync def test_no_retry_on_404(monkeypatch):\n    monkeypatch.setattr(\"fetchers.asyncio.sleep\", lambda *_: None)\n    route = respx.get(\"https://x.test/j\").mock(return_value=httpx.Response(404))\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(RuntimeError):\n            await _request(client, \"https://x.test/j\")\n    assert route.call_count == 1\n\n\n@respx.mock\nasync def test_exhausts_retries_and_raises_runtime_error(monkeypatch):\n    monkeypatch.setattr(\"fetchers.asyncio.sleep\", lambda *_: None)\n    respx.get(\"https://x.test/j\").mock(return_value=httpx.Response(500))\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(client, \"https://x.test/j\", retries=3)\n```\n\n**5b. `_balanced_json` — hand-rolled brace scanner, easy to break with escaped quotes.**\n```python\ndef test_balanced_json_handles_escaped_quotes_inside_string():\n    text = '{\"a\": \"he said \\\\\"hi\\\\\"\", \"b\": {\"c\": 1}}'\n    assert fetchers._balanced_json(text, 0) == text\n\ndef test_balanced_json_stops_at_first_balanced_close():\n    text = '{\"a\": 1}garbage-after'\n    assert fetchers._balanced_json(text, 0) == '{\"a\": 1}'\n\ndef test_balanced_json_returns_none_when_unterminated():\n    assert fetchers._balanced_json('{\"a\": 1', 0) is None\n```\n\n**5c. Each `parse_*` function — pure and cheap; one example, plus a table of missing edge cases per source.** These currently have **zero coverage** each. Pattern (using Greenhouse as the template — replicate for lever, ashby, ashby_page, smartrecruiters, recruitee, workable, google, deshaw, twosigma, optiver, apple, eightfold, bytedance, phenom, microsoft, netflix, amazon):\n\n```python\n# tests/test_parsers.py\nfrom fetchers import parse_greenhouse, parse_lever, _lever_salary, parse_ashby\n\nclass TestParseGreenhouse:\n    def test_maps_fields(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\",\n                           \"absolute_url\": \"https://gh/1\",\n                           \"location\": {\"name\": \"NYC\"},\n                           \"departments\": [{\"name\": \"Eng\"}],\n                           \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        [j] = parse_greenhouse(\"acme\", data)\n        assert j.external_id == \"1\" and j.location == \"NYC\" and j.department == \"Eng\"\n\n    def test_missing_optional_fields_default_empty(self):\n        [j] = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 2}]})\n        assert j.title == \"\" and j.location == \"\" and j.department == \"\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_jobs_key(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\n\nclass TestLeverSalary:\n    def test_range_present_formats_with_commas(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_falls_back_to_description_when_no_range(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty_string(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestParseAshby:\n    def test_unlisted_jobs_are_filtered_out(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False}, {\"id\": \"2\", \"isListed\": True}]}\n        [j] = parse_ashby(\"acme\", data)\n        assert j.external_id == \"2\"\n```\n\nGaps that recur across **every** bespoke-HTML/regex parser (`parse_google`/`_extract_ds1`, `parse_deshaw`, `parse_twosigma`, `_apple_hydration`/`parse_apple`, `_bd_location`) and are currently **completely unverified**:\n- Malformed/truncated HTML → must return `[]`, never raise (these are exactly the \"layout shift\" cases the docstrings warn about).\n- Duplicate entries in source HTML (`parse_twosigma` explicitly dedupes 3x-rendered cards, `parse_deshaw` dedupes via `seen` set) — no test proves the dedup actually works.\n- `_apple_posted_at` nanosecond-precision timestamp truncation — verify it doesn't raise on `fromisoformat` and produces a valid ISO string.\n- `_amazon_posted_at` — malformed date string (`\"garbage\"`) returns `\"\"` not raise; verify month-name lookup table covers all 12 months correctly (transposition bugs in a hand-written dict are a classic bug source).\n- `_ds1_posted_at` — index-out-of-bounds guard (`len(job) > idx`) when the positional array is short.\n\n```python\n# tests/test_parsers_edge_cases.py\nfrom fetchers import parse_google, _extract_ds1, parse_deshaw, parse_twosigma, _amazon_posted_at\n\nclass TestGoogleDs1:\n    def test_malformed_html_returns_empty_list(self):\n        assert _extract_ds1(\"<html>no blob here</html>\") == []\n\n    def test_truncated_json_in_blob_returns_empty_list(self):\n        html = \"key: 'ds:1', data:[[{not valid json, sideChannel\"\n        assert _extract_ds1(html) == []\n\nclass TestAmazonPostedAt:\n    def test_all_twelve_months_map_correctly(self):\n        for i, name in enumerate(\n            (\"January\",\"February\",\"March\",\"April\",\"May\",\"June\",\"July\",\n             \"August\",\"September\",\"October\",\"November\",\"December\"), 1):\n            assert _amazon_posted_at(f\"{name} 5, 2024\") == f\"2024-{i:02d}-05T00:00:00+00:00\"\n\n    def test_garbage_date_returns_empty_string(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\nclass TestDeshawDedup:\n    def test_duplicate_job_ids_deduped(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">A</span></div>'\n                '<div data-job-id=\"1\"><span class=\"job-display-name\">A</span></div>')\n        assert len(parse_deshaw(\"deshaw\", page)) == 1\n```\n\n**5d. `fetch_*` pagination/fallback logic — the actual bugs live here, not in the parsers.** These need `respx` (mocked HTTP) rather than pure unit tests:\n\n- `fetch_ashby`: posting-api 200 → use it; 404 → fall back to hosted page scrape; other non-200 → `raise_for_status()`. **All three branches untested.**\n- `fetch_workday` / `fetch_microsoft` / `fetch_netflix` / `fetch_amazon` / `fetch_eightfold` / `fetch_optiver` / `fetch_twosigma` / `fetch_bytedance` / `fetch_phenom` / `fetch_apple` / `fetch_google`: all share the \"paginate until no fresh items or `max_pages` cap hit\" pattern. Each needs at minimum: (1) stops when a page returns no new/fresh items, (2) stops at `max_pages` safety cap even if the server keeps returning data (regression guard against infinite loop / runaway pagination), (3) dedupes against `seen` across pages.\n- `fetch_meta`: token-scraping (`lsd`, `__spin_*`) via regex from HTML, the `\"for (;;);\"` XSSI-prefix strip, and the `data.get(\"errors\")` → `RuntimeError` path (this is the documented doc_id-rotation failure mode — a memory entry already documents this breaking in practice, so a test locking in the error-surfacing behavior is high value).\n\n```python\n# tests/test_fetch_meta.py\nimport httpx, pytest, respx\nfrom fetchers import fetch_meta\n\npytestmark = pytest.mark.asyncio\n\n@respx.mock\nasync def test_strips_xssi_prefix_and_parses_jobs():\n    respx.get(\"https://www.metacareers.com/jobs\").mock(\n        return_value=httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok123\"}] \"__spin_r\":5'))\n    respx.post(\"https://www.metacareers.com/graphql\").mock(\n        return_value=httpx.Response(200, text='for (;;);' + __import__(\"json\").dumps(\n            {\"data\": {\"job_search_with_featured_jobs_v2\":\n                {\"all_jobs\": [{\"id\": \"1\", \"title\": \"SWE\", \"locations\": [\"NYC\"]}]}}})))\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_meta(client, {\"company\": \"meta\"})\n    assert len(jobs) == 1 and jobs[0].external_id == \"1\"\n\n@respx.mock\nasync def test_graphql_errors_surface_as_runtime_error():\n    respx.get(\"https://www.metacareers.com/jobs\").mock(return_value=httpx.Response(200, text=\"\"))\n    respx.post(\"https://www.metacareers.com/graphql\").mock(\n        return_value=httpx.Response(200, text=__import__(\"json\").dumps(\n            {\"errors\": [{\"message\": \"doc_id not found\"}]})))\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(RuntimeError, match=\"doc_id\"):\n            await fetch_meta(client, {\"company\": \"meta\"})\n\n\n# tests/test_fetch_ashby.py\nfrom fetchers import fetch_ashby\n\n@respx.mock\nasync def test_posting_api_200_used_directly():\n    respx.get(url__startswith=\"https://api.ashbyhq.com/posting-api\").mock(\n        return_value=httpx.Response(200, json={\"jobs\": [{\"id\": \"1\", \"title\": \"SWE\"}]}))\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_ashby(client, {\"company\": \"acme\"})\n    assert len(jobs) == 1\n\n@respx.mock\nasync def test_404_falls_back_to_hosted_page_scrape():\n    respx.get(url__startswith=\"https://api.ashbyhq.com/posting-api\").mock(\n        return_value=httpx.Response(404))\n    html = ('window.__appData = {\"jobBoard\": {\"jobPostings\": '\n            '[{\"id\": \"1\", \"title\": \"SWE\", \"isListed\": true}]}}')\n    respx.get(\"https://jobs.ashbyhq.com/acme\").mock(return_value=httpx.Response(200, text=html))\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_ashby(client, {\"company\": \"acme\"})\n    assert len(jobs) == 1\n\n@respx.mock\nasync def test_non_404_non_200_raises():\n    respx.get(url__startswith=\"https://api.ashbyhq.com/posting-api\").mock(\n        return_value=httpx.Response(500))\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(httpx.HTTPStatusError):\n            await fetch_ashby(client, {\"company\": \"acme\"})\n```\n\n**5e. `fetch_all` — the top-level fan-out; integration-shaped.**\n- One source's fetcher raising must not abort the others (`try/except` inside `one()`).\n- `concurrency` semaphore actually bounds in-flight requests.\n- Results from multiple sources get flattened correctly.\n- Caller-supplied `client` is not closed by `fetch_all` (only the owned/auto-created one is); this is a subtle resource-management contract worth locking in.\n\n```python\n# tests/test_fetch_all.py\nimport httpx, pytest, respx\nfrom fetchers import fetch_all\n\npytestmark = pytest.mark.asyncio\n\n@respx.mock\nasync def test_one_source_failure_does_not_abort_others(capsys):\n    respx.get(url__startswith=\"https://boards-api.greenhouse.io\").mock(\n        return_value=httpx.Response(500))\n    respx.get(url__startswith=\"https://api.lever.co\").mock(\n        return_value=httpx.Response(200, json=[{\"id\": \"1\", \"text\": \"SWE\", \"hostedUrl\": \"u\"}]))\n    jobs = await fetch_all([\n        {\"ats\": \"greenhouse\", \"company\": \"bad\"},\n        {\"ats\": \"lever\", \"company\": \"good\"},\n    ])\n    assert len(jobs) == 1\n    assert \"failed\" in capsys.readouterr().out\n\nasync def test_does_not_close_caller_supplied_client():\n    client = httpx.AsyncClient()\n    await fetch_all([], client=client)\n    assert not client.is_closed\n    await client.aclose()\n\ndef test_unknown_ats_raises_value_error():\n    from fetchers import fetch_source\n    import asyncio\n    async def _run():\n        async with httpx.AsyncClient() as c:\n            with pytest.raises(ValueError, match=\"unknown ATS\"):\n                await fetch_source(c, {\"ats\": \"not-a-real-ats\"})\n    asyncio.run(_run())\n```\n\n---\n\n### 6. `pipeline.py` — integration gap\n\n**Untested:** `load_config` (defaults), `run` (dry-run vs. real path), `run_sync`.\n\n- `load_config` default-filling for missing `sources`/`filters`/`db`/`concurrency` keys.\n- `run(dry_run=True)` must **not** touch the `Store` at all (no dedup-state mutation, no notification dispatch) — this is a documented, deliberate behavior worth a test that spies on `Store`/`dispatch` and asserts zero calls.\n- `run(dry_run=False)` — full path: fetch → filter → store.diff → dispatch, using mocked `fetch_all`/`dispatch`.\n- Return dict shape (`matched`/`new`/`changed` counts) matches actual list lengths.\n\n```python\n# tests/test_pipeline.py\nimport pytest\nfrom pathlib import Path\nimport yaml\nimport pipeline\nfrom models import Job\n\npytestmark = pytest.mark.asyncio\n\n\ndef _job(eid=\"1\"):\n    return Job(source=\"s\", company=\"c\", external_id=eid, title=\"T\", url=\"u\")\n\n\nclass TestLoadConfig:\n    def test_fills_in_defaults(self, tmp_path):\n        cfg_path = tmp_path / \"cfg.yaml\"\n        cfg_path.write_text(yaml.dump({}))\n        cfg = pipeline.load_config(cfg_path)\n        assert cfg[\"sources\"] == [] and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\n    def test_preserves_explicit_values(self, tmp_path):\n        cfg_path = tmp_path / \"cfg.yaml\"\n        cfg_path.write_text(yaml.dump({\"concurrency\": 20, \"db\": \"custom.db\"}))\n        cfg = pipeline.load_config(cfg_path)\n        assert cfg[\"concurrency\"] == 20 and cfg[\"db\"] == \"custom.db\"\n\n\nclass TestRun:\n    async def test_dry_run_never_touches_store_or_notifies(self, tmp_path, monkeypatch):\n        cfg_path = tmp_path / \"cfg.yaml\"\n        cfg_path.write_text(yaml.dump({\"sources\": [], \"db\": str(tmp_path / \"j.db\")}))\n        monkeypatch.setattr(pipeline, \"fetch_all\", lambda *a, **k: _async([_job()]))\n        store_created = []\n        class SpyStore:\n            def __init__(self, *a, **k): store_created.append(True)\n        monkeypatch.setattr(pipeline, \"Store\", SpyStore)\n        result = await pipeline.run(cfg_path, dry_run=True)\n        assert store_created == []\n        assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n\n    async def test_real_run_diffs_and_dispatches(self, tmp_path, monkeypatch):\n        cfg_path = tmp_path / \"cfg.yaml\"\n        cfg_path.write_text(yaml.dump({\"sources\": [], \"db\": str(tmp_path / \"j.db\")}))\n        monkeypatch.setattr(pipeline, \"fetch_all\", lambda *a, **k: _async([_job()]))\n        dispatched = []\n        monkeypatch.setattr(pipeline, \"dispatch\", lambda new, changed: dispatched.append((new, changed)))\n        result = await pipeline.run(cfg_path, dry_run=False)\n        assert result[\"new\"] == 1\n        assert len(dispatched) == 1\n\n\nasync def _async(value):\n    return value\n```\n\n---\n\n### 7. `agent.py` — CLI + PDF pipeline, mixed pure/subprocess logic\n\n**Untested entirely.** Split into pure-logic (easy) vs. subprocess/filesystem (needs `tmp_path` + mocked `subprocess.run`).\n\n**7a. `_normalize_ats` — pure regex substitution, high test value (ATS parsing correctness is the whole point of `pdf-render`).**\n- Each rule fires independently (em-dash, en-dash, smart quotes both directions, ellipsis, zero-width chars, nbsp, arrows, middot/bullet, currency symbols).\n- Substitutions apply only to text **outside** `<style>`/`<script>`/tag-attribute content — the core \"don't corrupt markup\" guarantee.\n- Returns accurate `counts` dict for reporting.\n\n```python\n# tests/test_agent_normalize.py\nfrom agent import _normalize_ats\n\ndef test_em_dash_and_smart_quotes_replaced_in_body_text():\n    html = \"<p>He said \\u201chello\\u201d \\u2014 twice</p>\"\n    out, counts = _normalize_ats(html)\n    assert \"\\u201c\" not in out and \"\\u2014\" not in out\n    assert counts[\"em-dash\"] == 1 and counts[\"smart-double-quote\"] == 2\n\ndef test_style_block_contents_untouched():\n    html = \"<style>.x::before{content:'\\u2014'}</style><p>\\u2014</p>\"\n    out, counts = _normalize_ats(html)\n    assert \"\\u2014\" in out.split(\"</style>\")[0]     # preserved inside <style>\n    assert counts[\"em-dash\"] == 1                     # only counts the <p> occurrence\n\ndef test_script_block_contents_untouched():\n    html = '<script>var x=\"\\u2014\";</script><p>\\u2014</p>'\n    out, counts = _normalize_ats(html)\n    assert out.startswith('<script>var x=\"\\u2014\"')\n\ndef test_tag_attributes_untouched():\n    html = '<a title=\"em\\u2014dash\">text\\u2014here</a>'\n    out, _ = _normalize_ats(html)\n    assert 'title=\"em\\u2014dash\"' in out    # attribute preserved\n    assert \"text-here\" in out               # body text normalized\n\ndef test_no_replacements_needed_returns_empty_counts():\n    out, counts = _normalize_ats(\"<p>plain ascii</p>\")\n    assert counts == {}\n```\n\n**7b. `cmd_db_new` — the most logic-dense function in the file; currently zero coverage on any branch.**\n- First-run (no marker) uses `since_days` window.\n- `--posted-days` filtering: dated-old dropped, undated kept by default, undated dropped with `--dated-only`.\n- Group-boundary truncation at `--limit` (never splits a `first_seen` group mid-way — the docstring explicitly calls this out as a correctness requirement for watermark safety).\n- `watermark` in output equals the `since` value when zero rows match.\n\n```python\n# tests/test_agent_db_new.py\nimport json\nfrom datetime import datetime, timedelta, timezone\nimport pytest\nfrom store import Store\nfrom models import Job\nimport agent\n\ndef _seed(store, rows):\n    # rows: list of (external_id, first_seen_iso, posted_at)\n    for eid, first_seen, posted_at in rows:\n        job = Job(source=\"s\", company=\"c\", external_id=eid, title=\"T\", url=\"u\",\n                   posted_at=posted_at)\n        cur = store.conn.cursor()\n        store._insert(cur, job, first_seen)\n    store.conn.commit()\n\n@pytest.fixture\ndef cfg(tmp_path):\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(f'sources: []\\nfilters: {{}}\\ndb: \"{tmp_path / \"j.db\"}\"\\n')\n    return str(cfg_path)\n\nclass TestDbNew:\n    def test_first_run_uses_since_days_window(self, cfg, capsys):\n        agent.cmd_db_new([\"-c\", cfg, \"--since-days\", \"3\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n        assert out[\"count\"] == 0\n\n    def test_dated_only_drops_undated_rows(self, cfg, capsys):\n        with Store.__new__(Store) as _: pass  # placeholder if fixture needs real store setup\n        # (full seeding omitted for brevity — seed via _seed() helper above,\n        #  then assert out[\"undated_dropped\"] > 0 and no undated rows in out[\"jobs\"])\n\n    def test_group_truncation_never_splits_first_seen_group(self, cfg, capsys):\n        # seed two first_seen timestamps, first with 3 rows, second with 3 rows,\n        # set --limit 4 -> expect only the first group of 3 (not 4) returned,\n        # and truncated == True\n        pass  # fill in using _seed()\n```\n\n*(These two are marked as skeletons needing the `_seed` helper wired up — flagged rather than faked, since getting the SQLite fixture right matters more than a passing stub.)*\n\n**7c. `cmd_db_mark` — validation branch coverage.**\n```python\ndef test_rejects_non_iso_watermark(cfg, capsys):\n    rc = agent.cmd_db_mark([\"not-a-date\", \"-c\", cfg])\n    assert rc == 2\n\ndef test_accepts_now_flag(cfg, capsys):\n    rc = agent.cmd_db_mark([\"--now\", \"-c\", cfg])\n    assert rc == 0\n\ndef test_requires_watermark_or_now(cfg, capsys):\n    rc = agent.cmd_db_mark([\"-c\", cfg])\n    assert rc == 2\n```\n\n**7d. `cmd_pdf_render` / `_chrome_bin` — subprocess boundary; mock `subprocess.run` rather than actually shelling out to Chrome in CI.**\n- Missing input file → return code 2, stderr message, no subprocess call.\n- `CHROME_PATH` env var takes priority when it exists on disk.\n- Output validated by `%PDF` magic-bytes check — a Chrome failure (non-PDF output) must return 1 and print stderr tail, not silently \"succeed.\"\n- Temp `.ats.html` file is cleaned up even when the subprocess raises (the `finally: tmp.unlink(missing_ok=True)`).\n\n```python\n# tests/test_agent_pdf_render.py\nimport subprocess\nimport pytest\nimport agent\n\ndef test_missing_input_file_returns_2(tmp_path, capsys):\n    rc = agent.cmd_pdf_render([str(tmp_path / \"nope.html\")])\n    assert rc == 2\n\ndef test_chrome_path_env_var_used_when_file_exists(tmp_path, monkeypatch):\n    fake_chrome = tmp_path / \"chrome\"\n    fake_chrome.write_text(\"\")\n    monkeypatch.setenv(\"CHROME_PATH\", str(fake_chrome))\n    assert agent._chrome_bin() == str(fake_chrome)\n\ndef test_non_pdf_output_reports_failure(tmp_path, monkeypatch, capsys):\n    src = tmp_path / \"in.html\"\n    src.write_text(\"<html><body>hi</body></html>\")\n    monkeypatch.setattr(agent, \"_chrome_bin\", lambda: \"/bin/echo\")\n    def fake_run(*a, **k):\n        (tmp_path / \"in.pdf\").write_bytes(b\"not a pdf\")\n        return subprocess.CompletedProcess(a, 0, stdout=\"\", stderr=\"render error\")\n    monkeypatch.setattr(agent.subprocess, \"run\", fake_run)\n    rc = agent.cmd_pdf_render([str(src)])\n    assert rc == 1\n    assert \"render error\" in capsys.readouterr().err\n\ndef test_temp_ats_html_cleaned_up_even_on_subprocess_error(tmp_path, monkeypatch):\n    src = tmp_path / \"in.html\"\n    src.write_text(\"<html></html>\")\n    monkeypatch.setattr(agent, \"_chrome_bin\", lambda: \"/bin/false\")\n    def raising_run(*a, **k):\n        raise subprocess.TimeoutExpired(cmd=\"chrome\", timeout=1)\n    monkeypatch.setattr(agent.subprocess, \"run\", raising_run)\n    with pytest.raises(subprocess.TimeoutExpired):\n        agent.cmd_pdf_render([str(src)])\n    assert not (tmp_path / f\".{src.stem}.ats.html\").exists()\n```\n\n**7e. `main()` argv-dispatch routing — thin, but the mode-word/flag-splitting logic (`for i, t in enumerate(words): if t.startswith(\"-\")`) has an untested edge case: a bare `-i`/`--interactive` flag is filtered before the split, but any *other* leading flag (e.g. `agent.py --dry-run`) should split `mode_words=[]` `extra=[\"--dry-run\"]` — worth one test locking in that boundary.**\n\n---\n\n### 8. `cli.py`\n\nThin argparse wrapper around `run_sync`. Lowest priority, but a one-liner smoke test catches accidental arg-name typos:\n\n```python\n# tests/test_cli.py\nfrom unittest.mock import patch\nimport cli\n\ndef test_dry_run_flag_passed_through():\n    with patch(\"cli.run_sync\") as mock_run:\n        with patch(\"sys.argv\", [\"cli.py\", \"--dry-run\", \"-c\", \"custom.yaml\"]):\n            cli.main()\n  