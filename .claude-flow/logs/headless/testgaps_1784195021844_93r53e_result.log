        "code": "# tests/test_store.py\nimport sqlite3\nimport pytest\nfrom store import Store\nfrom models import Job\n\n\ndef _job(external_id=\"1\", title=\"Engineer\", company=\"acme\"):\n    return Job(source=\"greenhouse\", company=company, external_id=external_id,\n               title=title, url=\"https://x\")\n\n\n@pytest.fixture\ndef db_path(tmp_path):\n    return tmp_path / \"jobs.db\"\n\n\nclass TestDiff:\n    def test_new_job_goes_to_new_list(self, db_path):\n        with Store(db_path) as s:\n            new, changed = s.diff([_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_reseen_unchanged_job_is_neither_new_nor_changed(self, db_path):\n        with Store(db_path) as s:\n            s.diff([_job()])\n            new, changed = s.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_reseen_unchanged_job_bumps_last_seen(self, db_path):\n        with Store(db_path) as s:\n            s.diff([_job()])\n            row_before = s.conn.execute(\n                \"SELECT last_seen FROM jobs WHERE key=?\", (_job().key,)).fetchone()\n            s.diff([_job()])\n            row_after = s.conn.execute(\n                \"SELECT last_seen FROM jobs WHERE key=?\", (_job().key,)).fetchone()\n        assert row_after[\"last_seen\"] >= row_before[\"last_seen\"]\n\n    def test_changed_content_hash_goes_to_changed_list(self, db_path):\n        with Store(db_path) as s:\n            s.diff([_job(title=\"Engineer\")])\n            new, changed = s.diff([_job(title=\"Senior Engineer\")])\n        assert new == [] and len(changed) == 1\n        assert changed[0].title == \"Senior Engineer\"\n\n    def test_persists_across_store_reopen(self, db_path):\n        with Store(db_path) as s:\n            s.diff([_job()])\n        with Store(db_path) as s2:\n            assert s2.count() == 1\n\n\nclass TestMigration:\n    def test_old_schema_without_salary_range_gets_backfilled(self, db_path):\n        conn = sqlite3.connect(str(db_path))\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit()\n        conn.close()\n        with Store(db_path) as s:\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\n\nclass TestMetaAndSeq:\n    def test_get_meta_missing_key_returns_none(self, db_path):\n        with Store(db_path) as s:\n            assert s.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta_roundtrip(self, db_path):\n        with Store(db_path) as s:\n            s.set_meta(\"last_scan\", \"2024-01-01T00:00:00+00:00\")\n            assert s.get_meta(\"last_scan\") == \"2024-01-01T00:00:00+00:00\"\n\n    def test_next_seq_starts_at_one_and_increments(self, db_path):\n        with Store(db_path) as s:\n            assert s.next_seq(\"report_seq\") == 1\n            assert s.next_seq(\"report_seq\") == 2\n            assert s.next_seq(\"report_seq\") == 3\n\n\nclass TestAddedSince:\n    def test_strict_greater_than_excludes_boundary_ts(self, db_path):\n        with Store(db_path) as s:\n            s.diff([_job()])\n            ts = s.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n            assert s.added_since(ts) == []          # boundary excluded\n            assert len(s.added_since(\"2000-01-01T00:00:00+00:00\")) == 1\n\n    def test_ordering_by_first_seen_company_title(self, db_path):\n        with Store(db_path) as s:\n            s.diff([_job(external_id=\"2\", title=\"B\", company=\"z\"),\n                     _job(external_id=\"1\", title=\"A\", company=\"a\")])\n            rows = s.added_since(\"2000-01-01T00:00:00+00:00\")\n        assert [r[\"company\"] for r in rows] == [\"a\", \"z\"]"
