        "title": "tests/test_agent_pdf_render.py",
        "content": "import subprocess\nimport pytest\nimport agent\n\ndef test_missing_input_file_returns_2(tmp_path, capsys):\n    rc = agent.cmd_pdf_render([str(tmp_path / \"nope.html\")])\n    assert rc == 2\n\ndef test_chrome_path_env_var_used_when_file_exists(tmp_path, monkeypatch):\n    fake_chrome = tmp_path / \"chrome\"\n    fake_chrome.write_text(\"\")\n    monkeypatch.setenv(\"CHROME_PATH\", str(fake_chrome))\n    assert agent._chrome_bin() == str(fake_chrome)\n\ndef test_non_pdf_output_reports_failure(tmp_path, monkeypatch, capsys):\n    src = tmp_path / \"in.html\"\n    src.write_text(\"<html><body>hi</body></html>\")\n    monkeypatch.setattr(agent, \"_chrome_bin\", lambda: \"/bin/echo\")\n    def fake_run(*a, **k):\n        (tmp_path / \"in.pdf\").write_bytes(b\"not a pdf\")\n        return subprocess.CompletedProcess(a, 0, stdout=\"\", stderr=\"render error\")\n    monkeypatch.setattr(agent.subprocess, \"run\", fake_run)\n    rc = agent.cmd_pdf_render([str(src)])\n    assert rc == 1\n    assert \"render error\" in capsys.readouterr().err\n\ndef test_temp_ats_html_cleaned_up_even_on_subprocess_error(tmp_path, monkeypatch):\n    src = tmp_path / \"in.html\"\n    src.write_text(\"<html></html>\")\n    monkeypatch.setattr(agent, \"_chrome_bin\", lambda: \"/bin/false\")\n    def raising_run(*a, **k):\n        raise subprocess.TimeoutExpired(cmd=\"chrome\", timeout=1)\n    monkeypatch.setattr(agent.subprocess, \"run\", raising_run)\n    with pytest.raises(subprocess.TimeoutExpired):\n        agent.cmd_pdf_render([str(src)])\n    assert not (tmp_path / f\".{src.stem}.ats.html\").exists()\n```\n\n**7e. `main()` argv-dispatch routing — thin, but the mode-word/flag-splitting logic (`for i, t in enumerate(words): if t.startswith(\"-\")`) has an untested edge case: a bare `-i`/`--interactive` flag is filtered before the split, but any *other* leading flag (e.g. `agent.py --dry-run`) should split `mode_words=[]` `extra=[\"--dry-run\"]` — worth one test locking in that boundary.**\n\n---\n\n",
