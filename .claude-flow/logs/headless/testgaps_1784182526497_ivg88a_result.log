eps_recent_posting():\n    j = job(posted_at=datetime.now(timezone.utc).isoformat())\n    cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n    assert match(j, cutoff=cutoff)\n\n\ndef test_empty_rule_lists_do_not_filter():\n    assert match(job(), include=[], exclude=[], locations=[])\n\n\nclass TestFilterJobs:\n    def test_max_age_days_builds_cutoff(self):\n        fresh = job(external_id=\"1\", posted_at=datetime.now(timezone.utc).isoformat())\n        stale = job(external_id=\"2\", posted_at=\"2020-01-01T00:00:00Z\")\n        out = filter_jobs([fresh, stale], {\"max_age_days\": 7})\n        assert [j.external_id for j in out] == [\"1\"]\n\n    def test_no_rules_returns_all(self):\n        jobs = [job(external_id=\"1\"), job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs\n\n    def test_max_age_days_zero_is_falsy_and_skipped(self):\n        # rules.get(\"max_age_days\") truthiness means 0 behaves like \"unset\",\n        # not \"same day only\" — worth locking in since it's surprising.\n        stale = job(posted_at=\"2020-01-01T00:00:00Z\")\n        out = filter_jobs([stale], {\"max_age_days\": 0})\n        assert out == [stale]\n```\n\n---\n\n## 3. `store.py` — SQLite dedup engine; correctness-critical and currently has **zero** coverage of the diff/migration/concurrency logic\n\n### Gaps\n- `diff()`: new vs changed vs unchanged classification; `last_seen` bump on unchanged rows; multiple jobs sharing a `key` across runs.\n- `_migrate()`: additive migration path when `salary_range` column is missing from a pre-existing DB (currently *impossible to hit* without a legacy fixture — needs one).\n- `next_seq`: monotonic increase across calls; starts at 1; isolated per key.\n- `added_since`: strict `>` boundary (not `>=`), ordering.\n- `get_meta`/`set_meta`: missing key returns `None`; upsert overwrites.\n- Context manager (`__enter__`/`__exit__`) closes the connection.\n- **Integration gap**: no test exercises `next_seq`'s claimed concurrency-safety (`BEGIN IMMEDIATE`) under actual concurrent access — this is the one place the code comments specifically claim correctness under parallel workers ([[jobsquare-parallel-worker-collisions]] memory flags this exact area as previously fragile).\n\n```python\n# tests/test_store.py\nimport sqlite3\nimport threading\nimport pytest\nfrom store import Store\nfrom models import Job\n\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"jobs.db\")\n    yield s\n    s.close()\n\n\ndef job(external_id=\"1\", title=\"Engineer\", **kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=external_id,\n                title=title, url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\n\nclass TestDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([job()])\n        assert len(new) == 1 and changed == []\n\n    def test_reseen_unchanged_job_is_neither(self, store):\n        store.diff([job()])\n        new, changed = store.diff([job()])\n        assert new == [] and changed == []\n\n    def test_reseen_with_title_change_is_changed(self, store):\n        store.diff([job(title=\"Engineer I\")])\n        new, changed = store.diff([job(title=\"Engineer II\")])\n        assert new == [] and len(changed) == 1\n\n    def test_unchanged_row_bumps_last_seen(self, store):\n        store.diff([job()])\n        first = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()[\"last_seen\"]\n        store.diff([job()])\n        second = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()[\"last_seen\"]\n        assert second >= first  # TODO: freeze/advance clock to assert strictly >\n\n    def test_diff_persists_across_store_instances(self, tmp_path):\n        with Store(tmp_path / \"j.db\") as s1:\n            s1.diff([job()])\n        with Store(tmp_path / \"j.db\") as s2:\n            new, _ = s2.diff([job()])\n            assert new == []  # already known\n\n\nclass TestMeta:\n    def test_get_meta_missing_key_is_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta_roundtrips(self, store):\n        store.set_meta(\"k\", \"v1\")\n        assert store.get_meta(\"k\") == \"v1\"\n\n    def test_set_meta_upserts(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n\nclass TestNextSeq:\n    def test_starts_at_one(self, store):\n        assert store.next_seq(\"report_seq\") == 1\n\n    def test_increments_monotonically(self, store):\n        seqs = [store.next_seq(\"report_seq\") for _ in range(5)]\n        assert seqs == [1, 2, 3, 4, 5]\n\n    def test_independent_counters_per_key(self, store):\n        assert store.next_seq(\"a\") == 1\n        assert store.next_seq(\"b\") == 1\n        assert store.next_seq(\"a\") == 2\n\n    def test_concurrent_claimers_get_unique_sequential_ids(self, tmp_path):\n        # Regression guard for the BEGIN IMMEDIATE serialization the code\n        # comments claim protects parallel pipeline workers.\n        db = tmp_path / \"concurrent.db\"\n        results = []\n        lock = threading.Lock()\n\n        def claim():\n            with Store(db) as s:\n                n = s.next_seq(\"report_seq\")\n                with lock:\n                    results.append(n)\n\n        threads = [threading.Thread(target=claim) for _ in range(10)]\n        for t in threads: t.start()\n        for t in threads: t.join()\n        assert sorted(results) == list(range(1, 11))  # no duplicates, no gaps\n\n\nclass TestAddedSince:\n    def test_strict_greater_than_excludes_boundary_timestamp(self, store):\n        store.diff([job(external_id=\"1\")])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[\"first_seen\"]\n        assert store.added_since(ts) == []  # boundary row excluded (strict >)\n\n    def test_returns_rows_after_ts_ordered(self, store):\n        store.diff([job(external_id=\"1\")])\n        rows = store.added_since(\"2000-01-01T00:00:00\")\n        assert len(rows) == 1\n\n\nclass TestMigration:\n    def test_legacy_db_missing_salary_range_gets_column_added(self, tmp_path):\n        db = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(db)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n\n        with Store(db) as s:\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\n\ndef test_context_manager_closes_connection(tmp_path):\n    s = Store(tmp_path / \"j.db\")\n    with s:\n        pass\n    with pytest.raises(sqlite3.ProgrammingError):\n        s.conn.execute(\"SELECT 1\")\n\n\ndef test_count_reflects_row_total(store):\n    store.diff([job(external_id=\"1\"), job(external_id=\"2\")])\n    assert store.count() == 2\n```\n\n---\n\n## 4. `notify.py` — error isolation is the load-bearing behavior and is completely unverified\n\n### Gaps\n- `dispatch()`: the one job of this function is \"one notifier failing must not block the others\" — **not tested at all**.\n- Every notifier's env-var gating (missing var → no-op, no network call) — untested, and a regression here means silently leaking a webhook call or crashing on missing creds.\n- `notify_sms`: `resp.raise_for_status()` re-raising on Twilio failure (relies on `dispatch`'s catch-all).\n- `_sms_body`: truncation at `limit` and the \"+N more\" line.\n- `notify_slack`/`notify_webhook`/`notify_email`: no-op when both `new` and `changed` are empty even if env vars are set (avoid spurious pings).\n\n```python\n# tests/test_notify.py\nimport pytest\nfrom unittest.mock import patch, MagicMock\nfrom models import Job\nimport notify\n\n\ndef job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\n\nclass TestDispatchIsolation:\n    def test_one_notifier_raising_does_not_block_others(self, capsys):\n        calls = []\n        def ok(new, changed): calls.append(\"ok\")\n        def boom(new, changed): raise RuntimeError(\"twilio 500\")\n        with patch.object(notify, \"NOTIFIERS\", [boom, ok]):\n            notify.dispatch([job()], [])\n        assert calls == [\"ok\"]\n        assert \"notifier boom failed\" in capsys.readouterr().out\n\n\nclass TestConsole:\n    def test_no_fresh_listings_prints_message(self, capsys):\n        notify.notify_console([], [])\n        assert \"No fresh listings\" in capsys.readouterr().out\n\n    def test_new_and_changed_both_printed(self, capsys):\n        notify.notify_console([job(external_id=\"1\")], [job(external_id=\"2\")])\n        out = capsys.readouterr().out\n        assert \"NEW listing\" in out and \"UPDATED listing\" in out\n\n\nclass TestSlack:\n    def test_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_slack([job()], [])\n            post.assert_not_called()\n\n    def test_noop_when_no_new_or_changed_even_with_url_set(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_slack([], [])\n            post.assert_not_called()\n\n    def test_posts_when_configured_and_new_jobs_exist(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_slack([job()], [])\n            post.assert_called_once()\n\n\nclass TestSms:\n    def test_noop_unless_all_four_twilio_vars_set(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_sms([job()], [])\n            post.assert_not_called()\n\n    def test_raises_on_twilio_failure_response(self, monkeypatch):\n        for k, v in ((\"TWILIO_ACCOUNT_SID\", \"sid\"), (\"TWILIO_AUTH_TOKEN\", \"tok\"),\n                     (\"TWILIO_FROM\", \"+1\"), (\"TWILIO_TO\", \"+2\")):\n            monkeypatch.setenv(k, v)\n        resp = MagicMock()\n        resp.raise_for_status.side_effect = Exception(\"bad creds\")\n        with patch(\"notify.httpx.post\", return_value=resp):\n            with pytest.raises(Exception, match=\"bad creds\"):\n                notify.notify_sms([job()], [])\n\n    def test_sms_body_truncates_at_limit_with_more_count(self):\n        jobs = [job(external_id=str(i), title=f\"Job {i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n        assert body.count(\"\\n- Job\") == 8\n\n    def test_sms_body_is_ascii_only(self):\n        # regression guard: non-GSM chars force costly UCS-2 segments\n        body = notify._sms_body([job(title=\"Café Engineer\")], [])\n        # TODO: decide desired behavior — currently title chars pass through\n        # unescaped; assert whatever the intended sanitization is.\n\n\nclass TestEmail:\n    def test_noop_without_smtp_host_or_to(self, monkeypatch):\n        monkeypatch.delenv(\"SMTP_HOST\", raising=False)\n        monkeypatch.setenv(\"EMAIL_TO\", \"me@x.com\")\n        with patch(\"notify.smtplib.SMTP\") as smtp:\n            notify.notify_email([job()], [])\n            smtp.assert_not_called()\n\n    def test_sends_via_starttls_and_login_when_creds_set(self, monkeypatch):\n        monkeypatch.setenv(\"SMTP_HOST\", \"smtp.x.com\")\n        monkeypatch.setenv(\"EMAIL_TO\", \"me@x.com\")\n        monkeypatch.setenv(\"SMTP_USER\", \"u\")\n        monkeypatch.setenv(\"SMTP_PASS\", \"p\")\n        mock_smtp = MagicMock()\n        with patch(\"notify.smtplib.SMTP\", return_value=mock_smtp):\n            notify.notify_email([job()], [])\n        mock_smtp.__enter__.return_value.login.assert_called_once_with(\"u\", \"p\")\n```\n\n---\n\n## 5. `fetchers.py` — largest module, largest gap. Split into pure parsers (easy, high value) and network fetchers (need `respx`).\n\n### 5a. Pure parser functions — all currently untested, all have real edge cases baked into their docstrings/comments\n\n| Function | Edge case the code explicitly handles but nothing verifies |\n|---|---|\n| `parse_lever` / `_lever_salary` | missing `salaryRange` → falls back to `salaryDescriptionPlain`; only one of min/max present |\n| `parse_ashby` | `isListed is False` must be skipped |\n| `parse_google` / `_extract_ds1` / `_ds1_posted_at` | regex fallback when `sideChannel` key moves; empty/malformed JSON blob; prefers index 12 over 13/14 |\n| `parse_deshaw` | dedup via `seen`; missing `mtitle`/`mid` skipped; missing `mhref` falls back to constructed URL |\n| `parse_twosigma` | triple-rendered cards deduped via `seen` |\n| `_apple_hydration` | nanosecond timestamp truncation to microseconds; malformed JSON returns `None` |\n| `parse_apple` | one requisition → N results (one per location); location dedup via `dict.fromkeys` |\n| `_bd_location` | walks `parent` chain to build \"city, state, country\" |\n| `_amazon_posted_at` | `\"June 26, 2026\"` → ISO; malformed string → `\"\"` (not a crash) |\n| `parse_eightfold` | `location` singular vs `locations` list fallback |\n\n```python\n# tests/test_fetchers_parsers.py\nfrom fetchers import (\n    parse_greenhouse, parse_lever, _lever_salary, parse_ashby, _ashby_salary,\n    parse_smartrecruiters, parse_recruitee, parse_workable,\n    _extract_ds1, _ds1_posted_at, parse_google,\n    parse_deshaw, parse_twosigma,\n    _apple_hydration, _apple_posted_at, parse_apple,\n    parse_eightfold, _bd_location, parse_bytedance,\n    parse_microsoft, parse_netflix, _amazon_posted_at, parse_amazon,\n    parse_meta,\n)\n\n\nclass TestGreenhouse:\n    def test_basic_fields_mapped(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\",\n                           \"location\": {\"name\": \"NYC\"},\n                           \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Core\"}],\n                           \"updated_at\": \"2026-01-01\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].department == \"Eng, Core\"\n        assert jobs[0].location == \"NYC\"\n\n    def test_missing_location_and_departments_default_empty(self):\n        jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1}]})\n        assert jobs[0].location == \"\" and jobs[0].department == \"\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_jobs_key(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\n\nclass TestLeverSalary:\n    def test_min_and_max_present_formats_range(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_only_min_falls_back_to_description(self):\n        j = {\"salaryRange\": {\"min\": 100000}, \"salaryDescriptionPlain\": \"DOE\"}\n        assert _lever_salary(j) == \"DOE\"\n\n    def test_no_salary_info_returns_empty_string(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestAshby:\n    def test_unlisted_job_is_skipped(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"},\n                          {\"id\": \"2\", \"isListed\": True, \"title\": \"Visible\"}]}\n        jobs = parse_ashby(\"acme\", data)\n        assert [j.external_id for j in jobs] == [\"2\"]\n\n    def test_compensation_tier_summary_preferred_over_scrapeable(self):\n        j = {\"id\": \"1\", \"compensation\": {\"compensationTierSummary\": \"A\",\n                                          \"scrapeableCompensationSalarySummary\": \"B\"}}\n        assert _ashby_salary(j) == \"A\"\n\n\nclass TestGoogleDs1:\n    def test_extract_ds1_happy_path(self):\n        html = \"key: 'ds:1', foo: 1, data:[[[\\\"a\\\",\\\"b\\\"]]] , sideChannel:{}})\"\n        assert _extract_ds1(html) == [[\"a\", \"b\"]]\n\n    def test_extract_ds1_missing_blob_returns_empty_list(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_extract_ds1_malformed_json_returns_empty_list(self):\n        html = \"key: 'ds:1', data:[not valid json] , sideChannel:{}})\"\n        assert _extract_ds1(html) == []\n\n    def test_ds1_posted_at_prefers_index_12_over_13_and_14(self):\n        job = [None] * 15\n        job[12] = [1700000000, 0]\n        job[13] = [1800000000, 0]\n        assert \"2023\" in _ds1_posted_at(job)  # index 12's epoch year\n\n    def test_ds1_posted_at_missing_all_timestamps_returns_empty(self):\n        assert _ds1_posted_at([None] * 20) == \"\"\n\n    def test_parse_google_skips_falsy_entries(self):\n        assert parse_google(\"google\", [None, [None]]) == []\n\n\nclass TestDeshaw:\n    def test_dedups_repeated_job_ids(self):\n        page = ('data-job-id=\"1\" ... <span class=\"job-display-name\">SWE</span>'\n                * 1)  # single card, sanity that dedup logic doesn't drop it\n        # a fuller fixture with two identical data-job-id blocks belongs here\n        # to actually exercise the `seen` dedup branch — TODO capture real HTML\n\n    def test_missing_href_falls_back_to_constructed_url(self):\n        # TODO: build a minimal card fixture missing the `href=` group and\n        # assert url == f\"https://www.deshaw.com/careers/{id}\"\n        pass\n\n\nclass TestApplePostedAt:\n    def test_truncates_nanoseconds_to_microseconds(self):\n        assert _apple_posted_at(\"2026-01-15T10:00:03.812668311Z\") == \\\n            \"2026-01-15T10:00:03.812668+00:00\"\n\n    def test_no_fractional_seconds(self):\n        assert _apple_posted_at(\"2026-01-15T10:00:03Z\") == \"2026-01-15T10:00:03+00:00\"\n\n    def test_empty_or_none_returns_empty_string(self):\n        assert _apple_posted_at(\"\") == \"\"\n        assert _apple_posted_at(None) == \"\"\n\n\nclass TestAppleHydration:\n    def test_missing_marker_returns_none(self):\n        assert _apple_hydration(\"<html></html>\") is None\n\n    def test_malformed_json_returns_none(self):\n        html = 'window.__staticRouterHydrationData = JSON.parse(\"not json\")'\n        assert _apple_hydration(html) is None\n\n\nclass TestAmazonPostedAt:\n    def test_parses_us_format_date(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_date_returns_empty_string(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n        assert _amazon_posted_at(\"\") == \"\"\n\n    def test_unknown_month_name_returns_empty_string(self):\n        assert _amazon_posted_at(\"Frobtember 1, 2026\") == \"\"\n\n\nclass TestBdLocation:\n    def test_walks_parent_chain_city_state_country(self):\n        node = {\"en_name\": \"SF\", \"parent\": {\"en_name\": \"CA\",\n                 \"parent\": {\"en_name\": \"USA\", \"parent\": None}}}\n        assert _bd_location(node) == \"SF, CA, USA\"\n\n    def test_none_input_returns_empty_string(self):\n        assert _bd_location(None) == \"\"\n\n    def test_falls_back_to_name_when_en_name_missing(self):\n        assert _bd_location({\"name\": \"东京\", \"parent\": None}) == \"东京\"\n\n\nclass TestEightfold:\n    def test_location_singular_preferred_over_locations_list(self):\n        p = {\"id\": \"1\", \"location\": \"NYC\", \"locations\": [\"SF\", \"LA\"]}\n        assert parse_eightfold(\"acme\", \"h.example.com\", [p])[0].location == \"NYC\"\n\n    def test_locations_list_joined_and_commas_spaced(self):\n        p = {\"id\": \"1\", \"locations\": [\"SF,CA,USA\"]}\n        assert parse_eightfold(\"acme\", \"h.example.com\", [p])[0].location == \"SF, CA, USA\"\n```\n\n### 5b. Async network fetchers — need `respx`; currently **zero** coverage of retry/backoff, pagination stop conditions, or the concurrency/error-isolation contract in `fetch_all`\n\nThese are the highest-risk gap in the whole codebase: `_request`'s retry/backoff is shared by every fetcher, and a bug there silently degrades every ATS integration at once.\n\n```python\n# tests/test_fetchers_network.py\nimport httpx\nimport pytest\nimport respx\nfrom fetchers import _request, fetch_all, fetch_source, FETCHERS\n\n\n@pytest.mark.asyncio\nclass TestRequestRetry:\n    async def test_succeeds_without_retry_on_200(self):\n        async with httpx.AsyncClient() as client:\n            with respx.mock:\n                respx.get(\"https://x.test/ok\").mock(return_value=httpx.Response(200))\n                r = await _request(client, \"https://x.test/ok\")\n                assert r.status_code == 200\n\n    async def test_retries_on_503_then_succeeds(self, monkeypatch):\n        monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)  # skip backoff delay\n        async with httpx.AsyncClient() as client:\n            with respx.mock:\n                route = respx.get(\"https://x.test/flaky\")\n                route.side_effect = [httpx.Response(503), httpx.Response(200)]\n                r = await _request(client, \"https://x.test/flaky\")\n                assert r.status_code == 200\n                assert route.call_count == 2\n\n    async def test_exhausts_retries_and_raises_runtime_error(self, monkeypatch):\n        monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)\n        async with httpx.AsyncClient() as client:\n            with respx.mock:\n                respx.get(\"https://x.test/dead\").mock(return_value=httpx.Response(500))\n                with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n                    await _request(client, \"https://x.test/dead\", retries=2)\n\n    async def test_non_retryable_4xx_fails_fast_without_exhausting_retries(self, monkeypatch):\n        monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)\n        async with httpx.AsyncClient() as client:\n            with respx.mock:\n                route = respx.get(\"https://x.test/notfound\")\n                route.mock(return_value=httpx.Response(404))\n                with pytest.raises(RuntimeError):\n                    await _request(client, \"https://x.test/notfound\")\n                # TODO: decide/assert whether 404 should retry at all — currently\n                # raise_for_status() makes it retryable via the except clause,\n                # which may be unintentional (wastes ~4 attempts on a permanent 404).\n\n\n@pytest.mark.asyncio\nclass TestFetchSource:\n    async def test_unknown_ats_raises_value_error(self):\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(ValueError, match=\"unknown ATS\"):\n                await fetch_source(client, {\"ats\": \"not-a-real-ats\"})\n\n\n@pytest.mark.asyncio\nclass TestFetchAll:\n    async def test_one_source_failing_does_not_block_others(self, capsys):\n        async def boom(client, source): raise RuntimeError(\"network down\")\n        async def ok(client, source): \n            from models import Job\n            return [Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"t\", url=\"u\")]\n        with pytest.MonkeyPatch.context() as m:\n            m.setitem(FETCHERS, \"boom\", boom)\n            m.setitem(FETCHERS, \"ok\", ok)\n            jobs = await fetch_all([{\"ats\": \"boom\"}, {\"ats\": \"ok\"}])\n        assert len(jobs) == 1\n        assert \"failed\" in capsys.readouterr().out\n\n    async def test_concurrency_semaphore_caps_in_flight_requests(self):\n        # TODO: instrument a fake fetcher that records max concurrent\n        # in-flight calls via a counter + asyncio.Event, assert it never\n        # exceeds the `concurrency` kwarg.\n        pass\n\n    async def test_empty_sources_returns_empty_list(self):\n        assert await fetch_all([]) == []\n\n\n@pytest.mark.asyncio\nclass TestSimpleFetcherPagination:\n    async def test_greenhouse_end_to_end_via_simple(self):\n        with respx.mock:\n            respx.get(\"https://boards-api.greenhouse.io/v1/boards/acme/jobs\").mock(\n                return_value=httpx.Response(200, json={\"jobs\": [\n                    {\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\"}]}))\n            jobs = await fetch_source(None, {\"ats\": \"greenhouse\", \"company\": \"acme\"})\n            # NOTE: _simple() creates no client itself; needs a client param —\n            # confirm actual signature before finalizing this test (see gap below)\n\n\n@pytest.mark.asyncio\nclass TestPaginatedFetchers:\n    \"\"\"Every hand-rolled paginator (workday/google/apple/meta/microsoft/netflix/\n    amazon/bytedance/eightfold/twosigma/optiver) shares the same untested\n    stop-condition shape: `while fresh: ...; if not fresh: break`.\n    Each needs at least:\n      - a 2-page happy path (page 1 has N fresh ids, page 2 empty -> stop)\n      - a `seen`-id collision test (a repeated id across pages doesn't duplicate)\n      - the `max_pages` safety cap actually stopping runaway pagination\n    Below is the pattern for fetch_workday; replicate per-fetcher with respx\n    routes matching each one's URL/body shape (see each fetcher's docstring).\n    \"\"\"\n\n    async def test_workday_stops_when_offset_reaches_total(self):\n        with respx.mock:\n            respx.post(\"https://acme.wd5.myworkdayjobs.com/wday/cxs/acme/site/jobs\").mock(\n                side_effect=[\n                    httpx.Response(200, json={\"total\": 1, \"jobPostings\": [\n                        {\"title\": \"SWE\", \"externalPath\": \"/job/1\",\n                         \"bulletFields\": [\"R123\"], \"locationsText\": \"NYC\"}]}),\n                ])\n            from fetchers import fetch_workday\n            async with httpx.AsyncClient() as client:\n                jobs = await fetch_workday(client, {\n                    \"host\": \"acme.wd5.myworkdayjobs.com\", \"tenant\": \"acme\",\n                    \"site\": \"site\", \"page_size\": 20})\n            assert len(jobs) == 1\n\n    async def test_workday_safety_cap_at_5000_offset(self):\n        # TODO: mock a server that always returns postings + total > 5000\n        # to assert the safety cap actually halts the loop.\n        pass\n```\n\n**Note on `TestSimpleFetcherPagination`**: writing this test surfaced a real gap worth flagging directly — `_simple()`'s inner `_fetch` takes `client` as its first arg, but nothing currently constructs/injects a test client into it without going through `fetch_all`. Worth adding a thin `async def fetch_one(ats, source, client=None)` test seam, or just always drive these through `fetch_source`/`fetch_all` with a shared `httpx.AsyncClient` fixture in `conftest.py`.\n\n---\n\n## 6. `pipeline.py` — orchestration layer, **no test exercises the dry-run vs. persist branch split**\n\n### Gaps\n- `load_config`: defaults applied when keys absent (`sources`, `filters`, `db`, `concurrency`) vs. preserved when present.\n- `run(dry_run=True)`: must NOT touch the `Store` or call `dispatch` — currently unverified; a regression here would silently start persisting dedup state during a dry run.\n- `run(dry_run=False)`: must call `store.diff` then `dispatch` then close the store.\n- Return dict shape (`matched`/`new`/`changed`) for both branches.\n\n```python\n# tests/test_pipeline.py\nimport pytest\nfrom unittest.mock import patch, AsyncMock, MagicMock\nfrom pipeline import load_config, run\n\n\nclass TestLoadConfig:\n    def test_defaults_applied_when_missing(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"sources: []\\n\")\n        cfg = load_config(p)\n        assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\n    def test_explicit_values_preserved(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"sources: []\\nconcurrency: 2\\ndb: custom.db\\n\")\n        cfg = load_config(p)\n        assert cfg[\"concurrency\"] == 2 and cfg[\"db\"] == \"custom.db\"\n\n\n@pytest.mark.asyncio\nclass TestRun:\n    async def test_dry_run_never_touches_store_or_dispatch(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"sources: []\\n\")\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n             patch(\"pipeline.Store\") as store_cls, \\\n             patch(\"pipeline.dispatch\") as dispatch_fn:\n            result = await run(p, dry_run=True)\n        store_cls.assert_not_called()\n        dispatch_fn.assert_not_called()\n        assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n\n    async def test_persist_path_diffs_and_dispatches(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"sources: []\\n\")\n        mock_store = MagicMock()\n        mock_store.diff.return_value = ([], [])\n        mock_store.count.return_value = 0\n        mock_store.__enter__.return_value = mock_store\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n             patch(\"pipeline.Store\", return_value=mock_store), \\\n             patch(\"pipeline.dispatch\") as dispatch_fn:\n            await run(p, dry_run=False)\n        mock_store.diff.assert_called_once()\n        dispatch_fn.assert_called_once()\n\n    async def test_filters_applied_before_dedup(self, tmp_path):\n        # TODO: seed fetch_all with jobs that a filter rule should exclude,\n        # assert store.diff() is called with the filtered subset only.\n        pass\n```\n\n---\n\n## 7. `agent.py` — deterministic CLI helpers used by the headless scan pipeline; currently untested despite being the integration point between `Store` and Claude's mode files\n\n### Gaps\n- `cmd_db_new`: first-run window (no marker) vs. marker-based window; `--posted-days` filtering with the \"keep undated unless `--dated-only`\" rule (mirrors the same forgiving-by-design pattern as `filters.match`'s cutoff — same regression risk); group-boundary truncation not splitting a `first_seen` cohort; watermark advancing only up to the last *complete* group.\n- `cmd_db_mark`: rejects non-ISO watermark; `--now` vs explicit watermark; requires one of the two.\n- `cmd_report_num`: delegates to `Store.next_seq` — thin, but worth one smoke test tying the CLI output format (zero-padded 3 digits) to the counter.\n- `_normalize_ats`: the ATS character table (em-dash, smart quotes, bullets, nbsp, arrows) — untested per-rule, and the \"skip `<style>`/`<script>`/tag contents\" split logic is exactly the kind of regex-based HTML surgery that silently breaks on edge cases (self-closing tags, nested quotes in attributes).\n- `_chrome_bin`: `CHROME_PATH` env override, `shutil.which` fallback, hardcoded macOS app paths, `sys.exit` when nothing found — **zero** coverage, and the exit-on-failure path means a bad env in CI would currently hang/crash rather than fail a test cleanly.\n- **Integration gap**: `cmd_pdf_render` end-to-end (HTML → normalized → Chrome subprocess → PDF bytes) has no test; needs either a real headless Chrome in CI or a subprocess mock asserting the invoked command line and the `%PDF` byte-sniff / truncated-tempfile cleanup (`tmp.unlink` in `finally`).\n\n```python\n# tests/test_agent.py\nimport pytest\nfrom unittest.mock import patch, MagicMock\nfrom pathlib import Path\nfrom agent import (\n    cmd_db_new, cmd_db_mark, cmd_report_num, _normalize_ats, _chrome_bin, MARK_KEY,\n)\nfrom store import Store\nfrom models import Job\nimport json\nimport io\nimport contextlib\n\n\ndef _seed(tmp_path, jobs):\n    with Store(tmp_path / \"jobs.db\") as s:\n        s.diff(jobs)\n    return tmp_path / \"jobs.db\"\n\n\ndef _run_capture(fn, argv):\n    buf = io.StringIO()\n    with contextlib.redirect_stdout(buf):\n        rc = fn(argv)\n    return rc, buf.getvalue()\n\n\nclass TestDbNew:\n    def test_first_run_uses_since_days_window(self, tmp_path, monkeypatch):\n        monkeypatch.chdir(tmp_path)\n        db = _seed(tmp_path, [Job(source=\"greenhouse\", company=\"acme\",\n                                   external_id=\"1\", title=\"SWE\", url=\"u\")])\n        (tmp_path / \"sources.yaml\").write_text(f\"db: {db.name}\\n\")\n        rc, out = _run_capture(cmd_db_new, [\"-c\", \"sources.yaml\"])\n        data = json.loads(out)\n        assert data[\"first_run\"] is True\n        assert data[\"count\"] == 1\n\n    def test_posted_days_keeps_undated_by_default(self, tmp_path, monkeypatch):\n        monkeypatch.chdir(tmp_path)\n        db = _seed(tmp_path, [Job(source=\"greenhouse\", company=\"acme\",\n                                   external_id=\"1\", title=\"SWE\", url=\"u\",\n                                   posted_at=\"\")])  # undated\n        (tmp_path / \"sources.yaml\").write_text(f\"db: {db.name}\\n\")\n        rc, out = _run_capture(cmd_db_new, [\"-c\", \"sources.yaml\", \"--posted-days\", \"7\"])\n        data = json.loads(out)\n        assert data[\"undated_kept\"] == 1 and data[\"count\"] == 1\n\n    def test_dated_only_drops_undated(self, tmp_path, monkeypatch):\n        monkeypatch.chdir(tmp_path)\n        db = _seed(tmp_path, [Job(source=\"greenhouse\", company=\"acme\",\n                                   external_id=\"1\", title=\"SWE\", url=\"u\",\n                                   posted_at=\"\")])\n        (tmp_path / \"sources.yaml\").write_text(f\"db: {db.name}\\n\")\n        rc, out = _run_capture(cmd_db_new, [\"-c\", \"sources.yaml\", \"--dated-only\"])\n        data = json.loads(out)\n        assert data[\"count\"] == 0 and data[\"undated_dropped\"] == 1\n\n    def test_truncation_does_not_split_a_first_seen_group(self, tmp_path, monkeypatch):\n        # TODO: seed two Store.diff() calls (two distinct first_seen timestamps,\n        # the second with more rows than `--limit`), assert watermark stays\n        # at the first group's timestamp and `truncated` is True.\n        pass\n\n\nclass TestDbMark:\n    def test_rejects_non_iso_watermark(self, tmp_path, monkeypatch, capsys):\n        monkeypatch.chdir(tmp_path)\n        (tmp_path / \"sources.yaml\").write_text(\"db: jobs.db\\n\")\n        rc = cmd_db_mark([\"not-a-date\", \"-c\", \"sources.yaml\"])\n        assert rc == 2\n        assert \"not an ISO timestamp\" in capsys.readouterr().err\n\n    def test_requires_watermark_or_now(self, tmp_path, monkeypatch, capsys):\n        monkeypatch.chdir(tmp_path)\n        (tmp_path / \"sources.yaml\").write_text(\"db: jobs.db\\n\")\n        rc = cmd_db_mark([\"-c\", \"sources.yaml\"])\n        assert rc == 2\n\n    def test_now_flag_sets_current_timestamp(self, tmp_path, monkeypatch):\n        monkeypatch.chdir(tmp_path)\n        (tmp_path / \"sources.yaml\").write_text(\"db: jobs.db\\n\")\n        cmd_db_mark([\"--now\", \"-c\", \"sources.yaml\"])\n        with Store(tmp_path / \"jobs.db\") as s:\n            assert s.get_meta(MARK_KEY) is not None\n\n\nclass TestReportNum:\n    def test_output_is_zero_padded_three_digits(self, tmp_path, monkeypatch):\n        monkeypatch.chdir(tmp_path)\n        (tmp_path / \"sources.yaml\").write_text(\"db: jobs.db\\n\")\n        rc, out = _run_capture(cmd_report_num, [\"-c\", \"sources.yaml\"])\n        assert out.strip() == \"001\"\n\n\nclass TestNormalizeAts:\n    @pytest.mark.parametrize(\"raw,expected\", [\n        (\"\\u2014\", \"-\"), (\"\\u2018hi\\u2019\", \"'hi'\"),\n        (\"a\\u2026b\", \"a...b\"), (\"a\\u00A0b\", \"a b\"),\n        (\"x\\u2192y\", \"x to y\"), (\"\\u2022 item\", \"| item\"),\n    ])\n    def test_body_text_substitutions(self, raw, expected):\n        html, counts = _normalize_ats(f\"<p>{raw}</p>\")\n        assert expected in html\n\n    def test_does_not_touch_inside_style_or_script_blocks(self):\n        html = \"<style>.x::after{content:'\\u2014'}</style><p>\\u2014</p>\"\n        out, counts = _normalize_ats(html)\n        assert \"\\u2014\" in out.split(\"</style>\")[0]  # untouched inside <style>\n        assert \"-\" in out.split(\"</style>\")[1]        # replaced in body\n\n    def test_does_not_touch_tag_attributes(self):\n        html = '<a title=\"em\\u2014dash\">text</a>'\n        out, counts = _normalize_ats(html)\n        assert 'title=\"em\\u2014dash\"' in out  # attribute preserved untouched\n\n    def test_no_special_chars_returns_empty_counts(self):\n        html, counts = _normalize_ats(\"<p>plain ascii</p>\")\n        assert counts == {}\n\n\nclass TestChromeBin:\n    def test_chrome_path_env_var_used_when_file_exists(self, tmp_path, monkeypatch):\n        fake = tmp_path / \"chrome\"\n        fake.write_text(\"\")\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert _chrome_bin() == str(fake)\n\n    def test_falls_back_to_which_when_env_unset(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        with patch(\"shutil.which\", side_effect=lambda n: \"/usr/bin/chromium\" if n == \"chromium\" else None):\n            assert _chrome_bin() == \"/usr/bin/chromium\"\n\n    def test_exits_when_nothing_found(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        with patch(\"shutil.which\", return_value=None), \\\n             patch(\"pathlib.Path.exists\", return_value=False):\n            with pytest.raises(SystemExit, match=\"no Chrome\"):\n                _chrome_bin()\n\n\nclass TestPdfRenderIntegration:\n    def test_end_to_end_smoke(self, tmp_path):\n        # TODO: requires a real or mocked Chrome binary. Options:\n        #  (a) skip in CI unless CHROME_PATH is set (pytest.mark.skipif)\n        #  (