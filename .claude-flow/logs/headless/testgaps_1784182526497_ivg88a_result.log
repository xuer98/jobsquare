        "code": "# tests/test_filters.py\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\n\ndef job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Software Engineer\", url=\"https://x/1\",\n                location=\"Remote - US\", department=\"Platform\")\n    base.update(kw)\n    return Job(**base)\n\n\ndef test_include_matches_case_insensitive():\n    assert match(job(title=\"Backend Engineer\"), include=[\"engineer\"])\n\n\ndef test_include_no_match_returns_false():\n    assert not match(job(title=\"Product Manager\"), include=[\"engineer\"])\n\n\ndef test_exclude_wins_even_if_include_also_matches():\n    j = job(title=\"Senior Engineer - Intern Program\")\n    assert not match(j, include=[\"engineer\"], exclude=[\"intern\"])\n\n\ndef test_word_boundary_does_not_match_substring():\n    # \"react\" should not match \"reactor\" style false positives\n    j = job(title=\"Nuclear Reactor Engineer\")\n    assert not match(j, include=[\"react\"])\n\n\ndef test_word_boundary_handles_symbol_keywords_like_cpp():\n    j = job(title=\"C++ Developer\")\n    assert match(j, include=[\"C++\"])\n\n\ndef test_locations_substring_case_insensitive():\n    assert match(job(location=\"San Francisco, CA\"), locations=[\"san francisco\"])\n    assert not match(job(location=\"London, UK\"), locations=[\"san francisco\"])\n\n\ndef test_cutoff_drops_confirmed_old_posting():\n    old = job(posted_at=\"2020-01-01T00:00:00Z\")\n    cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n    assert not match(old, cutoff=cutoff)\n\n\ndef test_cutoff_keeps_unparseable_posted_at():\n    j = job(posted_at=\"Posted 3 Days Ago\")  # Workday prose, unparseable\n    cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n    assert match(j, cutoff=cutoff)  # forgiving-by-design; regression-prone\n\n\ndef test_cutoff_keeps_recent_posting():\n    j = job(posted_at=datetime.now(timezone.utc).isoformat())\n    cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n    assert match(j, cutoff=cutoff)\n\n\ndef test_empty_rule_lists_do_not_filter():\n    assert match(job(), include=[], exclude=[], locations=[])\n\n\nclass TestFilterJobs:\n    def test_max_age_days_builds_cutoff(self):\n        fresh = job(external_id=\"1\", posted_at=datetime.now(timezone.utc).isoformat())\n        stale = job(external_id=\"2\", posted_at=\"2020-01-01T00:00:00Z\")\n        out = filter_jobs([fresh, stale], {\"max_age_days\": 7})\n        assert [j.external_id for j in out] == [\"1\"]\n\n    def test_no_rules_returns_all(self):\n        jobs = [job(external_id=\"1\"), job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs\n\n    def test_max_age_days_zero_is_falsy_and_skipped(self):\n        # rules.get(\"max_age_days\") truthiness means 0 behaves like \"unset\",\n        # not \"same day only\" — worth locking in since it's surprising.\n        stale = job(posted_at=\"2020-01-01T00:00:00Z\")\n        out = filter_jobs([stale], {\"max_age_days\": 0})\n        assert out == [stale]"
