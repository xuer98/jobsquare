    def test_set_meta_overwrites(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n    def test_next_seq_starts_at_one_and_increments(self, store):\n        assert store.next_seq(\"report_seq\") == 1\n        assert store.next_seq(\"report_seq\") == 2\n\n\nclass TestAddedSince:\n    def test_strictly_after_ts_excludes_boundary(self, store):\n        store.diff([make_job()])\n        row = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()\n        assert store.added_since(row[\"first_seen\"]) == []  # not > ts\n\n    def test_ordering_by_first_seen_company_title(self, store):\n        store.diff([make_job(company=\"z\", external_id=\"1\"),\n                     make_job(company=\"a\", external_id=\"2\")])\n        rows = store.added_since(\"1970-01-01T00:00:00+00:00\")\n        assert [r[\"company\"] for r in rows] == [\"a\", \"z\"]\n\n\ndef test_migration_adds_salary_range_to_legacy_schema(tmp_path):\n    import sqlite3\n    db_path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(str(db_path))\n    conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT,\n        company TEXT, external_id TEXT, title TEXT, url TEXT, location TEXT,\n        department TEXT, employment_type TEXT, posted_at TEXT,\n        content_hash TEXT, first_seen TEXT, last_seen TEXT)\"\"\")\n    conn.commit(); conn.close()\n\n    with Store(db_path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n```\n\n---\n\n### 4. `notify.py` — untested error isolation + network side effects\n\n**Gaps:**\n- `dispatch()`'s core contract — **one notifier raising must not stop the others** — is completely untested. This is the highest-value test in the file since it's a resilience guarantee.\n- Every `notify_*` function's env-var gating: missing env var → no-op (no HTTP call attempted); env var present but `new`/`changed` both empty → still no-op (avoid spamming \"0 jobs\" pings).\n- `notify_sms`: `_sms_body` truncation at `limit=8` and the `\"+N more\"` line; ASCII-only comment — no test guards against a future emoji/bullet regression that would silently blow up SMS segment cost.\n- `notify_sms` calling `resp.raise_for_status()` — a 4xx from Twilio (bad creds) must propagate as an exception (caught by `dispatch`, not swallowed inside the notifier).\n- `notify_email`: SMTP auth only attempted when `SMTP_USER` is set — untested branch.\n- All HTTP-calling notifiers should be tested via `monkeypatch` on `httpx.post`/`smtplib.SMTP`, not real network calls.\n\n```python\n# tests/test_notify.py\nimport pytest\nfrom models import Job\nimport notify\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch, capsys):\n        calls = []\n        def boom(new, changed): raise RuntimeError(\"slack down\")\n        def ok(new, changed): calls.append(\"ok\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, ok])\n        notify.dispatch([make_job()], [])\n        assert calls == [\"ok\"]\n        assert \"notifier boom failed\" in capsys.readouterr().out\n\n\nclass TestSlack:\n    def test_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        called = []\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_slack([make_job()], [])\n        assert called == []\n\n    def test_noop_when_no_jobs_even_with_url(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.example/x\")\n        called = []\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_slack([], [])\n        assert called == []\n\n    def test_posts_when_configured_and_new_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.example/x\")\n        captured = {}\n        def fake_post(url, json, timeout):\n            captured[\"url\"], captured[\"json\"] = url, json\n        monkeypatch.setattr(notify.httpx, \"post\", fake_post)\n        notify.notify_slack([make_job(title=\"Engineer\")], [])\n        assert \"Engineer\" in captured[\"json\"][\"text\"]\n\n\nclass TestSms:\n    def test_body_truncates_at_limit_with_more_line(self):\n        jobs = [make_job(external_id=str(i), title=f\"Role {i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n        assert body.count(\"- Role\") == 8\n\n    def test_noop_unless_all_four_twilio_vars_set(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        called = []\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_sms([make_job()], [])\n        assert called == []\n\n    def test_raises_on_twilio_4xx_so_dispatch_can_catch_it(self, monkeypatch):\n        for k, v in dict(TWILIO_ACCOUNT_SID=\"s\", TWILIO_AUTH_TOKEN=\"t\",\n                          TWILIO_FROM=\"+1\", TWILIO_TO=\"+2\").items():\n            monkeypatch.setenv(k, v)\n        class FakeResp:\n            def raise_for_status(self): raise RuntimeError(\"401\")\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: FakeResp())\n        with pytest.raises(RuntimeError):\n            notify.notify_sms([make_job()], [])\n```\n\n---\n\n### 5. `pipeline.py` — orchestration, integration gap\n\n**Gaps:**\n- `load_config`: defaults applied when keys are missing (`sources`, `filters`, `db`, `concurrency`) — untested.\n- `run(..., dry_run=True)`: must NOT touch the `Store` at all (no dedup state written) and must return `{\"new\": 0, \"changed\": 0}` regardless of what `fetch_all`/`filter_jobs` return.\n- `run(..., dry_run=False)`: full path — fetch → filter → diff → dispatch — should be tested end-to-end with `fetch_all`, `dispatch`, and `Store` all mocked/patched, asserting the returned dict's counts line up.\n- No test exercises `run_sync` (the `asyncio.run` wrapper) at all.\n- This is the one place a genuine **integration test** belongs: real `Store(\":memory:\")` + fake fetcher + real `filter_jobs`, verifying a job flows end-to-end from raw fetch to dedup to notify.\n\n```python\n# tests/test_pipeline.py\nimport pytest\nimport yaml\nfrom pipeline import load_config, run\nfrom models import Job\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestLoadConfig:\n    def test_defaults_applied(self, tmp_path):\n        p = tmp_path / \"min.yaml\"\n        p.write_text(\"sources: []\\n\")\n        cfg = load_config(p)\n        assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\n    def test_explicit_values_preserved(self, tmp_path):\n        p = tmp_path / \"full.yaml\"\n        p.write_text(yaml.dump({\"sources\": [{\"a\": 1}], \"db\": \"x.db\", \"concurrency\": 3}))\n        cfg = load_config(p)\n        assert cfg[\"db\"] == \"x.db\" and cfg[\"concurrency\"] == 3\n\n\nclass TestRun:\n    @pytest.mark.asyncio\n    async def test_dry_run_does_not_touch_store(self, tmp_path, monkeypatch):\n        cfg_path = tmp_path / \"c.yaml\"\n        cfg_path.write_text(yaml.dump({\"sources\": [{\"type\": \"greenhouse\", \"company\": \"acme\"}],\n                                        \"db\": str(tmp_path / \"jobs.db\")}))\n        async def fake_fetch_all(sources, concurrency): return [make_job()]\n        monkeypatch.setattr(\"pipeline.fetch_all\", fake_fetch_all)\n        result = await run(cfg_path, dry_run=True)\n        assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n        assert not (tmp_path / \"jobs.db\").exists()\n\n    @pytest.mark.asyncio\n    async def test_full_run_persists_and_dispatches(self, tmp_path, monkeypatch):\n        cfg_path = tmp_path / \"c.yaml\"\n        db_path = tmp_path / \"jobs.db\"\n        cfg_path.write_text(yaml.dump({\"sources\": [{\"type\": \"greenhouse\", \"company\": \"acme\"}],\n                                        \"db\": str(db_path)}))\n        async def fake_fetch_all(sources, concurrency): return [make_job()]\n        dispatched = []\n        monkeypatch.setattr(\"pipeline.fetch_all\", fake_fetch_all)\n        monkeypatch.setattr(\"pipeline.dispatch\", lambda new, changed: dispatched.append((new, changed)))\n        result = await run(cfg_path, dry_run=False)\n        assert result[\"new\"] == 1\n        assert dispatched[0][0][0].title == \"Engineer\"\n        assert db_path.exists()\n```\n\n---\n\n### 6. `fetchers.py` — largest surface, largest gap (~50 functions, 0 tests)\n\nThis is the biggest risk in the repo: every ATS integration is a hand-written positional/defensive parser against an undocumented or semi-documented third-party JSON shape (per your own memory notes — Meta's `doc_id` rotates, ByteDance needs a strict schema + header, Google's parser scores the wrong job on a naive extraction, Apple embeds a hydration blob, D.E. Shaw/Two Sigma/Optiver scrape raw HTML with regex). These are exactly the functions most likely to silently break when a vendor changes their payload shape, and exactly the functions with zero regression protection today.\n\n**A. `_request` retry/backoff logic — untested, and it's shared by every fetcher**\n- Retries on `429/500/502/503/504`, does NOT retry on other 4xx (e.g. 404, 401).\n- Exhausts `retries` and raises `RuntimeError` wrapping the last exception.\n- Succeeds on the Nth attempt after N-1 failures.\n- Respects `httpx.TransportError` (connection drop) as retryable.\n\n```python\n# tests/test_fetchers.py\nimport pytest\nimport httpx\nfrom fetchers import _request, _get_json\n\ndef transport(responses):\n    \"\"\"responses: list of (status_code, json_body_or_None) consumed in order per URL call.\"\"\"\n    it = iter(responses)\n    def handler(request):\n        status, body = next(it)\n        return httpx.Response(status, json=body, request=request)\n    return httpx.MockTransport(handler)\n\nclass TestRequestRetry:\n    @pytest.mark.asyncio\n    async def test_succeeds_first_try(self):\n        client = httpx.AsyncClient(transport=transport([(200, {\"ok\": True})]))\n        r = await _request(client, \"https://x/\")\n        assert r.json() == {\"ok\": True}\n\n    @pytest.mark.asyncio\n    async def test_retries_on_503_then_succeeds(self, monkeypatch):\n        monkeypatch.setattr(\"fetchers.asyncio.sleep\", lambda s: None)  # skip real backoff\n        client = httpx.AsyncClient(transport=transport([(503, None), (200, {\"ok\": True})]))\n        r = await _request(client, \"https://x/\")\n        assert r.status_code == 200\n\n    @pytest.mark.asyncio\n    async def test_does_not_retry_on_404(self):\n        client = httpx.AsyncClient(transport=transport([(404, None)]))\n        with pytest.raises(RuntimeError):\n            await _request(client, \"https://x/\", retries=4)\n        # only one call consumed from the iterator — no retry attempted\n\n    @pytest.mark.asyncio\n    async def test_exhausts_retries_and_raises_runtime_error(self, monkeypatch):\n        monkeypatch.setattr(\"fetchers.asyncio.sleep\", lambda s: None)\n        client = httpx.AsyncClient(transport=transport([(500, None)] * 4))\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(client, \"https://x/\", retries=4)\n```\n\n**B. `parse_*` functions — every one needs: happy path, empty payload, and missing-optional-field cases.** Representative pattern (apply identically to `parse_greenhouse`, `parse_lever`, `parse_ashby`, `parse_smartrecruiters`, `parse_recruitee`, `parse_workable`, `parse_google`, `parse_deshaw`, `parse_twosigma`, `parse_optiver`, `parse_apple`, `parse_eightfold`, `parse_bytedance`, `parse_meta`, `parse_microsoft`, `parse_netflix`, `parse_amazon` — currently **none** have any coverage):\n\n```python\nclass TestParseGreenhouse:\n    def test_happy_path(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"Engineer\",\n                           \"absolute_url\": \"https://x/1\",\n                           \"location\": {\"name\": \"Remote\"},\n                           \"departments\": [{\"name\": \"Eng\"}],\n                           \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert len(jobs) == 1\n        assert jobs[0].title == \"Engineer\" and jobs[0].location == \"Remote\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_jobs_key(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\n    def test_missing_location_and_departments(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"Engineer\", \"absolute_url\": \"https://x/1\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].location == \"\" and jobs[0].department == \"\"\n```\n\nHighest-value specific cases per parser (beyond the generic template above), because these encode real edge cases already called out in your memory notes / the code's own comments:\n\n| Function | Specific gap to test |\n|---|---|\n| `_lever_salary` | `salaryRange` present with only `min` (no `max`) → falls through to `salaryDescriptionPlain`; both absent → `\"\"` |\n| `_ashby_salary` | `isListed: False` jobs are filtered out entirely — assert excluded |\n| `_extract_ds1` (Google) | Primary regex miss → fallback regex triggers; both miss → `[]`; malformed JSON in the blob → caught `JSONDecodeError` returns `[]` — **this is exactly the \"scores the wrong job\" trap your memory flags**, worth a dedicated regression test with a synthetic multi-block HTML fixture |\n| `_ds1_posted_at` | Missing indices 12/13/14 entirely (short array) → `\"\"`, not `IndexError` |\n| `_apple_hydration` | Malformed/missing hydration script tag → `None`, not a crash |\n| `_amazon_posted_at`, `_bd_location` | Same defensive-parsing pattern — malformed/missing nested fields must degrade gracefully, not raise |\n| `parse_bytedance` | Per your memory: strict-schema differences per site and no post dates — assert `posted_at` defaults sanely when absent |\n| `_normalize_ats` fields (`agent.py`, related family) | see agent.py section below |\n\n**C. `fetch_source` / `fetch_all` — orchestration, zero coverage**\n- `fetch_source` dispatches on `source[\"type\"]` to the right `parse_*`/fetch coroutine — untested for an **unknown type** (does it raise clearly, or silently return `[]`? worth locking down behavior either way).\n- `fetch_all` with `concurrency` — semaphore-bounded gather; one source raising must not abort the others (mirrors the `notify.dispatch` resilience contract — check if `fetch_all` actually has this guarantee or not, since that's not visible from the excerpt read so far and is worth verifying directly in the code before assuming).\n\n```python\nclass TestFetchAll:\n    @pytest.mark.asyncio\n    async def test_one_source_failing_does_not_abort_others(self, monkeypatch):\n        # verify current behavior first — this may reveal a real gap:\n        # does fetch_all swallow per-source exceptions like notify.dispatch does,\n        # or does one bad source currently kill the whole run?\n        ...\n\n    @pytest.mark.asyncio\n    async def test_unknown_source_type_behavior(self):\n        from fetchers import fetch_source\n        import httpx\n        client = httpx.AsyncClient()\n        # document whether this raises KeyError/ValueError or returns []\n        with pytest.raises(Exception):\n            await fetch_source(client, {\"type\": \"not-a-real-ats\", \"company\": \"x\"})\n```\n\nI flagged that last one as worth checking directly rather than assumed — I have not read `fetch_source`/`fetch_all`'s bodies (lines 996–1030+) in this pass, so before writing that test the actual current behavior needs confirming.\n\n---\n\n### 7. `agent.py` — CLI helpers, zero coverage, several sharp edges\n\n**`cmd_db_new`** — the most logic-dense function in the file, no tests:\n- First run (no marker) uses `since_days` window; subsequent runs use stored marker.\n- `--posted-days` + undated job → **kept** unless `--dated-only`; counts (`dropped_old`, `undated_kept`, `undated_dropped`) must be accurate.\n- Group-boundary truncation: the comment explains truncation only happens at `first_seen` boundaries so a batch isn't split — needs a test with two jobs sharing one `first_seen` timestamp and a `--limit` that would otherwise split them, asserting both are kept together (or both dropped together).\n- `watermark` in output equals the *last fully-included* group's timestamp, not `since`, when truncated.\n\n**`cmd_db_mark`**:\n- `--now` sets marker to current time.\n- Valid ISO watermark string is accepted.\n- Invalid watermark → exit code `2`, message to stderr, and **marker not written**.\n- Neither `watermark` nor `--now` passed → exit code `2`.\n\n**`_normalize_ats`**: pure function, easy high-value test — the whole point is ASCII-normalizing ATS-hostile characters *only in text nodes*, never inside tags/`<style>`/`<script>`.\n- Em-dash/en-dash/smart quotes/ellipsis/zero-width/nbsp/arrows/middot/bullet/euro/pound all replaced correctly, with counts returned.\n- Characters **inside an HTML tag attribute** (e.g. `<div data-foo=\"—\">`) must NOT be touched — this is the entire reason the function splits on `<[^>]*>`.\n- Characters inside `<style>`/`<script>` blocks must NOT be touched.\n- `counts` dict only includes labels that actually fired (no zero-entries).\n\n**`cmd_pdf_render`**: needs a fake/mocked `subprocess.run` and `_chrome_bin` (don't shell out to real Chrome in CI):\n- Missing input file → exit code `2`.\n- Successful render (`%PDF` magic bytes present) → exit `0`, temp `.ats.html` file cleaned up (even on failure — it's in a `finally`).\n- Render failure (output doesn't start with `%PDF`) → exit `1`, stderr surfaced.\n- `--format a4` vs default `letter` reflected in the injected `@page` CSS.\n- Existing `<head>` gets CSS injected before `</head>`; no `<head>` at all falls back to prepending.\n\n```python\n# tests/test_agent.py\nimport json\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nfrom agent import cmd_db_new, cmd_db_mark, cmd_report_num, _normalize_ats\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef cfg(tmp_path, monkeypatch):\n    db = tmp_path / \"jobs.db\"\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(f\"sources: []\\ndb: {db}\\n\")\n    return str(cfg_path)\n\ndef seed(cfg, jobs):\n    with Store  :  # placeholder — actually load db path from cfg via pipeline.load_config\n        pass\n\n\nclass TestNormalizeAts:\n    def test_em_dash_replaced_in_text(self):\n        html, counts = _normalize_ats(\"<p>a\\u2014b</p>\")\n        assert \"a-b\" in html and counts[\"em-dash\"] == 1\n\n    def test_tag_attributes_untouched(self):\n        html, counts = _normalize_ats('<div data-x=\"\\u2014\"></div>')\n        assert \"\\u2014\" in html\n        assert \"em-dash\" not in counts\n\n    def test_style_block_untouched(self):\n        html, counts = _normalize_ats(\"<style>.a::before{content:'\\u2014'}</style>\")\n        assert \"\\u2014\" in html and counts == {}\n\n    def test_script_block_untouched(self):\n        html, counts = _normalize_ats(\"<script>var x='\\u2014';</script>\")\n        assert \"\\u2014\" in html and counts == {}\n\n    def test_multiple_rules_counted_independently(self):\n        html, counts = _normalize_ats(\"<p>\\u2014 \\u2018hi\\u2019 \\u2026</p>\")\n        assert counts[\"em-dash\"] == 1\n        assert counts[\"smart-single-quote\"] == 2\n        assert counts[\"ellipsis\"] == 1\n\n    def test_no_changes_needed_returns_empty_counts(self):\n        html, counts = _normalize_ats(\"<p>plain ascii text</p>\")\n        assert counts == {}\n\n\nclass TestDbMark:\n    def test_invalid_watermark_exits_2_and_does_not_write(self, cfg, capsys):\n        rc = cmd_db_mark([\"not-a-date\", \"-c\", cfg])\n        assert rc == 2\n        assert \"not an ISO timestamp\" in capsys.readouterr().err\n\n    def test_neither_watermark_nor_now_exits_2(self, cfg, capsys):\n        rc = cmd_db_mark([\"-c\", cfg])\n        assert rc == 2\n\n    def test_now_flag_sets_current_marker(self, cfg):\n        from pipeline import load_config\n        rc = cmd_db_mark([\"--now\", \"-c\", cfg])\n        assert rc == 0\n        with Store(load_config(cfg)[\"db\"]) as s:\n            assert s.get_meta(\"last_scan\") is not None\n\n    def test_valid_iso_watermark_persisted(self, cfg):\n        from pipeline import load_config\n        cmd_db_mark([\"2024-01-01T00:00:00+00:00\", \"-c\", cfg])\n        with Store(load_config(cfg)[\"db\"]) as s:\n            assert s.get_meta(\"last_scan\") == \"2024-01-01T00:00:00+00:00\"\n\n\nclass TestReportNum:\n    def test_first_call_prints_001(self, cfg, capsys):\n        cmd_report_num([\"-c\", cfg])\n        assert capsys.readouterr().out.strip() == \"001\"\n\n    def test_increments_across_calls(self, cfg, capsys):\n        cmd_report_num([\"-c\", cfg]); capsys.readouterr()\n        cmd_report_num([\"-c\", cfg])\n        assert capsys.readouterr().out.strip() == \"002\"\n```\n\n*(For `cmd_db_new`, the fixture needs a helper that seeds `Store` with jobs at controlled `first_seen` timestamps — worth writing a small `seed_jobs(db_path, rows)` test helper that inserts directly via `Store._insert`, since `Store.diff` stamp