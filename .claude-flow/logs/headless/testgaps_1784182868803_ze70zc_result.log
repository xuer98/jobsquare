        "title": "tests/test_notify.py",
        "content": "import pytest\nfrom models import Job\nimport notify\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch, capsys):\n        calls = []\n        def boom(new, changed): raise RuntimeError(\"slack down\")\n        def ok(new, changed): calls.append(\"ok\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, ok])\n        notify.dispatch([make_job()], [])\n        assert calls == [\"ok\"]\n        assert \"notifier boom failed\" in capsys.readouterr().out\n\n\nclass TestSlack:\n    def test_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        called = []\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_slack([make_job()], [])\n        assert called == []\n\n    def test_noop_when_no_jobs_even_with_url(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.example/x\")\n        called = []\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_slack([], [])\n        assert called == []\n\n    def test_posts_when_configured_and_new_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.example/x\")\n        captured = {}\n        def fake_post(url, json, timeout):\n            captured[\"url\"], captured[\"json\"] = url, json\n        monkeypatch.setattr(notify.httpx, \"post\", fake_post)\n        notify.notify_slack([make_job(title=\"Engineer\")], [])\n        assert \"Engineer\" in captured[\"json\"][\"text\"]\n\n\nclass TestSms:\n    def test_body_truncates_at_limit_with_more_line(self):\n        jobs = [make_job(external_id=str(i), title=f\"Role {i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n        assert body.count(\"- Role\") == 8\n\n    def test_noop_unless_all_four_twilio_vars_set(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        called = []\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_sms([make_job()], [])\n        assert called == []\n\n    def test_raises_on_twilio_4xx_so_dispatch_can_catch_it(self, monkeypatch):\n        for k, v in dict(TWILIO_ACCOUNT_SID=\"s\", TWILIO_AUTH_TOKEN=\"t\",\n                          TWILIO_FROM=\"+1\", TWILIO_TO=\"+2\").items():\n            monkeypatch.setenv(k, v)\n        class FakeResp:\n            def raise_for_status(self): raise RuntimeError(\"401\")\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: FakeResp())\n        with pytest.raises(RuntimeError):\n            notify.notify_sms([make_job()], [])\n```\n\n---\n\n",
