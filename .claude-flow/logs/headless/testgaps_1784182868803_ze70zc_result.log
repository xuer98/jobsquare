        "language": "python",
        "code": "# tests/test_models.py\nimport pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_and_none_return_none(self):\n        assert parse_posted_at(\"\") is None\n        assert parse_posted_at(None) is None\n\n    def test_epoch_milliseconds(self):\n        dt = parse_posted_at(\"1643241332430\")  # Lever-style ms epoch\n        assert dt.tzinfo == timezone.utc\n        assert dt.year == 2022\n\n    def test_epoch_seconds(self):\n        dt = parse_posted_at(\"1643241332\")\n        assert dt.year == 2022\n\n    def test_epoch_boundary_1e12(self):\n        # exactly 1e12 must be treated as milliseconds, not seconds\n        dt = parse_posted_at(\"1000000000000\")\n        assert dt.year < 2000  # would be ~33658 if misread as seconds... assert it's NOT that\n\n    def test_iso8601_with_z_suffix(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso8601_naive_defaults_to_utc(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso8601_with_explicit_offset_preserved(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00+05:00\")\n        assert dt.utcoffset().total_seconds() == 5 * 3600\n\n    def test_unparseable_prose_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_negative_epoch(self):\n        # ensure lstrip(\"-\").isdigit() branch doesn't crash on pre-1970 dates\n        dt = parse_posted_at(\"-100\")\n        assert dt is not None\n\n\nclass TestJob:\n    def _job(self, **kw):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"Engineer\", url=\"https://x/1\")\n        base.update(kw)\n        return Job(**base)\n\n    def test_key_format(self):\n        assert self._job().key == \"greenhouse:acme:1\"\n\n    def test_content_hash_stable_for_identical_fields(self):\n        assert self._job().content_hash == self._job().content_hash\n\n    def test_content_hash_changes_on_title(self):\n        assert self._job().content_hash != self._job(title=\"Sr Engineer\").content_hash\n\n    def test_content_hash_ignores_posted_at_and_raw(self):\n        a = self._job(posted_at=\"2024-01-01\", raw={\"a\": 1})\n        b = self._job(posted_at=\"2024-06-01\", raw={\"a\": 2})\n        assert a.content_hash == b.content_hash\n\n    def test_posted_dt_none_when_unparseable(self):\n        assert self._job(posted_at=\"garbage\").posted_dt is None\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self):\n        row = self._job(raw={\"secret\": True}).to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == \"greenhouse:acme:1\"\n        assert \"content_hash\" in row"
