        "title": "tests/test_store.py",
        "content": "import pytest\nfrom models import Job\nfrom store import Store\n\n@pytest.fixture\ndef store():\n    with Store(\":memory:\") as s:\n        yield s\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestDiff:\n    def test_new_job_is_inserted_and_returned(self, store):\n        new, changed = store.diff([make_job()])\n        assert len(new) == 1 and changed == []\n        assert store.count() == 1\n\n    def test_unchanged_job_not_returned_second_run(self, store):\n        store.diff([make_job()])\n        new, changed = store.diff([make_job()])\n        assert new == [] and changed == []\n\n    def test_changed_job_returned_in_changed(self, store):\n        store.diff([make_job(title=\"Engineer\")])\n        new, changed = store.diff([make_job(title=\"Senior Engineer\")])\n        assert new == []\n        assert len(changed) == 1\n\n    def test_same_key_different_source_company_are_distinct_rows(self, store):\n        store.diff([make_job(company=\"acme\"), make_job(company=\"beta\")])\n        assert store.count() == 2\n\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta(self, store):\n        store.set_meta(\"k\", \"v1\")\n        assert store.get_meta(\"k\") == \"v1\"\n\n    def test_set_meta_overwrites(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n    def test_next_seq_starts_at_one_and_increments(self, store):\n        assert store.next_seq(\"report_seq\") == 1\n        assert store.next_seq(\"report_seq\") == 2\n\n\nclass TestAddedSince:\n    def test_strictly_after_ts_excludes_boundary(self, store):\n        store.diff([make_job()])\n        row = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()\n        assert store.added_since(row[\"first_seen\"]) == []  # not > ts\n\n    def test_ordering_by_first_seen_company_title(self, store):\n        store.diff([make_job(company=\"z\", external_id=\"1\"),\n                     make_job(company=\"a\", external_id=\"2\")])\n        rows = store.added_since(\"1970-01-01T00:00:00+00:00\")\n        assert [r[\"company\"] for r in rows] == [\"a\", \"z\"]\n\n\ndef test_migration_adds_salary_range_to_legacy_schema(tmp_path):\n    import sqlite3\n    db_path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(str(db_path))\n    conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT,\n        company TEXT, external_id TEXT, title TEXT, url TEXT, location TEXT,\n        department TEXT, employment_type TEXT, posted_at TEXT,\n        content_hash TEXT, first_seen TEXT, last_seen TEXT)\"\"\")\n    conn.commit(); conn.close()\n\n    with Store(db_path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n```\n\n---\n\n",
