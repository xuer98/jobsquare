l\": 1}))\n    async with httpx.AsyncClient() as c:\n        jobs = await fetch_workday(c, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\", \"page_size\": 20})\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_meta_strips_xssi_prefix_and_parses(monkeypatch):\n    respx.get(\"https://www.metacareers.com/jobs\").mock(\n        return_value=httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok\"}] \"__spin_r\":1'))\n    respx.post(\"https://www.metacareers.com/graphql\").mock(\n        return_value=httpx.Response(200, text='for (;;);{\"data\":{\"job_search_with_featured_jobs_v2\":'\n                                               '{\"all_jobs\":[{\"id\":\"1\",\"title\":\"SWE\"}]}}}'))\n    async with httpx.AsyncClient() as c:\n        jobs = await fetch_meta(c, {\"company\": \"meta\"})\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_meta_raises_on_graphql_errors_payload():\n    respx.get(\"https://www.metacareers.com/jobs\").mock(return_value=httpx.Response(200, text=\"\"))\n    respx.post(\"https://www.metacareers.com/graphql\").mock(\n        return_value=httpx.Response(200, text='{\"errors\":[{\"message\":\"doc_id not found\"}]}'))\n    async with httpx.AsyncClient() as c:\n        with pytest.raises(RuntimeError, match=\"doc_id not found\"):\n            await fetch_meta(c, {\"company\": \"meta\"})  # regression guard for the doc_id-rotation failure mode\n```\n\n#### 4d. `fetch_source` / `fetch_all` — orchestration\n\n**Gaps:** unknown `ats` raises `ValueError` listing known ATSes; `fetch_all` isolates a single source's exception (prints, returns `[]` for that source, doesn't abort the gather); concurrency semaphore actually bounds in-flight requests; client is closed only when `fetch_all` created it (not when caller passed one in).\n\n```python\n@pytest.mark.asyncio\nasync def test_fetch_source_unknown_ats_raises():\n    from fetchers import fetch_source\n    with pytest.raises(ValueError, match=\"unknown ATS\"):\n        await fetch_source(None, {\"ats\": \"bogus\"})\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_all_isolates_one_source_failure():\n    from fetchers import fetch_all\n    respx.get(\"https://boards-api.greenhouse.io/v1/boards/good/jobs\").mock(\n        return_value=httpx.Response(200, json={\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\"}]}))\n    respx.get(\"https://boards-api.greenhouse.io/v1/boards/bad/jobs\").mock(\n        return_value=httpx.Response(500))\n    jobs = await fetch_all([\n        {\"ats\": \"greenhouse\", \"company\": \"good\"},\n        {\"ats\": \"greenhouse\", \"company\": \"bad\"},\n    ])\n    assert len(jobs) == 1  # bad source failed silently, good source's results still returned\n\n@pytest.mark.asyncio\nasync def test_fetch_all_does_not_close_caller_provided_client():\n    ...\n```\n\n---\n\n### 5. `notify.py` — silent-failure risk (each notifier is env-gated and swallow-on-error)\n\n**Gaps:** every notifier's \"not configured → no-op, no crash\" branch (currently untested for all 5), `dispatch`'s exception isolation (one notifier raising must not block the rest — this is the whole point of the try/except in `dispatch` and has zero coverage), `_sms_body` truncation at `limit` and the \"+N more\" line, ASCII-only guarantee (the comment explicitly calls out GSM segment cost — no test enforces it), `notify_email`'s optional SMTP auth branch.\n\n```python\n# tests/test_notify.py\nimport pytest\nfrom unittest.mock import patch, MagicMock\nfrom notify import (notify_slack, notify_webhook, notify_sms, notify_email,\n                     notify_console, dispatch, _sms_body)\nfrom models import Job\n\ndef job(**kw):\n    return Job(source=\"s\", company=\"acme\", external_id=\"1\", title=\"SWE\", url=\"u\", **kw)\n\nclass TestEnvGating:\n    def test_slack_noop_when_webhook_url_unset(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with patch(\"notify.httpx.post\") as post:\n            notify_slack([job()], [])\n        post.assert_not_called()\n\n    def test_sms_noop_unless_all_four_twilio_vars_set(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        with patch(\"notify.httpx.post\") as post:\n            notify_sms([job()], [])\n        post.assert_not_called()\n\n    def test_sms_noop_when_no_new_or_changed_even_if_configured(self, monkeypatch):\n        for k, v in [(\"TWILIO_ACCOUNT_SID\", \"sid\"), (\"TWILIO_AUTH_TOKEN\", \"tok\"),\n                     (\"TWILIO_FROM\", \"+1\"), (\"TWILIO_TO\", \"+2\")]:\n            monkeypatch.setenv(k, v)\n        with patch(\"notify.httpx.post\") as post:\n            notify_sms([], [])\n        post.assert_not_called()\n\n\nclass TestSmsBody:\n    def test_truncates_at_limit_and_appends_more_count(self):\n        jobs = [job(external_id=str(i), title=f\"Role{i}\") for i in range(10)]\n        body = _sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n        assert body.count(\"- Role\") == 8\n\n    def test_body_is_ascii_only(self):\n        jobs = [job(title=\"Café Engineer\")]  # non-ascii input should still be handled deliberately\n        body = _sms_body(jobs, [])\n        # documents current behavior — does it strip/replace non-ascii, or pass through?\n        ...\n\n\nclass TestDispatch:\n    def test_one_notifier_raising_does_not_block_others(self, monkeypatch, capsys):\n        broken = MagicMock(side_effect=RuntimeError(\"boom\"), __name__=\"broken\")\n        ok = MagicMock(__name__=\"ok\")\n        monkeypatch.setattr(\"notify.NOTIFIERS\", [broken, ok])\n        dispatch([job()], [])\n        ok.assert_called_once()\n        assert \"broken failed\" in capsys.readouterr().out\n\n    def test_sms_http_error_is_caught_by_dispatch(self, monkeypatch):\n        # notify_sms calls resp.raise_for_status() — confirm that a 4xx doesn't propagate past dispatch\n        ...\n```\n\n---\n\n### 6. `pipeline.py` — integration glue, currently the single biggest blind spot\n\n**Gaps:** `load_config` default-filling for every missing key (`sources`, `filters`, `db`, `concurrency`), `dry_run=True` never touches the `Store` (i.e., `Store()` must not even be constructed — verify via mock/spy, since a bug here could accidentally persist state during a \"just show me\" run), `dry_run=False` full happy path (fetch → filter → diff → dispatch → count) with everything mocked, an exception inside `fetch_all` for one source doesn't abort the run (already covered at fetchers level, but the pipeline's aggregate print/counts should be verified end-to-end too).\n\n```python\n# tests/test_pipeline.py\nimport pytest\nfrom unittest.mock import patch, AsyncMock, MagicMock\nfrom pipeline import load_config, run\n\ndef test_load_config_fills_defaults(tmp_path):\n    p = tmp_path / \"cfg.yaml\"\n    p.write_text(\"sources: []\\n\")\n    cfg = load_config(p)\n    assert cfg[\"filters\"] == {}\n    assert cfg[\"db\"] == \"jobs.db\"\n    assert cfg[\"concurrency\"] == 8\n\n@pytest.mark.asyncio\nasync def test_dry_run_never_touches_store(tmp_path):\n    p = tmp_path / \"cfg.yaml\"\n    p.write_text(\"sources: []\\n\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n         patch(\"pipeline.Store\") as StoreCls:\n        result = await run(p, dry_run=True)\n    StoreCls.assert_not_called()\n    assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n\n@pytest.mark.asyncio\nasync def test_full_run_calls_diff_and_dispatch(tmp_path):\n    p = tmp_path / \"cfg.yaml\"\n    p.write_text(\"sources: []\\n\")\n    fake_store = MagicMock()\n    fake_store.diff.return_value = ([], [])\n    fake_store.count.return_value = 0\n    fake_store.__enter__.return_value = fake_store\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n         patch(\"pipeline.Store\", return_value=fake_store), \\\n         patch(\"pipeline.dispatch\") as dispatch_mock:\n        await run(p, dry_run=False)\n    dispatch_mock.assert_called_once()\n```\n\n---\n\n### 7. `agent.py` — deterministic helpers are pure-ish and cheap to test; the launcher is integration-shaped\n\n**Gaps (deterministic helpers, high value):**\n- `cmd_db_new`: first-run window (`marker is None` → `since_days` fallback), truncation only at `first_seen` group boundary (the \"don't split a group\" logic — currently exercised by nothing, and is subtle enough to regress silently), `--limit` boundary exactly at a group size, empty result set.\n- `cmd_db_mark`: `--now` path, valid watermark path, invalid ISO string returns exit code 2 and prints to stderr, neither `watermark` nor `--now` given returns 2.\n- `_normalize_ats`: each of the 14 char-class replacements, `<style>`/`<script>` blocks are *not* touched, tag attribute text is *not* touched (only text nodes between tags), counts dict aggregation.\n- `_chrome_bin`: `CHROME_PATH` env override when the path exists vs. doesn't exist, `shutil.which` fallback, hardcoded `_CHROME_APPS` fallback, `sys.exit` when nothing found.\n- `cmd_pdf_render`: input file missing → exit 2, output produced but doesn't start with `%PDF` → exit 1 with stderr tail, default output path derivation (`.pdf` suffix swap).\n- `main()`: routing for `db-new`/`db-mark`/`pdf-render`/`-h`, `-i`/`--interactive` flag detection triggering interactive mode, mode-words-stop-at-first-flag splitting logic.\n\n```python\n# tests/test_agent.py\nimport json, pytest\nfrom datetime import datetime, timedelta, timezone\nfrom unittest.mock import patch\nfrom agent import cmd_db_new, cmd_db_mark, _normalize_ats, _chrome_bin\nfrom store import Store\n\n@pytest.fixture\ndef cfg_and_store(tmp_path, monkeypatch):\n    db = tmp_path / \"jobs.db\"\n    cfg = tmp_path / \"sources.yaml\"\n    cfg.write_text(f\"db: {db}\\n\")\n    monkeypatch.chdir(tmp_path)\n    return cfg, db\n\nclass TestDbNew:\n    def test_first_run_uses_since_days_window(self, cfg_and_store, capsys):\n        cfg, _ = cfg_and_store\n        cmd_db_new([\"-c\", str(cfg), \"--since-days\", \"3\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n\n    def test_truncation_stops_at_group_boundary_not_mid_group(self, cfg_and_store, capsys):\n        # insert two first_seen groups of size 3 each via direct store manipulation,\n        # set --limit 4 (between the groups), assert count == 3, truncated == True\n        ...\n\n    def test_never_advances_marker(self, cfg_and_store):\n        cfg, db = cfg_and_store\n        with Store(db) as s:\n            s.set_meta(\"last_scan\", \"2024-01-01T00:00:00+00:00\")\n        cmd_db_new([\"-c\", str(cfg)])\n        with Store(db) as s:\n            assert s.get_meta(\"last_scan\") == \"2024-01-01T00:00:00+00:00\"\n\n\nclass TestDbMark:\n    def test_invalid_iso_returns_2(self, cfg_and_store, capsys):\n        cfg, _ = cfg_and_store\n        rc = cmd_db_mark([\"not-a-timestamp\", \"-c\", str(cfg)])\n        assert rc == 2\n\n    def test_neither_arg_returns_2(self, cfg_and_store):\n        cfg, _ = cfg_and_store\n        assert cmd_db_mark([\"-c\", str(cfg)]) == 2\n\n    def test_now_flag_sets_current_time(self, cfg_and_store):\n        cfg, db = cfg_and_store\n        cmd_db_mark([\"--now\", \"-c\", str(cfg)])\n        with Store(db) as s:\n            assert s.get_meta(\"last_scan\") is not None\n\n\nclass TestNormalizeAts:\n    def test_smart_quotes_replaced_in_text_not_in_tags(self):\n        html = '<p title=\"\\u201Ckeep\\u201D\">\\u201Chello\\u201D</p>'\n        out, counts = _normalize_ats(html)\n        assert out == '<p title=\"\\u201Ckeep\\u201D\">\"hello\"</p>'  # only text node changed\n        assert counts[\"smart-double-quote\"] == 2\n\n    def test_style_block_untouched(self):\n        html = '<style>.x::before{content:\"\\u2014\"}</style><p>\\u2014</p>'\n        out, counts = _normalize_ats(html)\n        assert '\\u2014' in out.split(\"</style>\")[0]  # style block preserved\n        assert counts[\"em-dash\"] == 1  # only the <p> one counted\n\n\nclass TestChromeBin:\n    def test_chrome_path_env_used_when_exists(self, monkeypatch, tmp_path):\n        fake = tmp_path / \"chrome\"\n        fake.touch()\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert _chrome_bin() == str(fake)\n\n    def test_exits_when_nothing_found(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        monkeypatch.setattr(\"shutil.which\", lambda name: None)\n        monkeypatch.setattr(\"agent.Path.exists\", lambda self: False)\n        with pytest.raises(SystemExit):\n            _chrome_bin()\n```\n\n---\n\n### 8. `cli.py` — thin, but the arg-parsing contract should still be pinned\n\n```python\n# tests/test_cli.py\nfrom unittest.mock import patch\nfrom cli import main\n\ndef test_dry_run_flag_forwarded():\n    with patch(\"cli.run_sync\") as run_sync, patch(\"sys.argv\", [\"cli.py\", \"--dry-run\"]):\n        main()\n    run_sync.assert_called_once_with(\"sources.yaml\", dry_run=True)\n\ndef test_config_flag_forwarded():\n    with patch(\"cli.run_sync\") as run_sync, patch(\"sys.argv\", [\"cli.py\", \"-c\", \"other.yaml\"]):\n        main()\n    run_sync.assert_called_once_with(\"other.yaml\", dry_run=False)\n```\n\n---\n\n### Priority ranking (where to start)\n\n| Priority | Module | Why |\n|---|---|---|\n| 1 | `models.py` (`parse_posted_at`, `content_hash`) | Silent dedup corruption is the worst failure mode — no crash, no alert |\n| 2 | `store.py` (`diff`) | Same — this is where dedup state actually lives |\n| 3 | `filters.py` | Silent job loss/leak, subtle regex/boundary bugs |\n| 4 | `fetchers.py` retry logic + `fetch_meta` doc_id failure | Reliability; the module's own comments flag Meta as fragile |\n| 5 | `notify.py` `dispatch` isolation | One bad notifier config shouldn't blind you to all channels |\n| 6 | Remaining parsers, `agent.py` helpers, `pipeline.py`, `cli.py` | Lower risk / more mechanical |\n\nWant me to actually scaffold `tests/` with the pytest config and start filling in module 1–3 (models/store/filters) for real, since those are the highest-value and cheapest to get passing without network mocking?\n",
