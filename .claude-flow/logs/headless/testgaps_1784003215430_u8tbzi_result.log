        "language": "python",
        "code": "# tests/test_models.py\nimport pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_and_none_return_none(self):\n        assert parse_posted_at(\"\") is None\n\n    @pytest.mark.parametrize(\"value,expected_year\", [\n        (\"1643241332430\", 2022),   # ms epoch (13 digits)\n        (\"1643241332\", 2022),      # sec epoch\n    ])\n    def test_epoch_variants(self, value, expected_year):\n        dt = parse_posted_at(value)\n        assert dt.year == expected_year\n        assert dt.tzinfo == timezone.utc\n\n    def test_epoch_boundary_exactly_1e12_treated_as_ms(self):\n        dt = parse_posted_at(\"1000000000000\")\n        assert dt is not None  # documents ms/sec cutover behavior\n\n    def test_iso_with_trailing_z(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_naive_gets_utc_attached(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_unparseable_prose_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None  # Workday format\n\n    def test_garbage_string_returns_none(self):\n        assert parse_posted_at(\"not-a-date\") is None\n\n\nclass TestJobIdentity:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"Engineer\", url=\"https://x/1\")\n        return Job(**{**base, **overrides})\n\n    def test_key_is_stable_and_composed(self):\n        j = self._job()\n        assert j.key == \"greenhouse:acme:1\"\n\n    def test_content_hash_stable_for_identical_input(self):\n        assert self._job().content_hash == self._job().content_hash\n\n    @pytest.mark.parametrize(\"field,new_value\", [\n        (\"title\", \"Senior Engineer\"), (\"location\", \"Remote\"),\n        (\"url\", \"https://x/2\"), (\"department\", \"Eng\"),\n    ])\n    def test_content_hash_changes_on_material_field(self, field, new_value):\n        a = self._job()\n        b = self._job(**{field: new_value})\n        assert a.content_hash != b.content_hash\n\n    @pytest.mark.parametrize(\"field,new_value\", [\n        (\"posted_at\", \"2024-01-01\"), (\"salary_range\", \"$100k\"),\n    ])\n    def test_content_hash_ignores_non_material_field(self, field, new_value):\n        a = self._job()\n        b = self._job(**{field: new_value})\n        assert a.content_hash == b.content_hash  # documents intentional exclusion\n\n    def test_to_row_drops_raw_and_adds_key_and_hash(self):\n        j = self._job(raw={\"secret\": 1})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash"
