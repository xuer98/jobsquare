    def test_smart_quotes_replaced_in_text_not_in_tags(self):\n        html = '<p title=\"\\u201Ckeep\\u201D\">\\u201Chello\\u201D</p>'\n        out, counts = _normalize_ats(html)\n        assert out == '<p title=\"\\u201Ckeep\\u201D\">\"hello\"</p>'  # only text node changed\n        assert counts[\"smart-double-quote\"] == 2\n\n    def test_style_block_untouched(self):\n        html = '<style>.x::before{content:\"\\u2014\"}</style><p>\\u2014</p>'\n        out, counts = _normalize_ats(html)\n        assert '\\u2014' in out.split(\"</style>\")[0]  # style block preserved\n        assert counts[\"em-dash\"] == 1  # only the <p> one counted\n\n\nclass TestChromeBin:\n    def test_chrome_path_env_used_when_exists(self, monkeypatch, tmp_path):\n        fake = tmp_path / \"chrome\"\n        fake.touch()\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert _chrome_bin() == str(fake)\n\n    def test_exits_when_nothing_found(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        monkeypatch.setattr(\"shutil.which\", lambda name: None)\n        monkeypatch.setattr(\"agent.Path.exists\", lambda self: False)\n        with pytest.raises(SystemExit):\n            _chrome_bin()"
