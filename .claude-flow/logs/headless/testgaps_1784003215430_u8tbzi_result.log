        "title": "tests/test_parsers.py",
        "content": "import pytest\nfrom fetchers import (parse_greenhouse, parse_lever, parse_ashby, parse_smartrecruiters,\n                       parse_recruitee, parse_workable, parse_google, parse_deshaw,\n                       parse_twosigma, parse_optiver, parse_meta, parse_microsoft,\n                       parse_netflix, parse_amazon, _lever_salary, _ashby_salary,\n                       _amazon_posted_at, _extract_ds1, _ds1_posted_at)\n\nclass TestParseGreenhouse:\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\n    def test_maps_fields_correctly(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\",\n                           \"location\": {\"name\": \"NYC\"},\n                           \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Platform\"}],\n                           \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        [j] = parse_greenhouse(\"acme\", data)\n        assert j.department == \"Eng, Platform\"\n        assert j.location == \"NYC\"\n\n    def test_missing_location_dict_does_not_crash(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\"}]}\n        [j] = parse_greenhouse(\"acme\", data)\n        assert j.location == \"\"\n\n    def test_missing_id_raises_keyerror(self):\n        # documents current (arguably fragile) behavior: one bad item kills the batch\n        with pytest.raises(KeyError):\n            parse_greenhouse(\"acme\", {\"jobs\": [{\"title\": \"SWE\"}]})\n\n\nclass TestLeverSalary:\n    def test_min_max_present_formats_range(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_missing_range_falls_back_to_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty_string(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestAmazonPostedAt:\n    def test_valid_date_string(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_string_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_unknown_month_name_returns_empty(self):\n        assert _amazon_posted_at(\"Frobtember 1, 2024\") == \"\"\n\n\nclass TestGoogleDS1Extraction:\n    def test_extracts_embedded_json_blob(self):\n        html = \"AF_initDataCallback({key: 'ds:1', hash: 'x', data:[[{\\\"a\\\":1}]] , sideChannel:{}});\"\n        # craft against actual regex shape used in _extract_ds1\n        ...\n\n    def test_missing_blob_returns_empty_list(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_malformed_json_returns_empty_list_not_raise(self):\n        html = \"key: 'ds:1', data:[not valid json], sideChannel\"\n        assert _extract_ds1(html) == []\n\n\nclass TestDeshawParsing:\n    def test_dedupes_repeated_job_ids(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">SWE</span>'\n                '<span class=\"location\">NYC</span></div>' * 2)\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert len(jobs) == 1\n\n    def test_html_entities_unescaped_in_title(self):\n        page = '<div data-job-id=\"1\"><span class=\"job-display-name\">R&amp;D Engineer</span></div>'\n        [j] = parse_deshaw(\"deshaw\", page)\n        assert j.title == \"R&D Engineer\"\n```\n*(Repeat the pattern above for `parse_ashby`, `parse_smartrecruiters`, `parse_recruitee`, `parse_workable`, `parse_twosigma`, `parse_optiver`, `parse_meta`, `parse_microsoft`, `parse_netflix` — each has at least one \"alternate/fallback field\" branch, e.g. `workable`'s dict-vs-flat location, `netflix`'s `t_create` vs `t_update` fallback, that's currently exercised by zero test.)*\n\n",
