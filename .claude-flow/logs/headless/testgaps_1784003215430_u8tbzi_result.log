  "output": "## Test coverage audit — jobsquare\n\n**Baseline: zero tests exist.** No `tests/` directory, no pytest config, no test-only deps in `requirements.txt`. Every function below is therefore \"untested\" in the literal sense — I've prioritized by blast radius (silent data corruption > crash > cosmetic) rather than listing all ~60 functions with equal weight.\n\n### 0. Missing infrastructure (do this first)\n\n```\n# requirements-dev.txt\npytest>=8.0\npytest-asyncio>=0.24\nrespx>=0.21        # mocks httpx at the transport layer — matches this codebase's injectable-client design\nfreezegun>=1.5      # for _now()/_iso_now()/posted_at parsing determinism\n```\n\n```ini\n# pytest.ini\n[pytest]\nasyncio_mode = auto\n```\n\n---\n\n### 1. `models.py` — highest priority (dedup correctness depends on this)\n\n`parse_posted_at`, `Job.key`, `Job.content_hash`, `Job.to_row` are load-bearing for `Store.diff`. A bug here silently breaks dedup (duplicate notifications or lost postings) rather than crashing — worth the most test weight per line.\n\n**Gaps:**\n- `parse_posted_at`: empty string, `None`-ish, ms-epoch vs sec-epoch boundary (exactly `1_000_000_000_000`), negative epoch, ISO with `Z`, ISO with offset, ISO already tz-aware, garbage string, whitespace-only, Workday prose (`\"Posted 3 Days Ago\"` — currently falls through to `None`, not tested/asserted).\n- `Job.content_hash`: stability across runs (same inputs → same hash), sensitivity to each of title/location/url/department changing, insensitivity to `posted_at`/`salary_range` changing (deliberate — no test proves it).\n- `Job.key`: uniqueness/stability, collision resistance across sources with same external_id.\n- `to_row`: `raw` is dropped, `key`/`content_hash` are injected.\n\n```python\n# tests/test_models.py\nimport pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_and_none_return_none(self):\n        assert parse_posted_at(\"\") is None\n\n    @pytest.mark.parametrize(\"value,expected_year\", [\n        (\"1643241332430\", 2022),   # ms epoch (13 digits)\n        (\"1643241332\", 2022),      # sec epoch\n    ])\n    def test_epoch_variants(self, value, expected_year):\n        dt = parse_posted_at(value)\n        assert dt.year == expected_year\n        assert dt.tzinfo == timezone.utc\n\n    def test_epoch_boundary_exactly_1e12_treated_as_ms(self):\n        dt = parse_posted_at(\"1000000000000\")\n        assert dt is not None  # documents ms/sec cutover behavior\n\n    def test_iso_with_trailing_z(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_naive_gets_utc_attached(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_unparseable_prose_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None  # Workday format\n\n    def test_garbage_string_returns_none(self):\n        assert parse_posted_at(\"not-a-date\") is None\n\n\nclass TestJobIdentity:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"Engineer\", url=\"https://x/1\")\n        return Job(**{**base, **overrides})\n\n    def test_key_is_stable_and_composed(self):\n        j = self._job()\n        assert j.key == \"greenhouse:acme:1\"\n\n    def test_content_hash_stable_for_identical_input(self):\n        assert self._job().content_hash == self._job().content_hash\n\n    @pytest.mark.parametrize(\"field,new_value\", [\n        (\"title\", \"Senior Engineer\"), (\"location\", \"Remote\"),\n        (\"url\", \"https://x/2\"), (\"department\", \"Eng\"),\n    ])\n    def test_content_hash_changes_on_material_field(self, field, new_value):\n        a = self._job()\n        b = self._job(**{field: new_value})\n        assert a.content_hash != b.content_hash\n\n    @pytest.mark.parametrize(\"field,new_value\", [\n        (\"posted_at\", \"2024-01-01\"), (\"salary_range\", \"$100k\"),\n    ])\n    def test_content_hash_ignores_non_material_field(self, field, new_value):\n        a = self._job()\n        b = self._job(**{field: new_value})\n        assert a.content_hash == b.content_hash  # documents intentional exclusion\n\n    def test_to_row_drops_raw_and_adds_key_and_hash(self):\n        j = self._job(raw={\"secret\": 1})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash\n```\n\n---\n\n### 2. `filters.py` — correctness bugs here silently drop or leak jobs\n\n**Gaps:** word-boundary regex behavior (substring vs whole-word match), case-insensitivity, `exclude` taking precedence over `include`, empty/`None` rule lists behaving as pass-through, location substring matching, cutoff with an unparseable `posted_at` (must be *kept*, not dropped — this is a documented intentional behavior with no test), `max_age_days` as float/string from YAML.\n\n```python\n# tests/test_filters.py\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nfrom filters import match, filter_jobs\nfrom models import Job\n\ndef job(**kw):\n    base = dict(source=\"s\", company=\"c\", external_id=\"1\", title=\"Software Engineer\",\n                url=\"u\", location=\"San Francisco, CA\", department=\"Engineering\")\n    return Job(**{**base, **kw})\n\nclass TestMatch:\n    def test_include_keyword_whole_word_only(self):\n        # \"eng\" should NOT match \"Engineering\" — \\b word boundary\n        assert match(job(title=\"Engineer\"), include=[\"eng\"]) is False\n        assert match(job(title=\"Eng\"), include=[\"eng\"]) is True\n\n    def test_include_case_insensitive(self):\n        assert match(job(title=\"ENGINEER\"), include=[\"engineer\"]) is True\n\n    def test_exclude_wins_over_include(self):\n        j = job(title=\"Senior Staff Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"senior\"]) is False\n\n    def test_no_include_rule_passes_everything(self):\n        assert match(job(), include=None) is True\n\n    def test_include_keyword_with_regex_metacharacters_is_escaped(self):\n        j = job(title=\"C++ Engineer\")\n        assert match(j, include=[\"C++\"]) is True  # must not raise/misbehave\n\n    def test_location_substring_case_insensitive(self):\n        assert match(job(location=\"San Francisco, CA\"), locations=[\"san francisco\"]) is True\n        assert match(job(location=\"Austin, TX\"), locations=[\"san francisco\"]) is False\n\n    def test_cutoff_drops_older_job(self):\n        old = job(posted_at=\"2020-01-01T00:00:00Z\")\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(old, cutoff=cutoff) is False\n\n    def test_cutoff_keeps_job_with_unparseable_posted_at(self):\n        j = job(posted_at=\"Posted 3 Days Ago\")  # unparseable -> keep, don't nuke\n        cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n        assert match(j, cutoff=cutoff) is True\n\n\nclass TestFilterJobs:\n    def test_max_age_days_builds_cutoff(self):\n        old = job(external_id=\"1\", posted_at=\"2020-01-01T00:00:00Z\")\n        new = job(external_id=\"2\", posted_at=datetime.now(timezone.utc).isoformat())\n        result = filter_jobs([old, new], {\"max_age_days\": 7})\n        assert [j.external_id for j in result] == [\"2\"]\n\n    def test_no_max_age_days_keeps_all_ages(self):\n        old = job(posted_at=\"2000-01-01T00:00:00Z\")\n        assert filter_jobs([old], {}) == [old]\n\n    def test_empty_rules_dict_returns_all(self):\n        jobs = [job(external_id=str(i)) for i in range(3)]\n        assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n### 3. `store.py` — the dedup engine; needs a real (temp) sqlite DB, no mocking\n\n**Gaps:** first insert vs. re-seen-unchanged vs. changed-content paths of `diff` (all three branches — currently 0% covered), `_migrate` adding `salary_range` to a pre-existing DB missing that column, `get_meta`/`set_meta` upsert-on-conflict, `added_since` boundary (`>` not `>=`) and ordering, `count`, context-manager close behavior, calling `diff` twice in the same run (last_seen bump without content change).\n\n```python\n# tests/test_store.py\nimport pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\ndef job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\", title=\"Engineer\", url=\"u\")\n    return Job(**{**base, **kw})\n\nclass TestDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([job()])\n        assert len(new) == 1 and changed == []\n        assert store.count() == 1\n\n    def test_reseen_unchanged_job_is_neither_new_nor_changed(self, store):\n        store.diff([job()])\n        new, changed = store.diff([job()])\n        assert new == [] and changed == []\n\n    def test_reseen_with_material_change_is_changed(self, store):\n        store.diff([job(title=\"Engineer\")])\n        new, changed = store.diff([job(title=\"Senior Engineer\")])\n        assert new == [] and len(changed) == 1\n\n    def test_diff_upserts_everything_seen_this_run(self, store):\n        store.diff([job(external_id=\"1\")])\n        store.diff([job(external_id=\"1\"), job(external_id=\"2\")])\n        assert store.count() == 2\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta_roundtrips(self, store):\n        store.set_meta(\"last_scan\", \"2024-01-01T00:00:00+00:00\")\n        assert store.get_meta(\"last_scan\") == \"2024-01-01T00:00:00+00:00\"\n\n    def test_set_meta_overwrites_existing_key(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\nclass TestAddedSince:\n    def test_excludes_rows_at_exact_timestamp(self, store):\n        # first_seen > ts is strict; a row stamped exactly at ts must be excluded\n        ...\n\n    def test_orders_by_first_seen_then_company_then_title(self, store):\n        ...\n\ndef test_migrate_adds_salary_range_to_legacy_db(tmp_path):\n    import sqlite3\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n        external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n        employment_type TEXT, posted_at TEXT, content_hash TEXT,\n        first_seen TEXT, last_seen TEXT)\"\"\")  # no salary_range column\n    conn.commit(); conn.close()\n    with Store(path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n```\n\n---\n\n### 4. `fetchers.py` — largest surface area, currently 0 covered lines\n\n#### 4a. `_request` retry/backoff — the reliability-critical piece, and totally untested\n\n**Gaps:** success on first try, retryable status codes (429/500/502/503/504) trigger retry, non-retryable 4xx (e.g. 404) raises immediately without retrying, exhausts `retries` and raises `RuntimeError` wrapping the last exception, transport errors (connection refused) are retried, backoff sleep is bounded.\n\n```python\n# tests/test_fetchers_request.py\nimport httpx, pytest, respx\nfrom fetchers import _request\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_success_first_try_no_retry():\n    respx.get(\"https://x/jobs\").mock(return_value=httpx.Response(200, json={}))\n    async with httpx.AsyncClient() as c:\n        r = await _request(c, \"https://x/jobs\")\n    assert r.status_code == 200\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_retries_on_503_then_succeeds(monkeypatch):\n    monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)  # no real delay in tests\n    route = respx.get(\"https://x/jobs\")\n    route.side_effect = [httpx.Response(503), httpx.Response(200, json={})]\n    async with httpx.AsyncClient() as c:\n        r = await _request(c, \"https://x/jobs\")\n    assert r.status_code == 200\n    assert route.call_count == 2\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_non_retryable_404_raises_without_retry():\n    route = respx.get(\"https://x/jobs\").mock(return_value=httpx.Response(404))\n    async with httpx.AsyncClient() as c:\n        with pytest.raises(RuntimeError):\n            await _request(c, \"https://x/jobs\", retries=4)\n    assert route.call_count == 1  # 404 isn't in the retryable set — fails fast? verify actual behavior\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_exhausts_retries_raises_runtime_error(monkeypatch):\n    monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)\n    respx.get(\"https://x/jobs\").mock(return_value=httpx.Response(500))\n    async with httpx.AsyncClient() as c:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(c, \"https://x/jobs\", retries=2)\n```\n*Note*: `test_non_retryable_404_raises_without_retry` needs verifying — `r.raise_for_status()` raises `HTTPStatusError` for 404 too, and that's caught by the same `except` clause as the retryable path, so 404 **is currently retried** up to `retries` times. Worth a test either confirming or flagging this as a bug (wasted retries on permanent client errors).\n\n#### 4b. Per-ATS parsers — table-driven, one fixture file per platform\n\n**Gaps common to all parsers:** missing/empty top-level key (`data.get(\"jobs\", [])` etc.), a single malformed item shouldn't crash the whole batch (currently it *would* — e.g. `j[\"id\"]` in `parse_greenhouse`/`parse_lever` raises `KeyError` on a missing id, uncaught), unicode/HTML-entity titles, empty list input.\n\n```python\n# tests/test_parsers.py\nimport pytest\nfrom fetchers import (parse_greenhouse, parse_lever, parse_ashby, parse_smartrecruiters,\n                       parse_recruitee, parse_workable, parse_google, parse_deshaw,\n                       parse_twosigma, parse_optiver, parse_meta, parse_microsoft,\n                       parse_netflix, parse_amazon, _lever_salary, _ashby_salary,\n                       _amazon_posted_at, _extract_ds1, _ds1_posted_at)\n\nclass TestParseGreenhouse:\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\n    def test_maps_fields_correctly(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\",\n                           \"location\": {\"name\": \"NYC\"},\n                           \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Platform\"}],\n                           \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        [j] = parse_greenhouse(\"acme\", data)\n        assert j.department == \"Eng, Platform\"\n        assert j.location == \"NYC\"\n\n    def test_missing_location_dict_does_not_crash(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\"}]}\n        [j] = parse_greenhouse(\"acme\", data)\n        assert j.location == \"\"\n\n    def test_missing_id_raises_keyerror(self):\n        # documents current (arguably fragile) behavior: one bad item kills the batch\n        with pytest.raises(KeyError):\n            parse_greenhouse(\"acme\", {\"jobs\": [{\"title\": \"SWE\"}]})\n\n\nclass TestLeverSalary:\n    def test_min_max_present_formats_range(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_missing_range_falls_back_to_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty_string(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestAmazonPostedAt:\n    def test_valid_date_string(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_string_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_unknown_month_name_returns_empty(self):\n        assert _amazon_posted_at(\"Frobtember 1, 2024\") == \"\"\n\n\nclass TestGoogleDS1Extraction:\n    def test_extracts_embedded_json_blob(self):\n        html = \"AF_initDataCallback({key: 'ds:1', hash: 'x', data:[[{\\\"a\\\":1}]] , sideChannel:{}});\"\n        # craft against actual regex shape used in _extract_ds1\n        ...\n\n    def test_missing_blob_returns_empty_list(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_malformed_json_returns_empty_list_not_raise(self):\n        html = \"key: 'ds:1', data:[not valid json], sideChannel\"\n        assert _extract_ds1(html) == []\n\n\nclass TestDeshawParsing:\n    def test_dedupes_repeated_job_ids(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">SWE</span>'\n                '<span class=\"location\">NYC</span></div>' * 2)\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert len(jobs) == 1\n\n    def test_html_entities_unescaped_in_title(self):\n        page = '<div data-job-id=\"1\"><span class=\"job-display-name\">R&amp;D Engineer</span></div>'\n        [j] = parse_deshaw(\"deshaw\", page)\n        assert j.title == \"R&D Engineer\"\n```\n*(Repeat the pattern above for `parse_ashby`, `parse_smartrecruiters`, `parse_recruitee`, `parse_workable`, `parse_twosigma`, `parse_optiver`, `parse_meta`, `parse_microsoft`, `parse_netflix` — each has at least one \"alternate/fallback field\" branch, e.g. `workable`'s dict-vs-flat location, `netflix`'s `t_create` vs `t_update` fallback, that's currently exercised by zero test.)*\n\n#### 4c. Paginated `fetch_*` functions — integration-shaped, needs multi-page respx sequencing\n\n**Gaps:** stops