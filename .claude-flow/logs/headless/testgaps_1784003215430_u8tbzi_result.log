        "content": "import json, pytest\nfrom datetime import datetime, timedelta, timezone\nfrom unittest.mock import patch\nfrom agent import cmd_db_new, cmd_db_mark, _normalize_ats, _chrome_bin\nfrom store import Store\n\n@pytest.fixture\ndef cfg_and_store(tmp_path, monkeypatch):\n    db = tmp_path / \"jobs.db\"\n    cfg = tmp_path / \"sources.yaml\"\n    cfg.write_text(f\"db: {db}\\n\")\n    monkeypatch.chdir(tmp_path)\n    return cfg, db\n\nclass TestDbNew:\n    def test_first_run_uses_since_days_window(self, cfg_and_store, capsys):\n        cfg, _ = cfg_and_store\n        cmd_db_new([\"-c\", str(cfg), \"--since-days\", \"3\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n\n    def test_truncation_stops_at_group_boundary_not_mid_group(self, cfg_and_store, capsys):\n        # insert two first_seen groups of size 3 each via direct store manipulation,\n        # set --limit 4 (between the groups), assert count == 3, truncated == True\n        ...\n\n    def test_never_advances_marker(self, cfg_and_store):\n        cfg, db = cfg_and_store\n        with Store(db) as s:\n            s.set_meta(\"last_scan\", \"2024-01-01T00:00:00+00:00\")\n        cmd_db_new([\"-c\", str(cfg)])\n        with Store(db) as s:\n            assert s.get_meta(\"last_scan\") == \"2024-01-01T00:00:00+00:00\"\n\n\nclass TestDbMark:\n    def test_invalid_iso_returns_2(self, cfg_and_store, capsys):\n        cfg, _ = cfg_and_store\n        rc = cmd_db_mark([\"not-a-timestamp\", \"-c\", str(cfg)])\n        assert rc == 2\n\n    def test_neither_arg_returns_2(self, cfg_and_store):\n        cfg, _ = cfg_and_store\n        assert cmd_db_mark([\"-c\", str(cfg)]) == 2\n\n    def test_now_flag_sets_current_time(self, cfg_and_store):\n        cfg, db = cfg_and_store\n        cmd_db_mark([\"--now\", \"-c\", str(cfg)])\n        with Store(db) as s:\n            assert s.get_meta(\"last_scan\") is not None\n\n\nclass TestNormalizeAts:\n    def test_smart_quotes_replaced_in_text_not_in_tags(self):\n        html = '<p title=\"\\u201Ckeep\\u201D\">\\u201Chello\\u201D</p>'\n        out, counts = _normalize_ats(html)\n        assert out == '<p title=\"\\u201Ckeep\\u201D\">\"hello\"</p>'  # only text node changed\n        assert counts[\"smart-double-quote\"] == 2\n\n    def test_style_block_untouched(self):\n        html = '<style>.x::before{content:\"\\u2014\"}</style><p>\\u2014</p>'\n        out, counts = _normalize_ats(html)\n        assert '\\u2014' in out.split(\"</style>\")[0]  # style block preserved\n        assert counts[\"em-dash\"] == 1  # only the <p> one counted\n\n\nclass TestChromeBin:\n    def test_chrome_path_env_used_when_exists(self, monkeypatch, tmp_path):\n        fake = tmp_path / \"chrome\"\n        fake.touch()\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert _chrome_bin() == str(fake)\n\n    def test_exits_when_nothing_found(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        monkeypatch.setattr(\"shutil.which\", lambda name: None)\n        monkeypatch.setattr(\"agent.Path.exists\", lambda self: False)\n        with pytest.raises(SystemExit):\n            _chrome_bin()\n```\n\n---\n\n",
