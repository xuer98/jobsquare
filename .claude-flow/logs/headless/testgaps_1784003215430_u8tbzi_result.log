obs_v2\":'\n                                               '{\"all_jobs\":[{\"id\":\"1\",\"title\":\"SWE\"}]}}}'))\n    async with httpx.AsyncClient() as c:\n        jobs = await fetch_meta(c, {\"company\": \"meta\"})\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_meta_raises_on_graphql_errors_payload():\n    respx.get(\"https://www.metacareers.com/jobs\").mock(return_value=httpx.Response(200, text=\"\"))\n    respx.post(\"https://www.metacareers.com/graphql\").mock(\n        return_value=httpx.Response(200, text='{\"errors\":[{\"message\":\"doc_id not found\"}]}'))\n    async with httpx.AsyncClient() as c:\n        with pytest.raises(RuntimeError, match=\"doc_id not found\"):\n            await fetch_meta(c, {\"company\": \"meta\"})  # regression guard for the doc_id-rotation failure mode"
