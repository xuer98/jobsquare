        "title": "tests/test_fetchers_request.py",
        "content": "import httpx, pytest, respx\nfrom fetchers import _request\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_success_first_try_no_retry():\n    respx.get(\"https://x/jobs\").mock(return_value=httpx.Response(200, json={}))\n    async with httpx.AsyncClient() as c:\n        r = await _request(c, \"https://x/jobs\")\n    assert r.status_code == 200\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_retries_on_503_then_succeeds(monkeypatch):\n    monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)  # no real delay in tests\n    route = respx.get(\"https://x/jobs\")\n    route.side_effect = [httpx.Response(503), httpx.Response(200, json={})]\n    async with httpx.AsyncClient() as c:\n        r = await _request(c, \"https://x/jobs\")\n    assert r.status_code == 200\n    assert route.call_count == 2\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_non_retryable_404_raises_without_retry():\n    route = respx.get(\"https://x/jobs\").mock(return_value=httpx.Response(404))\n    async with httpx.AsyncClient() as c:\n        with pytest.raises(RuntimeError):\n            await _request(c, \"https://x/jobs\", retries=4)\n    assert route.call_count == 1  # 404 isn't in the retryable set — fails fast? verify actual behavior\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_exhausts_retries_raises_runtime_error(monkeypatch):\n    monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)\n    respx.get(\"https://x/jobs\").mock(return_value=httpx.Response(500))\n    async with httpx.AsyncClient() as c:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(c, \"https://x/jobs\", retries=2)\n```\n*Note*: `test_non_retryable_404_raises_without_retry` needs verifying — `r.raise_for_status()` raises `HTTPStatusError` for 404 too, and that's caught by the same `except` clause as the retryable path, so 404 **is currently retried** up to `retries` times. Worth a test either confirming or flagging this as a bug (wasted retries on permanent client errors).\n\n",
