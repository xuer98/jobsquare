        "content": "import pytest\nfrom unittest.mock import patch, AsyncMock, MagicMock\nfrom pipeline import load_config, run\n\ndef test_load_config_fills_defaults(tmp_path):\n    p = tmp_path / \"cfg.yaml\"\n    p.write_text(\"sources: []\\n\")\n    cfg = load_config(p)\n    assert cfg[\"filters\"] == {}\n    assert cfg[\"db\"] == \"jobs.db\"\n    assert cfg[\"concurrency\"] == 8\n\n@pytest.mark.asyncio\nasync def test_dry_run_never_touches_store(tmp_path):\n    p = tmp_path / \"cfg.yaml\"\n    p.write_text(\"sources: []\\n\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n         patch(\"pipeline.Store\") as StoreCls:\n        result = await run(p, dry_run=True)\n    StoreCls.assert_not_called()\n    assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n\n@pytest.mark.asyncio\nasync def test_full_run_calls_diff_and_dispatch(tmp_path):\n    p = tmp_path / \"cfg.yaml\"\n    p.write_text(\"sources: []\\n\")\n    fake_store = MagicMock()\n    fake_store.diff.return_value = ([], [])\n    fake_store.count.return_value = 0\n    fake_store.__enter__.return_value = fake_store\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n         patch(\"pipeline.Store\", return_value=fake_store), \\\n         patch(\"pipeline.dispatch\") as dispatch_mock:\n        await run(p, dry_run=False)\n    dispatch_mock.assert_called_once()\n```\n\n---\n\n",
