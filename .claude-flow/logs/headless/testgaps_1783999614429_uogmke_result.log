        "code": "# test_fetchers_request.py\nimport httpx, pytest\nfrom fetchers import _request, _get_json\n\n@pytest.mark.asyncio\nasync def test_retries_on_503_then_succeeds(monkeypatch):\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        if calls[\"n\"] < 3:\n            return httpx.Response(503)\n        return httpx.Response(200, json={\"ok\": True})\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)  # skip backoff delay\n        data = await _get_json(client, \"https://x/test\")\n    assert data == {\"ok\": True}\n    assert calls[\"n\"] == 3\n\n@pytest.mark.asyncio\nasync def test_gives_up_after_max_retries(monkeypatch):\n    def handler(request): return httpx.Response(500)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _get_json(client, \"https://x/test\", retries=2)\n\n@pytest.mark.asyncio\nasync def test_non_retryable_4xx_raises_immediately_without_retry(monkeypatch):\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        return httpx.Response(404)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        with pytest.raises(RuntimeError):\n            await _get_json(client, \"https://x/test\")\n    assert calls[\"n\"] == 1  # 404 is not in the retryable set — must not retry 4x"
