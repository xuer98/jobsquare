        "title": "test_notify.py",
        "content": "from notify import dispatch, notify_console, _sms_body, notify_sms\nfrom models import Job\n\ndef make_job(**kw):\n    d = dict(source=\"g\", company=\"c\", external_id=\"1\", title=\"Eng\", url=\"u\")\n    d.update(kw); return Job(**d)\n\ndef test_dispatch_isolates_notifier_failures(monkeypatch, capsys):\n    def boom(new, changed): raise RuntimeError(\"webhook down\")\n    monkeypatch.setattr(\"notify.NOTIFIERS\", [boom, notify_console])\n    dispatch([make_job()], [])\n    out = capsys.readouterr().out\n    assert \"notifier boom failed\" in out\n    assert \"NEW listing\" in out  # console still ran\n\ndef test_notify_slack_noop_without_env_var(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    from notify import notify_slack\n    notify_slack([make_job()], [])  # must not raise, must not attempt HTTP\n\ndef test_notify_slack_noop_when_no_jobs(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n    from notify import notify_slack\n    notify_slack([], [])  # no jobs -> should not POST even though URL is set\n\ndef test_sms_body_ascii_only_and_truncates(monkeypatch):\n    jobs = [make_job(external_id=str(i), title=f\"Job {i}\") for i in range(12)]\n    body = _sms_body(jobs, [], limit=8)\n    assert \"•\" not in body and \"…\" not in body\n    assert \"+4 more\" in body\n\ndef test_notify_sms_requires_all_four_env_vars(monkeypatch):\n    for k in (\"TWILIO_ACCOUNT_SID\", \"TWILIO_AUTH_TOKEN\", \"TWILIO_FROM\", \"TWILIO_TO\"):\n        monkeypatch.delenv(k, raising=False)\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")  # only one set\n    notify_sms([make_job()], [])  # must no-op, not raise KeyError\n\ndef test_notify_sms_raises_on_twilio_error(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n    monkeypatch.setenv(\"TWILIO_AUTH_TOKEN\", \"tok\")\n    monkeypatch.setenv(\"TWILIO_FROM\", \"+1\")\n    monkeypatch.setenv(\"TWILIO_TO\", \"+2\")\n    import httpx\n    def raiser(*a, **k):\n        req = httpx.Request(\"POST\", \"https://api.twilio.com/x\")\n        return httpx.Response(401, request=req)\n    monkeypatch.setattr(\"httpx.post\", raiser)\n    import pytest\n    with pytest.raises(httpx.HTTPStatusError):\n        notify_sms([make_job()], [])  # raise_for_status must surface bad creds\n```\n\n---\n\n",
