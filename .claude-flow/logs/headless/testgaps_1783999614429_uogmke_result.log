        "content": "import httpx, pytest\nfrom fetchers import fetch_microsoft\n\n@pytest.mark.asyncio\nasync def test_fetch_microsoft_stops_at_max_pages_cap():\n    def handler(request):\n        # always return one \"new\" position with an incrementing id so it never naturally stops\n        start = int(httpx.QueryParams(request.url.query.decode())[\"start\"])\n        return httpx.Response(200, json={\"data\": {\"positions\": [\n            {\"id\": str(start), \"name\": \"Eng\", \"postedTs\": 1700000000}]}})\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        jobs = await fetch_microsoft(client, {\"company\": \"ms\", \"max_pages\": 3})\n    assert len(jobs) == 3  # capped, not infinite\n\n@pytest.mark.asyncio\nasync def test_fetch_microsoft_stops_when_page_has_no_fresh_ids():\n    def handler(request):\n        return httpx.Response(200, json={\"data\": {\"positions\": [\n            {\"id\": \"dup\", \"name\": \"Eng\", \"postedTs\": 1700000000}]}})\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        jobs = await fetch_microsoft(client, {\"company\": \"ms\", \"max_pages\": 10})\n    assert len(jobs) == 1  # second page returns only 'dup' -> loop breaks early\n```\n\n",
