        "content": "Untested: `\"for (;;);\"` XSSI-prefix stripping, GraphQL `errors` key raising `RuntimeError` with a truncated message (doc_id rotation — the exact failure mode the module comment warns about), token regexes failing to match (should degrade to empty string tokens, not crash), empty `all_jobs`.\n\n```python\n@pytest.mark.asyncio\nasync def test_fetch_meta_strips_for_loop_prefix_and_parses(monkeypatch):\n    page_html = '[\"LSD\",[],{\"token\":\"tok123\"}] \"__spin_r\":5 \"__spin_b\":\"b\" \"__spin_t\":1'\n    def handler(request):\n        if request.method == \"GET\":\n            return httpx.Response(200, text=page_html)\n        return httpx.Response(200, text='for (;;);{\"data\":{\"job_search_with_featured_jobs_v2\":'\n                                          '{\"all_jobs\":[{\"id\":\"1\",\"title\":\"Eng\",\"locations\":[],\"teams\":[]}]}}}')\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        jobs = await fetch_meta(client, {\"company\": \"meta\"})\n    assert jobs[0].external_id == \"1\"\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_raises_on_rotated_doc_id_error(monkeypatch):\n    def handler(request):\n        if request.method == \"GET\":\n            return httpx.Response(200, text=\"\")\n        return httpx.Response(200, text='{\"errors\":[{\"message\":\"Unknown doc_id\"}]}')\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        with pytest.raises(RuntimeError, match=\"meta graphql\"):\n            await fetch_meta(client, {\"company\": \"meta\"})\n```\n\n",
