        "code": "# tests/test_notify.py\nimport notify\nfrom models import Job\nfrom notify import dispatch, _sms_body\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\ndef test_dispatch_isolates_one_failing_notifier(monkeypatch):\n    calls = []\n    def boom(new, changed): raise RuntimeError(\"slack down\")\n    def ok(new, changed): calls.append(\"ok\")\n    monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, ok])\n    dispatch([make_job()], [])\n    assert calls == [\"ok\"]\n\ndef test_notify_slack_noop_without_webhook_url(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    called = []\n    monkeypatch.setattr(\"httpx.post\", lambda *a, **k: called.append(1))\n    notify.notify_slack([make_job()], [])\n    assert called == []\n\ndef test_notify_sms_noop_when_jobs_empty(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"s\")\n    monkeypatch.setenv(\"TWILIO_AUTH_TOKEN\", \"t\")\n    monkeypatch.setenv(\"TWILIO_FROM\", \"+1\")\n    monkeypatch.setenv(\"TWILIO_TO\", \"+2\")\n    called = []\n    monkeypatch.setattr(\"httpx.post\", lambda *a, **k: called.append(1))\n    notify.notify_sms([], [])\n    assert called == []\n\ndef test_notify_sms_raises_on_bad_creds(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"s\")\n    monkeypatch.setenv(\"TWILIO_AUTH_TOKEN\", \"t\")\n    monkeypatch.setenv(\"TWILIO_FROM\", \"+1\")\n    monkeypatch.setenv(\"TWILIO_TO\", \"+2\")\n    class FakeResp:\n        def raise_for_status(self): raise Exception(\"401\")\n    monkeypatch.setattr(\"httpx.post\", lambda *a, **k: FakeResp())\n    import pytest\n    with pytest.raises(Exception):\n        notify.notify_sms([make_job()], [])\n\ndef test_sms_body_truncates_at_limit_and_counts_remainder():\n    jobs = [make_job(external_id=str(i), title=f\"Job {i}\") for i in range(10)]\n    body = _sms_body(jobs, [], limit=8)\n    assert \"+2 more\" in body\n    assert body.count(\"\\n- \") == 8"
