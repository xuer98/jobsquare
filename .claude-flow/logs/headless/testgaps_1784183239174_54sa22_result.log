        "code": "# tests/test_agent.py\nimport pytest\nfrom agent import cmd_db_mark, cmd_report_num, _normalize_ats\nfrom pipeline import load_config\nfrom store import Store\n\n@pytest.fixture\ndef cfg(tmp_path):\n    db = tmp_path / \"jobs.db\"\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(f\"sources: []\\ndb: {db}\\n\")\n    return str(cfg_path)\n\nclass TestNormalizeAts:\n    def test_em_dash_replaced_in_text(self):\n        html, counts = _normalize_ats(\"<p>a\\u2014b</p>\")\n        assert \"a-b\" in html and counts[\"em-dash\"] == 1\n\n    def test_tag_attributes_untouched(self):\n        html, counts = _normalize_ats('<div data-x=\"\\u2014\"></div>')\n        assert \"\\u2014\" in html and \"em-dash\" not in counts\n\n    def test_style_and_script_blocks_untouched(self):\n        html, counts = _normalize_ats(\"<style>.a{content:'\\u2014'}</style><script>x='\\u2014'</script>\")\n        assert counts == {}\n\n    def test_no_changes_needed_returns_empty_counts(self):\n        assert _normalize_ats(\"<p>plain ascii</p>\")[1] == {}\n\n\nclass TestDbMark:\n    def test_invalid_watermark_exits_2_and_does_not_write(self, cfg, capsys):\n        assert cmd_db_mark([\"not-a-date\", \"-c\", cfg]) == 2\n        assert \"not an ISO timestamp\" in capsys.readouterr().err\n\n    def test_neither_watermark_nor_now_exits_2(self, cfg):\n        assert cmd_db_mark([\"-c\", cfg]) == 2\n\n    def test_now_flag_sets_current_marker(self, cfg):\n        cmd_db_mark([\"--now\", \"-c\", cfg])\n        with Store(load_config(cfg)[\"db\"]) as s:\n            assert s.get_meta(\"last_scan\") is not None\n\n\nclass TestReportNum:\n    def test_first_call_prints_001(self, cfg, capsys):\n        cmd_report_num([\"-c\", cfg])\n        assert capsys.readouterr().out.strip() == \"001\"\n\n\nclass TestMainRouting:\n    def test_db_new_subcommand_dispatches(self, monkeypatch):\n        import agent\n        called = []\n        monkeypatch.setattr(agent, \"cmd_db_new\", lambda argv: called.append(argv) or 0)\n        monkeypatch.setattr(\"sys.argv\", [\"agent.py\", \"db-new\", \"--limit\", \"5\"])\n        agent.main()\n        assert called == [[\"--limit\", \"5\"]]\n\n    def test_mode_words_stop_at_first_flag(self, monkeypatch):\n        import agent\n        captured = {}\n        def fake_run(mode_words, interactive, extra):\n            captured.update(mode_words=mode_words, interactive=interactive, extra=extra)\n            return 0\n        monkeypatch.setattr(agent, \"run_claude\", fake_run)\n        monkeypatch.setattr(\"sys.argv\", [\"agent.py\", \"scan\", \"--dry-run\"])\n        agent.main()\n        assert captured[\"mode_words\"] == [\"scan\"]\n        assert captured[\"extra\"] == [\"--dry-run\"]\n\n    def test_interactive_flag_forces_interactive_with_mode_words(self, monkeypatch):\n        import agent\n        captured = {}\n        monkeypatch.setattr(agent, \"run_claude\",\n            lambda mw, i, e: captured.update(interactive=i) or 0)\n        monkeypatch.setattr(\"sys.argv\", [\"agent.py\", \"scan\", \"-i\"])\n        agent.main()\n        assert captured[\"interactive\"] is True"
