        "content": "import pytest, yaml\nfrom pipeline import load_config, run\nfrom models import Job\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\ndef test_load_config_defaults(tmp_path):\n    p = tmp_path / \"min.yaml\"\n    p.write_text(\"sources: []\\n\")\n    cfg = load_config(p)\n    assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\n@pytest.mark.asyncio\nasync def test_dry_run_does_not_touch_store(tmp_path, monkeypatch):\n    cfg_path = tmp_path / \"c.yaml\"\n    db_path = tmp_path / \"jobs.db\"\n    cfg_path.write_text(yaml.dump({\"sources\": [{\"ats\": \"greenhouse\", \"company\": \"acme\"}],\n                                    \"db\": str(db_path)}))\n    async def fake_fetch_all(sources, concurrency): return [make_job()]\n    monkeypatch.setattr(\"pipeline.fetch_all\", fake_fetch_all)\n    result = await run(cfg_path, dry_run=True)\n    assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n    assert not db_path.exists()\n\n@pytest.mark.asyncio\nasync def test_full_run_persists_and_dispatches(tmp_path, monkeypatch):\n    cfg_path = tmp_path / \"c.yaml\"\n    db_path = tmp_path / \"jobs.db\"\n    cfg_path.write_text(yaml.dump({\"sources\": [{\"ats\": \"greenhouse\", \"company\": \"acme\"}],\n                                    \"db\": str(db_path)}))\n    async def fake_fetch_all(sources, concurrency): return [make_job()]\n    dispatched = []\n    monkeypatch.setattr(\"pipeline.fetch_all\", fake_fetch_all)\n    monkeypatch.setattr(\"pipeline.dispatch\", lambda new, changed: dispatched.append((new, changed)))\n    result = await run(cfg_path, dry_run=False)\n    assert result[\"new\"] == 1\n    assert dispatched[0][0][0].title == \"Engineer\"\n    assert db_path.exists()\n```\n\n(Note: config sources use the key **`ats`**, not `type` — confirmed against `fetchers.fetch_source` and `sources.yaml`.)\n\n---\n\n",
