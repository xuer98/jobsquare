        "title": "tests/test_filters.py",
        "content": "from datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Software Engineer\", url=\"https://x/1\",\n                location=\"San Francisco, CA\", department=\"Engineering\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestMatch:\n    def test_include_word_boundary_rejects_substring(self):\n        assert match(make_job(title=\"Django Developer\"), include=[\"go\"]) is False\n\n    def test_include_matches_whole_word(self):\n        assert match(make_job(title=\"Go Developer\"), include=[\"go\"]) is True\n\n    def test_exclude_wins_over_include(self):\n        j = make_job(title=\"Senior Intern Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"intern\"]) is False\n\n    def test_locations_substring_case_insensitive(self):\n        j = make_job(location=\"San Francisco, CA\")\n        assert match(j, locations=[\"francisco\"]) is True\n        assert match(j, locations=[\"seattle\"]) is False\n\n    def test_cutoff_drops_old_dated_job(self):\n        old = make_job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30))\n                        .isoformat(timespec=\"seconds\"))\n        assert match(old, cutoff=datetime.now(timezone.utc) - timedelta(days=7)) is False\n\n    def test_cutoff_keeps_undated_job(self):\n        undated = make_job(posted_at=\"\")\n        assert match(undated, cutoff=datetime.now(timezone.utc) - timedelta(days=7)) is True\n\n    def test_special_regex_chars_escaped(self):\n        assert match(make_job(title=\"C++ Engineer\"), include=[\"C++\"]) is True\n\n\nclass TestFilterJobs:\n    def test_empty_rules_keeps_everything(self):\n        jobs = [make_job(), make_job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs\n\n    def test_max_age_days_as_float_string(self):\n        old = make_job(posted_at=(datetime.now(timezone.utc) - timedelta(days=5))\n                        .isoformat(timespec=\"seconds\"))\n        assert filter_jobs([old], {\"max_age_days\": \"1.5\"}) == []\n\n    def test_max_age_days_zero_disables_cutoff(self):\n        # documents current behavior: `if max_age:` treats 0 as falsy\n        old = make_job(posted_at=(datetime.now(timezone.utc) - timedelta(days=999))\n                        .isoformat(timespec=\"seconds\"))\n        assert filter_jobs([old], {\"max_age_days\": 0}) == [old]\n```\n\n---\n\n",
