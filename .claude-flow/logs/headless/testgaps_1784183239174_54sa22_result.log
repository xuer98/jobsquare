        "code": "# tests/test_fetchers.py\nimport pytest, httpx\nfrom fetchers import _request\n\ndef transport(responses):\n    it = iter(responses)\n    def handler(request):\n        status, body = next(it)\n        return httpx.Response(status, json=body, request=request)\n    return httpx.MockTransport(handler)\n\nclass TestRequestRetry:\n    @pytest.mark.asyncio\n    async def test_succeeds_first_try(self):\n        client = httpx.AsyncClient(transport=transport([(200, {\"ok\": True})]))\n        assert (await _request(client, \"https://x/\")).json() == {\"ok\": True}\n\n    @pytest.mark.asyncio\n    async def test_retries_on_503_then_succeeds(self, monkeypatch):\n        monkeypatch.setattr(\"fetchers.asyncio.sleep\", lambda s: None)\n        client = httpx.AsyncClient(transport=transport([(503, None), (200, {\"ok\": True})]))\n        assert (await _request(client, \"https://x/\")).status_code == 200\n\n    @pytest.mark.asyncio\n    async def test_does_not_retry_on_404(self):\n        client = httpx.AsyncClient(transport=transport([(404, None)]))\n        with pytest.raises(RuntimeError):\n            await _request(client, \"https://x/\", retries=4)\n\n    @pytest.mark.asyncio\n    async def test_exhausts_retries_and_raises(self, monkeypatch):\n        monkeypatch.setattr(\"fetchers.asyncio.sleep\", lambda s: None)\n        client = httpx.AsyncClient(transport=transport([(500, None)] * 4))\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(client, \"https://x/\", retries=4)"
