        "code": "# tests/test_models.py\nimport pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\n@pytest.mark.parametrize(\"value,expected_year\", [\n    (\"1643241332430\", 2022),   # Lever ms epoch\n    (\"1643241332\", 2022),      # plain seconds epoch\n])\ndef test_parse_posted_at_epoch(value, expected_year):\n    dt = parse_posted_at(value)\n    assert dt.year == expected_year\n    assert dt.tzinfo == timezone.utc\n\ndef test_parse_posted_at_iso_with_z():\n    dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n    assert dt.tzinfo == timezone.utc\n\ndef test_parse_posted_at_naive_iso_gets_utc():\n    dt = parse_posted_at(\"2024-01-15T10:00:00\")\n    assert dt.tzinfo == timezone.utc\n\n@pytest.mark.parametrize(\"value\", [\"\", None, \"Posted 3 Days Ago\", \"not a date\"])\ndef test_parse_posted_at_unparseable_returns_none(value):\n    assert parse_posted_at(value) is None\n\ndef test_job_content_hash_ignores_posted_at_and_salary():\n    base = dict(source=\"gh\", company=\"acme\", external_id=\"1\", title=\"Eng\",\n                url=\"https://x\", location=\"NYC\")\n    a = Job(**base, posted_at=\"2024-01-01\", salary_range=\"100k\")\n    b = Job(**base, posted_at=\"2025-06-01\", salary_range=\"200k\")\n    assert a.content_hash == b.content_hash\n\ndef test_job_content_hash_changes_on_title():\n    base = dict(source=\"gh\", company=\"acme\", external_id=\"1\", url=\"https://x\")\n    a = Job(**base, title=\"Eng I\")\n    b = Job(**base, title=\"Eng II\")\n    assert a.content_hash != b.content_hash\n\ndef test_job_key_survives_title_change():\n    a = Job(source=\"gh\", company=\"acme\", external_id=\"1\", title=\"Eng I\", url=\"\")\n    b = Job(source=\"gh\", company=\"acme\", external_id=\"1\", title=\"Eng II\", url=\"\")\n    assert a.key == b.key\n\ndef test_job_to_row_drops_raw_and_adds_computed_fields():\n    j = Job(source=\"gh\", company=\"acme\", external_id=\"1\", title=\"Eng\", url=\"\",\n            raw={\"secret\": \"data\"})\n    row = j.to_row()\n    assert \"raw\" not in row\n    assert row[\"key\"] == j.key\n    assert row[\"content_hash\"] == j.content_hash"
