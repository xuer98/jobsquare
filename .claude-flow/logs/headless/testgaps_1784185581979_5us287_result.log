        "title": "tests/test_notify.py",
        "content": "import httpx\nimport pytest\nfrom models import Job\nfrom notify import dispatch, notify_slack, notify_sms, _sms_body\n\ndef _job(title=\"Eng\"):\n    return Job(source=\"gh\", company=\"acme\", external_id=\"1\", title=title, url=\"https://x\")\n\ndef test_slack_noop_without_env_var(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify_slack([_job()], [])\n    assert calls == []\n\ndef test_slack_noop_when_nothing_new(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack/x\")\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify_slack([], [])\n    assert calls == []\n\ndef test_dispatch_isolates_notifier_failures(monkeypatch, capsys):\n    def boom(new, changed): raise RuntimeError(\"bad webhook\")\n    monkeypatch.setattr(\"notify.NOTIFIERS\", [boom, lambda n, c: print(\"second ran\")])\n    dispatch([_job()], [])\n    out = capsys.readouterr().out\n    assert \"second ran\" in out\n    assert \"! boom failed\" in out or \"! <lambda> failed\" in out\n\ndef test_sms_body_truncates_and_ascii_only():\n    jobs = [_job(f\"Role {i}\") for i in range(10)]\n    body = _sms_body(jobs, [], limit=8)\n    assert \"+2 more\" in body\n    assert all(ord(c) < 128 for c in body)\n\n@pytest.mark.parametrize(\"missing_var\", [\"TWILIO_ACCOUNT_SID\", \"TWILIO_AUTH_TOKEN\",\n                                          \"TWILIO_FROM\", \"TWILIO_TO\"])\ndef test_sms_requires_all_four_env_vars(monkeypatch, missing_var):\n    for v in (\"TWILIO_ACCOUNT_SID\", \"TWILIO_AUTH_TOKEN\", \"TWILIO_FROM\", \"TWILIO_TO\"):\n        monkeypatch.setenv(v, \"x\")\n    monkeypatch.delenv(missing_var, raising=False)\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify_sms([_job()], [])\n    assert calls == []\n```\n\n---\n\n",
