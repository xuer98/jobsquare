        "language": "python",
        "code": "# tests/test_store.py\nimport sqlite3\nimport tempfile\nimport threading\nfrom pathlib import Path\nimport pytest\nfrom models import Job\nfrom store import Store\n\n@pytest.fixture\ndef db_path(tmp_path):\n    return tmp_path / \"test.db\"\n\ndef _job(external_id=\"1\", title=\"Eng\"):\n    return Job(source=\"gh\", company=\"acme\", external_id=external_id, title=title, url=\"\")\n\ndef test_diff_new_job_inserted(db_path):\n    with Store(db_path) as store:\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n        assert store.count() == 1\n\ndef test_diff_unchanged_job_not_reported_but_last_seen_bumped(db_path):\n    with Store(db_path) as store:\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\ndef test_diff_changed_job_reported_and_updated(db_path):\n    with Store(db_path) as store:\n        store.diff([_job(title=\"Eng I\")])\n        new, changed = store.diff([_job(title=\"Eng II\")])\n        assert new == [] and len(changed) == 1\n        row = store.conn.execute(\"SELECT title FROM jobs WHERE external_id='1'\").fetchone()\n        assert row[\"title\"] == \"Eng II\"\n\ndef test_migration_adds_salary_range_column(db_path):\n    conn = sqlite3.connect(str(db_path))\n    conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n        external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n        employment_type TEXT, posted_at TEXT, content_hash TEXT,\n        first_seen TEXT, last_seen TEXT)\"\"\")\n    conn.commit(); conn.close()\n    store = Store(db_path)  # must not raise\n    cols = {r[\"name\"] for r in store.conn.execute(\"PRAGMA table_info(jobs)\")}\n    assert \"salary_range\" in cols\n    store.close()\n\ndef test_meta_roundtrip_and_upsert(db_path):\n    with Store(db_path) as store:\n        assert store.get_meta(\"k\") is None\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\ndef test_next_seq_increments(db_path):\n    with Store(db_path) as store:\n        assert store.next_seq(\"c\") == 1\n        assert store.next_seq(\"c\") == 2\n        assert store.next_seq(\"c\") == 3\n\ndef test_next_seq_concurrent_callers_never_collide(db_path):\n    # Regression test for the parallel-worker collision class of bugs.\n    Store(db_path).close()  # create schema first\n    results = []\n    lock = threading.Lock()\n\n    def worker():\n        s = Store(db_path)\n        n = s.next_seq(\"report_seq\")\n        with lock:\n            results.append(n)\n        s.close()\n\n    threads = [threading.Thread(target=worker) for _ in range(20)]\n    for t in threads: t.start()\n    for t in threads: t.join()\n    assert sorted(results) == list(range(1, 21))  # no duplicates, no gaps\n\ndef test_added_since_is_strictly_greater_than(db_path):\n    with Store(db_path) as store:\n        store.diff([_job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n        assert store.added_since(ts) == []  # strict >, not >="
