        "title": "tests/test_filters.py",
        "content": "from datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(**kw):\n    return Job(source=\"gh\", company=\"acme\", external_id=\"1\", title=\"Engineer\",\n                url=\"\", location=\"New York\", department=\"Eng\", **kw)\n\ndef test_match_word_boundary_excludes_substring():\n    assert match(_job(title=\"Mango Developer\"), include=[\"go\"])  # matches \"Go\" boundary? check false positive\n    # \"go\" as \\bgo\\b should NOT match inside \"Mango\"\n    assert not match(_job(title=\"Mango Sales\"), include=[\"go\"])\n\ndef test_match_exclude_wins_over_include():\n    j = _job(title=\"Senior Manager\")\n    assert not match(j, include=[\"manager\"], exclude=[\"senior\"])\n\ndef test_match_locations_is_substring_case_insensitive():\n    assert match(_job(location=\"New York, NY\"), locations=[\"york\"])\n    assert not match(_job(location=\"Austin, TX\"), locations=[\"york\"])\n\ndef test_match_cutoff_keeps_unparseable_posted_at():\n    j = _job(posted_at=\"\")  # unparseable\n    cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n    assert match(j, cutoff=cutoff)\n\ndef test_match_cutoff_drops_old_dated_job():\n    j = _job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n    cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n    assert not match(j, cutoff=cutoff)\n\ndef test_filter_jobs_max_age_days_from_yaml_string():\n    j = _job(posted_at=datetime.now(timezone.utc).isoformat())\n    result = filter_jobs([j], {\"max_age_days\": \"7\"})\n    assert result == [j]\n```\n\n---\n\n",
