  "output": "## Test Coverage Analysis — jobsquare\n\n**Current state: 0% coverage.** No `tests/` directory, no pytest (or any test runner) in `requirements.txt`/`.venv`, no CI config referencing tests. Every module below is exercised only by manual runs. I'd recommend adding `pytest`, `pytest-asyncio`, and using `httpx.MockTransport` (no extra dependency needed, already have httpx) as dev dependencies.\n\n---\n\n### 1. `models.py` — pure logic, cheapest to cover, currently untested\n\n**Gaps:** `parse_posted_at` epoch/ISO branching, ms-vs-s boundary, `Job.key`/`content_hash` stability semantics, `to_row` shape.\n\n```python\n# tests/test_models.py\nimport pytest\nfrom datetime import datetime, timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_and_none_return_none(self):\n        assert parse_posted_at(\"\") is None\n\n    def test_ms_epoch_lever_style(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt == datetime.fromtimestamp(1643241332.430, tz=timezone.utc)\n\n    def test_second_epoch(self):\n        dt = parse_posted_at(\"1643241332\")\n        assert dt.tzinfo is not None\n\n    def test_epoch_boundary_exactly_1e12(self):\n        # 1_000_000_000_000 must be treated as ms, not s (year-33658 bug otherwise)\n        dt = parse_posted_at(\"1000000000000\")\n        assert dt.year < 2100\n\n    def test_negative_epoch(self):\n        dt = parse_posted_at(\"-100\")\n        assert dt is not None\n\n    def test_iso_with_trailing_z(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00Z\")\n        assert dt == datetime(2026, 1, 15, 10, 0, tzinfo=timezone.utc)\n\n    def test_iso_naive_gets_utc(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_with_explicit_offset_preserved(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00+05:00\")\n        assert dt.utcoffset().total_seconds() == 5 * 3600\n\n    def test_unparseable_prose_returns_none(self):\n        # Workday sends \"Posted 3 Days Ago\"\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_whitespace_only(self):\n        assert parse_posted_at(\"   \") is None\n\n\nclass TestJob:\n    def _job(self, **kw):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                    title=\"Engineer\", url=\"https://x/1\")\n        base.update(kw)\n        return Job(**base)\n\n    def test_key_is_stable_identity(self):\n        assert self._job().key == \"greenhouse:acme:1\"\n\n    def test_key_survives_title_change(self):\n        a, b = self._job(title=\"A\"), self._job(title=\"B\")\n        assert a.key == b.key\n\n    def test_content_hash_changes_on_title(self):\n        a, b = self._job(title=\"A\"), self._job(title=\"B\")\n        assert a.content_hash != b.content_hash\n\n    def test_content_hash_stable_when_only_salary_changes(self):\n        # salary/dept/employment_type not in the hash blob except department\n        a = self._job(salary_range=\"100k\")\n        b = self._job(salary_range=\"200k\")\n        assert a.content_hash == b.content_hash\n\n    def test_content_hash_changes_on_department(self):\n        a, b = self._job(department=\"Eng\"), self._job(department=\"Sales\")\n        assert a.content_hash != b.content_hash\n\n    def test_to_row_drops_raw_adds_key_and_hash(self):\n        row = self._job(raw={\"secret\": 1}).to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == \"greenhouse:acme:1\"\n        assert \"content_hash\" in row\n\n    def test_posted_dt_delegates_to_parse_posted_at(self):\n        assert self._job(posted_at=\"\").posted_dt is None\n```\n\n---\n\n### 2. `filters.py`\n\n**Gaps:** exclude-before-include precedence, word-boundary matching, cutoff semantics (keep-unparseable-dates rule), `max_age_days` wiring.\n\n```python\n# tests/test_filters.py\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef job(**kw):\n    base = dict(source=\"s\", company=\"c\", external_id=\"1\", title=\"Backend Engineer\",\n                url=\"u\", location=\"Remote - US\", department=\"Platform\")\n    base.update(kw)\n    return Job(**base)\n\ndef test_include_keyword_matches_whole_word_only():\n    assert match(job(title=\"Cat Herder\"), include=[\"cat\"])\n    assert not match(job(title=\"Concatenate\"), include=[\"cat\"])  # no substring match\n\ndef test_exclude_wins_over_include():\n    j = job(title=\"Senior Backend Engineer\")\n    assert not match(j, include=[\"backend\"], exclude=[\"senior\"])\n\ndef test_case_insensitive():\n    assert match(job(title=\"BACKEND\"), include=[\"backend\"])\n\ndef test_locations_substring_match():\n    assert match(job(location=\"San Francisco, CA\"), locations=[\"san francisco\"])\n    assert not match(job(location=\"NYC\"), locations=[\"san francisco\"])\n\ndef test_no_rules_keeps_everything():\n    assert match(job())\n\ndef test_cutoff_drops_confirmed_old_posting():\n    old = job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n    cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n    assert not match(old, cutoff=cutoff)\n\ndef test_cutoff_keeps_unparseable_date_rather_than_dropping():\n    j = job(posted_at=\"Posted 3 Days Ago\")  # Workday prose, unparseable\n    cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n    assert match(j, cutoff=cutoff)\n\ndef test_cutoff_keeps_no_posted_at():\n    assert match(job(posted_at=\"\"), cutoff=datetime.now(timezone.utc))\n\ndef test_filter_jobs_wires_max_age_days_to_cutoff():\n    fresh = job(external_id=\"1\", posted_at=datetime.now(timezone.utc).isoformat())\n    stale = job(external_id=\"2\", posted_at=(datetime.now(timezone.utc)\n                                             - timedelta(days=10)).isoformat())\n    out = filter_jobs([fresh, stale], {\"max_age_days\": 3})\n    assert [j.external_id for j in out] == [\"1\"]\n\ndef test_include_keyword_with_regex_special_chars_is_escaped():\n    j = job(title=\"C++ Developer\")\n    assert match(j, include=[\"C++\"])\n```\n\n---\n\n### 3. `store.py` — the dedup source of truth, zero coverage on the trickiest logic\n\n**Gaps:** new/changed/unchanged classification, `last_seen` bump on unchanged, schema migration for pre-existing DBs, `next_seq` atomicity (its entire purpose per the docstring — \"concurrent claimers serialize instead of racing\" — is untested), `added_since` boundary (`>` not `>=`), duplicate keys within one batch.\n\n```python\n# tests/test_store.py\nimport sqlite3\nimport threading\nimport pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"jobs.db\")\n    yield s\n    s.close()\n\ndef job(external_id=\"1\", title=\"Engineer\", **kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=external_id,\n                title=title, url=\"u\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_is_neither_new_nor_changed(self, store):\n        store.diff([job()])\n        new, changed = store.diff([job()])\n        assert new == [] and changed == []\n\n    def test_changed_content_hash_reports_as_changed(self, store):\n        store.diff([job(title=\"Engineer I\")])\n        new, changed = store.diff([job(title=\"Engineer II\")])\n        assert new == [] and len(changed) == 1\n\n    def test_unchanged_job_still_bumps_last_seen(self, store):\n        store.diff([job()])\n        row1 = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        store.diff([job()])\n        row2 = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        assert row2[\"last_seen\"] >= row1[\"last_seen\"]\n\n    def test_duplicate_key_within_same_batch(self, store):\n        # Same connection sees its own uncommitted writes — verify the second\n        # occurrence in one call is treated as an update, not a crash/dup insert.\n        new, changed = store.diff([job(title=\"A\"), job(title=\"B\")])\n        assert store.count() == 1\n\n    def test_empty_batch_is_noop(self, store):\n        assert store.diff([]) == ([], [])\n\n\nclass TestMigration:\n    def test_legacy_db_without_salary_range_gets_column_added(self, tmp_path):\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(path)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        s = Store(path)\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n        s.close()\n\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta_roundtrip(self, store):\n        store.set_meta(\"k\", \"v1\")\n        assert store.get_meta(\"k\") == \"v1\"\n\n    def test_set_meta_upserts(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n\nclass TestNextSeq:\n    def test_starts_at_one(self, store):\n        assert store.next_seq(\"seq\") == 1\n\n    def test_increments_sequentially(self, store):\n        assert [store.next_seq(\"seq\") for _ in range(3)] == [1, 2, 3]\n\n    def test_independent_keys_dont_interfere(self, store):\n        store.next_seq(\"a\")\n        assert store.next_seq(\"b\") == 1\n\n    def test_concurrent_callers_dont_double_assign(self, tmp_path):\n        # Regression test for the race the BEGIN IMMEDIATE lock exists to prevent.\n        path = tmp_path / \"concurrent.db\"\n        results = []\n        def worker():\n            with Store(path) as s:\n                results.append(s.next_seq(\"report_seq\"))\n        threads = [threading.Thread(target=worker) for _ in range(10)]\n        for t in threads: t.start()\n        for t in threads: t.join()\n        assert sorted(results) == list(range(1, 11))  # no duplicates/gaps\n\n\nclass TestAddedSince:\n    def test_strictly_after_excludes_exact_ts(self, store):\n        store.diff([job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[\"first_seen\"]\n        assert store.added_since(ts) == []\n\n    def test_ordering_oldest_first(self, store):\n        store.diff([job(external_id=\"1\")])\n        store.diff([job(external_id=\"2\")])\n        rows = store.added_since(\"2000-01-01T00:00:00+00:00\")\n        assert [r[\"external_id\"] for r in rows] == [\"1\", \"2\"]\n\n\ndef test_count_reflects_distinct_jobs(store):\n    store.diff([job(external_id=\"1\"), job(external_id=\"2\")])\n    assert store.count() == 2\n```\n\n---\n\n### 4. `notify.py`\n\n**Gaps:** every env-gated notifier's skip condition, `dispatch`'s fault isolation (its whole purpose is \"one notifier failing shouldn't kill the run\" — currently untested), SMS body truncation/ASCII-only, SMTP/HTTP call shape.\n\n```python\n# tests/test_notify.py\nimport pytest\nimport httpx\nfrom models import Job\nimport notify\n\ndef job(**kw):\n    base = dict(source=\"s\", company=\"Acme\", external_id=\"1\", title=\"Engineer\",\n                url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestNotifyConsole:\n    def test_prints_no_fresh_listings_when_both_empty(self, capsys):\n        notify.notify_console([], [])\n        assert \"No fresh listings\" in capsys.readouterr().out\n\n    def test_prints_new_and_updated_sections(self, capsys):\n        notify.notify_console([job()], [job(external_id=\"2\")])\n        out = capsys.readouterr().out\n        assert \"NEW listing\" in out and \"UPDATED listing\" in out\n\n\nclass TestNotifySlack:\n    def test_noop_when_env_var_unset(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        called = []\n        monkeypatch.setattr(httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_slack([job()], [])\n        assert not called\n\n    def test_noop_when_no_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n        called = []\n        monkeypatch.setattr(httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_slack([], [])\n        assert not called\n\n    def test_posts_expected_payload(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n        captured = {}\n        def fake_post(url, json, timeout):\n            captured.update(url=url, json=json)\n        monkeypatch.setattr(httpx, \"post\", fake_post)\n        notify.notify_slack([job()], [])\n        assert \"Engineer\" in captured[\"json\"][\"text\"]\n\n\nclass TestNotifySms:\n    @pytest.fixture(autouse=True)\n    def env(self, monkeypatch):\n        for k in (\"TWILIO_ACCOUNT_SID\", \"TWILIO_AUTH_TOKEN\", \"TWILIO_FROM\", \"TWILIO_TO\"):\n            monkeypatch.setenv(k, \"x\")\n\n    def test_noop_missing_any_of_four_vars(self, monkeypatch):\n        monkeypatch.delenv(\"TWILIO_TO\", raising=False)\n        called = []\n        monkeypatch.setattr(httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_sms([job()], [])\n        assert not called\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        def fake_post(*a, **k):\n            req = httpx.Request(\"POST\", \"https://api.twilio.com/x\")\n            resp = httpx.Response(400, request=req)\n            return resp\n        monkeypatch.setattr(httpx, \"post\", fake_post)\n        with pytest.raises(httpx.HTTPStatusError):\n            notify.notify_sms([job()], [])\n\n    def test_sms_body_truncates_and_counts_remainder(self):\n        jobs = [job(external_id=str(i), title=f\"J{i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n\n    def test_sms_body_is_ascii_only(self):\n        body = notify._sms_body([job(title=\"Café • Role\")], [])\n        body.encode(\"ascii\")  # raises UnicodeEncodeError if non-ASCII sneaks in\n\n\nclass TestDispatch:\n    def test_one_notifier_failure_does_not_block_others(self, monkeypatch, capsys):\n        def boom(new, changed): raise RuntimeError(\"smtp down\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, notify.notify_console])\n        notify.dispatch([job()], [])\n        out = capsys.readouterr().out\n        assert \"notifier boom failed\" in out\n        assert \"NEW listing\" in out  # console notifier still ran\n```\n\n---\n\n### 5. `fetchers.py` — largest gap by far (~1000 lines, 18 ATS integrations, zero tests)\n\nThe module docstring explicitly says the client is \"injectable so parsing logic is unit-testable against mocked transports\" — that design intent is currently unused.\n\n**Priority A — shared retry/parsing infra used by everything:**\n\n```python\n# tests/test_fetchers_core.py\nimport httpx\nimport pytest\nimport fetchers\n\n@pytest.mark.asyncio\nasync def test_request_retries_on_502_then_succeeds(monkeypatch):\n    monkeypatch.setattr(fetchers.asyncio, \"sleep\", lambda s: None)  # no real waits\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        if calls[\"n\"] < 3:\n            return httpx.Response(502)\n        return httpx.Response(200, json={\"ok\": True})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    r = await fetchers._request(client, \"https://x\")\n    assert r.json() == {\"ok\": True}\n    assert calls[\"n\"] == 3\n\n@pytest.mark.asyncio\nasync def test_request_gives_up_after_max_retries(monkeypatch):\n    monkeypatch.setattr(fetchers.asyncio, \"sleep\", lambda s: None)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(\n        lambda r: httpx.Response(503)))\n    with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n        await fetchers._request(client, \"https://x\", retries=2)\n\n@pytest.mark.asyncio\nasync def test_request_does_not_retry_non_retryable_4xx(monkeypatch):\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        return httpx.Response(404)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    with pytest.raises(RuntimeError):\n        await fetchers._request(client, \"https://x\")\n    assert calls[\"n\"] == 1  # no retry on a non-transient 404\n\n\nclass TestBalancedJson:\n    def test_extracts_simple_object(self):\n        text = 'prefix {\"a\": 1} suffix'\n        assert fetchers._balanced_json(text, text.find(\"{\")) == '{\"a\": 1}'\n\n    def test_handles_nested_braces(self):\n        text = '{\"a\": {\"b\": 1}}'\n        assert fetchers._balanced_json(text, 0) == text\n\n    def test_ignores_braces_inside_strings(self):\n        text = '{\"a\": \"} not a brace {\"}'\n        assert fetchers._balanced_json(text, 0) == text\n\n    def test_handles_escaped_quotes_in_strings(self):\n        text = r'{\"a\": \"he said \\\"hi\\\"\"}'\n        assert fetchers._balanced_json(text, 0) == text\n\n    def test_returns_none_when_unterminated(self):\n        assert fetchers._balanced_json('{\"a\": 1', 0) is None\n```\n\n**Priority B — the parser functions (pure, cheap, high-value; representative sample — replicate the pattern per ATS):**\n\n```python\n# tests/test_fetchers_parsers.py\nfrom fetchers import (parse_greenhouse, parse_lever, parse_ashby, _lever_salary,\n                       _ashby_salary, parse_amazon, _amazon_posted_at,\n                       parse_apple, _apple_posted_at, parse_meta, _bd_location,\n                       parse_google, _ds1_posted_at)\n\ndef test_parse_greenhouse_maps_fields():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\",\n                       \"location\": {\"name\": \"NYC\"}, \"departments\": [{\"name\": \"Eng\"}],\n                       \"updated_at\": \"2026-01-01T00:00:00Z\"}]}\n    jobs = parse_greenhouse(\"acme\", data)\n    assert jobs[0].external_id == \"1\" and jobs[0].location == \"NYC\"\n\ndef test_parse_greenhouse_empty_jobs_list():\n    assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\ndef test_lever_salary_formats_range_with_commas():\n    j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n    assert _lever_salary(j) == \"USD 100,000–150,000\"\n\ndef test_lever_salary_falls_back_to_plain_description():\n    j = {\"salaryDescriptionPlain\": \"Competitive\"}\n    assert _lever_salary(j) == \"Competitive\"\n\ndef test_lever_salary_missing_everything_is_empty_string():\n    assert _lever_salary({}) == \"\"\n\ndef test_parse_ashby_skips_unlisted_jobs():\n    data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"hidden\"},\n                     {\"id\": \"2\", \"title\": \"visible\"}]}\n    jobs = parse_ashby(\"acme\", data)\n    assert [j.external_id for j in jobs] == [\"2\"]\n\ndef test_amazon_posted_at_parses_us_date():\n    assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\ndef test_amazon_posted_at_malformed_returns_empty():\n    assert _amazon_posted_at(\"not a date\") == \"\"\n\ndef test_parse_amazon_falls_back_to_id_icims():\n    jobs = parse_amazon(\"amazon\", [{\"id_icims\": \"999\", \"title\": \"SDE\",\n                                     \"job_path\": \"/x\"}])\n    assert jobs[0].external_id == \"999\"\n\ndef test_apple_posted_at_trims_nanoseconds():\n    assert _apple_posted_at(\"2026-01-15T10:00:03.812668311Z\") == \\\n        \"2026-01-15T10:00:03.812668+00:00\"\n\ndef test_apple_posted_at_empty_input():\n    assert _apple_posted_at(\"\") == \"\"\n\ndef test_parse_meta_dedupes_by_id():\n    results = [{\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"1\", \"title\": \"A-dup\"}]\n    assert len(parse_meta(\"meta\", results)) == 1\n\ndef test_parse_meta_skips_missing_id():\n    assert parse_meta(\"meta\", [{\"title\": \"no id\"}]) == []\n\ndef test_bd_location_walks_parent_chain():\n    city = {\"en_name\": \"SF\", \"parent\": {\"en_name\": \"CA\",\n             \"parent\": {\"en_name\": \"US\", \"parent\": None}}}\n    assert _bd_location(city) == \"SF, CA, US\"\n\ndef test_bd_location_none_returns_empty():\n    assert _bd_location(None) == \"\"\n\ndef test_ds1_posted_at_prefers_create_over_update_time():\n    job = [None] * 15\n    job[12] = [1700000000]  # create\n    job[13] = [1800000000]  # update\n    assert \"2023\" in _ds1_posted_at(job)  # 1700000000 -> 2023, not the later ts\n\ndef test_ds1_posted_at_no_timestamps_returns_empty():\n    assert _ds1_posted_at([None] * 10) == \"\"\n\ndef test_parse_google_skips_falsy_first_element():\n    assert parse_google(\"google\", [None, [\"\"], [123]]) == []\n```\n\n*(Apply the same pure-function test pattern to `parse_smartrecruiters`, `parse_recruitee`, `parse_workable`, `parse_deshaw`, `parse_twosigma`, `parse_optiver`, `parse_eightfold`, `parse_bytedance`, `parse_phenom`, `parse_microsoft`, `parse_netflix` — each has at least one documented fallback/defensive branch in the source comments that has no assertion backing it today.)*\n\n**Priority C — the async fetch/pagination functions (need `httpx.MockTransport`):**\n\n```python\n# tests/test_fetchers_pagination.py\nimport httpx\nimport pytest\nimport fetchers\n\n@pytest.mark.asyncio\nasync def test_fetch_optiver_stops_when_page_empty():\n    pages = {0: {\"items\": [{\"title\": \"A\", \"href\": \"/1\"}]}, 1: {\"items\": []}}\n    def handler(request):\n        n = int(request.url.params[\"from\"]) // 16\n        return httpx.Response(200, json=pages.get(n, {\"items\": []}))\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetchers.fetch_optiver(client, {\"company\": \"optiver\"})\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\nasync def test_fetch_optiver_respects_max_pages_cap():\n    def handler(request):  # always returns one fresh item -> would loop forever\n        n = int(request.url.params[\"from\"])\n        return httpx.Response(200, json={\"items\": [{\"title\": f\"J{n}\", \"href\": f\"/{n}\"}]})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetchers.fetch_optiver(client, {\"company\": \"optiver\", \"max_pages\": 3})\n    assert len(jobs) == 3\n\n@pytest.mark.asyncio\nasync def test_fetch_ashby_falls_back_to_hosted_page_on_404():\n    def handler(request):\n        if \"posting-api\" in str(request.url):\n            return httpx.Response(404)\n        html = ('window.__appData = {\"jobBoard\": {\"jobPostings\": '\n                '[{\"id\": \"1\", \"title\": \"SWE\", \"isListed\": true}]}}')\n        return httpx.Response(200, text=html)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetchers.fetch_ashby(client, {\"company\": \"whatnot\"})\n    assert jobs[0].external_id == \"1\"\n\n@pytest.mark.asyncio\nasync def test_fetch_ashby_raises_when_no_appdata_and_no_api():\n    def handler(request):\n        if \"posting-api\" in str(request.url):\n            return httpx.Response(404)\n        return httpx.Response(200, text=\"<html>nothing here</html>\")\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    with pytest.raises(RuntimeError, match=\"no posting-api and no __appData\"):\n        await fetchers.fetch_ashby(client, {\"company\": \"x\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_workday_stops_at_safety_cap():\n    def handler(request):\n        return httpx.Response(200, json={\"jobPostings\": [{\"title\": \"J\",\n            \"bulletFields\": [\"1\"], \"externalPath\": \"/1\"}], \"total\": 100000})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetchers.fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\"})\n    assert len(jobs) <= 5000 // 20 + 1  # bounded by the `offset > 5000` cap\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_strips_for_semicolon_prefix_and_parses_json():\n    body = 'for (;;);{\"data\": {\"job_search_with_featured_jobs_v2\": {\"all_jobs\": []}}}'\n    def handler(request):\n        if request.method == \"POST\":\n            return httpx.Response(200, text=body)\n        return httpx.Response(200, text='\"LSD\",[],{\"token\":\"tok\"} \"__spin_r\":1')\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetchers.fetch_meta(client, {\"company\": \"meta\"})\n    assert jobs == []\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_raises_on_graphql_errors():\n    def handler(request):\n        if request.method == \"POST\":\n            return httpx.Response(200, text='{\"errors\": [{\"message\": \"doc_id invalid\"}]}')\n        return httpx.Response(200, text=\"\")\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    with pytest.raises(RuntimeError, match=\"doc_id invalid\"):\n        await fetchers.fetch_meta(client, {})\n\n\nclass TestFetchSourceAndAll:\n    @pytest.mark.asyncio\n    async def test_fetch_source_unknown_ats_raises_valueerror(self):\n        client = httpx.AsyncClient(transport=httpx.MockTransport(lambda r: httpx.Response(200)))\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            await fetchers.fetch_source(client, {\"ats\": \"nonexistent\"})\n\n    @pytest.mark.asyncio\n    async def test_fetch_all_continues_after_one_source_fails(self, capsys):\n        def handler(request):\n            if \"greenhouse\" in str(request.url):\n                return httpx.Response(500)\n            return httpx.Response(200, json={\"jobs\": []})\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        sources = [{\"ats\": \"greenhouse\", \"company\": \"bad\"},\n                   {\"ats\": \"greenhouse\", \"company\": \"good\"}]\n        # both hit /jobs so make bad's company distinguishable via url match above\n        jobs = await fetchers.fetch_all(sources, client=client)\n        assert jobs == []  # no crash — failures degrade to empty list\n        assert \"failed\" in capsys.readouterr().out\n\n    @pytest.mark.asyncio\n    async def test_fetch_all_respects_concurrency_semaphore(self):\n        in_flight = {\"n\": 0, \"max\": 0}\n        async def one(client, src):\n            in_flight[\"n\"] += 1\n            in_flight[\"max\"] = max(in_flight[\"max\"], in_flight[\"n\"])\n            await fetchers.asyncio.sleep(0.01)\n            in_flight[\"n\"] -= 1\n            return []\n        import unittest.mock as mock\n        with mock.patch.object(fetchers, \"fetch_source\", one):\n            await fetchers.fetch_all([{\"ats\": \"x\"}] * 20, concurrency=3)\n        assert in_flight[\"max\"] <= 3\n```\n\n---\n\n### 6. `pipeline.py` — the integration seam, currently untested end to end\n\n**Gaps:** config defaulting, dry-run vs persisted-run divergence, full wiring (fetch → filter → store → notify).\n\n```python\n# tests/test_pipeline.py\nimport pytest\nfrom unittest.mock import AsyncMock, patch\nimport pipeline\n\ndef test_load_config_applies_defaults(tmp_path):\n    cfg_path = tmp_path / \"min.yaml\"\n    cfg_path.write_text(\"sources: []\\n\")\n    cfg = pipeline.load_config(cfg_path)\n    assert cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8 and cfg[\"filters\"] == {}\n\n@pytest.mark.asyncio\nasync def test_dry_run_does_not_persist_or_notify(tmp_path):\n    cfg_path = tmp_path / \"c.yaml\"\n    cfg_path.write_text(f\"sources: []\\ndb: {tmp_path/'jobs.db'}\\n\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n         patch(\"pipeline.dispatch\") as mock_dispatch:\n        result = await pipeline.run(cfg_path, dry_run=True)\n    assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n    mock_dispatch.assert_not_called()\n    assert not (tmp_path / \"jobs.db\").exists()\n\n@pytest.mark.asyncio\nasync def test_full_run_persists_and_dispatches(tmp_path):\n    from models import Job\n    j = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")\n    cfg_path = tmp_path / \"c.yaml\"\n    cfg_path.write_text(f\"sources: []\\ndb: {tmp_path/'jobs.db'}\\n\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[j])), \\\n         patch(\"pipeline.dispatch\") as mock_dispatch:\n        result = await pipeline.run(cfg_path)\n    assert result == {\"matched\": 1, \"new\": 1, \"changed\": 0}\n    mock_dispatch.assert_called_once()\n    assert (tmp_path / \"jobs.db\").exists()\n\n@pytest.mark.asyncio\nasync def test_filters_are_applied_before_dedup(tmp_path):\n    from models import Job\n    matching = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Engineer\", url=\"u\")\n    excluded = Job(source=\"s\", company=\"c\", external_id=\"2\", title=\"Manager\", url=\"u\")\n    cfg_path = tmp_path / \"c.yaml\"\n    cfg_path.write_text(\n        f\"sources: []\\ndb: {tmp_path/'jobs.db'}\\n\"\n        \"filters:\\n  exclude_keywords: [Manager]\\n\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[matching, excluded])), \\\n         patch(\"pipeline.dispatch\"):\n        result = await pipeline.run(cfg_path)\n    assert result[\"matched\"] == 1\n```\n\n---\n\n### 7. `cli.py`\n\n```python\n# tests/test_cli.py\nfrom unittest.mock import patch\nimport cli\n\ndef test_default_config_path(monkeypatch):\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\"])\n    with patch(\"cli.run_sync\") as mock_run:\n        cli.main()\n    mock_run.assert_called_once_with(\"sources.yaml\", dry_run=False)\n\ndef test_dry_run_flag_propagates(monkeypatch):\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\", \"--dry-run\"])\n    with patch(\"cli.run_sync\") as mock_run:\n        cli.main()\n    mock_run.assert_called_once_with(\"sources.yaml\", dry_run=True)\n\ndef test_custom_config_flag(monkeypatch):\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\", \"-c\", \"other.yaml\"])\n    with patch(\"cli.run_sync\") as mock_run:\n        cli.main()\n    mock_run.assert_called_once_with(\"other.yaml\", dry_run=False)\n```\n\n---\n\n### 8. `agent.py`\n\n**Gaps:** `cmd_db_new`'s posted-days filtering/first-seen-group truncation (the trickiest logic in the file — explicitly the subject of an in-code comment about not splitting groups), `cmd_db_mark` validation, `_normalize_ats`'s tag/text-node split (must not touch `<style>`/`<script>`/attribute text), `_chrome_bin` discovery order, `main()`'s subcommand/flag-splitting dispatch.\n\n```python\n# tests/test_agent.py\nimport json\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nfrom agent import cmd_db_new, cmd_db_mark, _normalize_ats, _chrome_bin\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef cfg(tmp_path, monkeypatch):\n    db = tmp_path / \"jobs.db\"\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(f\"db: {db}\\nsources: []\\n\")\n    monkeypatch.chdir(tmp_path)\n    return str(cfg_path)\n\nclass TestDbNew:\n    def test_first_run_uses_since_days_window(self, cfg, capsys):\n        with Store(Store.__init__.__globals__ and cfg) :  # see note below\n            pass\n        # Simpler: seed via Store directly against the same db path\n        cmd_db_new([\"-c\", cfg])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n\n    def test_posted_days_drops_confirmed_old_and_counts_it(self, cfg, capsys, tmp_path):\n        with Store(str(tmp_path / \"jobs.db\")) as s:\n            s.diff([Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Old\",\n                         url=\"u\", posted_at=(datetime.now(timezone.utc)\n                         - timedelta(days=30)).isoformat())])\n        cmd_db_new([\"-c\", cfg, \"--posted-days\", \"7\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"dropped_old\"] == 1 and out[\"count\"] == 0\n\n    def test_undated_kept_by_default_dropped_with_dated_only(self, cfg, tmp_path, capsys):\n        with Store(str(tmp_path / \"jobs.db\")) as s:\n            s.diff([Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Undated\", url=\"u\")])\n        cmd_db_new([\"-c\", cfg, \"--posted-days\", \"7\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"undated_kept\"] == 1\n\n        cmd_db_new([\"-c\", cfg, \"--posted-days\", \"7\", \"--dated-only\"])\n        out2 = json.loads(capsys.readouterr().out)\n        assert out2[\"undated_dropped\"] == 1\n\n    def test_limit_truncates_at_first_seen_group_boundary_not_mid_group(self, cfg, tmp_path, capsys):\n        # Two jobs upserted in the same call share one first_seen timestamp —\n        # truncation must never split that group even if it exceeds --limit.\n        with Store(str(tmp_path / \"jobs.db\")) as s:\n            s.diff([Job(source=\"s\", company=\"c\", external_id=str(i), title=\"T\", url=\"u\")\n                     for i in range(5)])\n        cmd_db_new([\"-c\", cfg, \"--limit\", \"2\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"count\"] == 5  # whole group kept, not truncated to 2\n        assert out[\"truncated\"] is False\n\n\nclass TestDbMark:\n    def test_now_flag_sets_current_timestamp(self, cfg, capsys):\n        assert cmd_db_mark([\"--now\", \"-c\", cfg]) == 0\n\n    def test_invalid_watermark_returns_exit_2(self, cfg, capsys):\n        assert cmd_db_mark([\"not-a-date\", \"-c\", cfg]) == 2\n\n    def test_missing_both_args_returns_exit_2(self, cfg, capsys):\n        assert cmd_db_mark([\"-c\", cfg]) == 2\n\n\nclass TestNormalizeAts:\n    def test_replaces_em_dash_in_body_text(self):\n        html, counts = _normalize_ats(\"<p>a—b</p>\")\n        assert \"a-b\" in html and counts[\"em-dash\"] == 1\n\n    def test_does_not_touch_style_block(self):\n        html, counts = _normalize_ats('<style>p::before{content:\"—\"}</style>')\n        assert \"—\" in html and \"em-dash\" not in counts\n\n    def test_does_not_touch_script_block(self):\n        html, counts = _normalize_ats(\"<script>var x = '—';</script>\")\n        assert \"—\" in html and \"em-dash\" not in counts\n\n    def test_does_not_touch_tag_attributes(self):\n        html, counts = _normalize_ats('<div data-x=\"—\">text</div>')\n        assert 'data-x=\"—\"' in html\n\n    def test_smart_quotes_and_ellipsis(self):\n        html, counts = _normalize_ats(\"<p>\\u201cHi\\u201d\\u2026</p>\")\n        assert '\"Hi\"...' in html\n\n\nclass TestChromeBin:\n    def test_env_var_takes_priority(self, monkeypatch, tmp_path):\n        fake = tmp_path / \"chrome\"\n        fake.write_text(\"\")\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert _chrome_bin() == str(fake)\n\n    def test_falls_back_to_path_lookup(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        monkeypatch.setattr(\"shutil.which\", lambda name: \"/usr/bin/chromium\" if name == \"chromium\" else None)\n        assert _chrome_bin() == \"/usr/bin/chromium\"\n\n    def test_exits_when_nothing_found(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        monkeypatch.setattr(\"shutil.which\", lambda name: None)\n        monkeypatch.setattr(\"pathlib.Path.exists\", lambda self: False)\n        with pytest.raises(SystemExit):\n            _chrome_bin()\n\n\nclass TestMainDispatch:\n    def test_mode_words_split_before_first_flag(self):\n        from agent import main\n        import sys\n        # \"scan\" \"-i\" \"--foo\" -> mode_words=[\"scan\"], interactive=True\n        # verified via run_claude args in an integration-style test with a mock\n```\n\n---\n\n### Summary table\n\n| Module | Functions/branches with 0 coverage | Highest-risk gap |\n|---|---|---|\n| `models.py` | `parse_posted_at` (5 branches), `Job.key`/`content_hash`/`to_row` | epoch ms/s boundary miscalculation |\n| `filters.py` | `match`, `filter_jobs` | exclude/include precedence, \"keep unparseable dates\" rule |\n| `store.py` | `diff`, `_migrate`, `next_seq`, `added_since` | `next_seq` race safety — the one thing `BEGIN IMMEDIATE` exists for is unverified |\n| `notify.py` | all 5 notifiers + `dispatch` | `dispatch`'s fault isolation (one bad notifier shouldn't kill the run) is unverified |\n| `fetchers.py` | `_request` retry/backoff, `_balanced_json`, all 18 ATS parsers, all pagination loops, `fetch_all` concurrency/fault-isolation | zero tests despite the module explicitly being designed for mock-transport testing |\n| `pipeline.py` | `run` (dry-run vs persisted), `load_config` defaults | no end-to-end integration test exists at all |\n| `cli.py` | arg parsing → `run_sync` wiring | untested but low-risk (thin wrapper) |\n| `agent.py` | `cmd_db_new` group-truncation/posted-days logic, `_normalize_ats` tag/text split, `_chrome_bin` discovery order | `cmd_db_new`'s \"never split a first_seen group\" invariant is the most fragile untested logic in the repo |\n\nIf you want, I can scaffold the `tests/` directory with these files and add `pytest`/`pytest-asyncio` to a `requirements-dev.txt` — say the word and I'll wire it up and run the suite.\n",
