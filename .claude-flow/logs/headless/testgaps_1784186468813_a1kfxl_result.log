        "title": "tests/test_fetchers_pagination.py",
        "content": "import httpx\nimport pytest\nimport fetchers\n\n@pytest.mark.asyncio\nasync def test_fetch_optiver_stops_when_page_empty():\n    pages = {0: {\"items\": [{\"title\": \"A\", \"href\": \"/1\"}]}, 1: {\"items\": []}}\n    def handler(request):\n        n = int(request.url.params[\"from\"]) // 16\n        return httpx.Response(200, json=pages.get(n, {\"items\": []}))\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetchers.fetch_optiver(client, {\"company\": \"optiver\"})\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\nasync def test_fetch_optiver_respects_max_pages_cap():\n    def handler(request):  # always returns one fresh item -> would loop forever\n        n = int(request.url.params[\"from\"])\n        return httpx.Response(200, json={\"items\": [{\"title\": f\"J{n}\", \"href\": f\"/{n}\"}]})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetchers.fetch_optiver(client, {\"company\": \"optiver\", \"max_pages\": 3})\n    assert len(jobs) == 3\n\n@pytest.mark.asyncio\nasync def test_fetch_ashby_falls_back_to_hosted_page_on_404():\n    def handler(request):\n        if \"posting-api\" in str(request.url):\n            return httpx.Response(404)\n        html = ('window.__appData = {\"jobBoard\": {\"jobPostings\": '\n                '[{\"id\": \"1\", \"title\": \"SWE\", \"isListed\": true}]}}')\n        return httpx.Response(200, text=html)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetchers.fetch_ashby(client, {\"company\": \"whatnot\"})\n    assert jobs[0].external_id == \"1\"\n\n@pytest.mark.asyncio\nasync def test_fetch_ashby_raises_when_no_appdata_and_no_api():\n    def handler(request):\n        if \"posting-api\" in str(request.url):\n            return httpx.Response(404)\n        return httpx.Response(200, text=\"<html>nothing here</html>\")\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    with pytest.raises(RuntimeError, match=\"no posting-api and no __appData\"):\n        await fetchers.fetch_ashby(client, {\"company\": \"x\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_workday_stops_at_safety_cap():\n    def handler(request):\n        return httpx.Response(200, json={\"jobPostings\": [{\"title\": \"J\",\n            \"bulletFields\": [\"1\"], \"externalPath\": \"/1\"}], \"total\": 100000})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetchers.fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\"})\n    assert len(jobs) <= 5000 // 20 + 1  # bounded by the `offset > 5000` cap\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_strips_for_semicolon_prefix_and_parses_json():\n    body = 'for (;;);{\"data\": {\"job_search_with_featured_jobs_v2\": {\"all_jobs\": []}}}'\n    def handler(request):\n        if request.method == \"POST\":\n            return httpx.Response(200, text=body)\n        return httpx.Response(200, text='\"LSD\",[],{\"token\":\"tok\"} \"__spin_r\":1')\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetchers.fetch_meta(client, {\"company\": \"meta\"})\n    assert jobs == []\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_raises_on_graphql_errors():\n    def handler(request):\n        if request.method == \"POST\":\n            return httpx.Response(200, text='{\"errors\": [{\"message\": \"doc_id invalid\"}]}')\n        return httpx.Response(200, text=\"\")\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    with pytest.raises(RuntimeError, match=\"doc_id invalid\"):\n        await fetchers.fetch_meta(client, {})\n\n\nclass TestFetchSourceAndAll:\n    @pytest.mark.asyncio\n    async def test_fetch_source_unknown_ats_raises_valueerror(self):\n        client = httpx.AsyncClient(transport=httpx.MockTransport(lambda r: httpx.Response(200)))\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            await fetchers.fetch_source(client, {\"ats\": \"nonexistent\"})\n\n    @pytest.mark.asyncio\n    async def test_fetch_all_continues_after_one_source_fails(self, capsys):\n        def handler(request):\n            if \"greenhouse\" in str(request.url):\n                return httpx.Response(500)\n            return httpx.Response(200, json={\"jobs\": []})\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        sources = [{\"ats\": \"greenhouse\", \"company\": \"bad\"},\n                   {\"ats\": \"greenhouse\", \"company\": \"good\"}]\n        # both hit /jobs so make bad's company distinguishable via url match above\n        jobs = await fetchers.fetch_all(sources, client=client)\n        assert jobs == []  # no crash — failures degrade to empty list\n        assert \"failed\" in capsys.readouterr().out\n\n    @pytest.mark.asyncio\n    async def test_fetch_all_respects_concurrency_semaphore(self):\n        in_flight = {\"n\": 0, \"max\": 0}\n        async def one(client, src):\n            in_flight[\"n\"] += 1\n            in_flight[\"max\"] = max(in_flight[\"max\"], in_flight[\"n\"])\n            await fetchers.asyncio.sleep(0.01)\n            in_flight[\"n\"] -= 1\n            return []\n        import unittest.mock as mock\n        with mock.patch.object(fetchers, \"fetch_source\", one):\n            await fetchers.fetch_all([{\"ats\": \"x\"}] * 20, concurrency=3)\n        assert in_flight[\"max\"] <= 3\n```\n\n---\n\n",
