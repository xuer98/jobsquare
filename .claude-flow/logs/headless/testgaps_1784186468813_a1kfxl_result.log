        "title": "tests/test_filters.py",
        "content": "from datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef job(**kw):\n    base = dict(source=\"s\", company=\"c\", external_id=\"1\", title=\"Backend Engineer\",\n                url=\"u\", location=\"Remote - US\", department=\"Platform\")\n    base.update(kw)\n    return Job(**base)\n\ndef test_include_keyword_matches_whole_word_only():\n    assert match(job(title=\"Cat Herder\"), include=[\"cat\"])\n    assert not match(job(title=\"Concatenate\"), include=[\"cat\"])  # no substring match\n\ndef test_exclude_wins_over_include():\n    j = job(title=\"Senior Backend Engineer\")\n    assert not match(j, include=[\"backend\"], exclude=[\"senior\"])\n\ndef test_case_insensitive():\n    assert match(job(title=\"BACKEND\"), include=[\"backend\"])\n\ndef test_locations_substring_match():\n    assert match(job(location=\"San Francisco, CA\"), locations=[\"san francisco\"])\n    assert not match(job(location=\"NYC\"), locations=[\"san francisco\"])\n\ndef test_no_rules_keeps_everything():\n    assert match(job())\n\ndef test_cutoff_drops_confirmed_old_posting():\n    old = job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n    cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n    assert not match(old, cutoff=cutoff)\n\ndef test_cutoff_keeps_unparseable_date_rather_than_dropping():\n    j = job(posted_at=\"Posted 3 Days Ago\")  # Workday prose, unparseable\n    cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n    assert match(j, cutoff=cutoff)\n\ndef test_cutoff_keeps_no_posted_at():\n    assert match(job(posted_at=\"\"), cutoff=datetime.now(timezone.utc))\n\ndef test_filter_jobs_wires_max_age_days_to_cutoff():\n    fresh = job(external_id=\"1\", posted_at=datetime.now(timezone.utc).isoformat())\n    stale = job(external_id=\"2\", posted_at=(datetime.now(timezone.utc)\n                                             - timedelta(days=10)).isoformat())\n    out = filter_jobs([fresh, stale], {\"max_age_days\": 3})\n    assert [j.external_id for j in out] == [\"1\"]\n\ndef test_include_keyword_with_regex_special_chars_is_escaped():\n    j = job(title=\"C++ Developer\")\n    assert match(j, include=[\"C++\"])\n```\n\n---\n\n",
