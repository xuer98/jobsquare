        "code": "# tests/test_notify.py\nimport pytest\nimport httpx\nfrom models import Job\nimport notify\n\ndef job(**kw):\n    base = dict(source=\"s\", company=\"Acme\", external_id=\"1\", title=\"Engineer\",\n                url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestNotifyConsole:\n    def test_prints_no_fresh_listings_when_both_empty(self, capsys):\n        notify.notify_console([], [])\n        assert \"No fresh listings\" in capsys.readouterr().out\n\n    def test_prints_new_and_updated_sections(self, capsys):\n        notify.notify_console([job()], [job(external_id=\"2\")])\n        out = capsys.readouterr().out\n        assert \"NEW listing\" in out and \"UPDATED listing\" in out\n\n\nclass TestNotifySlack:\n    def test_noop_when_env_var_unset(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        called = []\n        monkeypatch.setattr(httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_slack([job()], [])\n        assert not called\n\n    def test_noop_when_no_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n        called = []\n        monkeypatch.setattr(httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_slack([], [])\n        assert not called\n\n    def test_posts_expected_payload(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n        captured = {}\n        def fake_post(url, json, timeout):\n            captured.update(url=url, json=json)\n        monkeypatch.setattr(httpx, \"post\", fake_post)\n        notify.notify_slack([job()], [])\n        assert \"Engineer\" in captured[\"json\"][\"text\"]\n\n\nclass TestNotifySms:\n    @pytest.fixture(autouse=True)\n    def env(self, monkeypatch):\n        for k in (\"TWILIO_ACCOUNT_SID\", \"TWILIO_AUTH_TOKEN\", \"TWILIO_FROM\", \"TWILIO_TO\"):\n            monkeypatch.setenv(k, \"x\")\n\n    def test_noop_missing_any_of_four_vars(self, monkeypatch):\n        monkeypatch.delenv(\"TWILIO_TO\", raising=False)\n        called = []\n        monkeypatch.setattr(httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_sms([job()], [])\n        assert not called\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        def fake_post(*a, **k):\n            req = httpx.Request(\"POST\", \"https://api.twilio.com/x\")\n            resp = httpx.Response(400, request=req)\n            return resp\n        monkeypatch.setattr(httpx, \"post\", fake_post)\n        with pytest.raises(httpx.HTTPStatusError):\n            notify.notify_sms([job()], [])\n\n    def test_sms_body_truncates_and_counts_remainder(self):\n        jobs = [job(external_id=str(i), title=f\"J{i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n\n    def test_sms_body_is_ascii_only(self):\n        body = notify._sms_body([job(title=\"Café • Role\")], [])\n        body.encode(\"ascii\")  # raises UnicodeEncodeError if non-ASCII sneaks in\n\n\nclass TestDispatch:\n    def test_one_notifier_failure_does_not_block_others(self, monkeypatch, capsys):\n        def boom(new, changed): raise RuntimeError(\"smtp down\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, notify.notify_console])\n        notify.dispatch([job()], [])\n        out = capsys.readouterr().out\n        assert \"notifier boom failed\" in out\n        assert \"NEW listing\" in out  # console notifier still ran"
