        "code": "# tests/test_agent.py\nimport json\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nfrom agent import cmd_db_new, cmd_db_mark, _normalize_ats, _chrome_bin\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef cfg(tmp_path, monkeypatch):\n    db = tmp_path / \"jobs.db\"\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(f\"db: {db}\\nsources: []\\n\")\n    monkeypatch.chdir(tmp_path)\n    return str(cfg_path)\n\nclass TestDbNew:\n    def test_first_run_uses_since_days_window(self, cfg, capsys):\n        with Store(Store.__init__.__globals__ and cfg) :  # see note below\n            pass\n        # Simpler: seed via Store directly against the same db path\n        cmd_db_new([\"-c\", cfg])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n\n    def test_posted_days_drops_confirmed_old_and_counts_it(self, cfg, capsys, tmp_path):\n        with Store(str(tmp_path / \"jobs.db\")) as s:\n            s.diff([Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Old\",\n                         url=\"u\", posted_at=(datetime.now(timezone.utc)\n                         - timedelta(days=30)).isoformat())])\n        cmd_db_new([\"-c\", cfg, \"--posted-days\", \"7\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"dropped_old\"] == 1 and out[\"count\"] == 0\n\n    def test_undated_kept_by_default_dropped_with_dated_only(self, cfg, tmp_path, capsys):\n        with Store(str(tmp_path / \"jobs.db\")) as s:\n            s.diff([Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Undated\", url=\"u\")])\n        cmd_db_new([\"-c\", cfg, \"--posted-days\", \"7\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"undated_kept\"] == 1\n\n        cmd_db_new([\"-c\", cfg, \"--posted-days\", \"7\", \"--dated-only\"])\n        out2 = json.loads(capsys.readouterr().out)\n        assert out2[\"undated_dropped\"] == 1\n\n    def test_limit_truncates_at_first_seen_group_boundary_not_mid_group(self, cfg, tmp_path, capsys):\n        # Two jobs upserted in the same call share one first_seen timestamp —\n        # truncation must never split that group even if it exceeds --limit.\n        with Store(str(tmp_path / \"jobs.db\")) as s:\n            s.diff([Job(source=\"s\", company=\"c\", external_id=str(i), title=\"T\", url=\"u\")\n                     for i in range(5)])\n        cmd_db_new([\"-c\", cfg, \"--limit\", \"2\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"count\"] == 5  # whole group kept, not truncated to 2\n        assert out[\"truncated\"] is False\n\n\nclass TestDbMark:\n    def test_now_flag_sets_current_timestamp(self, cfg, capsys):\n        assert cmd_db_mark([\"--now\", \"-c\", cfg]) == 0\n\n    def test_invalid_watermark_returns_exit_2(self, cfg, capsys):\n        assert cmd_db_mark([\"not-a-date\", \"-c\", cfg]) == 2\n\n    def test_missing_both_args_returns_exit_2(self, cfg, capsys):\n        assert cmd_db_mark([\"-c\", cfg]) == 2\n\n\nclass TestNormalizeAts:\n    def test_replaces_em_dash_in_body_text(self):\n        html, counts = _normalize_ats(\"<p>a—b</p>\")\n        assert \"a-b\" in html and counts[\"em-dash\"] == 1\n\n    def test_does_not_touch_style_block(self):\n        html, counts = _normalize_ats('<style>p::before{content:\"—\"}</style>')\n        assert \"—\" in html and \"em-dash\" not in counts\n\n    def test_does_not_touch_script_block(self):\n        html, counts = _normalize_ats(\"<script>var x = '—';</script>\")\n        assert \"—\" in html and \"em-dash\" not in counts\n\n    def test_does_not_touch_tag_attributes(self):\n        html, counts = _normalize_ats('<div data-x=\"—\">text</div>')\n        assert 'data-x=\"—\"' in html\n\n    def test_smart_quotes_and_ellipsis(self):\n        html, counts = _normalize_ats(\"<p>\\u201cHi\\u201d\\u2026</p>\")\n        assert '\"Hi\"...' in html\n\n\nclass TestChromeBin:\n    def test_env_var_takes_priority(self, monkeypatch, tmp_path):\n        fake = tmp_path / \"chrome\"\n        fake.write_text(\"\")\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert _chrome_bin() == str(fake)\n\n    def test_falls_back_to_path_lookup(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        monkeypatch.setattr(\"shutil.which\", lambda name: \"/usr/bin/chromium\" if name == \"chromium\" else None)\n        assert _chrome_bin() == \"/usr/bin/chromium\"\n\n    def test_exits_when_nothing_found(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        monkeypatch.setattr(\"shutil.which\", lambda name: None)\n        monkeypatch.setattr(\"pathlib.Path.exists\", lambda self: False)\n        with pytest.raises(SystemExit):\n            _chrome_bin()\n\n\nclass TestMainDispatch:\n    def test_mode_words_split_before_first_flag(self):\n        from agent import main\n        import sys\n        # \"scan\" \"-i\" \"--foo\" -> mode_words=[\"scan\"], interactive=True\n        # verified via run_claude args in an integration-style test with a mock"
