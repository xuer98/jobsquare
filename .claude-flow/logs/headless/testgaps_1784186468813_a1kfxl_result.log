        "title": "tests/test_store.py",
        "content": "import sqlite3\nimport threading\nimport pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"jobs.db\")\n    yield s\n    s.close()\n\ndef job(external_id=\"1\", title=\"Engineer\", **kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=external_id,\n                title=title, url=\"u\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_is_neither_new_nor_changed(self, store):\n        store.diff([job()])\n        new, changed = store.diff([job()])\n        assert new == [] and changed == []\n\n    def test_changed_content_hash_reports_as_changed(self, store):\n        store.diff([job(title=\"Engineer I\")])\n        new, changed = store.diff([job(title=\"Engineer II\")])\n        assert new == [] and len(changed) == 1\n\n    def test_unchanged_job_still_bumps_last_seen(self, store):\n        store.diff([job()])\n        row1 = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        store.diff([job()])\n        row2 = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        assert row2[\"last_seen\"] >= row1[\"last_seen\"]\n\n    def test_duplicate_key_within_same_batch(self, store):\n        # Same connection sees its own uncommitted writes — verify the second\n        # occurrence in one call is treated as an update, not a crash/dup insert.\n        new, changed = store.diff([job(title=\"A\"), job(title=\"B\")])\n        assert store.count() == 1\n\n    def test_empty_batch_is_noop(self, store):\n        assert store.diff([]) == ([], [])\n\n\nclass TestMigration:\n    def test_legacy_db_without_salary_range_gets_column_added(self, tmp_path):\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(path)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        s = Store(path)\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n        s.close()\n\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta_roundtrip(self, store):\n        store.set_meta(\"k\", \"v1\")\n        assert store.get_meta(\"k\") == \"v1\"\n\n    def test_set_meta_upserts(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n\nclass TestNextSeq:\n    def test_starts_at_one(self, store):\n        assert store.next_seq(\"seq\") == 1\n\n    def test_increments_sequentially(self, store):\n        assert [store.next_seq(\"seq\") for _ in range(3)] == [1, 2, 3]\n\n    def test_independent_keys_dont_interfere(self, store):\n        store.next_seq(\"a\")\n        assert store.next_seq(\"b\") == 1\n\n    def test_concurrent_callers_dont_double_assign(self, tmp_path):\n        # Regression test for the race the BEGIN IMMEDIATE lock exists to prevent.\n        path = tmp_path / \"concurrent.db\"\n        results = []\n        def worker():\n            with Store(path) as s:\n                results.append(s.next_seq(\"report_seq\"))\n        threads = [threading.Thread(target=worker) for _ in range(10)]\n        for t in threads: t.start()\n        for t in threads: t.join()\n        assert sorted(results) == list(range(1, 11))  # no duplicates/gaps\n\n\nclass TestAddedSince:\n    def test_strictly_after_excludes_exact_ts(self, store):\n        store.diff([job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[\"first_seen\"]\n        assert store.added_since(ts) == []\n\n    def test_ordering_oldest_first(self, store):\n        store.diff([job(external_id=\"1\")])\n        store.diff([job(external_id=\"2\")])\n        rows = store.added_since(\"2000-01-01T00:00:00+00:00\")\n        assert [r[\"external_id\"] for r in rows] == [\"1\", \"2\"]\n\n\ndef test_count_reflects_distinct_jobs(store):\n    store.diff([job(external_id=\"1\"), job(external_id=\"2\")])\n    assert store.count() == 2\n```\n\n---\n\n",
