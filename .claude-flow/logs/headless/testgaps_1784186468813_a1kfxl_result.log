        "title": "tests/test_models.py",
        "content": "import pytest\nfrom datetime import datetime, timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_and_none_return_none(self):\n        assert parse_posted_at(\"\") is None\n\n    def test_ms_epoch_lever_style(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt == datetime.fromtimestamp(1643241332.430, tz=timezone.utc)\n\n    def test_second_epoch(self):\n        dt = parse_posted_at(\"1643241332\")\n        assert dt.tzinfo is not None\n\n    def test_epoch_boundary_exactly_1e12(self):\n        # 1_000_000_000_000 must be treated as ms, not s (year-33658 bug otherwise)\n        dt = parse_posted_at(\"1000000000000\")\n        assert dt.year < 2100\n\n    def test_negative_epoch(self):\n        dt = parse_posted_at(\"-100\")\n        assert dt is not None\n\n    def test_iso_with_trailing_z(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00Z\")\n        assert dt == datetime(2026, 1, 15, 10, 0, tzinfo=timezone.utc)\n\n    def test_iso_naive_gets_utc(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_with_explicit_offset_preserved(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00+05:00\")\n        assert dt.utcoffset().total_seconds() == 5 * 3600\n\n    def test_unparseable_prose_returns_none(self):\n        # Workday sends \"Posted 3 Days Ago\"\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_whitespace_only(self):\n        assert parse_posted_at(\"   \") is None\n\n\nclass TestJob:\n    def _job(self, **kw):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                    title=\"Engineer\", url=\"https://x/1\")\n        base.update(kw)\n        return Job(**base)\n\n    def test_key_is_stable_identity(self):\n        assert self._job().key == \"greenhouse:acme:1\"\n\n    def test_key_survives_title_change(self):\n        a, b = self._job(title=\"A\"), self._job(title=\"B\")\n        assert a.key == b.key\n\n    def test_content_hash_changes_on_title(self):\n        a, b = self._job(title=\"A\"), self._job(title=\"B\")\n        assert a.content_hash != b.content_hash\n\n    def test_content_hash_stable_when_only_salary_changes(self):\n        # salary/dept/employment_type not in the hash blob except department\n        a = self._job(salary_range=\"100k\")\n        b = self._job(salary_range=\"200k\")\n        assert a.content_hash == b.content_hash\n\n    def test_content_hash_changes_on_department(self):\n        a, b = self._job(department=\"Eng\"), self._job(department=\"Sales\")\n        assert a.content_hash != b.content_hash\n\n    def test_to_row_drops_raw_adds_key_and_hash(self):\n        row = self._job(raw={\"secret\": 1}).to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == \"greenhouse:acme:1\"\n        assert \"content_hash\" in row\n\n    def test_posted_dt_delegates_to_parse_posted_at(self):\n        assert self._job(posted_at=\"\").posted_dt is None\n```\n\n---\n\n",
