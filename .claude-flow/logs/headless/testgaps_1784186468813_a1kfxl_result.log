        "title": "tests/test_fetchers_core.py",
        "content": "import httpx\nimport pytest\nimport fetchers\n\n@pytest.mark.asyncio\nasync def test_request_retries_on_502_then_succeeds(monkeypatch):\n    monkeypatch.setattr(fetchers.asyncio, \"sleep\", lambda s: None)  # no real waits\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        if calls[\"n\"] < 3:\n            return httpx.Response(502)\n        return httpx.Response(200, json={\"ok\": True})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    r = await fetchers._request(client, \"https://x\")\n    assert r.json() == {\"ok\": True}\n    assert calls[\"n\"] == 3\n\n@pytest.mark.asyncio\nasync def test_request_gives_up_after_max_retries(monkeypatch):\n    monkeypatch.setattr(fetchers.asyncio, \"sleep\", lambda s: None)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(\n        lambda r: httpx.Response(503)))\n    with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n        await fetchers._request(client, \"https://x\", retries=2)\n\n@pytest.mark.asyncio\nasync def test_request_does_not_retry_non_retryable_4xx(monkeypatch):\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        return httpx.Response(404)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    with pytest.raises(RuntimeError):\n        await fetchers._request(client, \"https://x\")\n    assert calls[\"n\"] == 1  # no retry on a non-transient 404\n\n\nclass TestBalancedJson:\n    def test_extracts_simple_object(self):\n        text = 'prefix {\"a\": 1} suffix'\n        assert fetchers._balanced_json(text, text.find(\"{\")) == '{\"a\": 1}'\n\n    def test_handles_nested_braces(self):\n        text = '{\"a\": {\"b\": 1}}'\n        assert fetchers._balanced_json(text, 0) == text\n\n    def test_ignores_braces_inside_strings(self):\n        text = '{\"a\": \"} not a brace {\"}'\n        assert fetchers._balanced_json(text, 0) == text\n\n    def test_handles_escaped_quotes_in_strings(self):\n        text = r'{\"a\": \"he said \\\"hi\\\"\"}'\n        assert fetchers._balanced_json(text, 0) == text\n\n    def test_returns_none_when_unterminated(self):\n        assert fetchers._balanced_json('{\"a\": 1', 0) is None\n```\n\n**Priority B — the parser functions (pure, cheap, high-value; representative sample — replicate the pattern per ATS):**\n\n```python\n",
