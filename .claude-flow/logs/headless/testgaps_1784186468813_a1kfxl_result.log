.db'}\\n\"\n        \"filters:\\n  exclude_keywords: [Manager]\\n\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[matching, excluded])), \\\n         patch(\"pipeline.dispatch\"):\n        result = await pipeline.run(cfg_path)\n    assert result[\"matched\"] == 1"
