        "title": "tests/test_fetchers_parsers.py",
        "content": "from fetchers import (parse_greenhouse, parse_lever, parse_ashby, _lever_salary,\n                       _ashby_salary, parse_amazon, _amazon_posted_at,\n                       parse_apple, _apple_posted_at, parse_meta, _bd_location,\n                       parse_google, _ds1_posted_at)\n\ndef test_parse_greenhouse_maps_fields():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\",\n                       \"location\": {\"name\": \"NYC\"}, \"departments\": [{\"name\": \"Eng\"}],\n                       \"updated_at\": \"2026-01-01T00:00:00Z\"}]}\n    jobs = parse_greenhouse(\"acme\", data)\n    assert jobs[0].external_id == \"1\" and jobs[0].location == \"NYC\"\n\ndef test_parse_greenhouse_empty_jobs_list():\n    assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\ndef test_lever_salary_formats_range_with_commas():\n    j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n    assert _lever_salary(j) == \"USD 100,000–150,000\"\n\ndef test_lever_salary_falls_back_to_plain_description():\n    j = {\"salaryDescriptionPlain\": \"Competitive\"}\n    assert _lever_salary(j) == \"Competitive\"\n\ndef test_lever_salary_missing_everything_is_empty_string():\n    assert _lever_salary({}) == \"\"\n\ndef test_parse_ashby_skips_unlisted_jobs():\n    data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"hidden\"},\n                     {\"id\": \"2\", \"title\": \"visible\"}]}\n    jobs = parse_ashby(\"acme\", data)\n    assert [j.external_id for j in jobs] == [\"2\"]\n\ndef test_amazon_posted_at_parses_us_date():\n    assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\ndef test_amazon_posted_at_malformed_returns_empty():\n    assert _amazon_posted_at(\"not a date\") == \"\"\n\ndef test_parse_amazon_falls_back_to_id_icims():\n    jobs = parse_amazon(\"amazon\", [{\"id_icims\": \"999\", \"title\": \"SDE\",\n                                     \"job_path\": \"/x\"}])\n    assert jobs[0].external_id == \"999\"\n\ndef test_apple_posted_at_trims_nanoseconds():\n    assert _apple_posted_at(\"2026-01-15T10:00:03.812668311Z\") == \\\n        \"2026-01-15T10:00:03.812668+00:00\"\n\ndef test_apple_posted_at_empty_input():\n    assert _apple_posted_at(\"\") == \"\"\n\ndef test_parse_meta_dedupes_by_id():\n    results = [{\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"1\", \"title\": \"A-dup\"}]\n    assert len(parse_meta(\"meta\", results)) == 1\n\ndef test_parse_meta_skips_missing_id():\n    assert parse_meta(\"meta\", [{\"title\": \"no id\"}]) == []\n\ndef test_bd_location_walks_parent_chain():\n    city = {\"en_name\": \"SF\", \"parent\": {\"en_name\": \"CA\",\n             \"parent\": {\"en_name\": \"US\", \"parent\": None}}}\n    assert _bd_location(city) == \"SF, CA, US\"\n\ndef test_bd_location_none_returns_empty():\n    assert _bd_location(None) == \"\"\n\ndef test_ds1_posted_at_prefers_create_over_update_time():\n    job = [None] * 15\n    job[12] = [1700000000]  # create\n    job[13] = [1800000000]  # update\n    assert \"2023\" in _ds1_posted_at(job)  # 1700000000 -> 2023, not the later ts\n\ndef test_ds1_posted_at_no_timestamps_returns_empty():\n    assert _ds1_posted_at([None] * 10) == \"\"\n\ndef test_parse_google_skips_falsy_first_element():\n    assert parse_google(\"google\", [None, [\"\"], [123]]) == []\n```\n\n*(Apply the same pure-function test pattern to `parse_smartrecruiters`, `parse_recruitee`, `parse_workable`, `parse_deshaw`, `parse_twosigma`, `parse_optiver`, `parse_eightfold`, `parse_bytedance`, `parse_phenom`, `parse_microsoft`, `parse_netflix` — each has at least one documented fallback/defensive branch in the source comments that has no assertion backing it today.)*\n\n**Priority C — the async fetch/pagination functions (need `httpx.MockTransport`):**\n\n```python\n",
