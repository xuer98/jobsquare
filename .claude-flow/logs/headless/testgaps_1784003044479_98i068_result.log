        "content": "import pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_epoch_milliseconds_lever(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt.tzinfo == timezone.utc\n        assert dt.year == 2022\n\n    def test_epoch_seconds(self):\n        dt = parse_posted_at(\"1643241332\")\n        assert dt.year == 2022\n\n    def test_iso8601_with_z_suffix(self):\n        assert parse_posted_at(\"2024-01-15T10:00:00Z\").tzinfo is not None\n\n    def test_iso8601_naive_gets_utc(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_workday_prose_is_unparseable(self):\n        # documents current behavior: recency filter can't act on Workday dates\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    @pytest.mark.parametrize(\"value\", [\"\", None])\n    def test_empty_returns_none(self, value):\n        assert parse_posted_at(value) is None\n\n    def test_garbage_string_returns_none(self):\n        assert parse_posted_at(\"not a date\") is None\n\nclass TestJob:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"Engineer\", url=\"https://x\", location=\"NYC\",\n                     department=\"Eng\")\n        return Job(**{**base, **overrides})\n\n    def test_key_is_stable_composite(self):\n        assert self._job().key == \"greenhouse:acme:1\"\n\n    def test_content_hash_ignores_raw_and_posted_at(self):\n        a = self._job(raw={\"x\": 1}, posted_at=\"2024-01-01\")\n        b = self._job(raw={\"x\": 2}, posted_at=\"2024-06-01\")\n        assert a.content_hash == b.content_hash\n\n    def test_content_hash_changes_on_title_edit(self):\n        a = self._job()\n        b = self._job(title=\"Senior Engineer\")\n        assert a.content_hash != b.content_hash\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self):\n        row = self._job(raw={\"secret\": 1}).to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] and row[\"content_hash\"]\n```\n\n---\n\n",
