        "title": "tests/test_parsers.py",
        "content": "from fetchers import (parse_greenhouse, parse_lever, _lever_salary,\n                       parse_google, _extract_ds1, _ds1_posted_at,\n                       parse_deshaw, _amazon_posted_at, parse_amazon)\n\nclass TestGreenhouse:\n    def test_maps_fields(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\",\n                           \"absolute_url\": \"https://x/1\",\n                           \"location\": {\"name\": \"NYC\"},\n                           \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Core\"}],\n                           \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        [j] = parse_greenhouse(\"acme\", data)\n        assert j.department == \"Eng, Core\"\n        assert j.location == \"NYC\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_optional_fields_dont_crash(self):\n        [j] = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1}]})\n        assert j.title == \"\" and j.location == \"\"\n\nclass TestLeverSalary:\n    def test_range_with_currency(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_falls_back_to_plain_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\nclass TestGoogleDs1:\n    def test_extract_ds1_happy_path(self):\n        html = \"before key: 'ds:1', ..., data:[[[\\\"a\\\"]]] , sideChannel:{} after\"\n        assert _extract_ds1(html) == [[\"a\"]]\n\n    def test_extract_ds1_missing_blob_returns_empty(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_extract_ds1_malformed_json_returns_empty(self):\n        html = \"key: 'ds:1', data:[[not json]] , sideChannel:{}\"\n        assert _extract_ds1(html) == []\n\n    def test_ds1_posted_at_prefers_create_time_index_12(self):\n        job = [None] * 15\n        job[12] = [1700000000]\n        job[13] = [1800000000]\n        assert _ds1_posted_at(job) != \"\"\n        assert \"2023\" in _ds1_posted_at(job)  # create-time, not update-time\n\n    def test_ds1_posted_at_missing_all_indices(self):\n        assert _ds1_posted_at([None] * 5) == \"\"\n\n    def test_parse_google_skips_falsy_id_entries(self):\n        assert parse_google(\"google\", [None, [0], []]) == []\n\nclass TestDeshaw:\n    def test_dedups_repeated_cards(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">SWE</span>'\n                '<span class=\"location\">NYC</span></div>'\n                '<div data-job-id=\"1\"><span class=\"job-display-name\">SWE</span></div>')\n        out = parse_deshaw(\"deshaw\", page)\n        assert len(out) == 1\n\n    def test_skips_cards_missing_title(self):\n        page = '<div data-job-id=\"1\"></div>'\n        assert parse_deshaw(\"deshaw\", page) == []\n\nclass TestAmazonDate:\n    def test_valid_date_normalizes_to_iso(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_garbage_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_missing_returns_empty(self):\n        assert _amazon_posted_at(\"\") == \"\"\n```\n\n> **Note:** the same pattern (happy path + empty/missing input + malformed input) needs to be replicated for the currently-untested `parse_ashby`, `parse_smartrecruiters`, `parse_recruitee`, `parse_workable`, `parse_twosigma`, `parse_optiver`, `parse_meta`, `parse_microsoft`, `parse_netflix`, and the inline Workday posting mapping in `fetch_workday`. Each has at least one non-obvious normalization worth pinning (e.g. `parse_workable`'s dict-vs-flat `location` shape, `parse_netflix`'s comma-to-`\", \"` location respacing, `parse_recruitee`'s assembled-vs-flat location).\n\n",
