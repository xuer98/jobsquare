        "content": "import httpx, pytest\nfrom fetchers import _request\n\ndef _client(handler):\n    return httpx.AsyncClient(transport=httpx.MockTransport(handler))\n\n@pytest.mark.asyncio\nasync def test_retries_on_503_then_succeeds():\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        if calls[\"n\"] < 3:\n            return httpx.Response(503)\n        return httpx.Response(200, json={\"ok\": True})\n    async with _client(handler) as c:\n        r = await _request(c, \"https://x/y\", retries=4)\n    assert r.status_code == 200 and calls[\"n\"] == 3\n\n@pytest.mark.asyncio\nasync def test_exhausts_retries_and_raises_runtime_error():\n    async def handler(request): return httpx.Response(503)\n    async with _client(handler) as c:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(c, \"https://x/y\", retries=2)\n\n@pytest.mark.asyncio\nasync def test_404_currently_also_gets_retried(monkeypatch):\n    # documents current (likely unintended) behavior — 404 is not distinguished\n    # from a transient 503 and burns the full retry budget.\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        return httpx.Response(404)\n    async with _client(handler) as c:\n        with pytest.raises(RuntimeError):\n            await _request(c, \"https://x/y\", retries=3)\n    assert calls[\"n\"] == 3\n```\n\n",
