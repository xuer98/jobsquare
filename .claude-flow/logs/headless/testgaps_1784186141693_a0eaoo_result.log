        "title": "tests/test_models.py",
        "content": "import pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\n\nclass TestParsePostedAt:\n    def test_empty_and_none_return_none(self):\n        assert parse_posted_at(\"\") is None\n        assert parse_posted_at(None) is None\n\n    def test_lever_millisecond_epoch(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt.tzinfo == timezone.utc\n        assert dt.year == 2022\n\n    def test_second_epoch_below_threshold(self):\n        dt = parse_posted_at(\"1643241332\")  # 10-digit, seconds\n        assert dt.year == 2022\n\n    def test_epoch_boundary_at_1e12(self):\n        # exactly 1e12 must be treated as milliseconds per the >= check\n        dt = parse_posted_at(\"1000000000000\")\n        assert dt.year == 2001  # not 33658 if mis-treated as seconds\n\n    def test_iso8601_with_z_suffix(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso8601_naive_assumed_utc(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso8601_with_explicit_offset(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00+05:00\")\n        assert dt.utcoffset().total_seconds() == 5 * 3600\n\n    def test_unparseable_prose_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_whitespace_padded_value(self):\n        assert parse_posted_at(\"  2024-01-15T10:00:00Z  \") is not None\n\n    @pytest.mark.parametrize(\"bad\", [\"not-a-date\", \"NaN\", \"12.5.3\"])\n    def test_various_garbage_returns_none(self, bad):\n        assert parse_posted_at(bad) is None\n\n\nclass TestJob:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"42\",\n                     title=\"Engineer\", url=\"https://x/42\")\n        base.update(overrides)\n        return Job(**base)\n\n    def test_key_is_st