        "title": "tests/test_filters.py",
        "content": "import pytest\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                 title=\"Software Engineer\", url=\"https://x/1\",\n                 location=\"New York, NY\", department=\"Engineering\")\n    base.update(kw)\n    return Job(**base)\n\n\nclass TestMatchKeywords:\n    def test_include_word_boundary_excludes_substring_match(self):\n        j = make_job(title=\"Django Developer\")\n        assert match(j, include=[\"go\"]) is False\n\n    def test_include_matches_whole_word(self):\n        j = make_job(title=\"Go Backend Engineer\")\n        assert match(j, include=[\"go\"]) is True\n\n    def test_case_insensitive_include(self):\n        j = make_job(title=\"SOFTWARE ENGINEER\")\n        assert match(j, include=[\"software\"]) is True\n\n    def test_exclude_wins_over_include_when_both_match(self):\n        j = make_job(title=\"Senior Software Engineer - Intern Program\")\n        assert match(j, include=[\"software\"], exclude=[\"intern\"]) is False\n\n    def test_no_include_list_means_no_filtering(self):\n        assert match(make_job(), include=None) is True\n\n    def test_include_list_with_no_match_excludes(self):\n        assert match(make_job(title=\"Sales Rep\"), include=[\"engineer\"]) is False\n\n    def test_regex_special_characters_are_escaped(self):\n        j = make_job(title=\"C++ Engineer\")\n        assert match(j, include=[\"C++\"]) is True\n\n\nclass TestMatchLocations:\n    def test_substring_case_insensitive_match(self):\n        assert match(make_job(location=\"New York, NY\"), locations=[\"new york\"]) is True\n\n    def test_no_location_match_excludes(self):\n        assert match(make_job(location=\"London, UK\"), locations=[\"new york\"]) is False\n\n    def test_empty_locations_list_no_filtering(self):\n        assert match(make_job(), locations=None) is True\n\n\nclass TestMatchCutoff:\n    def test_old_parseable_date_is_dropped(self):\n        j = make_job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(j, cutoff=cutoff) is False\n\n    def test_recent_parseable_date_is_kept(self):\n        j = make_job(posted_at=datetime.now(timezone.utc).isoformat())\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(j, cutoff=cutoff) is True\n\n    def test_unparseable_date_is_kept_not_dropped(self):\n        j = make_job(posted_at=\"Posted 3 Days Ago\")\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(j, cutoff=cutoff) is True\n\n    def test_no_posted_at_is_kept(self):\n        j = make_job(posted_at=\"\")\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(j, cutoff=cutoff) is True\n\n\nclass TestFilterJobs:\n    def test_empty_rules_passthrough(self):\n        jobs = [make_job()]\n        assert filter_jobs(jobs, {}) == jobs\n\n    def test_max_age_days_builds_cutoff(self):\n        old = make_job(external_id=\"1\",\n                        posted_at=(datetime.now(timezone.utc) - timedelta(days=10)).isoformat())\n        new = make_job(external_id=\"2\", posted_at=datetime.now(timezone.utc).isoformat())\n        result = filter_jobs([old, new], {\"max_age_days\": 5})\n        assert result == [new]\n\n    def test_max_age_days_as_string_is_coerced_to_float(self):\n        old = make_job(posted_at=(datetime.now(timezone.utc) - timedelta(days=10)).isoformat())\n        assert filter_jobs([old], {\"max_age_days\": \"5\"}) == []\n\n    def test_combined_rules_all_apply(self):\n        j = make_job(title=\"Sales Engineer\", location=\"Austin, TX\")\n        rules = {\"include_keywords\": [\"engineer\"], \"exclude_keywords\": [\"sales\"],\n                  \"locations\": [\"austin\"]}\n        assert filter_jobs([j], rules) == []\n```\n\n---\n\n",
        "level": 1
