        "title": "tests/test_agent.py",
        "content": "import json\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nimport agent\n\n\nclass TestNormalizeAts:\n    def test_em_dash_and_smart_quotes_replaced(self):\n        html, counts = agent._normalize_ats(\"<p>a\\u2014b \\u201Cquoted\\u201D</p>\")\n        assert \"\\u2014\" not in html and \"\\u201C\" not in html\n        assert counts[\"em-dash\"] == 1\n\n    def test_style_and_script_blocks_untouched(self):\n        html, counts = agent._normalize_ats(\n            '<style>.x::before{content:\"\\u2014\"}</style><p>a\\u2014b</p>')\n        assert html.count(\"\\u2014\") == 1  # only the one inside <style> survives\n        assert counts[\"em-dash\"] == 1\n\n    def test_tag_attributes_untouched(self):\n        html, counts = agent._normalize_ats('<a title=\"\\u2014\">text</a>')\n        assert 'title=\"\\u2014\"' in html\n        assert \"em-dash\" not in counts\n\n    def test_no_special_chars_empty_counts(self):\n        html, counts = agent._normalize_ats(\"<p>plain text</p>\")\n        assert counts == {}\n\n\nclass TestChromeBin:\n    def test_chrome_path_env_var_takes_precedence(self, monkeypatch, tmp_path):\n        fake = tmp_path / \"chrome\"\n        fake.write_text(\"\")\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert agent._chrome_bin() == str(fake)\n\n    def test_exits_when_nothing_found(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        monkeypatch.setattr(agent.shutil, \"which\", lambda name: None)\n        monkeypatch.setattr(agent.Path, \"exists\", lambda self: False)\n        with pytest.raises(SystemExit):\n            agent._chrome_bin()\n\n\nclass TestCmdDbMark:\n    def test_now_flag_sets_current_time(self, tmp_path, capsys):\n        rc = agent.cmd_db_mark([\"--now\", \"-c\", str(tmp_path / \"missing.yaml\")])\n        # would need a config fixture; illustrates the shape\n\n    def test_invalid_watermark_exits_2(self, capsys):\n        rc = agent.cmd_db_mark([\"not-a-timestamp\"])\n        assert rc == 2\n        assert \"not an ISO timestamp\" in capsys.readouterr().err\n\n    def test_no_args_exits_2(self, capsys):\n        rc = agent.cmd_db_mark([])\n        assert rc == 2\n\n\nclass TestCmdDbNew:\n    # requires a real Store fixture wired via sources.yaml pointing at tmp_path\n    def test_group_boundary_truncation_never_splits_a_first_seen_group(self, tmp_path, monkeypatch):\n        # Insert two first_seen groups where group 2 alone exceeds --limit;\n        # assert `jobs` stops at the END of group 1, not mid-group-2, and\n        # `truncated=True`.\n        pass\n\n    def test_posted_days_keeps_undated_jobs_by_default(self, tmp_path, monkeypatch):\n        # rows with unparseable posted_at counted in undated_kept, present in output\n        pass\n\n    def test_dated_only_drops_undated_jobs(self, tmp_path, monkeypatch):\n        pass\n\n\nclass TestMainDispatch:\n    def test_bare_invocation_is_interactive(self, monkeypatch):\n        called = {}\n        monkeypatch.setattr(agent, \"run_claude\",\n                             lambda mode_words, interactive, extra: called.update(\n                                 mode_words=mode_words, interactive=interactive) or 0)\n        agent.main.__wrapped__ if False else None  # illustrative\n        import sys\n        monkeypatch.setattr(sys, \"argv\", [\"agent.py\"])\n        agent.main()\n        assert called[\"interactive\"] is True\n\n    def test_mode_words_split_at_first_flag(self, monkeypatch):\n        called = {}\n        monkeypatch.setattr(agent, \"run_claude\",\n                             lambda mode_words, interactive, extra: called.update(\n                                 mode_words=mode_words, extra=extra) or 0)\n        import sys\n        monkeypatch.setattr(sys, \"argv\", [\"agent.py\", \"scan\", \"--verbose\"])\n        agent.main()\n        assert called[\"mode_words\"] == [\"scan\"]\n        assert called[\"extra\"] == [\"--verbose\"]\n```\n\n---\n\n",
