        "title": "4. `pipeline.py` ‚Äî `load_config`, `run`, `run_sync`",
        "content": "\n**Untested entirely.** This is the orchestration seam ‚Äî the highest-value integration test target since it wires fetch ‚Üí filter ‚Üí dedup ‚Üí notify.\n\n**Gaps:**\n- `load_config`: defaults applied when keys missing (`sources`, `filters`, `db`, `concurrency`)\n- `load_config`: malformed YAML raises\n- `run` with `dry_run=True`: does NOT touch the store, returns `{\"matched\": N, \"new\": 0, \"changed\": 0}` unconditionally regardless of actual new/changed\n- `run` with `dry_run=False`: calls `store.diff`, calls `dispatch`, returns correct counts\n- `run`: fetch failures don't propagate (delegated to `fetch_all`, but verify pipeline doesn't swallow a total fetch exception either)\n- `run_sync` wraps `asyncio.run` correctly (can't be called from within an existing event loop ‚Äî not guarded, worth noting even if not fixing)\n\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_pipeline.py",
        "content": "import pytest\nimport yaml\nfrom unittest.mock import AsyncMock, patch\nfrom models import Job\nimport pipeline\n\n\n@pytest.fixture\ndef config_file(tmp_path):\n    def _write(cfg: dict):\n        p = tmp_path / \"sources.yaml\"\n        p.write_text(yaml.dump(cfg))\n        return p\n    return _write\n\n\nclass TestLoadConfig:\n    def test_defaults_applied_when_missing(self, config_file):\n        cfg = pipeline.load_config(config_file({}))\n        assert cfg[\"sources\"] == []\n        assert cfg[\"filters\"] == {}\n        assert cfg[\"db\"] == \"jobs.db\"\n        assert cfg[\"concurrency\"] == 8\n\n    def test_explicit_values_preserved(self, config_file):\n        cfg = pipeline.load_config(config_file({\"db\": \"custom.db\", \"concurrency\": 3}))\n        assert cfg[\"db\"] == \"custom.db\"\n        assert cfg[\"concurrency\"] == 3\n\n    def test_malformed_yaml_raises(self, tmp_path):\n        p = tmp_path / \"bad.yaml\"\n        p.write_text(\"sources: [unclosed\")\n        with pytest.raises(yaml.YAMLError):\n            pipeline.load_config(p)\n\n\n@pytest.mark.asyncio\nclass TestRun:\n    async def test_dry_run_does_not_touch_store(self, config_file, tmp_path):\n        cfg_path = config_file({\"db\": str(tmp_path / \"jobs.db\"), \"sources\": []})\n        job = Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                    title=\"Engineer\", url=\"https://x/1\")\n        with patch.object(pipeline, \"fetch_all\", AsyncMock(return_value=[job])):\n            result = await pipeline.run(cfg_path, dry_run=True)\n        assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n        assert not (tmp_path / \"jobs.db\").exists()\n\n    async def test_persists_and_dispatches_on_real_run(self, config_file, tmp_path):\n        cfg_path = config_file({\"db\": str(tmp_path / \"jobs.db\"), \"sources\": []})\n        job = Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                    title=\"Engineer\", url=\"https://x/1\")\n        with patch.object(pipeline, \"fetch_all\", AsyncMock(return_value=[job])), \\\n             patch.object(pipeline, \"dispatch\") as mock_dispatch:\n            result = await pipeline.run(cfg_path, dry_run=False)\n        assert result == {\"matched\": 1, \"new\": 1, \"changed\": 0}\n        mock_dispatch.assert_called_once()\n\n    async def test_filters_applied_before_dedup(self, config_file, tmp_path):\n        cfg_path = config_file({\"db\": str(tmp_path / \"jobs.db\"), \"sources\": [],\n                                  \"filters\": {\"include_keywords\": [\"nonexistent\"]}})\n        job = Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                    title=\"Engineer\", url=\"https://x/1\")\n        with patch.object(pipeline, \"fetch_all\", AsyncMock(return_value=[job])):\n            result = await pipeline.run(cfg_path, dry_run=True)\n        assert result[\"matched\"] == 0\n```\n\n---\n\n",
        "level": 1
      },
      {
        "title": "5. `notify.py` ‚Äî notifiers + `dispatch`",
        "content": "\n**Untested entirely.** Each notifier has an env-var-gated activation branch that's easy to break silently.\n\n**Gaps (per-notifier):**\n- `notify_console`: new-only, changed-only, both, neither (\"No fresh listings\")\n- `notify_slack`: no-op when `SLACK_WEBHOOK_URL` unset; no-op when set but no jobs; posts correct block text when jobs present; salary appended only if present\n- `notify_webhook`: same env-gating; payload shape (`to_row()` used, so `raw` excluded)\n- `notify_email`: no-op when `SMTP_HOST`/`EMAIL_TO` unset; SMTP login only when `SMTP_USER` set; `starttls` called; message composed correctly\n- `notify_sms`: **requires ALL FOUR** Twilio vars ‚Äî test partial-set is still a no-op; `_sms_body` truncation at `limit` with \"+N more\" line; ASCII-only (no bullet/ellipsis chars); `raise_for_status()` surfaces bad-creds errors\n- `dispatch`: one notifier raising does NOT stop the others (`except Exception` + continue) ‚Äî this is the most important behavior to pin down since it's a resilience guarantee\n\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_notify.py",
        "content": "import json\nimport pytest\nimport respx\nimport httpx\nfrom models import Job\nimport notify\n\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                 title=\"Engineer\", url=\"https://x/1\", location=\"NYC\",\n                 salary_range=\"$150k-$200k\")\n    base.update(kw)\n    return Job(**base)\n\n\nclass TestNotifyConsole:\n    def test_prints_no_fresh_listings_when_empty(self, capsys):\n        notify.notify_console([], [])\n        assert \"No fresh listings\" in capsys.readouterr().out\n\n    def test_prints_new_and_changed_sections(self, capsys):\n        notify.notify_console([make_job()], [make_job(external_id=\"2\")])\n        out = capsys.readouterr().out\n        assert \"NEW listing\" in out and \"UPDATED listing\" in out\n\n\nclass TestNotifySlack:\n    def test_noop_without_env_var(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        # no respx mock registered -> any accidental call raises\n        notify.notify_slack([make_job()], [])\n\n    @respx.mock\n    def test_posts_block_text_with_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        route = respx.post(\"https://hooks.slack.test/x\").mock(\n            return_value=httpx.Response(200))\n        notify.notify_slack([make_job()], [])\n        assert route.called\n        body = json.loads(route.calls[0].request.content)\n        assert \"1 new job\" in body[\"text\"]\n\n    @respx.mock\n    def test_noop_when_no_jobs_even_with_env_set(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        route = respx.post(\"https://hooks.slack.test/x\")\n        notify.notify_slack([], [])\n        assert not route.called\n\n\nclass TestNotifySms:\n    def test_noop_when_only_some_twilio_vars_set(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.setenv(\"TWILIO_AUTH_TOKEN\", \"tok\")\n        monkeypatch.delenv(\"TWILIO_FROM\", raising=False)\n        monkeypatch.delenv(\"TWILIO_TO\", raising=False)\n        notify.notify_sms([make_job()], [])  # must not raise / not attempt request\n\n    def test_sms_body_is_ascii_only(self):\n        body = notify._sms_body([make_job(title=\"Engineer ‚Äî Backend\")], [])\n        assert all(ord(c) < 128 for c in body)\n\n    def test_sms_body_truncates_with_more_count(self):\n        jobs = [make_job(external_id=str(i)) for i in range(12)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+4 more\" in body\n\n    @respx.mock\n    def test_raises_on_bad_credentials(self, monkeypatch):\n        for k, v in [(\"TWILIO_ACCOUNT_SID\", \"sid\"), (\"TWILIO_AUTH_TOKEN\", \"tok\"),\n                     (\"TWILIO_FROM\", \"+1\"), (\"TWILIO_TO\", \"+2\")]:\n            monkeypatch.setenv(k, v)\n        respx.post(url__regex=r\".*api\\.twilio\\.com.*\").mock(\n            return_value=httpx.Response(401, json={\"message\": \"bad creds\"}))\n        with pytest.raises(httpx.HTTPStatusError):\n            notify.notify_sms([make_job()], [])\n\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch, capsys):\n        calls = []\n        def boom(new, changed): raise RuntimeError(\"smtp down\")\n        def ok(new, changed): calls.append(\"ok\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, ok])\n        notify.dispatch([make_job()], [])\n        assert calls == [\"ok\"]\n        assert \"notifier boom failed\" in capsys.readouterr().out\n```\n\n---\n\n",
        "level": 1
      },
      {
        "title": "6. `fetchers.py` ‚Äî the largest, riskiest, and 100% untested module",
        "content": "\nThis file has **~20 `parse_*` functions** (pure, easily unit-tested against fixture payloads) and **~15 `fetch_*` async functions** (need `respx`-mocked HTTP). It also has three genuinely tricky pieces of hand-rolled parsing logic that deserve dedicated tests: `_balanced_json`, `_apple_hydration`, `_extract_ds1`.\n\n**A. Parser-level gaps (pure functions ‚Äî test with fixture dicts, no network):**\n\nFor every `parse_*`, at minimum: (1) normal payload ‚Üí correct `Job` fields, (2) missing optional keys ‚Üí doesn't crash, defaults to `\"\"`, (3) empty list/dict input ‚Üí `[]`.\n\nSpecific edge cases per parser:\n- `parse_greenhouse`: `departments` list empty ‚Üí `\"\"`; multiple departments joined with `, `\n- `parse_lever` / `_lever_salary`: salary present with min+max ‚Üí formatted with commas; only `salaryDescriptionPlain` ‚Üí falls back; neither ‚Üí `\"\"`\n- `parse_ashby` / `parse_ashby_page`: `isListed: False` jobs excluded; `id` vs `jobId` fallback\n- `parse_smartrecruiters`: location assembled from partial city/region/country\n- `parse_recruitee`: `location` dict vs flat string dual-shape input\n- `parse_workable`: `location` as dict vs flat fields dual-shape\n- `parse_google` / `_extract_ds1` / `_ds1_posted_at`: malformed/missing `ds:1` blob ‚Üí `[]` not crash; entries with `j[0]` falsy skipped; timestamp preference order (12‚Üí13‚Üí14)\n- `parse_deshaw`: duplicate `data-job-id` dedup via `seen`; missing title/id skips card; HTML entity unescaping\n- `parse_twosigma`: triple-rendered card dedup; location lookup bounded to next anchor (doesn't leak into next card)\n- `parse_optiver`: `external_id` derivation from href with/without `join-us/jobs/` prefix\n- `parse_apple` / `_apple_hydration` / `_apple_posted_at`: nanosecond timestamp truncation to microseconds; multiple locations joined + deduped via `dict.fromkeys`; malformed `JSON.parse(\"...\")` blob ‚Üí `None`\n- `parse_eightfold`: `location` string vs `locations` list fallback; comma-space normalization\n- `parse_bytedance` / `_bd_location`: parent-chain walk terminates on non-dict; empty `city_info` ‚Üí `\"\"`\n- `parse_phenom`: `jobId` vs `jobSeqNo` fallback; `cityStateCountry` vs assembled fallback\n- `parse_microsoft`: `standardizedLocations` vs `locations` fallback; missing `postedTs` ‚Üí `\"\"`\n- `parse_netflix`: `t_create` vs `t_update` fallback; comma-packed location respacing\n- `parse_amazon` / `_amazon_posted_at`: month-name parsing, invalid month name ‚Üí `\"\"` (not crash); missing/malformed date string\n\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_fetchers_parsers.py",
        "content": "import pytest\nfrom fetchers import (\n    parse_greenhouse, parse_lever, _lever_salary, parse_ashby, parse_ashby_page,\n    parse_google, _extract_ds1, _ds1_posted_at, parse_deshaw, parse_twosigma,\n    parse_optiver, parse_apple, _apple_hydration, _apple_posted_at,\n    parse_eightfold, parse_bytedance, _bd_location, parse_phenom, parse_microsoft,\n    parse_netflix, parse_amazon, _amazon_posted_at, _balanced_json,\n)\n\n\nclass TestParseGreenhouse:\n    def test_normal_payload(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"https://x/1\",\n                            \"location\": {\"name\": \"NYC\"},\n                            \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Infra\"}],\n                            \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert len(jobs) == 1\n        assert jobs[0].department == \"Eng, Infra\"\n        assert jobs[0].location == \"NYC\"\n\n    def test_missing_location_and_departments(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"https://x/1\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].location == \"\" and jobs[0].department == \"\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_jobs_key(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\n\nclass TestLeverSalary:\n    def test_min_max_formatted_with_commas(self):\n        j = {\"salaryRange\": {\"min\": 150000, \"max\": 200000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 150,000‚Äì200,000\"\n\n    def test_falls_back_to_description_plain(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestParseAshby:\n    def test_unlisted_jobs_excluded(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"},\n                          {\"id\": \"2\", \"isListed\": True, \"title\": \"Visible\"}]}\n        jobs = parse_ashby(\"acme\", data)\n        assert len(jobs) == 1 and jobs[0].title == \"Visible\"\n\n    def test_id_fallback_to_jobid(self):\n        data = {\"jobs\": [{\"jobId\": \"abc\", \"title\": \"X\"}]}\n        assert parse_ashby(\"acme\", data)[0].external_id == \"abc\"\n\n\nclass TestGoogleDs1:\n    def test_extract_ds1_missing_blob_returns_empty(self):\n        assert _extract_ds1(\"<html>nothing here</html>\") == []\n\n    def test_extract_ds1_malformed_json_returns_empty(self):\n        html = \"key: 'ds:1', data:[not valid json], sideChannel:{}\"\n        assert _extract_ds1(html) == []\n\n    def test_ds1_posted_at_prefers_create_over_update(self):\n        job = [None] * 15\n        job[12] = [1700000000, 0]\n        job[13] = [1800000000, 0]\n        result = _ds1_posted_at(job)\n        assert \"2023\" in result  # from index 12, not 13\n\n    def test_ds1_posted_at_falls_back_when_create_missing(self):\n        job = [None] * 15\n        job[13] = [1700000000, 0]\n        assert _ds1_posted_at(job) != \"\"\n\n    def test_ds1_posted_at_no_timestamps_returns_empty(self):\n        assert _ds1_posted_at([None] * 15) == \"\"\n\n    def test_parse_google_skips_falsy_first_element(self):\n        assert parse_google(\"google\", [[None, \"title\"], [0, \"title\"]]) == []\n\n\nclass TestBalancedJson:\n    def test_simple_object(self):\n        text = '{\"a\": 1, \"b\": {\"c\": 2}}'\n        assert _balanced_json(text, 0) == text\n\n    def test_braces_inside_strings_ignored(self):\n        text = '{\"a\": \"text with } brace\"}'\n        assert _balanced_json(text, 0) == text\n\n    def test_escaped_quote_inside_string(self):\n        text = r'{\"a\": \"he said \\\"hi\\\" }\"}'\n        assert _balanced_json(text, 0) == text\n\n    def test_unterminated_object_returns_none(self):\n        assert _balanced_json('{\"a\": 1', 0) is None\n\n\nclass TestAppleHelpers:\n    def test_apple_hydration_missing_marker_returns_none(self):\n        assert _apple_hydration(\"<html></html>\") is None\n\n    def test_apple_hydration_malformed_json_returns_none(self):\n        html = 'window.__staticRouterHydrationData = JSON.parse(\"not valid\")'\n        assert _apple_hydration(html) is None\n\n    def test_apple_posted_at_truncates_nanoseconds(self):\n        result = _apple_posted_at(\"2024-01-15T10:00:03.812668311Z\")\n        assert result == \"2024-01-15T10:00:03.812668+00:00\"\n\n    def test_apple_posted_at_empty_input(self):\n        assert _apple_posted_at(\"\") == \"\"\n\n    def test_apple_posted_at_no_fractional_seconds(self):\n        result = _apple_posted_at(\"2024-01-15T10:00:03Z\")\n        assert result == \"2024-01-15T10:00:03+00:00\"\n\n\nclass TestParseDeshaw:\n    def test_dedups_repeated_job_ids(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">A</span>'\n                 '<span class=\"location\">NYC</span></div>'\n                 '<div data-job-id=\"1\"><span class=\"job-display-name\">A</span></div>')\n        assert len(parse_deshaw(\"deshaw\", page)) == 1\n\n    def test_missing_title_skips_card(self):\n        page = '<div data-job-id=\"1\"></div>'\n        assert parse_deshaw(\"deshaw\", page) == []\n\n    def test_html_entities_unescaped(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">'\n                 'R&amp;D Engineer</span></div>')\n        assert parse_deshaw(\"deshaw\", page)[0].title == \"R&D Engineer\"\n\n\nclass TestParseAmazonPostedAt:\n    def test_valid_date_string(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_invalid_month_name_returns_empty(self):\n        assert _amazon_posted_at(\"Junuary 26, 2026\") == \"\"\n\n    def test_malformed_string_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_empty_string_returns_empty(self):\n        assert _amazon_posted_at(\"\") == \"\"\n\n\nclass TestBdLocation:\n    def test_walks_parent_chain(self):\n        city = {\"en_name\": \"SF\", \"parent\": {\"en_name\": \"CA\",\n                 \"parent\": {\"en_name\": \"USA\", \"parent\": None}}}\n        assert _bd_location(city) == \"SF, CA, USA\"\n\n    def test_none_input_returns_empty(self):\n        assert _bd_location(None) == \"\"\n\n    def test_missing_names_skipped(self):\n        city = {\"parent\": {\"en_name\": \"USA\"}}\n        assert _bd_location(city) == \"USA\"\n```\n\n**B. HTTP-layer / `fetch_*` gaps (need `respx` mocking):**\n\n- `_request`: retries on 429/500/502/503/504, does NOT retry on 4xx (e.g. 400/404), exhausts `retries` then raises `RuntimeError`, backoff timing (mock `asyncio.sleep`)\n- `_simple`-built fetchers (greenhouse/lever/smartrecruiters/recruitee/workable): correct URL construction per company\n- `fetch_ashby`: 200 ‚Üí posting-api path; 404 ‚Üí falls back to hosted-page `__appData` scrape; other error status ‚Üí raised; missing `__appData` on fallback ‚Üí `RuntimeError`\n- `fetch_workday`: pagination stops at `total`, safety cap at offset > 5000, empty `postings` breaks loop\n- `fetch_google`/`fetch_apple`/`fetch_twosigma`/`fetch_optiver`/`fetch_eightfold`/`fetch_bytedance`/`fetch_phenom`/`fetch_microsoft`/`fetch_netflix`/`fetch_amazon`: pagination stop conditions ‚Äî empty page breaks, all-duplicate page breaks (the `fresh` check), `max_pages` cap respected, dedup via `seen` set across pages\n- `fetch_meta`: `for (;;);` JSON-hijacking prefix stripped; `errors` in response ‚Üí `RuntimeError` surfaced (this is the doc_id-rotation failure mode your memory already documents)\n- `fetch_source`: unknown ATS ‚Üí `ValueError` listing known ATSes\n- `fetch_all`: one source's exception is caught and logged, doesn't kill the whole batch; results flattened correctly; respects `concurrency` semaphore (can assert via a counter of max-concurrent calls); `owns_client` closes only self-created clients, not injected ones\n\n```python\n",
        "level": 1
      },
      {
        "title": "tests/test_fetchers_http.py",
        "content": "import pytest\nimport respx\nimport httpx\nfrom fetchers import (_request, fetch_source, fetch_all, fetch_ashby,\n                       fetch_meta, FETCHERS)\n\n\n@pytest.mark.asyncio\nclass TestRequestRetry:\n    @respx.mock\n    async def test_retries_on_503_then_succeeds(self, monkeypatch):\n        monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)\n        route = respx.get(\"https://x/y\").mock(side_effect=[\n            httpx.Response(503), httpx.Response(200, json={})])\n        async with httpx.AsyncClient() as client:\n            r = await _request(client, \"https://x/y\")\n        assert r.status_code == 200 and route.call_count == 2\n\n    @respx.mock\n    async def test_does_not_retry_on_404(self):\n        respx.get(\"https://x/y\").mock(return_value=httpx.Response(404))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError):\n                await _request(client, \"https://x/y\", retries=4)\n        assert respx.calls.call_count == 1\n\n    @respx.mock\n    async def test_exhausts_retries_and_raises(self, monkeypatch):\n        monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)\n        respx.get(\"https://x/y\").mock(return_value=httpx.Response(500))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n                await _request(client, \"https://x/y\", retries=3)\n        assert respx.calls.call_count == 3\n\n\n@pytest.mark.asyncio\nclass TestFetchAshby:\n    @respx.mock\n    async def test_uses_posting_api_on_200(self):\n        respx.get(url__regex=r\".*api\\.ashbyhq\\.com.*\").mock(\n            return_value=httpx.Response(200, json={\"jobs\": [{\"id\": \"1\", \"title\": \"X\"}]}))\n        async with httpx.AsyncClient() as client:\n            jobs = await fetch_ashby(client, {\"company\": \"acme\"})\n        assert len(jobs) == 1\n\n    @respx.mock\n    async def test_falls_back_to_hosted_page_on_404(self):\n        respx.get(url__regex=r\".*api\\.ashbyhq\\.com.*\").mock(return_value=httpx.Response(404))\n        html = ('window.__appData = {\"jobBoard\": {\"jobPostings\": '\n                '[{\"id\": \"1\", \"title\": \"X\"}]}}')\n        respx.get(url__regex=r\".*jobs\\.ashbyhq\\.com.*\").mock(\n            return_value=httpx.Response(200, text=html))\n        async with httpx.AsyncClient() as client:\n            jobs = await fetch_ashby(client, {\"company\": \"acme\"})\n        assert len(jobs) == 1\n\n    @respx.mock\n    async def test_404_and_no_appdata_raises(self):\n        respx.get(url__regex=r\".*api\\.ashbyhq\\.com.*\").mock(return_value=httpx.Response(404))\n        respx.get(url__regex=r\".*jobs\\.ashbyhq\\.com.*\").mock(\n            return_value=httpx.Response(200, text=\"<html>no data here</html>\"))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError, match=\"no posting-api\"):\n                await fetch_ashby(client, {\"company\": \"acme\"})\n\n    @respx.mock\n    async def test_non_404_error_status_raised(self):\n        respx.get(url__regex=r\".*api\\.ashbyhq\\.com.*\").mock(return_value=httpx.Response(500))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(httpx.HTTPStatusError):\n                await fetch_ashby(client, {\"company\": \"acme\"})\n\n\n@pytest.mark.asyncio\nclass TestFetchMeta:\n    @respx.mock\n    async def test_strips_json_hijack_prefix(self):\n        respx.get(\"https://www.metacareers.com/jobs\").mock(\n            return_value=httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok\"}]\"__spin_r\":1'))\n        respx.post(\"https://www.metacareers.com/graphql\").mock(\n            return_value=httpx.Response(200, text='for (;;);{\"data\":{'\n                '\"job_search_with_featured_jobs_v2\":{\"all_jobs\":[]}}}'))\n        async with httpx.AsyncClient() as client:\n            jobs = await fetch_meta(client, {\"company\": \"meta\"})\n        assert jobs == []\n\n    @respx.mock\n    async def test_graphql_errors_raise_with_message(self):\n        respx.get(\"https://www.metacareers.com/jobs\").mock(\n            return_value=httpx.Response(200, text=\"no tokens here\"))\n        respx.post(\"https://www.metacareers.com/graphql\").mock(\n            return_value=httpx.Response(200, text='{\"errors\":[{\"message\":\"doc_id invalid\"}]}'))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError, match=\"doc_id invalid\"):\n                await fetch_meta(client, {\"company\": \"meta\"})\n\n\n@pytest.mark.asyncio\nclass TestFetchSource:\n    async def test_unknown_ats_raises_value_error(self):\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(ValueError, match=\"unknown ATS\"):\n                await fetch_source(client, {\"ats\": \"bogus\"})\n\n\n@pytest.mark.asyncio\nclass TestFetchAll:\n    @respx.mock\n    async def test_one_source_failure_does_not_kill_batch(self, capsys):\n        respx.get(url__regex=r\".*boards-api\\.greenhouse\\.io.*\").mock(\n            return_value=httpx.Response(200, json={\"jobs\": [{\"id\": 1, \"title\": \"X\"}]}))\n        respx.get(url__regex=r\".*api\\.lever\\.co.*\").mock(return_value=httpx.Response(500))\n        sources = [{\"ats\": \"greenhouse\", \"company\": \"acme\"},\n                   {\"ats\": \"lever\", \"company\": \"beta\"}]\n        jobs = await fetch_all(sources, concurrency=2)\n        assert len(jobs) == 1\n        assert \"failed\" in capsys.readouterr().out\n\n    async def test_empty_sources_returns_empty_list(self):\n        assert await fetch_all([]) == []\n```\n\n---\n\n",
