        "content": "import sqlite3\nfrom models import Job\nfrom store import Store\n\ndef _job(ext_id=\"1\", title=\"T\", **kw):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id, title=title, url=\"u\", **kw)\n\ndef test_diff_first_seen_is_new(tmp_path):\n    with Store(tmp_path / \"t.db\") as s:\n        new, changed = s.diff([_job()])\n        assert len(new) == 1 and changed == [] and s.count() == 1\n\ndef test_diff_unchanged_reports_neither(tmp_path):\n    with Store(tmp_path / \"t.db\") as s:\n        s.diff([_job()])\n        assert s.diff([_job()]) == ([], [])\n\ndef test_diff_changed_content_hash_reports_changed(tmp_path):\n    with Store(tmp_path / \"t.db\") as s:\n        s.diff([_job(title=\"Engineer\")])\n        new, changed = s.diff([_job(title=\"Senior Engineer\")])\n        assert new == [] and len(changed) == 1\n\ndef test_migrate_adds_salary_range_to_legacy_schema(tmp_path):\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n        external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n        employment_type TEXT, posted_at TEXT, content_hash TEXT, first_seen TEXT, last_seen TEXT)\"\"\")\n    conn.commit(); conn.close()\n    with Store(path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\ndef test_added_since_is_strictly_after_boundary(tmp_path):\n    with Store(tmp_path / \"t.db\") as s:\n        s.diff([_job()])\n        boundary = s.added_since(\"2024-01-01T00:00:00+00:00\")[0][\"first_seen\"]\n        assert s.added_since(boundary) == []  # exclusive\n\ndef test_get_meta_missing_key_returns_none(tmp_path):\n    with Store(tmp_path / \"t.db\") as s:\n        assert s.get_meta(\"nope\") is None\n\ndef test_diff_duplicate_key_within_same_batch_does_not_crash(tmp_path):\n    with Store(tmp_path / \"t.db\") as s:\n        dup = _job(ext_id=\"1\")\n        new, changed = s.diff([dup, dup])  # defines expected behavior for a batch with dupes\n        assert len(new) + len(changed) <= 2\n```\n\n---\n\n",
