_jobs)])\n        out = capsys.readouterr().out\n        assert '\"first_run\": true' in out\n\n    def test_respects_existing_marker(self, store_with_jobs, capsys):\n        with Store.__init__:  # gap: set a marker via Store then confirm db-new uses it, not since-days\n            ...\n\n    def test_truncation_never_splits_a_first_seen_group(self, tmp_path, monkeypatch):\n        # gap: this is the load-bearing invariant the code comment calls out —\n        # insert two jobs with identical first_seen exceeding `--limit`, assert\n        # the whole group is either fully included or fully excluded\n        ...\n\n    def test_never_advances_marker(self, store_with_jobs):\n        # gap: db-new must be read-only w.r.t. the meta marker\n        ...\n\n\nclass TestDbMark:\n    def test_now_flag_sets_current_timestamp(self, store_with_jobs):\n        assert agent.cmd_db_mark([\"--now\", \"-c\", str(store_with_jobs)]) == 0\n\n    def test_invalid_watermark_rejected(self, store_with_jobs, capsys):\n        rc = agent.cmd_db_mark([\"not-a-date\", \"-c\", str(store_with_jobs)])\n        assert rc == 2\n        assert \"not an ISO timestamp\" in capsys.readouterr().err\n\n    def test_no_args_returns_error(self, store_with_jobs):\n        assert agent.cmd_db_mark([\"-c\", str(store_with_jobs)]) == 2\n\n\nclass TestNormalizeAts:\n    def test_replaces_smart_quotes_in_body_text(self):\n        html, counts = agent._normalize_ats(\"<p>\\u201cHello\\u201d</p>\")\n        assert '\"Hello\"' in html and counts[\"smart-double-quote\"] == 2\n\n    def test_does_not_touch_style_block_content(self):\n        html, counts = agent._normalize_ats('<style>.x{content:\"\\u2014\"}</style><p>\\u2014</p>')\n        assert html.count(\"\\u2014\") == 1  # only the <p> one replaced\n        assert counts[\"em-dash\"] == 1\n\n    def test_does_not_touch_script_block_content(self):\n        html, _ = agent._normalize_ats('<script>var x=\"\\u2013\";</script>')\n        assert \"\\u2013\" in html