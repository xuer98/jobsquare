ivalent classes for parse_smartrecruiters, parse_recruitee,\n#     parse_workable (dict vs string location branch!), parse_twosigma (3x\n#     duplicate-anchor dedup), parse_optiver, parse_meta (dedup + id fallback),\n#     parse_microsoft (postedTs → posted_at), parse_netflix (t_create vs\n#     t_update fallback, comma-packed locations)\n```\n\n**(c) Pagination loops** (`fetch_twosigma`, `fetch_optiver`, `fetch_google`, `fetch_microsoft`, `fetch_netflix`, `fetch_amazon`, `fetch_workday`) — untested: stop-on-empty-page, `max_pages` safety cap, dedup across pages, `offset >= total` termination for Workday.\n\n```python\n# test_fetchers_pagination.py\nimport httpx, pytest, respx\nfrom fetchers import fetch_optiver, fetch_workday\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_optiver_stops_on_empty_page():\n    respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(side_effect=[\n        httpx.Response(200, json={\"items\": [{\"href\": \"/join-us/jobs/a\", \"title\": \"A\"}]}),\n        httpx.Response(200, json={\"items\": []}),\n    ])\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_optiver(client, {\"company\": \"optiver\"})\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_optiver_respects_max_pages_cap():\n    route = respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n        return_value=httpx.Response(200, json={\"items\": [{\"href\": f\"/join-us/jobs/x{__import__('random').random()}\",\n                                                            \"title\": \"X\"}]}))\n    async with httpx.AsyncClient() as client:\n        await fetch_optiver(client, {\"company\": \"optiver\", \"max_pages\": 3})\n    assert route.call_count == 3  # gap: infinite-loop guard, never verified\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_workday_stops_when_offset_reaches_total():\n    respx.post(\"https://h/wday/cxs/t/s/jobs\").mock(side_effect=[\n        httpx.Response(200, json={\"jobPostings\": [{\"externalPath\": \"/job/1\", \"title\": \"A\",\n                                                     \"bulletFields\": [\"R123\"]}], \"total\": 1}),\n    ])\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\", \"page_size\": 1})\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_workday_safety_cap_at_5000_offset():\n    # gap: verify the hardcoded `offset > 5000` breaker actually triggers\n    ...\n```\n\n**(d) `fetch_source` / `fetch_all` dispatch**\n\n```python\n# test_fetchers_dispatch.py\nimport pytest\nfrom fetchers import fetch_source, fetch_all\n\n@pytest.mark.asyncio\nasync def test_fetch_source_unknown_ats_raises():\n    with pytest.raises(ValueError, match=\"unknown ATS\"):\n        await fetch_source(None, {\"ats\": \"bogus\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_all_continues_after_one_source_fails(monkeypatch):\n    # patch FETCHERS so one source raises and one succeeds; assert the\n    # failure is swallowed+logged and the good source's jobs still return\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_all_respects_concurrency_semaphore():\n    # gap: no test ever exercises the semaphore bound\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_all_closes_owned_client_but_not_injected_one():\n    # gap: owns_client branch entirely untested\n    ...\n```\n\n---\n\n### 5. `pipeline.py` — orchestration (needs mocking `fetch_all`, `filter_jobs`, `Store`, `dispatch`)\n\nGaps: config defaults (`sources`, `filters`, `db`, `concurrency`), dry-run skipping persistence/notify, return-dict shape on both paths.\n\n```python\n# test_pipeline.py\nimport pytest\nfrom unittest.mock import patch, MagicMock\nimport pipeline\n\ndef test_load_config_applies_defaults(tmp_path):\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(\"db: custom.db\\n\")\n    cfg = pipeline.load_config(cfg_path)\n 