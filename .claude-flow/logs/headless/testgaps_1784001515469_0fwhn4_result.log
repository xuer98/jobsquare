lass TestNormalizeAts:\n    def test_replaces_smart_quotes_in_body_text(self):\n        html, counts = agent._normalize_ats(\"<p>\\u201cHello\\u201d</p>\")\n        assert '\"Hello\"' in html and counts[\"smart-double-quote\"] == 2\n\n    def test_does_not_touch_style_block_content(self):\n        html, counts = agent._normalize_ats('<style>.x{content:\"\\u2014\"}</style><p>\\u2014</p>')\n        assert html.count(\"\\u2014\") == 1  # only the <p> one replaced\n        assert counts[\"em-dash\"] == 1\n\n    def test_does_not_touch_script_block_content(self):\n        html, _ = agent._normalize_ats('<script>var x=\"\\u2013\";</script>')\n        assert \"\\u2013\" in html  # untouched inside <script>\n\n    def test_does_not_touch_tag_attributes(self):\n        html, counts = agent._normalize_ats('<a title=\"\\u2014\">text</a>')\n        assert \"counts\" not in locals() or True  # gap: verify attrs inside <...> are skipped\n\n\nclass TestChromeBin:\n    def test_chrome_path_env_var_takes_precedence(self, monkeypatch, tmp_path):\n        fake = tmp_path / \"chrome\"; fake.write_text(\"\")\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert agent._chrome_bin() == str(fake)\n\n    def test_falls_back_to_path_lookup(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        with patch(\"shutil.which\", return_value=\"/usr/bin/chromium\"):\n            assert agent._chrome_bin() == \"/usr/bin/chromium\"\n\n    def test_exits_when_nothing_found(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        with patch(\"shutil.which\", return_value=None), \\\n             patch(\"pathlib.Path.exists\", return_value=False):\n            with pytest.raises(SystemExit):\n                agent._chrome_bin()\n\n\nclass TestMainDispatch:\n    def test_bare_invocation_is_interactive(self):\n        # gap: verify `interactive=True` and os.execvp path when argv is empty\n        ...\n\n    def test_mode_wor