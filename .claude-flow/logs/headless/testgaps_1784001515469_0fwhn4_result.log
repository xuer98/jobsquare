def test_epoch_variants(self, value, expected):\n        assert parse_posted_at(value) == expected\n\n    def test_iso8601_with_z_suffix(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n        assert dt == datetime(2024, 1, 15, 10, 0, tzinfo=timezone.utc)\n\n    def test_iso8601_naive_gets_utc(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_unparseable_prose_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None  # Workday format\n\n    def test_garbage_string_returns_none(self):\n        assert parse_posted_at(\"not a date\") is None\n\n\nclass TestJob:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"123\",\n                     title=\"Engineer\", url=\"https://x/1\")\n        return Job(**{**base, **overrides})\n\n    def test_key_is_stable_composite(self):\n        assert self._job().key == \"greenhouse:acme:123\"\n\n    def test_content_hash_changes_on_title_change(self):\n        j1, j2 = self._job(), self._job(title=\"Senior Engineer\")\n        assert j1.content_hash != j2.content_hash\n\n    def test_content_hash_stable_for_identical_material_fields(self):\n        assert self._job().content_hash == self._job().content_hash\n\n    def test_content_hash_ignores_salary_and_posted_at(self):\n        # gap: verify these are intentionally excluded from change detection\n        j1 = self._job(salary_range=\"100k\", posted_at=\"2024-01-01\")\n        j2 = self._job(salary_range=\"200k\", posted_at=\"2024-02-01\")\n        assert j1.content_hash == j2.content_hash\n\n    def test_to_row_excludes_raw_and_includes_key_and_hash(self):\n        row = self._job(raw={\"secret\": \"data\"}).to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == \"greenhouse:acme:123\"\n        assert \"content_hash\" in row\n\n    def test_posted_dt_property_delegates_to_parse(self):\n        assert self._job(posted_at=\"\").posted_dt is None\n```\n\n---\n\n### 2. `filters.py` — `match`, `filter_jobs` (pure, high value)\n\nGaps: word-boundary regex edge cases (e.g. `\"c++\"` or hyphenated keywords breaking `\\b`), exclude-wins-over-include precedence, unparseable `posted_at` treated as \"keep\" (documented intentional behavior — untested), case sensitivity, empty rule dicts.\n\n```python\n# test_filters.py\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(title=\"\", department=\"\", location=\"\", posted_at=\"\"):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=title,\n               url=\"u\", department=department, location=location, posted_at=posted_at)\n\nclass TestMatch:\n    def test_no_rules_matches_everything(self):\n        assert match(_job(title=\"anything\")) is True\n\n    def test_include_keyword_matches_word_boundary(self):\n        assert match(_job(title=\"Backend Engineer\"), include=[\"engineer\"]) is True\n\n    def test_include_keyword_no_match(self):\n        assert match(_job(title=\"Sales Rep\"), include=[\"engineer\"]) is False\n\n    def test_include_keyword_substring_false_positive_guard(self):\n        # \"eng\" should NOT match \"engineering\" without \\b false-triggering unrelated words\n        assert match(_job(title=\"Engineering Manager\"), include=[\"eng\"]) is True\n        assert match(_job(title=\"England Office\"), include=[\"eng\"]) is False  # gap: verify boundary semantics\n\n    def test_exclude_beats_include(self):\n        j = _job(title=\"Senior Intern Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"intern\"]) is False\n\n    def test_case_insensitive(self):\n        assert match(_job(title=\"ENGINEER\"), include=[\"engineer\"]) is True\n\n    def test_locations_substring_match_case_insensitive(self):\n        assert match(_job(location=\"San Francisco, CA\"), locations=[\"san francisco\"]) is True\n\n    def test_locations_no_match(self):\n        assert match(_job(location=\"Remote - EU\"), locations=[\"san francisco\"]) is False\n\n    def test_cutoff_drops_old_job(self):\n        old = _job(posted_at=\"2020-01-01T00:00:00Z\")\n        assert match(old, cutoff=datetime.now(timezone.utc) - timedelta(days=1)) is False\n\n    def test_cutoff_keeps_unparseable_posted_at(self):\n        # documented behavior: don't nuke jobs whose timestamp we can't parse\n        j = _job(posted_at=\"Posted 3 Days Ago\")\n        assert match(j, cutoff=datetime.now(timezone.utc)) is True\n\n    def test_cutoff_keeps_job_with_no_posted_at(self):\n        assert match(_job(posted_at=\"\"), cutoff=datetime.now(timezone.utc)) is True\n\n\nclass TestFilterJobs:\n    def test_max_age_days_builds_cutoff(self):\n        fresh = _job(title=\"a\", posted_at=datetime.now(timezone.utc).isoformat())\n        stale = _job(title=\"b\", posted_at=\"2020-01-01T00:00:00Z\")\n        result = filter_jobs([fresh, stale], {\"max_age_days\": 1})\n        assert result == [fresh]\n\n    def test_empty_rules_returns_all(self):\n        jobs = [_job(title=\"a\"), _job(title=\"b\")]\n        assert filter_jobs(jobs, {}) == jobs\n\n    def test_combines_include_exclude_location(self):\n        jobs = [_job(title=\"Backend Engineer\", location=\"NYC\"),\n                _job(title=\"Backend Engineer\", location=\"LA\")]\n        result = filter_jobs(jobs, {\"include_keywords\": [\"engineer\"], \"locations\": [\"nyc\"]})\n        assert len(result) == 1 and result[0].location == \"NYC\"\n```\n\n---\n\n### 3. `store.py` — `Store` (needs a real/temp SQLite db, no mocking needed — high value, currently zero coverage of dedup logic which is the core product guarantee)\n\nGaps: new vs. changed vs. unchanged classification, `last_seen` bump on unchanged rows, schema migration path for pre-`salary_range` DBs, `added_since` string-comparison ordering, `context manager` close behavior, `count()`.\n\n```python\n# test_store.py\nimport sqlite3\nimport pytest\nfrom pathlib import Path\nfrom models import Job\nfrom store import Store\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"test.db\")\n    yield s\n    s.close()\n\ndef _job(external_id=\"1\", title=\"Engineer\", company=\"acme\"):\n    return Job(source=\"greenhouse\", company=company, external_id=external_id,\n               title=title, url=\"https://x\")\n\nclass TestDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_on_second_run_is_neither(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_content_change_marks_as_changed(self, store):\n        store.diff([_job(title=\"Engineer\")])\n        new, changed = store.diff([_job(title=\"Senior Engineer\")])\n        assert new == [] and len(changed) == 1\n\n    def test_unchanged_job_still_bumps_last_seen(self, store):\n        store.diff([_job()])\n        before = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()[\"last_seen\"]\n        store.diff([_job()])\n        after = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()[\"last_seen\"]\n        assert after >= before  # gap: needs freezegun to assert strict > deterministically\n\n    def test_diff_persists_across_store_instances(self, tmp_path):\n        path = tmp_path / \"persist.db\"\n        with Store(path) as s1:\n            s1.diff([_job()])\n        with Store(path) as s2:\n            assert s2.count() == 1\n\n\nclass TestMigration:\n    def test_migrates_db_missing_salary_range_column(self, tmp_path):\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(str(path))\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n            CREATE TABLE meta (k TEXT PRIMARY KEY, v TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        with Store(path) as s:\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta(self, store):\n        store.set_meta(\"last_scan\", \"2024-01-01T00:00:00+00:00\")\n        assert store.get_meta(\"last_scan\") == \"2024-01-01T00:00:00+00:00\"\n\n    def test_set_meta_overwrites(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n\nclass TestAddedSince:\n    def test_returns_only_rows_after_timestamp_ordered(self, store):\n        store.diff([_job(external_id=\"1\")])\n        rows = store.added_since(\"2000-01-01T00:00:00+00:00\")\n        assert len(rows) == 1\n\n    def test_excludes_rows_at_exact_boundary(self, store):\n        store.diff([_job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[\"first_seen\"]\n        assert store.added_since(ts) == []  # strictly-after semantics\n\n\nclass TestCount:\n    def test_count_empty_db(self, store):\n        assert store.count() == 0\n\n    def test_count_after_inserts(self, store):\n        store.diff([_job(external_id=\"1\"), _job(external_id=\"2\")])\n        assert store.count() == 2\n\n\ndef test_context_manager_closes_connection(tmp_path):\n    with Store(tmp_path / \"cm.db\") as s:\n        pass\n    with pytest.raises(sqlite3.ProgrammingError):\n        s.conn.execute(\"SELECT 1\")\n```\n\n---\n\n### 4. `fetchers.py` — biggest gap by volume. Split into (a)