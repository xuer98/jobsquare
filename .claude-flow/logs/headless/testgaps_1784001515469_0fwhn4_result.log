        "title": "test_notify.py",
        "content": "import httpx, pytest, respx\nfrom models import Job\nimport notify\n\ndef _job(title=\"Eng\"):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=title, url=\"u\")\n\nclass TestNotifySlack:\n    def test_noop_when_env_var_unset(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        notify.notify_slack([_job()], [])  # should not raise / not attempt HTTP\n\n    def test_noop_when_no_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n        notify.notify_slack([], [])  # no HTTP call expected\n\n    @respx.mock\n    def test_posts_new_jobs_summary(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n        route = respx.post(\"https://hooks/x\").mock(return_value=httpx.Response(200))\n        notify.notify_slack([_job()], [])\n        assert route.called\n\n\nclass TestNotifySms:\n    def test_noop_unless_all_four_env_vars_set(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        notify.notify_sms([_job()], [])  # should be a no-op, partial config\n\n    def test_sms_body_truncates_at_limit(self):\n        jobs = [_job(title=f\"Job {i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n\n    @respx.mock\n    def test_raises_on_twilio_http_error(self, monkeypatch):\n        for k, v in {\"TWILIO_ACCOUNT_SID\": \"s\", \"TWILIO_AUTH_TOKEN\": \"t\",\n                     \"TWILIO_FROM\": \"+1\", \"TWILIO_TO\": \"+2\"}.items():\n            monkeypatch.setenv(k, v)\n        respx.post(url__regex=r\".*Messages\\.json\").mock(return_value=httpx.Response(400))\n        with pytest.raises(httpx.HTTPStatusError):\n            notify.notify_sms([_job()], [])\n\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch, capsys):\n        calls = []\n        def bad(new, changed): raise RuntimeError(\"boom\")\n        def good(new, changed): calls.append(\"ran\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [bad, good])\n        notify.dispatch([_job()], [])\n        assert calls == [\"ran\"]\n        assert \"boom\" in capsys.readouterr().out\n```\n\n---\n\n",
