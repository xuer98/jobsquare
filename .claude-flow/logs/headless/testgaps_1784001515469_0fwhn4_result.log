        "content": "from fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       parse_google, _extract_ds1, _ds1_posted_at, parse_deshaw,\n                       parse_twosigma, parse_optiver, parse_meta, parse_microsoft,\n                       parse_netflix, parse_amazon, _amazon_posted_at)\n\nclass TestParseGreenhouse:\n    def test_basic_job_maps_fields(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"https://x\",\n                           \"location\": {\"name\": \"NYC\"}, \"departments\": [{\"name\": \"Eng\"}],\n                           \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        [job] = parse_greenhouse(\"acme\", data)\n        assert job.external_id == \"1\" and job.location == \"NYC\" and job.department == \"Eng\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_optional_fields_dont_crash(self):\n        [job] = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1}]})\n        assert job.title == \"\" and job.location == \"\"\n\n    def test_missing_jobs_key(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\n\nclass TestLeverSalary:\n    def test_min_max_formats_with_thousands_separator(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_falls_back_to_description_plain(self):\n        j = {\"salaryDescriptionPlain\": \"DOE\"}\n        assert _lever_salary(j) == \"DOE\"\n\n    def test_no_salary_info_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestGoogleDs1:\n    def test_extract_ds1_finds_embedded_json(self):\n        html = \"AF_initDataCallback({key: 'ds:1', ..., data:[[[\\\"1\\\",\\\"Title\\\"]]], sideChannel:{}});\"\n        assert _extract_ds1(html) == [[\"1\", \"Title\"]]\n\n    def test_extract_ds1_missing_blob_returns_empty(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_extract_ds1_malformed_json_returns_empty(self):\n        html = \"key: 'ds:1', data:[not valid json], sideChannel\"\n        assert _extract_ds1(html) == []\n\n    def test_ds1_posted_at_prefers_create_over_update_time(self):\n        job = [None] * 15\n        job[12] = [1700000000, 0]\n        job[13] = [1800000000, 0]\n        assert \"2023\" in _ds1_posted_at(job)  # create-time wins\n\n    def test_ds1_posted_at_short_list_returns_empty(self):\n        assert _ds1_posted_at([\"id\"]) == \"\"\n\n\nclass TestAmazonPostedAt:\n    def test_parses_us_format_date(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_date_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_empty_string_returns_empty(self):\n        assert _amazon_posted_at(\"\") == \"\"\n\n\nclass TestParseDeshaw:\n    def test_dedups_repeated_job_ids(self):\n        page = ('data-job-id=\"1\"><span class=\"job-display-name\">SWE</span>'\n                '<span class=\"location\">NYC</span>'\n                'data-job-id=\"1\"><span class=\"job-display-name\">SWE</span>')\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert len(jobs) == 1\n\n    def test_missing_title_skips_card(self):\n        page = 'data-job-id=\"1\">no title here'\n        assert parse_deshaw(\"deshaw\", page) == []\n\n    def test_html_entities_unescaped_in_title(self):\n        page = 'data-job-id=\"1\"><span class=\"job-display-name\">R&amp;D Engineer</span>'\n        [job] = parse_deshaw(\"deshaw\", page)\n        assert job.title == \"R&D Engineer\"\n\n",
