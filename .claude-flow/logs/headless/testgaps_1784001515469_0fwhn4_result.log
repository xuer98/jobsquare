        "content": "import pytest\nfrom datetime import datetime, timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_returns_none(self):\n        assert parse_posted_at(\"\") is None\n\n    def test_none_like_returns_none(self):\n        assert parse_posted_at(None) is None  # gap: value: str typed but called with None from raw payloads\n\n    @pytest.mark.parametrize(\"value,expected\", [\n        (\"1643241332430\", datetime(2022, 1, 26, 22, 15, 32, tzinfo=timezone.utc)),  # ms epoch (Lever)\n        (\"1643241332\", datetime(2022, 1, 26, 22, 15, 32, tzinfo=timezone.utc)),     # s epoch\n        (\"-5\", None),  # gap: negative epoch edge — currently falls into isdigit()? verify branch\n    ])\n    def test_epoch_variants(self, value, expected):\n        assert parse_posted_at(value) == expected\n\n    def test_iso8601_with_z_suffix(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n        assert dt == datetime(2024, 1, 15, 10, 0, tzinfo=timezone.utc)\n\n    def test_iso8601_naive_gets_utc(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_unparseable_prose_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None  # Workday format\n\n    def test_garbage_string_returns_none(self):\n        assert parse_posted_at(\"not a date\") is None\n\n\nclass TestJob:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"123\",\n                     title=\"Engineer\", url=\"https://x/1\")\n        return Job(**{**base, **overrides})\n\n    def test_key_is_stable_composite(self):\n        assert self._job().key == \"greenhouse:acme:123\"\n\n    def test_content_hash_changes_on_title_change(self):\n        j1, j2 = self._job(), self._job(title=\"Senior Engineer\")\n        assert j1.content_hash != j2.content_hash\n\n    def test_content_hash_stable_for_identical_material_fields(self):\n        assert self._job().content_hash == self._job().content_hash\n\n    def test_content_hash_ignores_salary_and_posted_at(self):\n        # gap: verify these are intentionally excluded from change detection\n        j1 = self._job(salary_range=\"100k\", posted_at=\"2024-01-01\")\n        j2 = self._job(salary_range=\"200k\", posted_at=\"2024-02-01\")\n        assert j1.content_hash == j2.content_hash\n\n    def test_to_row_excludes_raw_and_includes_key_and_hash(self):\n        row = self._job(raw={\"secret\": \"data\"}).to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == \"greenhouse:acme:123\"\n        assert \"content_hash\" in row\n\n    def test_posted_dt_property_delegates_to_parse(self):\n        assert self._job(posted_at=\"\").posted_dt is None\n```\n\n---\n\n",
