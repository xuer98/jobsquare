      {
        "title": "tests/test_fetchers.py",
        "content": "import pytest\nimport httpx\nimport respx\nfrom fetchers import (\n    parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n    parse_google, _extract_ds1, _ds1_posted_at, parse_deshaw,\n    parse_twosigma, parse_optiver, parse_meta, parse_microsoft,\n    parse_netflix, parse_amazon, _amazon_posted_at,\n    fetch_source, fetch_all, _request,\n)\n\n\nclass TestParseGreenhouse:\n    def test_missing_location_and_departments(self):\n        jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1, \"title\": \"Eng\"}]})\n        assert jobs[0].location == \"\" and jobs[0].department == \"\"\n\n\nclass TestLeverSalary:\n    def test_range_present(self):\n        assert _lever_salary({\"salaryRange\": {\"min\": 100000, \"max\": 150000,\n                                               \"currency\": \"USD\"}}) == \"USD 100,000â€“150,000\"\n\n    def test_falls_back_to_description(self):\n        assert _lever_salary({\"salaryDescriptionPlain\": \"Competitive\"}) == \"Competitive\"\n\n    def test_neither_present(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestParseAshby:\n    def test_unlisted_jobs_filtered(self):\n        jobs = parse_ashby(\"acme\", {\"jobs\": [\n            {\"id\": \"1\", \"title\": \"A\", \"isListed\": False},\n            {\"id\": \"2\", \"title\": \"B\", \"isListed\": True},\n        ]})\n        assert [j.external_id for j in jobs] == [\"2\"]\n\n\nclass TestGoogleDs1:\n    def test_extract_missing_sidechannel_falls_back(self):\n        html = \"key: 'ds:1', ..., data:[[[\\\"1\\\",\\\"Title\\\"]]]);\"\n        assert _extract_ds1(html) != []\n\n    def test_extract_no_match_returns_empty(self):\n        assert _extract_ds1(\"<html>nothing</html>\") == []\n\n    def test_posted_at_missing_timestamp_indices(self):\n        assert _ds1_posted_at([\"1\"]) == \"\"\n\n    def test_parse_google_skips_falsy_entries(self):\n        assert parse_google(\"google\", [None, [\"\"]]) == []\n\n\nclass TestAmazonPostedAt:\n    @pytest.mark.parametrize(\"value,expected_prefix\", [\n        (\"June 26, 2026\", \"2026-06-26\"),\n    ])\n    def test_valid_date(self, value, expected_prefix):\n        assert _amazon_posted_at(value).startswith(expected_prefix)\n\n    def test_malformed_date_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_unknown_month_returns_empty(self):\n        assert _amazon_posted_at(\"Fooember 1, 2024\") == \"\"\n\n\nclass TestFetchSource:\n    @pytest.mark.asyncio\n    async def test_unknown_ats_raises(self):\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(ValueError, match=\"unknown ATS\"):\n                await fetch_source(client, {\"ats\": \"bogus\"})\n\n\nclass TestRequestRetry:\n    @respx.mock\n    @pytest.mark.asyncio\n    async def test_retries_on_503_then_succeeds(self):\n        route = respx.get(\"https://x.test/jobs\").mock(side_effect=[\n            httpx.Response(503), httpx.Response(200, json={\"jobs\": []}),\n        ])\n        async with httpx.AsyncClient() as client:\n            r = await _request(client, \"https://x.test/jobs\", retries=3)\n        assert r.status_code == 200\n        assert route.call_count == 2\n\n    @respx.mock\n    @pytest.mark.asyncio\n    async def test_gives_up_after_max_retries(self):\n        respx.get(\"https://x.test/jobs\").mock(return_value=httpx.Response(500))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n                await _request(client, \"https://x.test/jobs\", retries=2)\n\n\nclass TestFetchAll:\n    @pytest.mark.asyncio\n    async def test_one_source_failing_does_not_kill_others(self, capsys):\n        async with httpx.AsyncClient() as client:\n            sources = [{\"ats\": \"bogus\", \"company\": \"x\"},\n                       {\"ats\": \"greenhouse\", \"company\": \"y\"}]\n            with respx.mock:\n                respx.get(url__regex=r\".*boards-api\\.greenhouse\\.io.*\").mock(\n                    return_value=httpx.Response(200, json={\"jobs\": []}))\n                jobs = await fetch_all(sources, client=client)\n        assert jobs == []\n        assert \"failed\" in capsys.readouterr().out\n\n    @pytest.mark.asyncio\n    async def test_external_client_not_closed(self):\n        client = httpx.AsyncClient()\n        await fetch_all([], client=client)\n        assert not client.is_closed\n        await client.aclose()\n```\n\nAlso worth a **pagination-specific** test class per multi-page fetcher (e.g. `fetch_optiver`, `fetch_workday`) mocking two pages of `respx` responses and asserting: (a) results from both pages are merged, (b) loop stops when a page returns no *fresh* ids even if the payload isn't empty (simulates server-side duplicate padding), (c) `max_pages` cap is respected even if the server never returns empty.\n\n---\n\n",
