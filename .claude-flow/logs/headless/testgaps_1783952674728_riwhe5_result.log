        "code": "# tests/test_store.py\nimport pytest\nimport sqlite3\nfrom store import Store\nfrom models import Job\n\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"test.db\")\n    yield s\n    s.close()\n\n\ndef _job(external_id=\"1\", title=\"Engineer\", **kw):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=external_id,\n               title=title, url=\"https://x/1\", **kw)\n\n\nclass TestSchemaAndMigration:\n    def test_creates_schema_on_fresh_db(self, tmp_path):\n        with Store(tmp_path / \"fresh.db\") as s:\n            assert s.count() == 0\n\n    def test_migrates_db_missing_salary_range_column(self, tmp_path):\n        path = tmp_path / \"old.db\"\n        conn = sqlite3.connect(str(path))\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (\n                key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT\n            );\n        \"\"\")\n        conn.commit(); conn.close()\n\n        with Store(path) as s:\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\n\nclass TestDiff:\n    def test_new_job_reported_as_new(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n        assert store.count() == 1\n\n    def test_unchanged_job_on_second_run_is_neither_new_nor_changed(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_material_change_detected(self, store):\n        store.diff([_job(title=\"Engineer I\")])\n        new, changed = store.diff([_job(title=\"Engineer II\")])\n        assert new == [] and len(changed) == 1\n\n    def test_cosmetic_only_change_not_flagged(self, store):\n        store.diff([_job(posted_at=\"2024-01-01\")])\n        new, changed = store.diff([_job(posted_at=\"2024-06-01\")])\n        assert new == [] and changed == []\n\n    def test_duplicate_key_within_same_batch_last_write_wins(self, store):\n        # two Job objects sharing (source, company, external_id) in one call\n        new, changed = store.diff([_job(title=\"A\"), _job(title=\"B\")])\n        assert store.count() == 1\n\n\nclass TestMeta:\n    def test_get_meta_missing_returns_none(self, store):\n        assert store.get_meta(\"last_scan\") is None\n\n    def test_set_then_get_meta(self, store):\n        store.set_meta(\"last_scan\", \"2024-01-01T00:00:00+00:00\")\n        assert store.get_meta(\"last_scan\") == \"2024-01-01T00:00:00+00:00\"\n\n    def test_set_meta_upserts(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n\nclass TestAddedSince:\n    def test_excludes_rows_at_exact_boundary(self, store, monkeypatch):\n        store.diff([_job(external_id=\"1\")])\n        ts = store.conn.execute(\n            \"SELECT first_seen FROM jobs WHERE external_id='1'\").fetchone()[0]\n        assert store.added_since(ts) == []\n\n    def test_orders_oldest_first(self, store):\n        store.diff([_job(external_id=\"1\"), _job(external_id=\"2\")])\n        rows = store.added_since(\"1970-01-01T00:00:00+00:00\")\n        assert len(rows) == 2"
