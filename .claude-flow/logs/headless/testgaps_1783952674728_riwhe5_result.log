        "content": "import pytest\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\n\ndef _job(**kw):\n    defaults = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"Software Engineer\", url=\"https://x/1\",\n                     location=\"San Francisco, CA\", department=\"Engineering\")\n    return Job(**{**defaults, **kw})\n\n\nclass TestMatch:\n    def test_no_rules_passes(self):\n        assert match(_job()) is True\n\n    def test_include_keyword_hit(self):\n        assert match(_job(title=\"Senior ML Engineer\"), include=[\"ML\"]) is True\n\n    def test_include_keyword_miss(self):\n        assert match(_job(title=\"Sales Rep\"), include=[\"Engineer\"]) is False\n\n    def test_include_respects_word_boundary(self):\n        # \"ai\" should not match inside \"Maintain\"\n        assert match(_job(title=\"Maintainer\"), include=[\"ai\"]) is False\n\n    def test_exclude_overrides_include(self):\n        j = _job(title=\"Senior Manager Engineer\")\n        assert match(j, include=[\"Engineer\"], exclude=[\"Manager\"]) is False\n\n    def test_exclude_case_insensitive(self):\n        assert match(_job(title=\"INTERN role\"), exclude=[\"intern\"]) is False\n\n    def test_locations_substring_no_word_boundary(self):\n        # documents current behavior: \"SF\" as a bare substring filter\n        assert match(_job(location=\"San Francisco\"), locations=[\"Francisco\"]) is True\n        assert match(_job(location=\"San Francisco\"), locations=[\"SF\"]) is False\n\n    def test_cutoff_drops_old_parseable_job(self):\n        cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n        old = (cutoff - timedelta(days=10)).isoformat()\n        assert match(_job(posted_at=old), cutoff=cutoff) is False\n\n    def test_cutoff_keeps_unparseable_posted_at(self):\n        cutoff = datetime.now(timezone.utc)\n        assert match(_job(posted_at=\"Posted 3 Days Ago\"), cutoff=cutoff) is True\n\n    def test_cutoff_keeps_recent_job(self):\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        recent = datetime.now(timezone.utc).isoformat()\n        assert match(_job(posted_at=recent), cutoff=cutoff) is True\n\n\nclass TestFilterJobs:\n    def test_empty_rules_returns_all(self):\n        jobs = [_job(external_id=str(i)) for i in range(3)]\n        assert filter_jobs(jobs, {}) == jobs\n\n    def test_max_age_days_computes_cutoff(self):\n        jobs = [_job(posted_at=datetime.now(timezone.utc).isoformat())]\n        result = filter_jobs(jobs, {\"max_age_days\": 1})\n        assert result == jobs\n\n    def test_max_age_days_as_fractional_string_from_yaml(self):\n        jobs = [_job(posted_at=datetime.now(timezone.utc).isoformat())]\n        result = filter_jobs(jobs, {\"max_age_days\": \"0.5\"})\n        assert result == jobs\n\n    def test_combines_all_rule_types(self):\n        jobs = [\n            _job(external_id=\"1\", title=\"ML Engineer\", location=\"Remote\"),\n            _job(external_id=\"2\", title=\"Sales\", location=\"Remote\"),\n        ]\n        result = filter_jobs(jobs, {\"include_keywords\": [\"Engineer\"],\n                                     \"locations\": [\"Remote\"]})\n        assert [j.external_id for j in result] == [\"1\"]\n```\n\n---\n\n",
