utc\n\n    def test_iso8601_with_z(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00Z\")\n        assert dt.tzinfo is not None\n\n    def test_iso8601_naive_defaults_to_utc(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_negative_epoch(self):\n        assert parse_posted_at(\"-1000\") is not None\n\n\nclass TestJob:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"Engineer\", url=\"https://x\", location=\"NYC\")\n        return Job(**{**base, **overrides})\n\n    def test_key_is_stable_identity(self):\n        j = self._job()\n        assert j.key == \"greenhouse:acme:1\"\n\n    def test_content_hash_changes_on_title(self):\n        a, b = self._job(), self._job(title=\"Senior Engineer\")\n        assert a.content_hash != b.content_hash\n\n    def test_content_hash_stable_when_posted_at_or_salary_changes(self):\n        a = self._job(posted_at=\"2024-01-01\", salary_range=\"100k\")\n        b = self._job(posted_at=\"2024-06-01\", salary_range=\"200k\")\n        assert a.content_hash == b.content_hash  # dedup relies on this\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self):\n        j = self._job(raw={\"secret\": 1})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash\n```\n\n---\n\n### 2. `filters.py` — pure logic, high-value, untested branches include precedence\n\n**Gaps:**\n- exclude takes priority over include when both match.\n- word-boundary regex behaves correctly (`\"eng\"` shouldn't match `\"engineering\"` — wait, actually it *would* since `\\b` only anchors word edges around \"eng\" as substring... need to verify: `\\beng\\b` won't match \"engineering\" since no boundary after \"eng\". Worth a test to lock behavior in).\n- location matching is substring + case-insensitive, not exact.\n- `cutoff` behavior: jobs with unparseable `posted_at` are **kept** (not dropped) — this is a deliberate, non-obvious choice per the comment and easy to regress.\n- `filter_jobs` with empty/missing `rules` dict keys.\n\n```python\n# tests/test_filters.py\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(title=\"Software Engineer\", dept=\"\", loc=\"Remote\", posted_at=\"\"):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=title,\n                url=\"u\", department=dept, location=loc, posted_at=posted_at)\n\ndef test_exclude_wins_over_include_on_same_match():\n    j = _job(title=\"Senior Manager\")\n    assert match(j, include=[\"manager\"], exclude=[\"manager\"]) is False\n\ndef test_include_word_boundary_no_partial_match():\n    j = _job(title=\"Engineering Manager\")\n    assert match(j, include=[\"eng\"]) is False  # \"eng\" != whole word\n\ndef test_location_is_case_insensitive_substring():\n    j = _job(loc=\"San Francisco, CA\")\n    assert match(j, locations=[\"san francisco\"]) is True\n\ndef test_cutoff_drops_confirmed_old_job():\n    old = _job(posted_at=\"2020-01-01T00:00:00Z\")\n    cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n    assert match(old, cutoff=cutoff) is False\n\ndef test_cutoff_keeps_unparseable_posted_at():\n    j = _job(posted_at=\"garbage\")\n    cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n    assert match(j, cutoff=cutoff) is True  # can't confirm it's old -> keep\n\ndef test_filter_jobs_max_age_days_converts_to_cutoff():\n    old = _job(posted_at=\"2000-01-01T00:00:00Z\")\n    fresh = _job(title=\"X\", posted_at=datetime.now(timezone.utc).isoformat())\n    out = filter_jobs([old, fresh], {\"max_age_days\": 7})\n    assert out == [fresh]\n\ndef test_filter_jobs_empty_rules_returns_all():\n    jobs = [_job(), _job(title=\"Other\")]\n    assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n### 3. `store.py` — needs a real (temp file or `:memory:`) SQLite, no mocking needed\n\n**Gaps:**\n- schema creation from scratch.\n- **migration path**: opening a pre-existing DB file that lacks `salary_range` (simulate by creating the old schema manually, then opening with `Store`).\n- `diff()` three-way branch: new / changed (hash mismatch) / unchanged (only `last_seen` bumped).\n- `get_meta`/`set_meta` upsert (insert then update same key).\n- `added_since` strict `>` boundary and ordering.\n- `count()`.\n- context manager closes connection.\n\n```python\n# tests/test_store.py\nimport sqlite3\nimport pytest\nfrom store import Store\nfrom models import Job\n\ndef _job(ext_id=\"1\", title=\"Engineer\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id,\n                title=title, url=\"https://x\", location=\"NYC\")\n\ndef test_diff_new_job_is_inserted(tmp_db):\n    with Store(tmp_db) as store:\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n        assert store.count() == 1\n\ndef test_diff_unchanged_job_only_bumps_last_seen(tmp_db):\n    with Store(tmp_db) as store:\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\ndef test_diff_changed_content_hash_is_reported(tmp_db):\n    with Store(tmp_db) as store:\n        store.diff([_job()])\n        new, changed = store.diff([_job(title=\"Senior Engineer\")])\n        assert new == []\n        assert len(changed) == 1\n\ndef test_migration_adds_salary_range_to_legacy_db(tmp_db):\n    conn = sqlite3.connect(str(tmp_db))\n    conn.executescript(\"\"\"\n        CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n          external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n          employment_type TEXT, posted_at TEXT, content_hash TEXT,\n          first_seen TEXT, last_seen TEXT);\n    \"\"\")\n    conn.commit(); conn.close()\n    with Store(tmp_db) as store:\n        cols = {r[\"name\"] for r in store.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\ndef test_meta_set_then_get_upserts(tmp_db):\n    with Store(tmp_db) as store:\n        store.set_meta(\"last_scan\", \"2024-01-01T00:00:00\")\n        store.set_meta(\"last_scan\", \"2024-06-01T00:00:00\")\n        assert store.get_meta(\"last_scan\") == \"2024-06-01T00:00:00\"\n\ndef test_get_meta_missing_key_returns_none(tmp_db):\n    with Store(tmp_db) as store:\n        assert store.get_meta(\"nope\") is None\n\ndef test_added_since_is_strictly_after_and_ordered(tmp_db):\n    with Store(tmp_db) as store:\n        store.diff([_job(\"1\")])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n        store.diff([_job(\"2\")])\n        rows = store.added_since(ts)\n        assert [r[\"external_id\"] for r in rows] == [\"2\"]\n```\n\n---\n\n### 4. `pipeline.py` — orchestration, needs mocking of `fetch_all`/`dispatch`/`Store`\n\n**Gaps:**\n- `load_config`: defaults applied (`sources`, `filters`, `db`, `concurrency`) when omitted from YAML; missing file raises.\n- `run(dry_run=True)`: does **not** touch the store or call `dispatch` (currently unverified — a regression here would silently start persisting/notifying during dry runs).\n- `run(dry_run=False)`: calls `store.diff`, then `dispatch(new, changed)`, returns correct counts dict.\n- `run_sync` wraps `asyncio.run` correctly (can just check it returns the coroutine's result via monkeypatching `run`).\n\n```python\n# tests/test_pipeline.py\nimport pytest\nimport pipeline\n\ndef test_load_config_applies_defaults(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(\"sources: []\\n\")\n    cfg = pipeline.load_config(cfg_file)\n    assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\ndef test_load_config_missing_file_raises(tmp_path):\n    with pytest.raises(FileNotFoundError):\n        pipeline.load_config(tmp_path / \"nope.yaml\")\n\n@pytest.mark.asyncio\nasync def test_dry_run_does_not_touch_store_or_notify(tmp_path, monkeypatch):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(f\"sources: []\\ndb: {tmp_path/'jobs.db'}\\n\")\n\n    async def fake_fetch_all(sources, concurrency): return [make_job()]\n    monkeypatch.setattr(pipeline, \"fetch_all\", fake_fetch_all)\n    monkeypatch.setattr(pipeline, \"filter_jobs\", lambda jobs, rules: jobs)\n    dispatch_called = []\n    monkeypatch.setattr(pipeline, \"dispatch\", lambda n, c: dispatch_called.append(1))\n\n    result = await pipeline.run(cfg_file, dry_run=True)\n    assert dispatch_called == []\n    assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n    assert not (tmp_path / \"jobs.db\").exists()\n\n@pytest.mark.asyncio\nasync def test_full_run_persists_and_dispatches(tmp_path, monkeypatch):\n    # arrange fake fetch_all/filter_jobs as above, real Store on tmp_path\n    ...  # assert store now has 1 row, dispatch called with (new=[job], changed=[])\n```\n\n---\n\n### 5. `notify.py` — needs `monkeypatch.setenv`/`delenv` + mocking `httpx.post`/`smtplib.SMTP`\n\n**Gaps (each notifier has an untested no-op guard AND an untested send path):**\n- `notify_slack`/`notify_webhook`/`notify_email`/`notify_sms`: no-op when env var(s) unset; no-op when `new`/`changed` both empty even if configured; correct payload shape when configured.\n- `notify_sms`: partial env vars (3 of 4 set) still no-ops; `resp.raise_for_status()` propagates on Twilio error (e.g. bad creds) — this exception is what `dispatch` is relied on to catch.\n- `_sms_body`: truncates at `limit`, \"+N more\" line, ASCII-only (no `•`/`…`).\n- `dispatch`: **critical gap** — a failing notifier (e.g. Slack webhook down) must not prevent later notifiers (SMS, email) from running. This is the entire reason `dispatch` wraps each call in try/except but it's never verified.\n\n```python\n# tests/test_notify.py\nimport pytest\nimport notify\nfrom models import Job\n\ndef _job(title=\"Engineer\", company=\"acme\"):\n    return Job(source=\"s\", company=company, external_id=\"1\", title=title, url=\"u\")\n\nclass TestNotifySlack:\n    def test_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        called = []\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_slack([_job()], [])\n        assert called == []\n\n    def test_noop_when_nothing_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n        called = []\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_slack([], [])\n        assert called == []\n\n    def test_posts_payload_when_configured(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n        captured = {}\n        def fake_post(url, json, timeout): captured.update(url=url, json=json)\n        monkeypatch.setattr(notify.httpx, \"post\", fake_post)\n        notify.notify_slack([_job()], [])\n        assert \"Engineer\" in captured[\"json\"][\"text\"]\n\n\nclass TestNotifySms:\n    def test_noop_with_partial_env(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.setenv(\"TWILIO_AUTH_TOKEN\", \"tok\")\n        monkeypatch.delenv(\"TWILIO_FROM\", raising=False)\n        monkeypatch.delenv(\"TWILIO_TO\", raising=False)\n        called = []\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_sms([_job()], [])\n        assert called == []\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        for k, v in {\"TWILIO_ACCOUNT_SID\": \"s\", \"TWILIO_AUTH_TOKEN\": \"t\",\n                     \"TWILIO_FROM\": \"+1\", \"TWILIO_TO\": \"+2\"}.items():\n            monkeypatch.setenv(k, v)\n        class FakeResp:\n            def raise_for_status(self): raise RuntimeError(\"401 unauthorized\")\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: FakeResp())\n        with pytest.raises(RuntimeError):\n            notify.notify_sms([_job()], [])\n\n\nclass TestSmsBody:\n    def test_truncates_and_reports_remainder(self):\n        jobs = [_job(title=f\"Job {i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n\n    def test_ascii_only_no_unicode_bullets(self):\n        body = notify._sms_body([_job()], [])\n        assert all(ord(c) < 128 for c in body)\n\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch):\n        calls = []\n        def boom(new, changed): raise RuntimeError(\"slack down\")\n        def ok(new, changed): calls.append(\"ok\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, ok])\n        notify.dispatch([_job()], [])\n        assert calls == [\"ok\"]\n```\n\n---\n\n### 6. `fetchers.py` — largest surface, currently **zero coverage** on 15 ATS parsers + pagination + retry\n\nThis module is explicitly designed to be testable (\"client is injectable... unit-testable against mocked transports\") — but nothing exercises that design.\n\n**A. Retry/backoff (`_request`) — highest priority, this is shared infra for every fetcher:**\n- 200 on first try (no retry).\n- 500 then 200 → succeeds after retry (use `respx` or a fake transport, and monkeypatch `asyncio.sleep` to avoid real delays).\n- 429 exhausts all `retries` → raises `RuntimeError`.\n- non-retryable 4xx (e.g. 404) raises immediately without retrying.\n- `httpx.TransportError` (connection reset) retried same as 5xx.\n\n```python\n# tests/test_fetchers_request.py\nimport httpx, pytest\nimport fetchers\n\n@pytest.mark.asyncio\nasync def test_retries_on_500_then_succeeds(monkeypatch):\n    monkeypatch.setattr(fetchers.asyncio, \"sleep\", lambda *_: None)\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        if calls[\"n\"] < 2:\n            return httpx.Response(500)\n        return httpx.Response(200, json={\"jobs\": []})\n    transport = httpx.MockTransport(handler)\n    async with httpx.AsyncClient(transport=transport) as client:\n        r = await fetchers._request(client, \"https://x/jobs\")\n        assert r.status_code == 200 and calls[\"n\"] == 2\n\n@pytest.mark.asyncio\nasync def test_exhausts_retries_raises_runtimeerror(monkeypatch):\n    monkeypatch.setattr(fetchers.asyncio, \"sleep\", lambda *_: None)\n    transport = httpx.MockTransport(lambda r: httpx.Response(429))\n    async with httpx.AsyncClient(transport=transport) as client:\n        with pytest.raises(RuntimeError):\n            await fetchers._request(client, \"https://x/jobs\", retries=2)\n\n@pytest.mark.asyncio\nasync def test_404_raises_without_retry(monkeypatch):\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        return httpx.Response(404)\n    transport = httpx.MockTransport(handler)\n    async with httpx.AsyncClient(transport=transport) as client:\n        with pytest.raises(RuntimeError):\n            await fetchers._request(client, \"https://x/jobs\", retries=3)\n        assert calls[\"n\"] == 1  # no retry on non-retryable status\n```\n\n**B. Parsers — pure functions, trivially unit-testable with fixture payloads, currently 0 of 15 covered:**\n\nEach of `parse_greenhouse`, `parse_lever` (+`_lever_salary`), `parse_ashby` (+`_ashby_salary`, `isListed=False` filter), `parse_smartrecruiters`, `parse_recruitee` (flat-string vs city/country-assembled location), `parse_workable` (dict-location vs flat-location branches), `parse_google` (+`_extract_ds1` regex, +`_ds1_posted_at` index fallback 12→13→14), `parse_deshaw` (regex-card dedup via `seen`), `parse_twosigma` (3x-render dedup, bounded location lookahead), `parse_optiver` (external_id slug derivation), `parse_microsoft`, `parse_netflix` (comma-packed location respacing), `parse_amazon` (+`_amazon_posted_at` valid/malformed).\n\n```python\n# tests/test_parsers.py\nfrom fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       parse_google, _extract_ds1, _ds1_posted_at,\n                       parse_amazon, _amazon_posted_at, parse_deshaw)\n\ndef test_parse_greenhouse_maps_fields():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\", \"absolute_url\": \"https://x\",\n                       \"location\": {\"name\": \"NYC\"}, \"departments\": [{\"name\": \"Platform\"}],\n                       \"updated_at\": \"2024-01-01\"}]}\n    jobs = parse_greenhouse(\"acme\", data)\n    assert jobs[0].location == \"NYC\" and jobs[0].department == \"Platform\"\n\ndef test_parse_ashby_skips_unlisted():\n    data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"}]}\n    assert parse_ashby(\"acme\", data) == []\n\ndef test_lever_salary_formats_range():\n    j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n    assert _lever_salary(j) == \"USD 100,000–150,000\"\n\ndef test_lever_salary_falls_back_to_plain_description():\n    j = {\"salaryDescriptionPlain\": \"Competitive\"}\n    assert _lever_salary(j) == \"Competitive\"\n\ndef test_extract_ds1_parses_embedded_blob():\n    html = \"key: 'ds:1', ..., data:[[[\\\"1\\\",\\\"Title\\\"]]], sideChannel:{}\"\n    assert _extract_ds1(html) == [[\"1\", \"Title\"]]\n\ndef test_extract_ds1_missing_blob_returns_empty():\n    assert _extract_ds1(\"<html>no data here</html>\") == []\n\ndef test_ds1_posted_at_prefers_create_over_update_time():\n    job = [None]*13 + [[1700000000]]  # index 12 = create-time\n    assert _ds1_posted_at(job) != \"\"\n\ndef test_amazon_posted_at_valid():\n    assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\ndef test_amazon_posted_at_malformed_returns_empty():\n    assert _amazon_posted_at(\"not a date\") == \"\"\n\ndef test_parse_deshaw_dedups_repeated_cards():\n    page = 'data-job-id=\"1\"class=\"job-display-name\">Eng<' \\\n           'data-job-id=\"1\"class=\"job-display-name\">Eng<'\n    assert len(parse_deshaw(\"deshaw\", page)) == 1\n```\n\n**C. Pagination fetchers (`fetch_workday`, `fetch_google`, `fetch_meta`, `fetch_twosigma`, `fetch_optiver`, `fetch_microsoft`, `fetch_netflix`, `fetch_amazon`) — 0 covered:**\n- Stop-on-empty-page condition for each.\n- `fetch_workday`'s `offset >= total` stop AND the `offset > 5000` safety cap (nobody has ever exercised the cap branch).\n- `fetch_meta`: `\"for (;;);\"` prefix stripping; `data.get(\"errors\")` → raises `RuntimeError` (this is the doc_id-rotation failure path called out in the comment at fetchers.py:510 — worth locking down since memory notes it breaks periodically).\n- Dedup-by-`external_id` across pages in every paginated fetcher (`seen` set logic).\n\n```python\n# tests/test_fetch_pagination.py\nimport httpx, pytest\nimport fetchers\n\n@pytest.mark.asyncio\nasync def test_fetch_optiver_stops_on_empty_page():\n    def handler(request):\n        offset = int(request.url.params.get(\"from\", 0))\n        items = [] if offset > 0 else [{\"href\": \"/join-us/jobs/a\", \"title\": \"A\"}]\n        return httpx.Response(200, json={\"items\": items})\n    transport = httpx.MockTransport(handler)\n    async with httpx.AsyncClient(transport=transport) as client:\n        jobs = await fetchers.fetch_optiver(client, {\"company\": \"optiver\"})\n        assert len(jobs) == 1\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_raises_on_graphql_error(monkeypatch):\n    async def fake_get_text(client, url, **kw):\n        if \"graphql\" in url:\n            return 'for (;;);{\"errors\":[{\"message\":\"doc_id invalid\"}]}'\n        return '[\"LSD\",[],{\"token\":\"tok\"}]__spin_r\":1'\n    monkeypatch.setattr(fetchers, \"_get_text\", fake_get_text)\n    with pytest.raises(RuntimeError, match=\"doc_id invalid\"):\n        await fetchers.fetch_meta(httpx.AsyncClient(), {\"company\": \"meta\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_workday_stops_at_safety_cap(monkeypatch):\n    # data.total always huge -> loop must stop via offset > 5000, not hang\n    async def fake_get_json(client, url, **kw):\n        return {\"jobPostings\": [{\"externalPath\": \"/x\", \"bulletFields\": [\"r1\"]}],\n                 \"total\": 999999}\n    monkeypatch.setattr(fetchers, \"_get_json\", fake_get_json)\n    jobs = await fetchers.fetch_workday(\n        httpx.AsyncClient(), {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\", \"page_size\": 20})\n    assert len(jobs) <= 5000 // 20 + 1\n```\n\n**D. `fetch_source`/`fetch_all`:**\n- `fetch_source` raises `ValueError` for unknown `ats` key, message lists known ATS.\n- `fetch_all`: one source raising doesn't kill the others (currently the whole *point* of the try/except in `one()`, never verified); semaphore actually bounds concurrency; caller-supplied `client` isn't closed (`owns_client=False`) vs internally-created client is closed.\n\n```python\n@pytest.mark.asyncio\nasync def test_fetch_source_unknown_ats_raises():\n    with pytest.raises(ValueError, match=\"unknown ATS\"):\n        await fetchers.fetch_source(httpx.AsyncClient(), {\"ats\": \"bogus\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_all_isolates_failing_source(monkeypatch):\n    async def fake_fetch_source(client, src):\n        if src[\"ats\"] == \"broken\":\n            raise RuntimeError(\"boom\")\n        return [fetchers.Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")]\n    monkeypatch.setattr(fetchers, \"fetch_source\", fake_fetch_source)\n    jobs = await fetchers.fetch_all(\n        [{\"ats\": \"broken\", \"company\": \"b\"}, {\"ats\": \"ok\", \"company\": \"o\"}])\n    assert len(jobs) == 1\n```\n\n---\n\n### 7. `agent.py` — deterministic helpers, no LLM involved, fully testable\n\n**Gaps:**\n- `cmd_db_new`: first-run window (`since_days`) applied when no marker; existing marker used instead; **group-boundary truncation** at `limit` (never splits a `first_seen` group — worth a test where a group of 3 rows sharing one timestamp straddles the limit) and `watermark` reflects the last *complete* group, not a partial one.\n- `cmd_db_mark`: `--now`; valid explicit watermark; invalid ISO string → returns `2` and doesn't call `set_meta`; neither arg → returns `2`.\n- `_normalize_ats`: each of the 14 char-replacement rules; replacements skipped inside `<style>`/`<script>` and inside tag attributes (only body text, per the comment at agent.py:181-184) — the split-on-tags logic is subtle and untested.\n- `cmd_pdf_render`: missing input file → returns `2`; output not starting with `%PDF` → returns `1` and prints stderr tail (mock `subprocess.run`).\n- `_chrome_bin`: `CHROME_PATH` env override when path exists; `shutil.which` discovery; macOS app-bundle fallback; `sys.exit` when nothing found.\n- `main()` argv routing: bare invocation → interactive; `scan` → headless; `-i` flag anywhere → forces interactive; flag splitting between mode words and passthrough `extra` args.\n\n```python\n# tests/test_agent.py\nimport json\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nimport agent\nfrom store import Store\nfrom models import Job\n\ndef test_db_mark_invalid_watermark_returns_2(tmp_path, capsys):\n    cfg = tmp_path / \"sources.yaml\"\n    cfg.write_text(f\"db: {tmp_path/'jobs.db'}\\n\")\n    rc = agent.cmd_db_mark([\"not-a-timestamp\", \"-c\", str(cfg)])\n    assert rc == 2\n\ndef test_db_mark_neither_arg_returns_2(tmp_path):\n    cfg = tmp_path / \"sources.yaml\"\n    cfg.write_text(f\"db: {tmp_path/'jobs.db'}\\n\")\n    assert agent.cmd_db_mark([\"-c\", str(cfg)]) == 2\n\ndef test_db_new_truncation_never_splits_a_first_seen_group(tmp_path, capsys):\n    cfg = tmp_path / \"sources.yaml\"\n    db_path = tmp_path / \"jobs.db\"\n    cfg.write_text(f\"db: {db_path}\\n\")\n    with Store(db_path) as store:\n        # 3 jobs inserted in the same pipeline run share one first_seen\n        store.diff([Job(source=\"s\", company=\"c\", external_id=str(i),\n                         title=f\"T{i}\", url=\"u\") for i in range(3)])\n    agent.cmd_db_new([\"--limit\", \"2\", \"-c\", str(cfg)])\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"count\"] == 0 or out[\"count\"] % 3 == 0  # never a partial group\n    assert out[\"truncated\"] is True\n\nclass TestNormalizeAts:\n    def test_em_dash_replaced_in_body_text(self):\n        html, counts = agent._normalize_ats(\"<p>a\\u2014b</p>\")\n        assert \"a-b\" in html and counts[\"em-dash\"] == 1\n\n    def test_smart_quotes_not_replaced_inside_style_block(self):\n        html, counts = agent._normalize_ats(\n            '<style>content: \"\\u201C\"</style><p>x</p>')\n        assert \"smart-double-quote\" not in counts\n\n    def test_char_inside_tag_attribute_not_touched(self):\n        html, counts = agent._normalize_ats('<a title=\"\\u2014\">x</a>')\n        assert \"\\u2014\" in html  # only body text is normalized, not attributes\n\n\ndef test_chrome_bin_prefers_chrome_path_env(monkeypatch, tmp_path):\n    fake = tmp_path / \"chrome\"\n    fake.write_text(\"\")\n    monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n    assert agent._chrome_bin() == str(fake)\n\ndef test_chrome_bin_exits_when_none_found(monkeypatch):\n    monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n    monkeypatch.setattr(agent.shutil, \"which\", lambda name: None)\n    monkeypatch.setattr(agent.Path, \"exists\", lambda self: False)\n    with pytest.raises(SystemExit):\n        agent._chrome_bin()\n```\n\n---\n\n### Priority order for actually writing these\n\n1. **`models.py` + `filters.py`** — pure, no I/O, highest bug-catching value per line of test code (date parsing edge cases and the include/exclude/cutoff precedence rules are exactly the kind of logic that regresses silently).\n2. **`store.py`** — the dedup/migration logic is the system's source of truth; a `diff()` regression means every job gets re-notified or nothing does.\n3. **`notify.py`'s `dispatch` isolation** — currently unverified that one dead webhook doesn't silently kill SMS/email too.\n4. **`fetchers.py` retry logic + parsers** — largest surface, but parsers are pure and cheap to test; retry/pagination need `httpx.MockTransport`.\n5. **`agent.py`** — lower run frequency but the truncation-at-group-boundary logic in `cmd_db_new` is subtle enough to deserve its own test regardless of priority.\n6. **`pipeline.py`/`cli.py`** — thin glue; cover with 2-3 integration-style tests once the above exist, mocking `fetch_all`/`dispatch`.\n\nNo integration test currently exists that runs a fake ATS payload through `fetch_all → filter_jobs → Store.diff → dispatch` end-to-end — worth one such test once the unit layer is in place.\n",
