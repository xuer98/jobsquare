        "content": "import pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_returns_none(self):\n        assert parse_posted_at(\"\") is None\n\n    @pytest.mark.parametrize(\"value\", [None, \"not-a-date\", \"   \"])\n    def test_unparseable_returns_none(self, value):\n        assert parse_posted_at(value) is None\n\n    def test_epoch_milliseconds(self):\n        dt = parse_posted_at(\"1643241332430\")  # Lever-style ms\n        assert dt.year == 2022\n\n    def test_epoch_seconds(self):\n        dt = parse_posted_at(\"1643241332\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso8601_with_z(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00Z\")\n        assert dt.tzinfo is not None\n\n    def test_iso8601_naive_defaults_to_utc(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_negative_epoch(self):\n        assert parse_posted_at(\"-1000\") is not None\n\n\nclass TestJob:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"Engineer\", url=\"https://x\", location=\"NYC\")\n        return Job(**{**base, **overrides})\n\n    def test_key_is_stable_identity(self):\n        j = self._job()\n        assert j.key == \"greenhouse:acme:1\"\n\n    def test_content_hash_changes_on_title(self):\n        a, b = self._job(), self._job(title=\"Senior Engineer\")\n        assert a.content_hash != b.content_hash\n\n    def test_content_hash_stable_when_posted_at_or_salary_changes(self):\n        a = self._job(posted_at=\"2024-01-01\", salary_range=\"100k\")\n        b = self._job(posted_at=\"2024-06-01\", salary_range=\"200k\")\n        assert a.content_hash == b.content_hash  # dedup relies on this\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self):\n        j = self._job(raw={\"secret\": 1})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash\n```\n\n---\n\n",
