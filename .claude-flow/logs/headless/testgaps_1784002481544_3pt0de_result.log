        "title": "tests/test_fetch_pagination.py",
        "content": "import httpx, pytest\nimport fetchers\n\n@pytest.mark.asyncio\nasync def test_fetch_optiver_stops_on_empty_page():\n    def handler(request):\n        offset = int(request.url.params.get(\"from\", 0))\n        items = [] if offset > 0 else [{\"href\": \"/join-us/jobs/a\", \"title\": \"A\"}]\n        return httpx.Response(200, json={\"items\": items})\n    transport = httpx.MockTransport(handler)\n    async with httpx.AsyncClient(transport=transport) as client:\n        jobs = await fetchers.fetch_optiver(client, {\"company\": \"optiver\"})\n        assert len(jobs) == 1\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_raises_on_graphql_error(monkeypatch):\n    async def fake_get_text(client, url, **kw):\n        if \"graphql\" in url:\n            return 'for (;;);{\"errors\":[{\"message\":\"doc_id invalid\"}]}'\n        return '[\"LSD\",[],{\"token\":\"tok\"}]__spin_r\":1'\n    monkeypatch.setattr(fetchers, \"_get_text\", fake_get_text)\n    with pytest.raises(RuntimeError, match=\"doc_id invalid\"):\n        await fetchers.fetch_meta(httpx.AsyncClient(), {\"company\": \"meta\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_workday_stops_at_safety_cap(monkeypatch):\n    # data.total always huge -> loop must stop via offset > 5000, not hang\n    async def fake_get_json(client, url, **kw):\n        return {\"jobPostings\": [{\"externalPath\": \"/x\", \"bulletFields\": [\"r1\"]}],\n                 \"total\": 999999}\n    monkeypatch.setattr(fetchers, \"_get_json\", fake_get_json)\n    jobs = await fetchers.fetch_workday(\n        httpx.AsyncClient(), {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\", \"page_size\": 20})\n    assert len(jobs) <= 5000 // 20 + 1\n```\n\n**D. `fetch_source`/`fetch_all`:**\n- `fetch_source` raises `ValueError` for unknown `ats` key, message lists known ATS.\n- `fetch_all`: one source raising doesn't kill the others (currently the whole *point* of the try/except in `one()`, never verified); semaphore actually bounds concurrency; caller-supplied `client` isn't closed (`owns_client=False`) vs internally-created client is closed.\n\n```python\n@pytest.mark.asyncio\nasync def test_fetch_source_unknown_ats_raises():\n    with pytest.raises(ValueError, match=\"unknown ATS\"):\n        await fetchers.fetch_source(httpx.AsyncClient(), {\"ats\": \"bogus\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_all_isolates_failing_source(monkeypatch):\n    async def fake_fetch_source(client, src):\n        if src[\"ats\"] == \"broken\":\n            raise RuntimeError(\"boom\")\n        return [fetchers.Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")]\n    monkeypatch.setattr(fetchers, \"fetch_source\", fake_fetch_source)\n    jobs = await fetchers.fetch_all(\n        [{\"ats\": \"broken\", \"company\": \"b\"}, {\"ats\": \"ok\", \"company\": \"o\"}])\n    assert len(jobs) == 1\n```\n\n---\n\n",
