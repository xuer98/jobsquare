        "code": "# tests/test_notify.py\nimport pytest\nimport notify\nfrom models import Job\n\ndef _job(title=\"Engineer\", company=\"acme\"):\n    return Job(source=\"s\", company=company, external_id=\"1\", title=title, url=\"u\")\n\nclass TestNotifySlack:\n    def test_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        called = []\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_slack([_job()], [])\n        assert called == []\n\n    def test_noop_when_nothing_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n        called = []\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_slack([], [])\n        assert called == []\n\n    def test_posts_payload_when_configured(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n        captured = {}\n        def fake_post(url, json, timeout): captured.update(url=url, json=json)\n        monkeypatch.setattr(notify.httpx, \"post\", fake_post)\n        notify.notify_slack([_job()], [])\n        assert \"Engineer\" in captured[\"json\"][\"text\"]\n\n\nclass TestNotifySms:\n    def test_noop_with_partial_env(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.setenv(\"TWILIO_AUTH_TOKEN\", \"tok\")\n        monkeypatch.delenv(\"TWILIO_FROM\", raising=False)\n        monkeypatch.delenv(\"TWILIO_TO\", raising=False)\n        called = []\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: called.append(1))\n        notify.notify_sms([_job()], [])\n        assert called == []\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        for k, v in {\"TWILIO_ACCOUNT_SID\": \"s\", \"TWILIO_AUTH_TOKEN\": \"t\",\n                     \"TWILIO_FROM\": \"+1\", \"TWILIO_TO\": \"+2\"}.items():\n            monkeypatch.setenv(k, v)\n        class FakeResp:\n            def raise_for_status(self): raise RuntimeError(\"401 unauthorized\")\n        monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **k: FakeResp())\n        with pytest.raises(RuntimeError):\n            notify.notify_sms([_job()], [])\n\n\nclass TestSmsBody:\n    def test_truncates_and_reports_remainder(self):\n        jobs = [_job(title=f\"Job {i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n\n    def test_ascii_only_no_unicode_bullets(self):\n        body = notify._sms_body([_job()], [])\n        assert all(ord(c) < 128 for c in body)\n\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch):\n        calls = []\n        def boom(new, changed): raise RuntimeError(\"slack down\")\n        def ok(new, changed): calls.append(\"ok\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, ok])\n        notify.dispatch([_job()], [])\n        assert calls == [\"ok\"]"
