(\"kaboom\")\n    boom.__name__ = \"boom\"\n    good = MagicMock(__name__=\"good\")\n    with patch(\"notify.NOTIFIERS\", [boom, good]):\n        notify.dispatch([make_job()], [])\n    good.assert_called_once()\n    assert \"kaboom\" in capsys.readouterr().out"
