        "code": "# tests/test_store.py\nimport sqlite3\nimport pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef job():\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x\", location=\"NYC\")\n\ndef test_diff_inserts_new_job(tmp_path, job):\n    with Store(tmp_path / \"jobs.db\") as store:\n        new, changed = store.diff([job])\n        assert new == [job]\n        assert changed == []\n        assert store.count() == 1\n\ndef test_diff_unchanged_job_not_reported_as_changed(tmp_path, job):\n    with Store(tmp_path / \"jobs.db\") as store:\n        store.diff([job])\n        new, changed = store.diff([job])\n        assert new == [] and changed == []\n\ndef test_diff_detects_content_change(tmp_path, job):\n    with Store(tmp_path / \"jobs.db\") as store:\n        store.diff([job])\n        updated = Job(**{**job.__dict__, \"title\": \"Senior Engineer\"})\n        new, changed = store.diff([updated])\n        assert new == []\n        assert changed == [updated]\n\ndef test_diff_first_seen_stable_across_runs(tmp_path, job):\n    with Store(tmp_path / \"jobs.db\") as store:\n        store.diff([job])\n        row1 = store.conn.execute(\"SELECT first_seen FROM jobs WHERE key=?\", (job.key,)).fetchone()\n        store.diff([job])\n        row2 = store.conn.execute(\"SELECT first_seen FROM jobs WHERE key=?\", (job.key,)).fetchone()\n        assert row1[\"first_seen\"] == row2[\"first_seen\"]\n\ndef test_migration_adds_salary_range_to_legacy_db(tmp_path):\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(str(path))\n    conn.executescript(\"\"\"\n        CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n          external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n          employment_type TEXT, posted_at TEXT, content_hash TEXT,\n          first_seen TEXT, last_seen TEXT);\n    \"\"\")\n    conn.commit(); conn.close()\n    with Store(path) as store:\n        cols = {r[\"name\"] for r in store.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\ndef test_get_set_meta_roundtrip_and_overwrite(tmp_path):\n    with Store(tmp_path / \"jobs.db\") as store:\n        assert store.get_meta(\"last_scan\") is None\n        store.set_meta(\"last_scan\", \"2026-01-01T00:00:00+00:00\")\n        assert store.get_meta(\"last_scan\") == \"2026-01-01T00:00:00+00:00\"\n        store.set_meta(\"last_scan\", \"2026-02-01T00:00:00+00:00\")\n        assert store.get_meta(\"last_scan\") == \"2026-02-01T00:00:00+00:00\"\n\ndef test_added_since_excludes_boundary_and_orders_correctly(tmp_path, job):\n    with Store(tmp_path / \"jobs.db\") as store:\n        store.diff([job])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n        assert store.added_since(ts) == []          # strict > excludes equal timestamp\n        assert len(store.added_since(\"2000-01-01T00:00:00\")) == 1"
