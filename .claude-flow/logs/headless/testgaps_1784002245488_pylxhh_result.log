        "code": "# tests/test_pipeline.py\nimport pytest\nfrom unittest.mock import AsyncMock, patch\nimport pipeline\nfrom models import Job\n\ndef test_load_config_applies_defaults(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(\"db: custom.db\\n\")\n    cfg = pipeline.load_config(cfg_file)\n    assert cfg[\"sources\"] == []\n    assert cfg[\"filters\"] == {}\n    assert cfg[\"concurrency\"] == 8\n    assert cfg[\"db\"] == \"custom.db\"\n\n@pytest.mark.asyncio\nasync def test_run_dry_run_skips_store_and_dispatch(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(\"sources: []\\n\")\n    job = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[job])), \\\n         patch(\"pipeline.filter_jobs\", return_value=[job]), \\\n         patch(\"pipeline.Store\") as mock_store, \\\n         patch(\"pipeline.dispatch\") as mock_dispatch:\n        result = await pipeline.run(cfg_file, dry_run=True)\n    mock_store.assert_not_called()\n    mock_dispatch.assert_not_called()\n    assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n\n@pytest.mark.asyncio\nasync def test_run_full_path_persists_and_dispatches(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(f\"db: {tmp_path / 'jobs.db'}\\nsources: []\\n\")\n    job = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[job])), \\\n         patch(\"pipeline.filter_jobs\", return_value=[job]), \\\n         patch(\"pipeline.dispatch\") as mock_dispatch:\n        result = await pipeline.run(cfg_file, dry_run=False)\n    assert result[\"new\"] == 1\n    mock_dispatch.assert_called_once()\n\ndef test_run_sync_invokes_asyncio_run(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(\"sources: []\\n\")\n    with patch(\"pipeline.run\", new=AsyncMock(return_value={\"matched\": 0, \"new\": 0, \"changed\": 0})):\n        result = pipeline.run_sync(cfg_file)\n    assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}"
