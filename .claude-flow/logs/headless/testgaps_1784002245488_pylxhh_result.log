        "content": "import pytest\nfrom unittest.mock import patch, MagicMock\nimport notify\nfrom models import Job\n\ndef make_job(**kw):\n    defaults = dict(source=\"s\", company=\"c\", external_id=\"1\", title=\"Eng\", url=\"u\")\n    defaults.update(kw)\n    return Job(**defaults)\n\ndef test_notify_slack_noop_without_env(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    with patch(\"notify.httpx.post\") as post:\n        notify.notify_slack([make_job()], [])\n    post.assert_not_called()\n\ndef test_notify_slack_noop_when_no_jobs(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n    with patch(\"notify.httpx.post\") as post:\n        notify.notify_slack([], [])\n    post.assert_not_called()\n\ndef test_notify_slack_posts_when_configured_and_new_jobs(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n    with patch(\"notify.httpx.post\") as post:\n        notify.notify_slack([make_job()], [])\n    post.assert_called_once()\n    assert \"Eng\" in post.call_args.kwargs[\"json\"][\"text\"]\n\ndef test_sms_body_truncates_and_is_ascii_only():\n    jobs = [make_job(external_id=str(i), title=f\"Role {i}\") for i in range(10)]\n    body = notify._sms_body(jobs, [], limit=8)\n    assert \"+2 more\" in body\n    assert body.isascii()\n\ndef test_notify_sms_raises_on_http_error(monkeypatch):\n    for k, v in {\"TWILIO_ACCOUNT_SID\": \"sid\", \"TWILIO_AUTH_TOKEN\": \"tok\",\n                 \"TWILIO_FROM\": \"+1\", \"TWILIO_TO\": \"+2\"}.items():\n        monkeypatch.setenv(k, v)\n    resp = MagicMock()\n    resp.raise_for_status.side_effect = Exception(\"bad creds\")\n    with patch(\"notify.httpx.post\", return_value=resp):\n        with pytest.raises(Exception, match=\"bad creds\"):\n            notify.notify_sms([make_job()], [])\n\ndef test_dispatch_isolates_notifier_failures(capsys):\n    def boom(new, changed): raise RuntimeError(\"kaboom\")\n    boom.__name__ = \"boom\"\n    good = MagicMock(__name__=\"good\")\n    with patch(\"notify.NOTIFIERS\", [boom, good]):\n        notify.dispatch([make_job()], [])\n    good.assert_called_once()\n    assert \"kaboom\" in capsys.readouterr().out\n```\n\n---\n\n",
