        "title": "--- pure parser tests (no network) -----------------------------------------",
        "content": "\ndef test_parse_greenhouse_basic():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\", \"absolute_url\": \"u\",\n                       \"location\": {\"name\": \"NYC\"}, \"departments\": [{\"name\": \"Infra\"}],\n                       \"updated_at\": \"2026-01-01T00:00:00Z\"}]}\n    jobs = parse_greenhouse(\"acme\", data)\n    assert len(jobs) == 1 and jobs[0].location == \"NYC\" and jobs[0].department == \"Infra\"\n\ndef test_lever_salary_prefers_min_max_over_description():\n    j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"},\n         \"salaryDescriptionPlain\": \"ignored\"}\n    assert _lever_salary(j) == \"USD 100,000–150,000\"\n\ndef test_lever_salary_falls_back_to_description():\n    assert _lever_salary({\"salaryDescriptionPlain\": \"Competitive\"}) == \"Competitive\"\n\ndef test_parse_ashby_skips_unlisted_jobs():\n    data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"},\n                     {\"id\": \"2\", \"isListed\": True, \"title\": \"Visible\"}]}\n    jobs = parse_ashby(\"x\", data)\n    assert len(jobs) == 1 and jobs[0].title == \"Visible\"\n\ndef test_parse_workable_handles_dict_and_flat_location():\n    data = {\"jobs\": [\n        {\"shortcode\": \"a\", \"title\": \"T1\", \"location\": {\"location_str\": \"Remote\"}},\n        {\"shortcode\": \"b\", \"title\": \"T2\", \"city\": \"Austin\", \"state\": \"TX\", \"country\": \"US\"},\n    ]}\n    jobs = parse_workable(\"x\", data)\n    assert jobs[0].location == \"Remote\"\n    assert jobs[1].location == \"Austin, TX, US\"\n\ndef test_extract_ds1_returns_empty_on_no_match():\n    assert _extract_ds1(\"<html>no data here</html>\") == []\n\ndef test_extract_ds1_returns_empty_on_malformed_json():\n    html = \"key: 'ds:1', data:[not valid json], sideChannel\"\n    assert _extract_ds1(html) == []\n\ndef test_parse_google_handles_short_arrays_defensively():\n    # missing indices 9, 12-14 shouldn't raise\n    jobs = parse_google(\"google\", [[\"123\", \"Title\"]])\n    assert jobs[0].external_id == \"123\" and jobs[0].location == \"\"\n\ndef test_parse_deshaw_dedups_repeated_cards():\n    html = ('data-job-id=\"1\" class=\"job-display-name\">Engineer<'\n            'data-job-id=\"1\" class=\"job-display-name\">Engineer<')\n    jobs = parse_deshaw(\"deshaw\", html)\n    assert len(jobs) == 1\n\ndef test_amazon_posted_at_malformed_returns_empty():\n    assert _amazon_posted_at(\"garbage\") == \"\"\n\ndef test_amazon_posted_at_valid():\n    assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\ndef test_fetch_source_unknown_ats_raises():\n    with pytest.raises(ValueError, match=\"unknown ATS\"):\n        import asyncio\n        asyncio.run(fetch_source(None, {\"ats\": \"bogus\"}))\n\n",
