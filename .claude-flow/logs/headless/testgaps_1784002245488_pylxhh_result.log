        "content": "import json\nimport httpx\nimport pytest\nimport respx\nfrom fetchers import (\n    parse_greenhouse, parse_lever, _lever_salary, parse_ashby, parse_workable,\n    _extract_ds1, parse_google, parse_deshaw, parse_twosigma,\n    _amazon_posted_at, parse_amazon, fetch_source, fetch_all, _request, FETCHERS,\n)\n\n",
