        "title": "--- network-mocked tests (respx) -------------------------------------------",
        "content": "\n@pytest.mark.asyncio\n@respx.mock\nasync def test_request_retries_on_503_then_succeeds():\n    route = respx.get(\"https://x/y\")\n    route.side_effect = [httpx.Response(503), httpx.Response(200, json={\"ok\": True})]\n    async with httpx.AsyncClient() as client:\n        r = await _request(client, \"https://x/y\", retries=3)\n    assert r.status_code == 200\n    assert route.call_count == 2\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_request_gives_up_after_max_retries():\n    respx.get(\"https://x/y\").mock(return_value=httpx.Response(500))\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(client, \"https://x/y\", retries=2)\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_all_isolates_per_source_failures(capsys):\n    respx.get(\"https://boards-api.greenhouse.io/v1/boards/good/jobs\").mock(\n        return_value=httpx.Response(200, json={\"jobs\": []}))\n    respx.get(\"https://boards-api.greenhouse.io/v1/boards/bad/jobs\").mock(\n        return_value=httpx.Response(500))\n    sources = [{\"ats\": \"greenhouse\", \"company\": \"good\"},\n               {\"ats\": \"greenhouse\", \"company\": \"bad\"}]\n    jobs = await fetch_all(sources, concurrency=2)\n    assert jobs == []  # both empty, but crucially it didn't raise\n    assert \"failed\" in capsys.readouterr().out\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_optiver_pagination_stops_on_empty_page():\n    respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(side_effect=[\n        httpx.Response(200, json={\"items\": [{\"href\": \"/join-us/jobs/a\", \"title\": \"A\"}]}),\n        httpx.Response(200, json={\"items\": []}),\n    ])\n    from fetchers import fetch_optiver\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_optiver(client, {\"company\": \"optiver\"})\n    assert len(jobs) == 1\n```\n\n---\n\n",
