        "code": "# tests/test_store.py\nimport sqlite3\nfrom models import Job\nfrom store import Store\n\n\ndef _job(ext_id=\"1\", title=\"Eng\", location=\"NYC\"):\n    return Job(source=\"lever\", company=\"acme\", external_id=ext_id, title=title,\n               location=location, url=\"u\")\n\n\ndef test_diff_first_seen_is_all_new(store):\n    new, changed = store.diff([_job(\"1\"), _job(\"2\")])\n    assert {j.external_id for j in new} == {\"1\", \"2\"}\n    assert changed == []\n    assert store.count() == 2\n\n\ndef test_diff_unchanged_job_is_neither_new_nor_changed(store):\n    store.diff([_job(\"1\")])\n    new, changed = store.diff([_job(\"1\")])\n    assert new == changed == []\n    assert store.count() == 1\n\n\ndef test_diff_material_change_is_reported_as_changed(store):\n    store.diff([_job(\"1\", title=\"Eng I\")])\n    new, changed = store.diff([_job(\"1\", title=\"Eng II\")])\n    assert new == []\n    assert [j.external_id for j in changed] == [\"1\"]\n\n\ndef test_diff_updates_last_seen_even_when_unchanged(store):\n    store.diff([_job(\"1\")])\n    row_before = store.conn.execute(\"SELECT last_seen FROM jobs WHERE key=?\", (_job(\"1\").key,)).fetchone()\n    store.diff([_job(\"1\")])\n    row_after = store.conn.execute(\"SELECT last_seen FROM jobs WHERE key=?\", (_job(\"1\").key,)).fetchone()\n    assert row_after[\"last_seen\"] >= row_before[\"last_seen\"]\n\n\ndef test_migration_adds_salary_range_to_legacy_db(tmp_path):\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.executescript(\"\"\"\n        CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n          external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n          employment_type TEXT, posted_at TEXT, content_hash TEXT,\n          first_seen TEXT, last_seen TEXT);\n        CREATE TABLE meta (k TEXT PRIMARY KEY, v TEXT);\n    \"\"\")\n    conn.commit(); conn.close()\n    with Store(path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\n\ndef test_meta_get_set_roundtrip(store):\n    assert store.get_meta(\"missing\") is None\n    store.set_meta(\"last_scan\", \"2026-01-01T00:00:00+00:00\")\n    assert store.get_meta(\"last_scan\") == \"2026-01-01T00:00:00+00:00\"\n    store.set_meta(\"last_scan\", \"2026-02-01T00:00:00+00:00\")  # upsert path\n    assert store.get_meta(\"last_scan\") == \"2026-02-01T00:00:00+00:00\"\n\n\ndef test_next_seq_increments_and_persists(store):\n    assert store.next_seq(\"report_seq\") == 1\n    assert store.next_seq(\"report_seq\") == 2\n    assert store.get_meta(\"report_seq\") == \"2\"\n\n\ndef test_added_since_orders_by_first_seen_then_company_title(store):\n    store.diff([_job(\"1\")])\n    ts = store.get_meta(\"__marker__\") or \"1970-01-01T00:00:00+00:00\"\n    store.set_meta(\"__marker__\", ts)\n    rows = store.added_since(\"1970-01-01T00:00:00+00:00\")\n    assert len(rows) == 1\n    assert rows[0][\"external_id\"] == \"1\"\n\n\ndef test_added_since_excludes_rows_at_exact_boundary(store):\n    \"\"\"Boundary is strict '>' — a row with first_seen == ts must not reappear\n    on the next scan (this is what prevents duplicate notifications).\"\"\"\n    store.diff([_job(\"1\")])\n    ts = store.conn.execute(\"SELECT first_seen FROM jobs WHERE external_id='1'\").fetchone()[0]\n    assert store.added_since(ts) == []"
      },
