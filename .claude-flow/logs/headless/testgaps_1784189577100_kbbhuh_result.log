        "code": "# tests/test_fetchers_http.py\nimport httpx\nimport pytest\nfrom fetchers import _request, fetch_all, fetch_source, FETCHERS\n\n\n@pytest.mark.asyncio\nasync def test_request_retries_on_429_then_succeeds():\n    calls = {\"n\": 0}\n    def handler(req):\n        calls[\"n\"] += 1\n        if calls[\"n\"] < 3:\n            return httpx.Response(429)\n        return httpx.Response(200, json={\"jobs\": []})\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        r = await _request(client, \"https://x.test/jobs\", retries=4)\n    assert r.status_code == 200\n    assert calls[\"n\"] == 3\n\n\n@pytest.mark.asyncio\nasync def test_request_exhausts_retries_and_raises_runtimeerror():\n    async def handler(req): return httpx.Response(500)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(client, \"https://x.test/jobs\", retries=2)\n\n\n@pytest.mark.asyncio\nasync def test_request_does_not_retry_non_retryable_4xx():\n    calls = {\"n\": 0}\n    def handler(req):\n        calls[\"n\"] += 1\n        return httpx.Response(404)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        with pytest.raises(RuntimeError):\n            await _request(client, \"https://x.test/jobs\", retries=4)\n    assert calls[\"n\"] == 1  # raise_for_status on first attempt, no retry loop for plain 404\n\n\n@pytest.mark.asyncio\nasync def test_fetch_source_unknown_ats_raises_valueerror():\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            await fetch_source(client, {\"ats\": \"not-a-real-ats\"})\n\n\n@pytest.mark.asyncio\nasync def test_fetch_all_isolates_one_source_failure(capsys):\n    async def handler(req):\n        if \"greenhouse\" in str(req.url):\n            return httpx.Response(500)\n        return httpx.Response(200, json={\"jobs\": []})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    sources = [{\"ats\": \"greenhouse\", \"company\": \"broken\"},\n               {\"ats\": \"greenhouse\", \"company\": \"ok\"}]\n    # both hit the same handler branch here; use distinct handler per-url in a real test\n    jobs = await fetch_all(sources, client=client)\n    assert jobs == []  # no exception propagated\n    assert \"failed\" in capsys.readouterr().out\n\n\n@pytest.mark.asyncio\nasync def test_fetch_ashby_falls_back_to_hosted_page_on_404():\n    def handler(req):\n        if \"posting-api\" in str(req.url):\n            return httpx.Response(404)\n        html = ('window.__appData = {\"jobBoard\": {\"jobPostings\": '\n                '[{\"id\": \"1\", \"title\": \"Eng\", \"isListed\": true}]}};')\n        return httpx.Response(200, text=html)\n    from fetchers import fetch_ashby\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetch_ashby(client, {\"company\": \"acme\"})\n    assert len(jobs) == 1 and jobs[0].external_id == \"1\"\n\n\n@pytest.mark.asyncio\nasync def test_pagination_loop_stops_when_no_fresh_items(monkeypatch):\n    \"\"\"Pattern shared by twosigma/optiver/apple/microsoft/netflix/amazon/eightfold/\n    bytedance/phenom: dedup-by-seen-id must terminate pagination, not loop to max_pages.\"\"\"\n    calls = {\"n\": 0}\n    def handler(req):\n        calls[\"n\"] += 1\n        return httpx.Response(200, json={\"data\": {\"positions\": []}})\n    from fetchers import fetch_microsoft\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetch_microsoft(client, {\"company\": \"microsoft\", \"max_pages\": 40})\n    assert jobs == []\n    assert calls[\"n\"] == 1  # stopped after first empty page, didn't run all 40"
