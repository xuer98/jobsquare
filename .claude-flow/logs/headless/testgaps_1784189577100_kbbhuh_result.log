        "code": "# tests/test_notify.py\nimport pytest\nfrom models import Job\nimport notify\n\n\ndef _job(title=\"Eng\"):\n    return Job(source=\"s\", company=\"acme\", external_id=\"1\", title=title, url=\"u\", location=\"NYC\")\n\n\ndef test_notify_slack_noop_without_webhook_env(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    notify.notify_slack([_job()], [])  # must not raise, must not call httpx\n\n\ndef test_notify_slack_posts_when_configured(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n    calls = []\n    monkeypatch.setattr(notify.httpx, \"post\", lambda url, **kw: calls.append((url, kw)))\n    notify.notify_slack([_job()], [])\n    assert len(calls) == 1\n    assert \"Eng\" in calls[0][1][\"json\"][\"text\"]\n\n\ndef test_notify_slack_skips_post_when_nothing_new_or_changed(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n    calls = []\n    monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **kw: calls.append(1))\n    notify.notify_slack([], [])\n    assert calls == []\n\n\ndef test_sms_body_is_ascii_only_and_truncates_to_limit():\n    jobs = [_job(f\"Role {i}\") for i in range(12)]\n    body = notify._sms_body(jobs, [], limit=8)\n    assert body.isascii()\n    assert \"+4 more\" in body\n    assert body.count(\"\\n- \") == 8\n\n\ndef test_notify_sms_requires_all_four_twilio_vars(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n    monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)  # missing\n    calls = []\n    monkeypatch.setattr(notify.httpx, \"post\", lambda *a, **kw: calls.append(1))\n    notify.notify_sms([_job()], [])\n    assert calls == []\n\n\ndef test_dispatch_isolates_a_failing_notifier(monkeypatch, capsys):\n    def boom(new, changed): raise RuntimeError(\"smtp down\")\n    monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, notify.notify_console])\n    notify.dispatch([_job()], [])   # must not raise\n    out = capsys.readouterr().out\n    assert \"notifier boom failed\" in out\n    assert \"Eng\" in out  # console notifier still ran"
