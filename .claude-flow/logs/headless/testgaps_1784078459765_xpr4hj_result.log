        "content": "import pytest, yaml\nfrom pipeline import load_config, run\n\ndef test_load_config_fills_defaults(tmp_path):\n    p = tmp_path / \"c.yaml\"\n    p.write_text(yaml.dump({}))\n    cfg = load_config(p)\n    assert cfg == {\"sources\": [], \"filters\": {}, \"db\": \"jobs.db\", \"concurrency\": 8}\n\n@pytest.mark.asyncio\nasync def test_run_dry_run_does_not_persist(tmp_path, monkeypatch):\n    cfg_path = tmp_path / \"c.yaml\"\n    cfg_path.write_text(yaml.dump({\"sources\": [], \"db\": str(tmp_path / \"jobs.db\")}))\n    result = await run(cfg_path, dry_run=True)\n    assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n    assert not (tmp_path / \"jobs.db\").exists()  # store never opened\n\n@pytest.mark.asyncio\nasync def test_run_persists_and_dispatches(tmp_path, monkeypatch):\n    import pipeline\n    async def fake_fetch_all(sources, concurrency): \n        from models import Job\n        return [Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"t\", url=\"u\")]\n    dispatched = {}\n    monkeypatch.setattr(pipeline, \"fetch_all\", fake_fetch_all)\n    monkeypatch.setattr(pipeline, \"dispatch\", lambda new, changed: dispatched.update(new=new))\n\n    cfg_path = tmp_path / \"c.yaml\"\n    cfg_path.write_text(yaml.dump({\"sources\": [{}], \"db\": str(tmp_path / \"jobs.db\")}))\n    result = await run(cfg_path, dry_run=False)\n    assert result[\"new\"] == 1\n    assert len(dispatched[\"new\"]) == 1\n```\n\n---\n\n",
