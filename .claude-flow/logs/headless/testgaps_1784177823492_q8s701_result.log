        "content": "from fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       parse_smartrecruiters, parse_recruitee, parse_workable)\n\ndef test_greenhouse_maps_department_and_location():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\",\n                       \"location\": {\"name\": \"NYC\"},\n                       \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Infra\"}],\n                       \"updated_at\": \"2026-01-01T00:00:00Z\"}]}\n    jobs = parse_greenhouse(\"acme\", data)\n    assert jobs[0].department == \"Eng, Infra\"\n\ndef test_greenhouse_missing_location_defaults_empty():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\"}]}\n    assert parse_greenhouse(\"acme\", data)[0].location == \"\"\n\nclass TestLeverSalary:\n    def test_min_and_max_present_formats_with_commas(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000ā€“150,000\"\n\n    def test_missing_range_falls_back_to_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_neither_present_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\ndef test_ashby_filters_unlisted_jobs():\n    data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"},\n                      {\"id\": \"2\", \"isListed\": True, \"title\": \"Visible\"}]}\n    jobs = parse_ashby(\"acme\", data)\n    assert len(jobs) == 1 and jobs[0].title == \"Visible\"\n\ndef test_recruitee_location_flat_string_vs_assembled():\n    flat = parse_recruitee(\"c\", {\"offers\": [{\"id\": 1, \"title\": \"T\", \"location\": \"Berlin\"}]})\n    assembled = parse_recruitee(\"c\", {\"offers\": [{\"id\": 2, \"title\": \"T\", \"city\": \"Berlin\", \"country\": \"DE\"}]})\n    assert flat[0].location == \"Berlin\"\n    assert assembled[0].location == \"Berlin, DE\"\n\ndef test_workable_location_dict_vs_flat_fields():\n    dict_loc = parse_workable(\"c\", {\"jobs\": [{\"id\": 1, \"title\": \"T\",\n                                              \"location\": {\"location_str\": \"Remote\"}}]})\n    flat_loc = parse_workable(\"c\", {\"jobs\": [{\"id\": 2, \"title\": \"T\",\n                                              \"city\": \"Austin\", \"state\": \"TX\", \"country\": \"US\"}]})\n    assert dict_loc[0].location == \"Remote\"\n    assert flat_loc[0].location == \"Austin, TX, US\"\n```\n\n",
