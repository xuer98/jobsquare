t(\"999999999999\")   # 1e12 - 1 -> treated as seconds -> far future\n        just_at = parse_posted_at(\"1000000000000\")      # treated as ms\n        assert just_under.year != just_at.year\n\n    def test_negative_epoch(self):\n        assert parse_posted_at(\"-100\") is not None  # lstrip(\"-\").isdigit() path\n\n    def test_iso8601_with_z_suffix(self):\n        dt = parse_posted_at(\"2026-06-26T00:00:00Z\")\n        assert dt == datetime(2026, 6, 26, tzinfo=timezone.utc)\n\n    def test_iso8601_naive_gets_utc(self):\n        dt = parse_posted_at(\"2026-06-26T00:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_workday_prose_is_unparseable(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_garbage_string(self):\n        assert parse_posted_at(\"not-a-date\") is None\n\n    def test_whitespace_stripped(self):\n        assert parse_posted_at(\"  1643241332430  \") is not None\n\n\nclass TestJob:\n    def _job(self, **kw):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"Engineer\", url=\"https://x\", location=\"NYC\")\n        return Job(**{**base, **kw})\n\n    def test_key_is_stable_across_title_edits(self):\n        j1, j2 = self._job(title=\"Engineer I\"), self._job(title=\"Engineer II\")\n        assert j1.key == j2.key  # key ignores title\n\n    def test_content_hash_changes_on_title(self):\n        assert self._job(title=\"A\").content_hash != self._job(title=\"B\").content_hash\n\n    def test_content_hash_stable_for_identical_fields(self):\n        assert self._job().content_hash == self._job().content_hash\n\n    def test_content_hash_ignores_external_id_and_raw(self):\n        j1 = self._job(raw={\"a\": 1})\n        j2 = self._job(raw={\"a\": 2})\n        assert j1.content_hash == j2.content_hash\n\n    def test_posted_dt_delegates_to_parse_posted_at(self):\n        assert self._job(posted_at=\"\").posted_dt is None\n\n    def test_to_row_