        "title": "tests/test_fetchers_request.py",
        "content": "import httpx, pytest, respx\nfrom fetchers import _request\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_succeeds_first_try():\n    respx.get(\"https://x/j\").mock(return_value=httpx.Response(200, json={}))\n    async with httpx.AsyncClient() as c:\n        r = await _request(c, \"https://x/j\")\n        assert r.status_code == 200\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_retries_on_502_then_succeeds():\n    route = respx.get(\"https://x/j\")\n    route.side_effect = [httpx.Response(502), httpx.Response(200, json={})]\n    async with httpx.AsyncClient() as c:\n        r = await _request(c, \"https://x/j\", retries=3)\n        assert r.status_code == 200\n        assert route.call_count == 2\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_exhausts_retries_and_raises_runtimeerror():\n    respx.get(\"https://x/j\").mock(return_value=httpx.Response(503))\n    async with httpx.AsyncClient() as c:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(c, \"https://x/j\", retries=2)\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_non_retryable_4xx_raises_immediately_without_retry():\n    route = respx.get(\"https://x/j\").mock(return_value=httpx.Response(404))\n    async with httpx.AsyncClient() as c:\n        with pytest.raises(RuntimeError):\n            await _request(c, \"https://x/j\", retries=5)\n        assert route.call_count == 1  # no retries wasted on a real 404\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_transport_error_is_retried():\n    respx.get(\"https://x/j\").mock(side_effect=httpx.ConnectError(\"dns\"))\n    async with httpx.AsyncClient() as c:\n        with pytest.raises(RuntimeError):\n            await _request(c, \"https://x/j\", retries=2)\n```\n\n",
