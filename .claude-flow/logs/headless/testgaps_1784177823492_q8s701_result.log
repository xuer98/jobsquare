        "content": "\n```python\ndef test_fetch_source_raises_on_unknown_ats():\n    import pytest\n    from fetchers import fetch_source\n    with pytest.raises(ValueError, match=\"unknown ATS\"):\n        import asyncio; asyncio.run(fetch_source(None, {\"ats\": \"bogus\"}))\n\n@pytest.mark.asyncio\nasync def test_fetch_all_isolates_one_source_failure(monkeypatch):\n    # one source raising must not prevent others' jobs from being returned\n    from fetchers import fetch_all\n    async def boom(client, source): raise RuntimeError(\"down\")\n    async def ok(client, source): return [_job()]\n    monkeypatch.setitem(__import__(\"fetchers\").FETCHERS, \"greenhouse\", boom)\n    monkeypatch.setitem(__import__(\"fetchers\").FETCHERS, \"lever\", ok)\n    jobs = await fetch_all([{\"ats\": \"greenhouse\", \"company\": \"x\"},\n                             {\"ats\": \"lever\", \"company\": \"y\"}])\n    assert len(jobs) == 1\n```\n\n---\n\n",
