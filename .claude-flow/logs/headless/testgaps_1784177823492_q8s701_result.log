      {
        "title": "tests/test_agent.py",
        "content": "import json, pytest\nfrom store import Store\nimport agent\n\nclass TestCmdDbNew:\n    def test_first_run_uses_since_days_window(self, tmp_path, capsys):\n        db = tmp_path / \"j.db\"\n        Store(db).close()\n        cfg = tmp_path / \"c.yaml\"; cfg.write_text(f\"db: {db}\\n\")\n        agent.cmd_db_new([\"-c\", str(cfg), \"--since-days\", \"3\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n\n    def test_truncation_never_splits_a_first_seen_group(self, tmp_path, capsys):\n        # regression: cmd_db_new must truncate at group boundaries, not mid-group,\n        # since one pipeline run stamps every new row with an identical timestamp\n        db = tmp_path / \"j.db\"\n        with Store(db) as s:\n            from models import Job\n            # simulate two \"runs\" each inserting 3 jobs with distinct timestamps\n            # via direct SQL since Store.diff always uses \"now\"\n            ...\n        cfg = tmp_path / \"c.yaml\"; cfg.write_text(f\"db: {db}\\n\")\n        agent.cmd_db_new([\"-c\", str(cfg), \"--limit\", \"2\"])  # limit smaller than a group\n        out = json.loads(capsys.readouterr().out)\n        # all jobs sharing the oldest first_seen must be present together, or none\n        seen_ts = {j[\"first_seen\"] for j in out[\"jobs\"]}\n        assert len(seen_ts) <= 1 or out[\"truncated\"] is False\n\n\nclass TestCmdDbMark:\n    def test_now_flag_sets_current_time(self, tmp_path):\n        db = tmp_path / \"j.db\"; Store(db).close()\n        cfg = tmp_path / \"c.yaml\"; cfg.write_text(f\"db: {db}\\n\")\n        assert agent.cmd_db_mark([\"--now\", \"-c\", str(cfg)]) == 0\n\n    def test_invalid_watermark_returns_exit_code_2(self, tmp_path, capsys):\n        cfg = tmp_path / \"c.yaml\"; cfg.write_text(f\"db: {tmp_path/'j.db'}\\n\")\n        assert agent.cmd_db_mark([\"not-a-date\", \"-c\", str(cfg)]) == 2\n\n    def test_no_args_returns_exit_code_2(self, tmp_path):\n        cfg = tmp_path / \"c.yaml\"; cfg.write_text(f\"db: {tmp_path/'j.db'}\\n\")\n        assert agent.cmd_db_mark([\"-c\", str(cfg)]) == 2\n\n\nclass TestNormalizeAts:\n    def test_smart_quotes_and_dashes_replaced(self):\n        html, counts = agent._normalize_ats(\"<p>\\u201cHello\\u201d \\u2014 world\\u2026</p>\")\n        assert '\"Hello\"' in html and \"- world...\" in html\n        assert counts[\"smart-double-quote\"] == 2\n\n    def test_does_not_touch_style_or_script_blocks(self):\n        html, counts = agent._normalize_ats(\n            \"<style>.x::before{content:'\\u2014'}</style><p>\\u2014</p>\")\n        assert \"\\u2014\" in html.split(\"</style>\")[0]  # style block untouched\n        assert counts.get(\"em-dash\") == 1  # only the <p> occurrence counted\n\n    def test_no_special_chars_returns_empty_counts(self):\n        html, counts = agent._normalize_ats(\"<p>plain text</p>\")\n        assert counts == {}\n\n\nclass TestPdfRender:\n    def test_missing_input_file_returns_exit_2(self, tmp_path, capsys):\n        rc = agent.cmd_pdf_render([str(tmp_path / \"nope.html\")])\n        assert rc == 2\n\n    def test_tmp_file_cleaned_up_even_when_chrome_fails(self, tmp_path, monkeypatch):\n        src = tmp_path / \"in.html\"; src.write_text(\"<html></html>\")\n        monkeypatch.setattr(agent, \"_chrome_bin\", lambda: \"/bin/false\")\n        agent.cmd_pdf_render([str(src)])\n        assert not (tmp_path / \".in.ats.html\").exists()\n\n\nclass TestMainRouting:\n    def test_bare_invocation_is_interactive(self, monkeypatch):\n        called = {}\n        monkeypatch.setattr(agent, \"run_claude\",\n                             lambda words, interactive, extra: called.update(\n                                 words=words, interactive=interactive) or 0)\n        import sys\n        monkeypatch.setattr(sys, \"argv\", [\"agent.py\"])\n        agent.main()\n        assert called[\"interactive\"] is True\n\n    def test_mode_words_stop_at_first_flag(self, monkeypatch):\n        called = {}\n        monkeypatch.setattr(agent, \"run_claude\",\n                             lambda words, interactive, extra: called.update(\n                                 words=words, extra=extra) or 0)\n        import sys\n        monkeypatch.setattr(sys, \"argv\", [\"agent.py\", \"scan\", \"--foo\", \"bar\"])\n        agent.main()\n        assert called[\"words\"] == [\"scan\"]\n        assert called[\"extra\"] == [\"--foo\", \"bar\"]\n```\n\n---\n\n",
