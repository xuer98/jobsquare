        "title": "tests/test_filters.py",
        "content": "from datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(title=\"Software Engineer\", dept=\"\", loc=\"Remote\", posted_at=\"\"):\n    return Job(source=\"x\", company=\"c\", external_id=\"1\", title=title,\n               url=\"u\", department=dept, location=loc, posted_at=posted_at)\n\nclass TestMatch:\n    def test_exclude_takes_priority_over_include(self):\n        j = _job(title=\"Senior Manager Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"manager\"]) is False\n\n    def test_word_boundary_prevents_substring_false_positive(self):\n        # \"eng\" should not match \"engineering\" ā€” regex uses \\b\n        j = _job(title=\"Engineering Lead\")\n        assert match(j, include=[\"eng\"]) is False\n\n    def test_include_is_case_insensitive(self):\n        assert match(_job(title=\"ENGINEER\"), include=[\"engineer\"]) is True\n\n    def test_no_include_keeps_everything(self):\n        assert match(_job(title=\"Anything\"), include=None) is True\n\n    def test_location_substring_match_is_case_insensitive(self):\n        assert match(_job(loc=\"San Francisco, CA\"), locations=[\"san francisco\"]) is True\n\n    def test_location_no_match_excludes(self):\n        assert match(_job(loc=\"London\"), locations=[\"New York\"]) is False\n\n    def test_cutoff_drops_confirmed_old_posting(self):\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        old = _job(posted_at=(cutoff - timedelta(days=1)).isoformat())\n        assert match(old, cutoff=cutoff) is False\n\n    def test_cutoff_keeps_unparseable_posted_at(self):\n        # documented behavior: don't nuke postings whose date we can't parse\n        cutoff = datetime.now(timezone.utc)\n        j = _job(posted_at=\"Posted 3 Days Ago\")\n        assert match(j, cutoff=cutoff) is True\n\n    def test_cutoff_keeps_recent_posting(self):\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        recent = _job(posted_at=datetime.now(timezone.utc).isoformat())\n        assert match(recent, cutoff=cutoff) is True\n\n\nclass TestFilterJobs:\n    def test_max_age_days_converts_to_cutoff(self):\n        jobs = [_job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())]\n        assert filter_jobs(jobs, {\"max_age_days\": 7}) == []\n\n    def test_empty_rules_returns_all(self):\n        jobs = [_job(), _job(title=\"Other\")]\n        assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n",
