        "code": "# tests/test_store.py\nimport sqlite3\nimport pytest\nfrom models import Job\nfrom store import Store\n\ndef _job(ext_id=\"1\", title=\"Engineer\", loc=\"NYC\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id,\n               title=title, url=\"https://x\", location=loc)\n\nclass TestDiff:\n    def test_new_job_is_inserted_and_returned_as_new(self, tmp_path):\n        with Store(tmp_path / \"j.db\") as s:\n            new, changed = s.diff([_job()])\n            assert len(new) == 1 and changed == []\n            assert s.count() == 1\n\n    def test_unchanged_job_updates_last_seen_only_not_reported(self, tmp_path):\n        with Store(tmp_path / \"j.db\") as s:\n            s.diff([_job()])\n            new, changed = s.diff([_job()])  # identical content_hash\n            assert new == [] and changed == []\n\n    def test_changed_content_hash_is_reported_and_persisted(self, tmp_path):\n        with Store(tmp_path / \"j.db\") as s:\n            s.diff([_job(title=\"Old Title\")])\n            new, changed = s.diff([_job(title=\"New Title\")])\n            assert new == [] and len(changed) == 1\n            row = s.conn.execute(\"SELECT title FROM jobs WHERE key=?\",\n                                  (_job().key,)).fetchone()\n            assert row[\"title\"] == \"New Title\"\n\n    def test_diff_is_idempotent_across_calls_same_run(self, tmp_path):\n        with Store(tmp_path / \"j.db\") as s:\n            jobs = [_job(\"1\"), _job(\"2\")]\n            new1, _ = s.diff(jobs)\n            new2, _ = s.diff(jobs)\n            assert len(new1) == 2 and len(new2) == 0\n\n\nclass TestMigration:\n    def test_legacy_db_without_salary_range_gets_column_added(self, tmp_path):\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(path)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        with Store(path) as s:  # must not raise\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, tmp_path):\n        with Store(tmp_path / \"j.db\") as s:\n            assert s.get_meta(\"nope\") is None\n\n    def test_set_meta_then_get_meta_roundtrip(self, tmp_path):\n        with Store(tmp_path / \"j.db\") as s:\n            s.set_meta(\"last_scan\", \"2026-07-01T00:00:00+00:00\")\n            assert s.get_meta(\"last_scan\") == \"2026-07-01T00:00:00+00:00\"\n\n    def test_set_meta_overwrites_existing_key(self, tmp_path):\n        with Store(tmp_path / \"j.db\") as s:\n            s.set_meta(\"k\", \"v1\"); s.set_meta(\"k\", \"v2\")\n            assert s.get_meta(\"k\") == \"v2\"\n\n    def test_next_seq_increments(self, tmp_path):\n        with Store(tmp_path / \"j.db\") as s:\n            assert s.next_seq(\"report_seq\") == 1\n            assert s.next_seq(\"report_seq\") == 2\n\n    def test_next_seq_is_atomic_across_two_connections(self, tmp_path):\n        # regression coverage for the BEGIN IMMEDIATE serialization the\n        # docstring claims ā€” spawn concurrent claimers and assert no duplicate\n        import threading\n        path = tmp_path / \"j.db\"\n        Store(path).close()  # create schema first\n        results = []\n        def claim():\n            with Store(path) as s:\n                results.append(s.next_seq(\"report_seq\"))\n        threads = [threading.Thread(target=claim) for _ in range(10)]\n        [t.start() for t in threads]; [t.join() for t in threads]\n        assert sorted(results) == list(range(1, 11))  # no duplicates/gaps\n\n\nclass TestAddedSince:\n    def test_strictly_after_boundary_excludes_equal_timestamp(self, tmp_path):\n        with Store(tmp_path / \"j.db\") as s:\n            s.diff([_job()])\n            ts = s.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n            assert s.added_since(ts) == []  # strict >, not >=\n\n    def test_ordered_oldest_first_by_company_then_title(self, tmp_path):\n        with Store(tmp_path / \"j.db\") as s:\n            s.diff([_job(\"2\", title=\"Zeta\"), _job(\"1\", title=\"Alpha\")])\n            rows = s.added_since(\"1970-01-01T00:00:00+00:00\")\n            assert [r[\"title\"] for r in rows] == [\"Alpha\", \"Zeta\"]"
