        "content": "import pytest\nimport notify\nfrom models import Job\n\ndef _job(**kw):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Engineer\",\n               url=\"https://x\", **kw)\n\nclass TestDispatch:\n    def test_one_failing_notifier_does_not_block_others(self, monkeypatch, capsys):\n        calls = []\n        def boom(new, changed): raise RuntimeError(\"slack down\")\n        def ok(new, changed): calls.append(\"ok\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, ok])\n        notify.dispatch([_job()], [])\n        assert calls == [\"ok\"]\n        assert \"boom\" in capsys.readouterr().out or \"failed\" in capsys.readouterr().out\n\n\nclass TestNotifySlack:\n    def test_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        notify.notify_slack([_job()], [])  # must not raise / must not call httpx\n\n    def test_noop_when_no_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.example\")\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_slack([], [])\n            post.assert_not_called()\n\n    def test_posts_when_webhook_and_jobs_present(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.example\")\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_slack([_job(salary_range=\"$100k\")], [])\n            assert post.called\n            assert \"$100k\" in post.call_args.kwargs[\"json\"][\"text\"]\n\n\nclass TestNotifySms:\n    def test_requires_all_four_twilio_env_vars(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        # missing TOKEN/FROM/TO\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_sms([_job()], [])\n            post.assert_not_called()\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        for k, v in {\"TWILIO_ACCOUNT_SID\": \"sid\", \"TWILIO_AUTH_TOKEN\": \"tok\",\n                      \"TWILIO_FROM\": \"+1\", \"TWILIO_TO\": \"+2\"}.items():\n            monkeypatch.setenv(k, v)\n        with patch(\"notify.httpx.post\") as post:\n            post.return_value.raise_for_status.side_effect = Exception(\"401\")\n            with pytest.raises(Exception):\n                notify.notify_sms([_job()], [])\n\nclass TestSmsBody:\n    def test_truncates_at_limit_with_overflow_count(self):\n        jobs = [_job(external_id=str(i)) for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n\n    def test_ascii_only_no_bullet_or_ellipsis_chars(self):\n        body = notify._sms_body([_job()], [])\n        assert \"ā€¢\" not in body and \"ā€¦\" not in body\n```\n\n---\n\n",
