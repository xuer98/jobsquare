      {
        "title": "tests/test_fetchers_pagination.py",
        "content": "import httpx, pytest, respx\nfrom fetchers import fetch_optiver  # swap per-fetcher; same shape\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_stops_when_no_fresh_ids_even_if_page_nonempty():\n    # page 2 returns the *same* ids as page 1 ā€” must not loop past max_pages\n    respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n        return_value=httpx.Response(200, json={\"items\": [\n            {\"href\": \"/join-us/jobs/eng/a/1\", \"title\": \"T\", \"location\": \"AMS\"}]}))\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_optiver(client, {\"max_pages\": 5})\n    assert len(jobs) == 1  # deduped, didn't multiply across 5 pages\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_respects_max_pages_cap_on_endless_fresh_results():\n    call_count = 0\n    def responder(request):\n        nonlocal call_count\n        call_count += 1\n        return httpx.Response(200, json={\"items\": [\n            {\"href\": f\"/join-us/jobs/eng/a/{call_count}\", \"title\": \"T\", \"location\": \"AMS\"}]})\n    respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(side_effect=responder)\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_optiver(client, {\"max_pages\": 3})\n    assert call_count == 3\n```\n\n",
