_across_immaterial_fields(self, make_job):\n        j1 = make_job(salary_range=\"\", posted_at=\"\")\n        j2 = make_job(salary_range=\"$100k\", posted_at=\"2024-01-01\")\n        assert j1.content_hash == j2.content_hash  # dedup must not fire on these\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self, make_job):\n        j = make_job(raw={\"secret\": True})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash\n```\n\n---\n\n## 2. `filters.py` — pure logic, zero deps, untested\n\n**Missing:**\n- Word-boundary regex behavior — `\"eng\"` must NOT match inside `\"engineering\"` (this is the entire point of `\\b...\\b` and is unverified).\n- Case-insensitivity.\n- `exclude` short-circuits before `include` is even checked.\n- `cutoff` keeps jobs with unparseable `posted_at` (explicit design decision in the comment, untested).\n- Boundary: `posted_dt == cutoff` exactly (kept, since condition is `<` not `<=`).\n- `filter_jobs` with empty/absent `rules` dict keys.\n\n```python\n# test_filters.py\nfrom datetime import datetime, timedelta, timezone\nfrom filters import match, filter_jobs\n\nclass TestMatch:\n    def test_include_word_boundary_not_substring(self, make_job):\n        j = make_job(title=\"Senior Engineering Manager\")\n        assert match(j, include=[\"eng\"]) is False  # \"eng\" != \"engineering\"\n        assert match(j, include=[\"engineering\"]) is True\n\n    def test_case_insensitive(self, make_job):\n        j = make_job(title=\"Backend Engineer\")\n        assert match(j, include=[\"ENGINEER\"]) is True\n\n    def test_exclude_wins_over_include(self, make_job):\n        j = make_job(title=\"Staff Engineer\", department=\"Sales\")\n        assert match(j, include=[\"engineer\"], exclude=[\"sales\"]) is False\n\n    def test_location_substring_case_insensitive(self, make_job):\n        j = make_job(location=\"Remote - New York, NY\")\n        assert match(j, locations=[\"new york\"]) is True\n        assert match(j, locations=[\"seattle\"]) is False\n\n    def test_cutoff_keeps_unparseable_posted_at(self, make_job):\n        j = make_job(posted_at=\"garbage\")\n        cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n        assert match(j, cutoff=cutoff) is True  # can't confirm stale -> keep\n\n    def test_cutoff_drops_older(self, make_job):\n        old = (datetime.now(timezone.utc) - timedelta(days=10)).isoformat()\n        j = make_job(posted_at=old)\n        cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n        assert match(j, cutoff=cutoff) is False\n\n    def test_no_filters_passes_everything(self, make_job):\n        assert match(make_job()) is True\n\n\nclass TestFilterJobs:\n    def test_max_age_days_builds_cutoff(self, make_job):\n        stale = make_job(external_id=\"1\",\n                          posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n        fresh = make_job(external_id=\"2\",\n                          posted_at=datetime.now(timezone.utc).isoformat())\n        result = filter_jobs([stale, fresh], {\"max_age_days\": 7})\n        assert result == [fresh]\n\n    def test_empty_rules_returns_all(self, make_job):\n        jobs = [make_job(external_id=str(i)) for i in range(3)]\n        assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n## 3. `fetchers.py` — largest surface, highest risk, fully untested\n\n787 lines, 16 registered ATS backends, all pure `parse_*` functions designed for this per the module docstring, and none tested.\n\n**Untested parsers** (each has missing-field / malformed-input edge cases):\n- `parse_greenhouse` — missing `location`/`departments`\n- `parse_lever` + `_lever_salary` — salary present vs falls back to `salaryDescriptionPlain`; only one of lo/hi set\n- `parse_ashby` + `_ashby_salary` — `isListed: False` must be filtered out; `id` vs `jobId` fallback\n- `parse_smartrecruiters` — partial location (missing city/region/country)\n- `parse_recruitee` — flat string location vs assembled from city/country\n- `parse_workable` — dict location vs flat fields\n- `_extract_ds1` — primary regex match, fallback regex match, invalid JSON, no match at all\n- `_ds1_posted_at` — prefers index 12 over 13/14; short array\n- `parse_google` — skips falsy `j[0]`; short arrays\n- `parse_deshaw` — dedup via `seen`; missing optional `mloc`/`mhref` groups\n- `parse_twosigma` — dedup (cards render 3x per role — explicitly commented, untested)\n- `parse_optiver` — id derived from href with/without `join-us/jobs/` prefix\n- `_amazon_posted_at` — valid date, malformed (`ValueError`/`KeyError` caught → `\"\"`)\n- `parse_amazon` — `id` vs `id_icims` fallback\n- `parse_microsoft` — `postedTs` missing; `standardizedLocations` vs `locations` fallback\n- `parse_netflix` — `t_create` vs `t_update` fallback; comma-packed location reformatting\n\n**Untested control flow (needs `respx` to mock httpx):**\n- `_request` retry/backoff: succeeds after transient 5xx, exhausts retries → `RuntimeError`. **Bug-shaped edge case worth a test:** a non-retryable 404 is caught by the same `except (..., httpx.HTTPStatusError)` clause as a 500, so it gets retried `retries` times before failing — confirm this is intentional.\n- `fetch_source` — unknown `ats` raises `ValueError`\n- `fetch_all` — one source failing doesn't kill the others; results are flattened\n- Pagination loops (`fetch_workday`, `fetch_google`, `fetch_twosigma`, `fetch_optiver`, `fetch_microsoft`, `fetch_netflix`, `fetch_amazon`) — stop-on-no-fresh-results logic, `max_pages` cap respected, Workday's `offset > 5000` safety cap\n\n```python\n# test_fetchers.py\nimport httpx\nimport pytest\nimport respx\nfrom fetchers import (parse_greenhouse, parse_lever, parse_ashby, _extract_ds1,\n                       _ds1_posted_at, _amazon_posted_at, parse_amazon,\n                       fetch_source, fetch_all, _request)\n\nclass TestParseGreenhouse:\n    def test