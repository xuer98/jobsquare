        "title": "test_agent.py",
        "content": "import pytest\nfrom unittest.mock import patch, MagicMock\nfrom agent import cmd_db_mark, _normalize_ats, cmd_pdf_render, _chrome_bin\n\nclass TestCmdDbMark:\n    def test_invalid_watermark_returns_2(self, capsys):\n        assert cmd_db_mark([\"not-a-timestamp\"]) == 2\n        assert \"not an ISO timestamp\" in capsys.readouterr().err\n\n    def test_neither_watermark_nor_now_returns_2(self, capsys):\n        assert cmd_db_mark([]) == 2\n\nclass TestNormalizeAts:\n    def test_smart_quotes_replaced_in_body(self):\n        html = \"<p>\\u201cHello\\u201d</p>\"\n        out, counts = _normalize_ats(html)\n        assert '\"Hello\"' in out\n        assert counts[\"smart-double-quote\"] == 2\n\n    def test_does_not_touch_style_block(self):\n        html = \"<style>content: '\\u2014';</style><p>\\u2014</p>\"\n        out, counts = _normalize_ats(html)\n        assert \"\\u2014\" in out.split(\"</style>\")[0]  # untouched inside <style>\n        assert counts[\"em-dash\"] == 1  # only the <p> occurrence counted\n\n    def test_does_not_touch_tag_attributes(self):\n        html = '<a title=\"\\u2014\">text\\u2014</a>'\n        out, counts = _normalize_ats(html)\n        assert 'title=\"\\u2014\"' in out  # attribute preserved\n        assert counts[\"em-dash\"] == 1  # only body text counted\n\nclass TestCmdPdfRender:\n    def test_missing_input_file_returns_2(self, tmp_path, capsys):\n        assert cmd_pdf_render([str(tmp_path / \"nope.html\")]) == 2\n\n    def test_render_failure_surfaces_stderr(self, tmp_path):\n        src = tmp_path / \"in.html\"\n        src.write_text(\"<html></html>\")\n        with patch(\"agent._chrome_bin\", return_value=\"/bin/true\"), \\\n             patch(\"agent.subprocess.run\") as mock_run:\n            mock_run.return_value = MagicMock(stderr=\"chrome crashed\", returncode=1)\n            assert cmd_pdf_render([str(src)]) == 1\n\nclass TestChromeBin:\n    def test_chrome_path_env_wins(self, monkeypatch, tmp_path):\n        fake = tmp_path / \"chrome\"\n        fake.write_text(\"\")\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert _chrome_bin() == str(fake)\n\n    def test_none_found_exits(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        with patch(\"agent.shutil.which\", return_value=None), \\\n             patch(\"agent.Path.exists\", return_value=False):\n            with pytest.raises(SystemExit):\n                _chrome_bin()\n```\n\nAlso missing: `cmd_db_new` group-truncation test (needs a `Store` fixture with rows sharing `first_seen` timestamps — verify a truncation never splits a group), and `main()`'s argv-routing branches (`db-new`/`db-mark`/`pdf-render`/bare/`-i`/mode-words-vs-trailing-flags split).\n\n---\n\n",
