f):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n        assert _amazon_posted_at(\"\") == \"\"\n\nclass TestFetchSource:\n    @pytest.mark.asyncio\n    async def test_unknown_ats_raises(self):\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(ValueError, match=\"unknown ATS\"):\n                await fetch_source(client, {\"ats\": \"bogus\", \"company\": \"x\"})\n\nclass TestFetchAll:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_one_source_failure_does_not_kill_run(self):\n        respx.get(\"https://boards-api.greenhouse.io/v1/boards/good/jobs\").mock(\n            return_value=httpx.Response(200, json={\"jobs\": [{\"id\": 1, \"title\": \"Eng\"}]}))\n        respx.get(\"https://boards-api.greenhouse.io/v1/boards/bad/jobs\").mock(\n            return_value=httpx.Response(500))\n        sources = [{\"ats\": \"greenhouse\", \"company\": \"good\"},\n                   {\"ats\": \"greenhouse\", \"company\": \"bad\"}]\n        jobs = await fetch_all(sources, concurrency=2)\n        assert len(jobs) == 1  # good source's job survives; bad source logs & returns []\n\nclass TestRequestRetry:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_retries_then_succeeds(self):\n        route = respx.get(\"https://x/y\").mock(side_effect=[\n            httpx.Response(503), httpx.Response(200, json={\"ok\": True})])\n        async with httpx.AsyncClient() as client:\n            r = await _request(client, \"https://x/y\", retries=3)\n        assert r.status_code == 200\n        assert route.call_count == 2\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_exhausts_retries_raises_runtimeerror(self):\n        respx.get(\"https://x/y\").mock(return_value=httpx.Response(500))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n                await _request(client, \"https://x/y\", retries=2)"
