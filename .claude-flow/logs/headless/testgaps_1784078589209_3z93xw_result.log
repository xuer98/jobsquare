        "content": "import httpx\nimport pytest\nimport respx\nfrom notify import notify_console, notify_slack, notify_sms, _sms_body, dispatch\n\nclass TestNotifyConsole:\n    def test_no_jobs_prints_none_message(self, capsys, make_job):\n        notify_console([], [])\n        assert \"No fresh listings\" in capsys.readouterr().out\n\nclass TestNotifySlack:\n    def test_noop_without_webhook_env(self, monkeypatch, make_job):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with respx.mock:\n            notify_slack([make_job()], [])\n            # assert no calls were made at all\n            assert respx.calls.call_count == 0\n\n    @respx.mock\n    def test_posts_when_configured(self, monkeypatch, make_job):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        route = respx.post(\"https://hooks.slack.test/x\").mock(return_value=httpx.Response(200))\n        notify_slack([make_job()], [])\n        assert route.called\n\nclass TestSmsBody:\n    def test_truncates_at_limit(self, make_job):\n        jobs = [make_job(external_id=str(i), title=f\"Job {i}\") for i in range(12)]\n        body = _sms_body(jobs, [], limit=8)\n        assert \"+4 more\" in body\n\n    def test_ascii_only_no_bullets(self, make_job):\n        body = _sms_body([make_job()], [])\n        assert \"\\u2022\" not in body  # no bullet char — GSM segment cost\n\nclass TestNotifySms:\n    def test_noop_unless_all_four_env_vars_set(self, monkeypatch, make_job):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)  # only 1 of 4\n        with respx.mock:\n            from notify import notify_sms\n            notify_sms([make_job()], [])\n            assert respx.calls.call_count == 0\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch, capsys, make_job):\n        import notify\n        def boom(new, changed): raise RuntimeError(\"smtp down\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, notify.notify_console])\n        dispatch([make_job()], [])\n        assert \"failed\" in capsys.readouterr().out\n```\n\n---\n\n",
