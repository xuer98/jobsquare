xecute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n```\n\n---\n\n## 5. `pipeline.py` — the one integration seam that exists, untested end-to-end\n\n```python\n# test_pipeline.py\nimport pytest\nfrom unittest.mock import AsyncMock, patch\nfrom pipeline import load_config, run\n\nclass TestLoadConfig:\n    def test_fills_defaults(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(\"sources: []\\n\")\n        cfg = load_config(cfg_path)\n        assert cfg[\"db\"] == \"jobs.db\"\n        assert cfg[\"concurrency\"] == 8\n        assert cfg[\"filters\"] == {}\n\nclass TestRun:\n    @pytest.mark.asyncio\n    async def test_dry_run_skips_store_and_notify(self, tmp_path, make_job):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(f\"sources: []\\ndb: {tmp_path/'x.db'}\\n\")\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[make_job()])), \\\n             patch(\"pipeline.dispatch\") as mock_dispatch:\n            result = await run(cfg_path, dry_run=True)\n        mock_dispatch.assert_not_called()\n        assert result[\"new\"] == 0 and result[\"changed\"] == 0\n\n    @pytest.mark.asyncio\n    async def test_full_run_persists_and_notifies(self, tmp_path, make_job):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(f\"sources: []\\ndb: {tmp_path/'x.db'}\\n\")\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[make_job()])), \\\n             patch(\"pipeline.dispatch\") as mock_dispatch:\n            result = await run(cfg_path, dry_run=False)\n        assert result[\"new\"] == 1\n        mock_dispatch.assert_called_once()\n```\n\n---\n\n## 6. `notify.py` — env-var gating is the risk, none of it tested\n\nEvery notifier no-ops on missing env vars — that gating logic (easy to silently break) is unverified, as is the SMS char-budget truncation.\n\n```python\n# test_notify.py\nimport httpx\nimport pytest\nimport respx\nfrom notify import notify_console, notify_slack, notify_sms, _sms_body, dispatch\n\nclass TestNotifyConsole:\n    def test_no_jobs_prints_none_message(self, capsys, make_job):\n        notify_console([], [])\n        assert \"No fresh listings\" in capsys.readouterr().out\n\nclass TestNotifySlack:\n    def test_noop_without_webhook_env(self, monkeypatch, make_job):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with respx.mock:\n            notify_slack([make_job()], [])\n            # assert no calls were made at all\n            assert respx.calls.call_count == 0\n\n    @respx.mock\n    def test_posts_when_configured(self, monkeypatch, make_job):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        route = respx.post(\"https://hooks.slack.test/x\").mock(return_value=httpx.Response(200))\n        notify_slack([make_job()], [])\n        assert route.called\n\nclass TestSmsBody:\n    def test_truncates_at_limit(self, make_job):\n        jobs = [make_job(external_id=str(i), title=f\"Job {i}\") for i in range(12)]\n        body = _sms_body(jobs, [], limit=8)\n        assert \"+4 more\" in body\n\n    def test_ascii_only_no_bullets(self, make_job):\n        body = _sms_body([make_job()], [])\n        assert \"\\u2022\" not in body  # no bullet char — GSM segment cost\n\nclass TestNotifySms:\n    def test_noop_unless_all_four_env_vars_set(self, monkeypatch, make_job):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)  # only 1 of 4\n        with respx.mock:\n            from notify import notify_sms\n            notify_sms([make_job()], [])\n            assert respx.calls.call_count == 0\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch, capsys, make_job):\n        import notify\n        def boom(new, changed): raise RuntimeError(\"smtp down\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, notify.notify_console])\n        dispatch([make_job()], [])\n        assert \"failed\" in capsys.readouterr().out\n```\n\n---\n\n## 7. `agent.py` — mixed deterministic logic + subprocess/exec, untested\n\nThe deterministic half (`cmd_db_new`'s group-truncation logic, `_normalize_ats`) is high-value and easy to test in isolation. The subprocess half needs mocking.\n\n**Key missing edge case:** `cmd_db_new`'s truncation must only cut at `first_seen` group boundaries (never split a timestamp-group), per the inline comment — this is subtle and completely unverified.\n\n```python\n# test_agent.py\nimport pytest\nfrom unittest.mock import patch, MagicMock\nfrom agent import cmd_db_mark, _normalize_ats, cmd_pdf_render, _chrome_bin\n\nclass TestCmdDbMark:\n    def test_invalid_watermark_returns_2(self, capsys):\n        assert cmd_db_mark([\"not-a-timestamp\"]) == 2\n        assert \"not an ISO timestamp\" in capsys.readouterr().err\n\n    def test_neither_watermark_nor_now_returns_2(self, capsys):\n        assert cmd_db_mark([]) == 2\n\nclass TestNormalizeAts:\n    def test_smart_quotes_replaced_in_body(self):\n        html = \"<p>\\u201cHello\\u201d</p>\"\n        out, counts = _normalize_ats(html)\n        assert '\"Hello\"' in out\n        assert counts[\"smart-double-quote\"] == 2\n\n    def test_does_not_touch_style_block(self):\n        html = \"<style>content: '\\u2014';</style><p>\\u2014</p>\"\n        out, counts = _normalize_ats(html)\n        assert \"\\u2014\" in out.split(\"</style>\")[0]  # untouched inside <style>\n        assert counts[\"em-dash\"] == 1  # only the <p> occurrence counted\n\n    def test_does_not_touch_tag_attributes(self):\n        html = '<a title=\"\\u2014\">text\\u2014</a>'\n        out, counts = _normalize_ats(html)\n        assert 'title=\"\\u2014\"' in out  # attribute preserved\n        assert counts[\"em-dash\"] == 1  # only body text counted\n\nclass TestCmdPdfRender:\n    def test_missing_input_file_returns_2(self, tmp_path, capsys):\n        assert cmd_pdf_render([str(tmp_path / \"nope.html\")]) == 2\n\n    def test_render_failure_surfaces_stderr(self, tmp_path):\n        src = tmp_path / \"in.html\"\n        src.write_text(\"<html></html>\")\n        with patch(\"agent._chrome_bin\", return_value=\"/bin/true\"), \\\n             patch(\"agent.subprocess.run\") as mock_run:\n            mock_run.return_value = MagicMock(stderr=\"chrome crashed\", returncode=1)\n            assert cmd_pdf_render([str(src)]) == 1\n\nclass TestChromeBin:\n    def test_chrome_path_env_wins(self, monkeypatch, tmp_path):\n        fake = tmp_path / \"chrome\"\n        fake.write_text(\"\")\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert _chrome_bin() == str(fake)\n\n    def test_none_found_exits(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        with patch(\"agent.shutil.which\", return_value=None), \\\n             patch(\"agent.Path.exists\", return_value=False):\n            with pytest.raises(SystemExit):\n                _chrome_bin()\n```\n\nAlso missing: `cmd_db_new` group-truncation test (needs a `Store` fixture with rows sharing `first_seen` timestamps — verify a truncation never splits a group), and `main()`'s argv-routing branches (`db-new`/`db-mark`/`pdf-render`/bare/`-i`/mode-words-vs-trailing-flags split).\n\n---\n\n## 8. `cli.py` — trivial but zero coverage\n\n```python\n# test_cli.py\nfrom unittest.mock import patch\nfrom cli import main\n\ndef test_dry_run_flag_forwarded(monkeypatch):\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\", \"--dry-run\"])\n    with patch(\"cli.run_sync\") as mock_run:\n        main()\n    mock_run.assert_called_once_with(\"sources.yaml\", dry_run=True)\n```\n\n---\n\n## Priority order\n\n1. **`models.py` + `filters.py`** — zero-dependency pure logic, cheapest to test, and `content_hash`'s field-selection invariant is silently load-bearing for dedup correctness.\n2. **`fetch