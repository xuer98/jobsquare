        "content": "\nUntested entirely — this is the orchestration glue, worth an integration-style test with everything mocked.\n\n```python\nimport pytest\nfrom unittest.mock import AsyncMock, patch\nfrom pipeline import load_config, run\n\nclass TestLoadConfig:\n    def test_defaults_applied(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"sources: []\")\n        cfg = load_config(p)\n        assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\n    def test_explicit_values_not_overridden(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"sources: []\\nconcurrency: 2\\ndb: other.db\")\n        cfg = load_config(p)\n        assert cfg[\"concurrency\"] == 2 and cfg[\"db\"] == \"other.db\"\n\n\nclass TestRun:\n    @pytest.mark.asyncio\n    async def test_dry_run_does_not_touch_store_or_notify(self, tmp_path, make_job):\n        cfg_path = tmp_path / \"c.yaml\"\n        cfg_path.write_text(f\"sources: []\\ndb: {tmp_path/'x.db'}\")\n        with patch(\"pipeline.fetch_all\", AsyncMock(return_value=[make_job()])), \\\n             patch(\"pipeline.dispatch\") as mock_dispatch:\n            result = await run(cfg_path, dry_run=True)\n        mock_dispatch.assert_not_called()\n        assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n\n    @pytest.mark.asyncio\n    async def test_full_run_persists_and_notifies(self, tmp_path, make_job):\n        cfg_path = tmp_path / \"c.yaml\"\n        cfg_path.write_text(f\"sources: []\\ndb: {tmp_path/'x.db'}\")\n        with patch(\"pipeline.fetch_all\", AsyncMock(return_value=[make_job()])), \\\n             patch(\"pipeline.dispatch\") as mock_dispatch:\n            result = await run(cfg_path, dry_run=False)\n        mock_dispatch.assert_called_once()\n        assert result[\"new\"] == 1\n```\n\n---\n\n",
