        "title": "5. `notify.py` — dispatch and per-channel notifiers",
        "content": "\nUntested entirely, including the error-isolation guarantee in `dispatch` — this is the single most important behavior in this module (one broken webhook shouldn't kill SMS/email) and nothing currently proves it.\n\n```python\nimport pytest\nfrom unittest.mock import patch, Mock\nfrom notify import dispatch, notify_slack, notify_sms, _sms_body, notify_email\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, make_job):\n        calls = []\n        def boom(new, changed): raise RuntimeError(\"webhook down\")\n        def ok(new, changed): calls.append(\"ran\")\n        with patch(\"notify.NOTIFIERS\", [boom, ok]):\n            dispatch([make_job()], [])\n        assert calls == [\"ran\"]\n\n\nclass TestNotifySlack:\n    def test_noop_without_env_var(self, monkeypatch, make_job):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with patch(\"notify.httpx.post\") as post:\n            notify_slack([make_job()], [])\n        post.assert_not_called()\n\n    def test_noop_when_nothing_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n        with patch(\"notify.httpx.post\") as post:\n            notify_slack([], [])\n        post.assert_not_called()\n\n    def test_posts_when_configured_and_new(self, monkeypatch, make_job):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n        with patch(\"notify.httpx.post\") as post:\n            notify_slack([make_job()], [])\n        post.assert_called_once()\n\n\nclass TestSmsBody:\n    def test_truncates_after_limit_with_more_count(self, make_job):\n        jobs = [make_job(external_id=str(i), title=f\"Role {i}\") for i in range(10)]\n        body = _sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n\n    def test_ascii_only_no_bullets_or_ellipsis(self, make_job):\n        body = _sms_body([make_job()], [])\n        assert \"\\u2022\" not in body and \"\\u2026\" not in body\n\n\nclass TestNotifySms:\n    def test_missing_any_of_four_env_vars_noops(self, monkeypatch, make_job):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        # TWILIO_AUTH_TOKEN intentionally unset\n        with patch(\"notify.httpx.post\") as post:\n            notify_sms([make_job()], [])\n        post.assert_not_called()\n\n    def test_bad_response_raises_via_raise_for_status(self, monkeypatch, make_job):\n        for k, v in [(\"TWILIO_ACCOUNT_SID\",\"s\"),(\"TWILIO_AUTH_TOKEN\",\"t\"),\n                     (\"TWILIO_FROM\",\"+1\"),(\"TWILIO_TO\",\"+2\")]:\n            monkeypatch.setenv(k, v)\n        resp = Mock(); resp.raise_for_status.side_effect = RuntimeError(\"401\")\n        with patch(\"notify.httpx.post\", return_value=resp):\n            with pytest.raises(RuntimeError):\n                notify_sms([make_job()], [])\n```\n\nAlso missing: `notify_email` SMTP happy path + `SMTP_USER` login branch (needs `smtplib.SMTP` mocked), and `notify_webhook` payload shape (`{\"new\": [...], \"changed\": [...]}` using `to_row()`).\n\n---\n\n",
