at(\"not a date\") == \"\"\n\n    def test_empty_string(self):\n        assert _amazon_posted_at(\"\") == \"\"\n\n\nclass TestBalancedJson:\n    def test_simple_object(self):\n        assert _balanced_json('{\"a\": 1}', 0) == '{\"a\": 1}'\n\n    def test_nested_braces(self):\n        text = '{\"a\": {\"b\": 1}}'\n        assert _balanced_json(text, 0) == text\n\n    def test_brace_inside_string_is_ignored(self):\n        text = '{\"a\": \"}\"}'\n        assert _balanced_json(text, 0) == text\n\n    def test_escaped_quote_inside_string(self):\n        text = r'{\"a\": \"\\\"\"}'\n        assert _balanced_json(text, 0) == text\n\n    def test_unterminated_returns_none(self):\n        assert _balanced_json('{\"a\": 1', 0) is None"
