        "code": "# tests/test_fetchers_http.py â€” needs respx (pip install respx)\nimport httpx\nimport pytest\nimport respx\nfrom fetchers import _request, fetch_all\n\n\n@pytest.mark.asyncio\nclass TestRequestRetries:\n    async def test_retries_on_503_then_succeeds(self, respx_mock):\n        route = respx_mock.get(\"https://x/y\").mock(\n            side_effect=[httpx.Response(503), httpx.Response(200, json={})])\n        async with httpx.AsyncClient() as client:\n            r = await _request(client, \"https://x/y\", retries=3)\n        assert r.status_code == 200\n        assert route.call_count == 2\n\n    async def test_does_not_retry_on_404(self, respx_mock):\n        respx_mock.get(\"https://x/y\").mock(return_value=httpx.Response(404))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError):\n                await _request(client, \"https://x/y\", retries=3)\n        assert respx_mock.calls.call_count == 1\n\n    async def test_exhausts_retries_and_raises(self, respx_mock):\n        respx_mock.get(\"https://x/y\").mock(return_value=httpx.Response(500))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError):\n                await _request(client, \"https://x/y\", retries=2)\n\n\n@pytest.mark.asyncio\nclass TestFetchAll:\n    async def test_one_source_failure_does_not_abort_others(self, respx_mock):\n        respx_mock.get(\"https://boards-api.greenhouse.io/v1/boards/bad/jobs\").mock(\n            return_value=httpx.Response(500))\n        respx_mock.get(\"https://boards-api.greenhouse.io/v1/boards/good/jobs\").mock(\n            return_value=httpx.Response(200, json={\"jobs\": [{\"id\": 1, \"title\": \"T\"}]}))\n        sources = [{\"ats\": \"greenhouse\", \"company\": \"bad\"},\n                   {\"ats\": \"greenhouse\", \"company\": \"good\"}]\n        jobs = await fetch_all(sources, concurrency=2)\n        assert len(jobs) == 1"
