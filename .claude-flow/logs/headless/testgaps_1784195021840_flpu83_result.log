        "code": "# tests/test_store.py\nimport pytest\nfrom store import Store\nfrom models import Job\n\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\n\ndef _job(ext_id=\"1\", title=\"Engineer\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id,\n               title=title, url=\"https://x\", location=\"Remote\")\n\n\nclass TestDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_is_neither(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_changed_title_reports_as_changed(self, store):\n        store.diff([_job(title=\"Engineer I\")])\n        new, changed = store.diff([_job(title=\"Engineer II\")])\n        assert new == [] and len(changed) == 1\n\n    def test_last_seen_bumped_on_unchanged_reseen(self, store):\n        store.diff([_job()])\n        row_before = store.conn.execute(\n            \"SELECT last_seen FROM jobs WHERE key=?\", (_job().key,)).fetchone()\n        store.diff([_job()])\n        row_after = store.conn.execute(\n            \"SELECT last_seen FROM jobs WHERE key=?\", (_job().key,)).fetchone()\n        assert row_after[\"last_seen\"] >= row_before[\"last_seen\"]\n\n\nclass TestMigration:\n    def test_adds_salary_range_column_to_old_schema(self, tmp_path):\n        import sqlite3\n        path = tmp_path / \"old.db\"\n        conn = sqlite3.connect(path)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        with Store(path) as s:\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_roundtrip(self, store):\n        store.set_meta(\"k\", \"v1\")\n        assert store.get_meta(\"k\") == \"v1\"\n\n    def test_set_meta_upserts(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n    def test_next_seq_increments(self, store):\n        assert store.next_seq(\"counter\") == 1\n        assert store.next_seq(\"counter\") == 2\n\n\nclass TestAddedSince:\n    def test_excludes_exact_boundary_timestamp(self, store):\n        store.diff([_job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n        assert store.added_since(ts) == []\n\n    def test_orders_by_first_seen_company_title(self, store):\n        store.diff([_job(\"1\", \"Zebra\"), _job(\"2\", \"Apple\")])\n        rows = store.added_since(\"1970-01-01T00:00:00+00:00\")\n        titles = [r[\"title\"] for r in rows]\n        assert titles == sorted(titles)"
