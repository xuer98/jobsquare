      {
        "title": "tests/test_filters.py",
        "content": "import pytest\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(title=\"Software Engineer\", dept=\"\", loc=\"Remote\", posted_at=\"\"):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=title,\n               url=\"u\", department=dept, location=loc, posted_at=posted_at)\n\ndef test_exclude_takes_priority_over_include():\n    j = _job(title=\"Senior Staff Manager Engineer\")\n    assert match(j, include=[\"engineer\"], exclude=[\"manager\"]) is False\n\ndef test_include_keyword_requires_word_boundary_not_substring():\n    j = _job(title=\"Engineering Intern\")\n    # \"engineer\" should NOT match \"Engineering\" as substring via \\b...\\b if plural/gerund differs\n    assert match(j, include=[\"engineer\"]) is False  # documents current behavior\n\ndef test_locations_filter_is_substring_case_insensitive():\n    j = _job(loc=\"San Francisco, CA\")\n    assert match(j, locations=[\"san francisco\"]) is True\n    assert match(j, locations=[\"nyc\"]) is False\n\ndef test_cutoff_keeps_jobs_with_unparseable_posted_at():\n    j = _job(posted_at=\"garbage\")\n    cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n    assert match(j, cutoff=cutoff) is True  # deliberate: don't nuke undated jobs\n\ndef test_cutoff_drops_jobs_older_than_cutoff():\n    old = _job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n    cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n    assert match(old, cutoff=cutoff) is False\n\ndef test_filter_jobs_empty_rules_returns_everything():\n    jobs = [_job(), _job(title=\"Other\")]\n    assert filter_jobs(jobs, {}) == jobs\n\ndef test_filter_jobs_max_age_days_accepts_float_string():\n    jobs = [_job(posted_at=datetime.now(timezone.utc).isoformat())]\n    assert len(filter_jobs(jobs, {\"max_age_days\": \"0.5\"})) == 1\n```\n\n---\n\n",
