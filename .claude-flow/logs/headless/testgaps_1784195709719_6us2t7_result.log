        "code": "# tests/test_pipeline.py\nimport pytest\nfrom unittest.mock import AsyncMock, patch\nfrom models import Job\nimport pipeline\n\ndef test_load_config_applies_defaults(tmp_path):\n    cfg_path = tmp_path / \"empty.yaml\"\n    cfg_path.write_text(\"{}\")\n    cfg = pipeline.load_config(cfg_path)\n    assert cfg == {\"sources\": [], \"filters\": {}, \"db\": \"jobs.db\", \"concurrency\": 8}\n\n@pytest.mark.asyncio\nasync def test_dry_run_does_not_touch_store(tmp_path, monkeypatch):\n    cfg_path = tmp_path / \"c.yaml\"\n    cfg_path.write_text(f\"db: {tmp_path/'x.db'}\\nsources: []\\n\")\n    monkeypatch.setattr(pipeline, \"fetch_all\", AsyncMock(\n        return_value=[Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")]))\n    result = await pipeline.run(cfg_path, dry_run=True)\n    assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n    assert not (tmp_path / \"x.db\").exists()  # store never opened\n\n@pytest.mark.asyncio\nasync def test_run_dispatches_notifications_for_new_jobs(tmp_path, monkeypatch):\n    cfg_path = tmp_path / \"c.yaml\"\n    cfg_path.write_text(f\"db: {tmp_path/'x.db'}\\nsources: []\\n\")\n    job = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")\n    monkeypatch.setattr(pipeline, \"fetch_all\", AsyncMock(return_value=[job]))\n    dispatched = []\n    monkeypatch.setattr(pipeline, \"dispatch\", lambda new, changed: dispatched.append((new, changed)))\n    result = await pipeline.run(cfg_path)\n    assert result[\"new\"] == 1\n    assert dispatched[0][0] == [job]"
