        "title": "tests/test_pipeline.py",
        "content": "import pytest\nfrom unittest.mock import AsyncMock\nimport pipeline\nfrom models import Job\n\ndef test_load_config_fills_defaults(tmp_path):\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(\"sources: []\\n\")\n    cfg = pipeline.load_config(cfg_path)\n    assert cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8 and cfg[\"filters\"] == {}\n\n@pytest.mark.asyncio\nasync def test_run_dry_run_does_not_persist(tmp_path, monkeypatch):\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(f\"sources: []\\ndb: {tmp_path / 'jobs.db'}\\n\")\n    monkeypatch.setattr(pipeline, \"fetch_all\",\n                         AsyncMock(return_value=[Job(source=\"s\", company=\"c\",\n                                   external_id=\"1\", title=\"Eng\", url=\"u\")]))\n    result = await pipeline.run(cfg_path, dry_run=True)\n    assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n    assert not (tmp_path / \"jobs.db\").exists()\n\n@pytest.mark.asyncio\nasync def test_run_persists_and_dispatches(tmp_path, monkeypatch):\n    cfg_path = tmp_path / \"sources.yaml\"\n    db_path = tmp_path / \"jobs.db\"\n    cfg_path.write_text(f\"sources: []\\ndb: {db_path}\\n\")\n    job = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Eng\", url=\"u\")\n    monkeypatch.setattr(pipeline, \"fetch_all\", AsyncMock(return_value=[job]))\n    dispatched = {}\n    monkeypatch.setattr(pipeline, \"dispatch\",\n                         lambda new, changed: dispatched.update(new=new, changed=changed))\n    result = await pipeline.run(cfg_path, dry_run=False)\n    assert result == {\"matched\": 1, \"new\": 1, \"changed\": 0}\n    assert dispatched[\"new\"] == [job]\n    assert db_path.exists()\n```\n\n---\n\n",
