        "content": "import pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\n@pytest.mark.parametrize(\"raw,expected_epoch\", [\n    (\"1643241332430\", 1643241332),      # Lever ms\n    (\"1643241332\", 1643241332),          # plain seconds\n    (\"2022-01-26T00:00:00Z\", 1643155200),\n])\ndef test_parse_posted_at_numeric_and_iso(raw, expected_epoch):\n    dt = parse_posted_at(raw)\n    assert dt.tzinfo == timezone.utc\n    assert int(dt.timestamp()) == expected_epoch\n\n@pytest.mark.parametrize(\"raw\", [\"\", None, \"Posted 3 Days Ago\", \"not-a-date\"])\ndef test_parse_posted_at_unparseable_returns_none(raw):\n    assert parse_posted_at(raw) is None\n\ndef test_parse_posted_at_naive_iso_gets_utc():\n    dt = parse_posted_at(\"2022-01-26T00:00:00\")\n    assert dt.tzinfo == timezone.utc\n\ndef test_job_key_is_stable_identity():\n    j = Job(source=\"greenhouse\", company=\"acme\", external_id=\"42\", title=\"X\", url=\"u\")\n    assert j.key == \"greenhouse:acme:42\"\n\ndef test_content_hash_changes_on_material_fields_only():\n    base = dict(source=\"lever\", company=\"acme\", external_id=\"1\", title=\"Eng\", url=\"u\",\n                location=\"NYC\", department=\"Infra\")\n    j1 = Job(**base)\n    j2 = Job(**{**base, \"posted_at\": \"2024-01-01\", \"salary_range\": \"$1\"})\n    assert j1.content_hash == j2.content_hash   # non-material fields ignored\n\n    j3 = Job(**{**base, \"title\": \"Sr Eng\"})\n    assert j1.content_hash != j3.content_hash   # material field changes hash\n\ndef test_to_row_drops_raw_and_adds_key_and_hash():\n    j = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"t\", url=\"u\", raw={\"x\": 1})\n    row = j.to_row()\n    assert \"raw\" not in row\n    assert row[\"key\"] == j.key\n    assert row[\"content_hash\"] == j.content_hash\n```\n\n---\n\n",
