        "code": "# tests/test_agent.py\nimport json\nfrom datetime import datetime, timedelta, timezone\nimport pytest\nfrom agent import cmd_db_new, cmd_db_mark, _normalize_ats\nfrom models import Job\nfrom store import Store\n\ndef test_db_new_first_run_uses_since_days_window(tmp_path, capsys):\n    cfg = tmp_path / \"sources.yaml\"\n    db = tmp_path / \"jobs.db\"\n    cfg.write_text(f\"sources: []\\ndb: {db}\\n\")\n    with Store(db) as s:\n        s.diff([Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Eng\", url=\"u\")])\n    cmd_db_new([\"-c\", str(cfg), \"--since-days\", \"7\"])\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"first_run\"] is True and out[\"count\"] == 1\n\ndef test_db_new_truncates_at_group_boundary_not_mid_group(tmp_path, capsys, monkeypatch):\n    cfg = tmp_path / \"sources.yaml\"\n    db = tmp_path / \"jobs.db\"\n    cfg.write_text(f\"sources: []\\ndb: {db}\\n\")\n    with Store(db) as s:\n        # two separate pipeline runs -> two distinct first_seen groups of 3 each\n        s.diff([Job(source=\"s\", company=\"c\", external_id=str(i), title=\"E\", url=\"u\")\n                for i in range(3)])\n        s.diff([Job(source=\"s\", company=\"c\", external_id=str(i), title=\"E\", url=\"u\")\n                for i in range(3, 6)])\n    cmd_db_new([\"-c\", str(cfg), \"--limit\", \"4\"])  # limit falls mid-second-group\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"count\"] == 3 and out[\"truncated\"] is True  # only first group kept whole\n\ndef test_db_mark_rejects_invalid_watermark(tmp_path, capsys):\n    cfg = tmp_path / \"sources.yaml\"\n    cfg.write_text(f\"sources: []\\ndb: {tmp_path / 'jobs.db'}\\n\")\n    rc = cmd_db_mark([\"not-a-timestamp\", \"-c\", str(cfg)])\n    assert rc == 2\n\ndef test_db_mark_requires_watermark_or_now(tmp_path):\n    cfg = tmp_path / \"sources.yaml\"\n    cfg.write_text(f\"sources: []\\ndb: {tmp_path / 'jobs.db'}\\n\")\n    assert cmd_db_mark([\"-c\", str(cfg)]) == 2\n\ndef test_normalize_ats_skips_style_and_script_blocks():\n    html = '<style>content: \"\\u2014\";</style><p>real \\u2014 dash</p><script>\"\\u2014\"</script>'\n    out, counts = _normalize_ats(html)\n    assert '<style>content: \"\\u2014\"' in out          # untouched inside <style>\n    assert \"real - dash\" in out                        # replaced in body text\n    assert counts[\"em-dash\"] == 1                       # only the body occurrence counted\n\ndef test_normalize_ats_does_not_touch_tag_attributes():\n    html = '<a href=\"x\\u2014y\">text\\u2014here</a>'\n    out, _ = _normalize_ats(html)\n    assert 'href=\"x\\u2014y\"' in out       # attribute left alone\n    assert \"text-here\" in out             # text node replaced"
