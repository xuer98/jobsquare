len(rows) == 1\n    exact_ts = rows[0][\"first_seen\"]\n    assert store.added_since(exact_ts) == []  # boundary is exclusive\n\ndef test_set_meta_upserts(store):\n    store.set_meta(\"k\", \"v1\")\n    store.set_meta(\"k\", \"v2\")\n    assert store.get_meta(\"k\") == \"v2\"\n\ndef test_next_seq_increments(store):\n    assert store.next_seq(\"counter\") == 1\n    assert store.next_seq(\"counter\") == 2\n\ndef test_next_seq_serializes_concurrent_callers(tmp_path):\n    # Regression guard for the parallel-worker collision failure mode.\n    results = []\n    def worker():\n        with Store(tmp_path / \"shared.db\") as s:\n            results.append(s.next_seq(\"report_seq\"))\n    threads = [threading.Thread(target=worker) for _ in range(10)]\n    [t.start() for t in threads]\n    [t.join() for t in threads]\n    assert sorted(results) == list(range(1, 11))  # no duplicate/skipped ids"
