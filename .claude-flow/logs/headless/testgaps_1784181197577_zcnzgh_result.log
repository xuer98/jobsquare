le>content: '\\u2014';</style><p>\\u2014</p>\"\n        html_out, counts = _normalize_ats(html_in)\n        assert \"content: '\\u2014';\" in html_out  # untouched inside <style>\n        assert counts[\"em-dash\"] == 1  # only the <p> occurrence counted\n\n    def test_skips_tag_attributes(self):\n        html_in = '<a title=\"\\u2014\">\\u2014</a>'\n        html_out, counts = _normalize_ats(html_in)\n        assert 'title=\"\\u2014\"' in html_out\n        assert counts[\"em-dash\"] == 1\n\n\nclass TestMainArgParsing:\n    def test_bare_invocation_is_interactive(self, monkeypatch):\n        called = {}\n        monkeypatch.setattr(\"agent.run_claude\", lambda mw, i, e: called.update(mw=mw, i=i, e=e))\n        main.__wrapped__ if hasattr(main, \"__wrapped__\") else None\n        # patch sys.argv and assert run_claude called with interactive=True\n\n    def test_flag_after_mode_words_splits_correctly(self, monkeypatch):\n        # e.g. `agent.py scan --foo bar` -> mode_words=[\"scan\"], extra=[\"--foo\",\"bar\"]\n        pass"
