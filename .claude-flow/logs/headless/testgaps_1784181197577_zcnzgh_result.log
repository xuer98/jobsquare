        "content": "import pytest\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef make_job(title=\"Senior Engineer\", department=\"\", location=\"Remote\", posted_at=\"\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=title, url=\"u\", department=department, location=location,\n                posted_at=posted_at)\n\nclass TestMatch:\n    def test_include_keyword_word_boundary_not_substring(self):\n        # \"eng\" shouldn't match \"engineering\" — \\b enforces whole words\n        assert match(make_job(title=\"Engineering Manager\"), include=[\"eng\"]) is False\n        assert match(make_job(title=\"Eng Manager\"), include=[\"eng\"]) is True\n\n    def test_exclude_takes_precedence_over_include(self):\n        j = make_job(title=\"Senior Staff Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"senior\"]) is False\n\n    def test_case_insensitive(self):\n        assert match(make_job(title=\"ENGINEER\"), include=[\"engineer\"]) is True\n\n    def test_locations_substring_match(self):\n        assert match(make_job(location=\"San Francisco, CA\"), locations=[\"san francisco\"]) is True\n        assert match(make_job(location=\"Austin, TX\"), locations=[\"san francisco\"]) is False\n\n    def test_cutoff_drops_old_confirmed_date(self):\n        old = (datetime.now(timezone.utc) - timedelta(days=30)).isoformat()\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(make_job(posted_at=old), cutoff=cutoff) is False\n\n    def test_cutoff_keeps_unparseable_date(self):\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(make_job(posted_at=\"Posted recently\"), cutoff=cutoff) is True\n\n    def test_no_filters_passes_everything(self):\n        assert match(make_job()) is True\n\n\nclass TestFilterJobs:\n    def test_empty_rules_dict_returns_all(self):\n        jobs = [make_job(), make_job(title=\"Other\")]\n        assert filter_jobs(jobs, {}) == jobs\n\n    def test_max_age_days_computes_cutoff(self):\n        old = (datetime.now(timezone.utc) - timedelta(days=10)).isoformat()\n        jobs = [make_job(posted_at=old)]\n        assert filter_jobs(jobs, {\"max_age_days\": 5}) == []\n\n    def test_max_age_days_as_string(self):\n        # rules.get(\"max_age_days\") cast via float(); confirm string input works\n        jobs = [make_job(posted_at=\"\")]\n        assert filter_jobs(jobs, {\"max_age_days\": \"5\"}) == jobs\n```\n\n---\n\n",
