        "code": "# tests/test_agent.py\nimport pytest\nfrom store import Store\nfrom models import Job\nimport agent\n\n\n@pytest.fixture\ndef config(tmp_path):\n    cfg = tmp_path / \"sources.yaml\"\n    cfg.write_text(f\"sources: []\\ndb: {tmp_path/'jobs.db'}\\n\")\n    return str(cfg)\n\n\nclass TestCmdDbNew:\n    def test_first_run_uses_since_days_window(self, config, capsys):\n        assert agent.cmd_db_new([\"-c\", config, \"--since-days\", \"3\"]) == 0\n        import json\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True and out[\"count\"] == 0\n\n    def test_truncates_only_at_first_seen_group_boundary(self, config, capsys, monkeypatch):\n        # two jobs from run A (same first_seen) + one from run B must not be\n        # split mid-group even if --limit lands inside run A's group\n        with Store(agent.load_config(config)[\"db\"]) as store:\n            store.diff([Job(source=\"greenhouse\", company=\"acme\", external_id=str(i),\n                             title=f\"J{i}\", url=\"u\") for i in range(3)])\n        agent.cmd_db_new([\"-c\", config, \"--limit\", \"1\"])\n        import json\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"truncated\"] is True\n        assert out[\"count\"] in (0, 3)  # never 1 or 2 -- whole group or none\n\n    def test_dated_only_drops_undated_rows(self, config, capsys):\n        with Store(agent.load_config(config)[\"db\"]) as store:\n            store.diff([Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                             title=\"J\", url=\"u\", posted_at=\"\")])\n        agent.cmd_db_new([\"-c\", config, \"--dated-only\"])\n        import json\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"undated_dropped\"] == 1 and out[\"count\"] == 0\n\n\nclass TestCmdDbMark:\n    def test_now_sets_current_timestamp(self, config, capsys):\n        assert agent.cmd_db_mark([\"--now\", \"-c\", config]) == 0\n\n    def test_invalid_watermark_returns_error_code(self, config, capsys):\n        assert agent.cmd_db_mark([\"not-a-date\", \"-c\", config]) == 2\n\n    def test_no_args_returns_error_code(self, config):\n        assert agent.cmd_db_mark([\"-c\", config]) == 2\n\n\nclass TestNormalizeAts:\n    def test_em_dash_replaced_in_body_text(self):\n        html, counts = agent._normalize_ats(\"<p>a\\u2014b</p>\")\n        assert \"a-b\" in html and counts[\"em-dash\"] == 1\n\n    def test_not_replaced_inside_tag_attributes(self):\n        html, counts = agent._normalize_ats('<a title=\"a\\u2014b\">text</a>')\n        assert 'title=\"a\\u2014b\"' in html  # attribute untouched\n        assert \"em-dash\" not in counts\n\n    def test_not_replaced_inside_style_block(self):\n        html, counts = agent._normalize_ats(\"<style>.x::before{content:'\\u2014'}</style>\")\n        assert \"em-dash\" not in counts\n\n    def test_smart_quotes_and_ellipsis(self):\n        html, counts = agent._normalize_ats(\"<p>\\u201cHi\\u201d\\u2026</p>\")\n        assert '\"Hi\"...' in html\n\n\nclass TestChromeBinDiscovery:\n    def test_chrome_path_env_takes_priority(self, monkeypatch, tmp_path):\n        fake = tmp_path / \"chrome\"; fake.write_text(\"\")\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert agent._chrome_bin() == str(fake)\n\n    def test_nonexistent_chrome_path_falls_through_to_which(self, monkeypatch):\n        monkeypatch.setenv(\"CHROME_PATH\", \"/nonexistent/chrome\")\n        monkeypatch.setattr(\"shutil.which\", lambda name: \"/usr/bin/chromium\" if name == \"chromium\" else None)\n        assert agent._chrome_bin() == \"/usr/bin/chromium\"\n\n    def test_none_found_exits(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        monkeypatch.setattr(\"shutil.which\", lambda name: None)\n        monkeypatch.setattr(\"pathlib.Path.exists\", lambda self: False)\n        with pytest.raises(SystemExit):\n            agent._chrome_bin()\n\n\nclass TestMainDispatch:\n    def test_help_flag_prints_docstring_and_returns_zero(self, capsys, monkeypatch):\n        monkeypatch.setattr(\"sys.argv\", [\"agent.py\", \"--help\"])\n        assert agent.main() == 0\n\n    def test_mode_words_stop_at_first_flag(self, monkeypatch):\n        captured = {}\n        monkeypatch.setattr(agent, \"run_claude\",\n                             lambda mode_words, interactive, extra: captured.update(\n                                 mode_words=mode_words, interactive=interactive, extra=extra) or 0)\n        monkeypatch.setattr(\"sys.argv\", [\"agent.py\", \"scan\", \"--verbose\"])\n        agent.main()\n        assert captured[\"mode_words\"] == [\"scan\"] and captured[\"extra\"] == [\"--verbose\"]"
