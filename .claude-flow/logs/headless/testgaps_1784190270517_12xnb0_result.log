      {
        "title": "2. `filters.py` (P0 — untested entirely)",
        "content": "\n**Gaps:** `match()`'s include/exclude/locations/cutoff interplay, `filter_jobs()`'s `max_age_days` handling.\n\n**Real bug risk found:** `filter_jobs` uses `if max_age:` — `max_age_days: 0` (meaning \"today only\") is falsy in Python, so it silently **disables** the cutoff instead of applying the strictest one. And `include`/`exclude` use `\\b` word-boundary regex, so `include=[\"eng\"]` will **not** match \"Engineering\" — non-obvious if someone assumes substring matching (which `locations` *does* use, inconsistently).\n\n```python\n",
        "level": 2
      },
      {
        "title": "tests/test_filters.py",
        "content": "import pytest\nfrom datetime import datetime, timedelta, timezone\nfrom filters import match, filter_jobs\nfrom models import Job\n\n\ndef make_job(**kw):\n    d = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n              title=\"Software Engineer\", url=\"https://x/1\",\n              location=\"New York, NY\", department=\"Engineering\")\n    return Job(**{**d, **kw})\n\n\nclass TestMatch:\n    def test_exclude_wins_over_include(self):\n        j = make_job(title=\"Senior Software Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"senior\"]) is False\n\n    def test_include_requires_word_boundary_not_substring(self):\n        assert match(make_job(title=\"Engineering Manager\"), include=[\"eng\"]) is False\n\n    def test_include_case_insensitive(self):\n        assert match(make_job(title=\"SOFTWARE ENGINEER\"), include=[\"software engineer\"])\n\n    def test_locations_is_substring_match_not_word_boundary(self):\n        j = make_job(location=\"San Francisco Bay Area\")\n        assert match(j, locations=[\"francisco\"]) is True\n\n    def test_cutoff_drops_confirmed_old_postings(self):\n        j = make_job(posted_at=\"2020-01-01T00:00:00Z\")\n        assert match(j, cutoff=datetime.now(timezone.utc) - timedelta(days=30)) is False\n\n    def test_cutoff_keeps_unparseable_dates(self):\n        j = make_job(posted_at=\"Posted 3 Days Ago\")\n        assert match(j, cutoff=datetime.now(timezone.utc)) is True\n\n    def test_cutoff_keeps_undated_jobs(self):\n        assert match(make_job(posted_at=\"\"), cutoff=datetime.now(timezone.utc)) is True\n\n    def test_cutoff_boundary_equal_timestamp_is_kept(self):\n        now = datetime.now(timezone.utc)\n        assert match(make_job(posted_at=now.isoformat()), cutoff=now) is True  # dt < cutoff, equal is kept\n\n\nclass TestFilterJobs:\n    def test_max_age_days_zero_silently_disables_filter(self):\n        old = make_job(posted_at=\"2000-01-01T00:00:00Z\")\n        # documents current behavior -- likely surprising if a user sets 0\n        # expecting \"today only\" instead of \"no cutoff\"\n        assert filter_jobs([old], {\"max_age_days\": 0}) == [old]\n\n    def test_max_age_days_as_yaml_string(self):\n        old = make_job(posted_at=\"2000-01-01T00:00:00Z\")\n        assert filter_jobs([old], {\"max_age_days\": \"1\"}) == []\n\n    def test_empty_rules_returns_all(self):\n        jobs = [make_job(), make_job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n",
        "level": 1
      },
      {
        "title": "3. `store.py` (P0 — untested entirely; this *is* the correctness-critical module)",
        "content": "\n**Gaps:** insert vs. update vs. no-op branches of `diff()`, the additive migration path, `next_seq` atomicity, `added_since`'s strict `>` semantics, meta upsert.\n\n```python\n",
        "level": 2
      },
      {
        "title": "tests/test_store.py",
        "content": "import sqlite3\nimport pytest\nfrom store import Store\nfrom models import Job\n\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"test.db\")\n    yield s\n    s.close()\n\n\ndef make_job(**kw):\n    d = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n              title=\"Engineer\", url=\"https://x/1\", location=\"NYC\")\n    return Job(**{**d, **kw})\n\n\nclass TestDiff:\n    def test_new_job_is_new(self, store):\n        new, changed = store.diff([make_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_rewatched_unchanged_job_is_neither(self, store):\n        j = make_job()\n        store.diff([j])\n        new, changed = store.diff([j])\n        assert new == [] and changed == []\n\n    def test_content_change_is_reported_and_persisted(self, store):\n        store.diff([make_job(title=\"Engineer\")])\n        new, changed = store.diff([make_job(title=\"Senior Engineer\")])\n        assert new == [] and len(changed) == 1\n        row = store.conn.execute(\"SELECT title FROM jobs WHERE key=?\",\n                                  (make_job().key,)).fetchone()\n        assert row[\"title\"] == \"Senior Engineer\"\n\n    def test_empty_batch(self, store):\n        assert store.diff([]) == ([], [])\n\n    def test_duplicate_key_within_same_batch(self, store):\n        # same key appears twice in one fetch batch with different content --\n        # second occurrence re-reads the row the first occurrence just inserted\n        j1, j2 = make_job(title=\"Engineer\"), make_job(title=\"Senior Engineer\")\n        new, changed = store.diff([j1, j2])\n        assert len(new) == 1 and len(changed) == 1  # documents actual behavior\n\n\nclass TestMigration:\n    def test_opens_pre_salary_range_db_without_error(self, tmp_path):\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(path)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        s = Store(path)\n        assert \"salary_range\" in {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        s.close()\n\n\nclass TestMetaAndSeq:\n    def test_get_meta_missing_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_meta_overwrites(self, store):\n        store.set_meta(\"k\", \"v1\"); store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n    def test_next_seq_increments_from_one(self, store):\n        assert [store.next_seq(\"s\") for _ in range(3)] == [1, 2, 3]\n\n    def test_next_seq_independent_per_key(self, store):\n        assert store.next_seq(\"a\") == 1 and store.next_seq(\"b\") == 1\n\n\nclass TestAddedSinceAndCount:\n    def test_strictly_after_excludes_exact_timestamp(self, store):\n        j = make_job()\n        store.diff([j])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs WHERE key=?\", (j.key,)).fetchone()[\"first_seen\"]\n        assert store.added_since(ts) == []\n\n    def test_count_reflects_rows(self, store):\n        assert store.count() == 0\n        store.diff([make_job()])\n        assert store.count() == 1\n```\n\n---\n\n",
        "level": 1
      },
      {
        "title": "4. `pipeline.py` (P1 — untested entirely)",
        "content": "\n**Gaps:** `load_config` defaults, `run()`'s dry-run vs. persist branches, `run_sync`'s asyncio wrapping.\n\n**Real bug risk found:** `yaml.safe_load(\"\")` returns `None`, and `load_config` immediately calls `cfg.setdefault(...)` on it — an empty/comment-only `sources.yaml` crashes with an unhelpful `AttributeError` instead of a clear config error.\n\n```python\n",
        "level": 2
      },
      {
        "title": "tests/test_pipeline.py",
        "content": "import pytest\nfrom unittest.mock import AsyncMock, MagicMock\nfrom pipeline import load_config, run, run_sync\nfrom models import Job\n\n\nclass TestLoadConfig:\n    def test_defaults_applied(self, tmp_path):\n        p = tmp_path / \"cfg.yaml\"; p.write_text(\"sources: []\\n\")\n        cfg = load_config(p)\n        assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\n    def test_explicit_values_kept(self, tmp_path):\n        p = tmp_path / \"cfg.yaml\"; p.write_text(\"sources: []\\ndb: custom.db\\nconcurrency: 4\\n\")\n        cfg = load_config(p)\n        assert cfg[\"db\"] == \"custom.db\" and cfg[\"concurrency\"] == 4\n\n    def test_empty_file_raises_cleanly(self, tmp_path):\n        # yaml.safe_load(\"\") -> None -> None.setdefault() -- currently an\n        # opaque AttributeError instead of a config-validation error\n        p = tmp_path / \"empty.yaml\"; p.write_text(\"\")\n        with pytest.raises(AttributeError):\n            load_config(p)\n\n\nclass TestRun:\n    async def test_dry_run_never_constructs_store_or_notifies(self, tmp_path, monkeypatch):\n        cfg = tmp_path / \"cfg.yaml\"; cfg.write_text(\"sources: [{ats: greenhouse, company: acme}]\\n\")\n        job = Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\", title=\"Engineer\", url=\"u\")\n        monkeypatch.setattr(\"pipeline.fetch_all\", AsyncMock(return_value=[job]))\n        monkeypatch.setattr(\"pipeline.Store\", MagicMock(side_effect=AssertionError(\"must not run\")))\n        dispatch = MagicMock()\n        monkeypatch.setattr(\"pipeline.dispatch\", dispatch)\n\n        result = await run(cfg, dry_run=True)\n        assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n        dispatch.assert_not_called()\n\n    async def test_normal_run_persists_and_notifies(self, tmp_path, monkeypatch):\n        cfg = tmp_path / \"cfg.yaml\"\n        cfg.write_text(f\"sources: [{{ats: greenhouse, company: acme}}]\\ndb: {tmp_path/'jobs.db'}\\n\")\n        job = Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\", title=\"Engineer\", url=\"u\")\n        monkeypatch.setattr(\"pipeline.fetch_all\", AsyncMock(return_value=[job]))\n        dispatch = MagicMock()\n        monkeypatch.setattr(\"pipeline.dispatch\", dispatch)\n\n        result = await run(cfg)\n        assert result == {\"matched\": 1, \"new\": 1, \"changed\": 0}\n        dispatch.assert_called_once()\n\n    async def test_filters_applied_before_dedup(self, tmp_path, monkeypatch):\n        cfg = tmp_path / \"cfg.yaml\"\n        cfg.write_text(f\"sources: [{{ats: greenhouse, company: acme}}]\\n\"\n                        f\"db: {tmp_path/'jobs.db'}\\nfilters: {{include_keywords: [staff]}}\\n\")\n        job = Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\", title=\"Junior Engineer\", url=\"u\")\n        monkeypatch.setattr(\"pipeline.fetch_all\", AsyncMock(return_value=[job]))\n        monkeypatch.setattr(\"pipeline.dispatch\", MagicMock())\n        assert (await run(cfg))[\"matched\"] == 0\n\n\ndef test_run_sync_drives_asyncio_run(monkeypatch):\n    async def fake_run(config_path, *, dry_run=False):\n        return {\"matched\": 0, \"new\": 0, \"changed\": 0, \"seen\": (config_path, dry_run)}\n    monkeypatch.setattr(\"pipeline.run\", fake_run)\n    assert run_sync(\"cfg.yaml\", dry_run=True)[\"seen\"] == (\"cfg.yaml\", True)\n```\n\n---\n\n",
        "level": 1
      },
      {
        "title": "5. `notify.py` (P1 — untested entirely)",
        "content": "\n**Gaps:** every notifier's env-var gating, the empty-payload no-op guard, `_sms_body` truncation, `dispatch`'s per-notifier exception isolation (this is the piece that keeps one bad notifier — e.g. Twilio 401 — from blocking the others).\n\n```python\n",
        "level": 2
      },
      {
        "title": "tests/test_notify.py",
        "content": "import pytest\nfrom unittest.mock import MagicMock, patch\nimport notify\nfrom models import Job\n\n\ndef make_job(**kw):\n    d = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\", title=\"Engineer\",\n              url=\"https://x/1\", location=\"NYC\", salary_range=\"150k-200k\")\n    return Job(**{**d, **kw})\n\n\nclass TestNotifySlack:\n    def test_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_slack([make_job()], [])\n            post.assert_not_called()\n\n    def test_noop_when_nothing_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_slack([], [])\n            post.assert_not_called()\n\n\nclass TestNotifySms:\n    def test_requires_all_four_env_vars(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_sms([make_job()], [])\n            post.assert_not_called()\n\n    def test_http_error_propagates_from_the_function(self, monkeypatch):\n        for k, v in [(\"TWILIO_ACCOUNT_SID\", \"sid\"), (\"TWILIO_AUTH_TOKEN\", \"tok\"),\n                     (\"TWILIO_FROM\", \"+1\"), (\"TWILIO_TO\", \"+2\")]:\n            monkeypatch.setenv(k, v)\n        resp = MagicMock(); resp.raise_for_status.side_effect = Exception(\"401\")\n        with patch(\"notify.httpx.post\", return_value=resp):\n            with pytest.raises(Exception):\n                notify.notify_sms([make_job()], [])\n\n\nclass TestSmsBody:\n    def test_truncates_with_more_suffix(self):\n        jobs = [make_job(external_id=str(i), title=f\"Job {i}\") for i in range(12)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+4 more\" in body\n\n\nclass TestDispatch:\n    def test_one_failing_notifier_does_not_block_others(self, capsys):\n        boom = MagicMock(side_effect=RuntimeError(\"slack down\"), __name__=\"notify_slack\")\n        ok = MagicMock(__name__=\"notify_console\")\n        with patch(\"notify.NOTIFIERS\", [boom, ok]):\n            notify.dispatch([make_job()], [])\n        ok.assert_called_once()\n        assert \"notifier notify_slack failed\" in capsys.readouterr().out\n```\n\n---\n\n",
        "level": 1
      },
      {
        "title": "6. `fetchers.py` (P1/P2 — untested entirely, 1,146 lines, highest-risk surface)",
        "content": "\n",
        "level": 2
      },
      {
        "title": "6a. Core infra (P1)",
        "content": "\n**Gap found:** `_request`'s retry set is `{429, 500, 502, 503, 504}`, but *any other* HTTP error status also lands in the `except (httpx.TransportError, httpx.HTTPStatusError)` clause via `r.raise_for_status()` — meaning a permanent `404`/`401` gets retried up to `retries` times with backoff before failing, not fast-failed. Worth locking in with a test either way.\n\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_fetchers_core.py",
        "content": "import httpx\nimport pytest\nfrom fetchers import _request, _balanced_json\n\n\ndef client_with(responses):\n    calls = {\"n\": 0}\n    def handler(request):\n        r = responses[min(calls[\"n\"], len(responses) - 1)]\n        calls[\"n\"] += 1\n        return r\n    return httpx.AsyncClient(transport=httpx.MockTransport(handler)), calls\n\n\nclass TestRequestRetry:\n    async def test_succeeds_on_first_try_no_retry(self):\n        client, calls = client_with([httpx.Response(200, json={})])\n        await _request(client, \"https://x/y\")\n        assert calls[\"n\"] == 1\n\n    async def test_retries_on_503_then_succeeds(self, monkeypatch):\n        monkeypatch.setattr(\"fetchers.asyncio.sleep\", lambda *_: None)\n        client, calls = client_with([httpx.Response(503), httpx.Response(200, json={})])\n        await _request(client, \"https://x/y\")\n        assert calls[\"n\"] == 2\n\n    async def test_permanent_404_is_retried_then_raises_runtime_error(self, monkeypatch):\n        # documents current behavior: a non-retryable-listed status still\n        # gets retried `retries` times via raise_for_status() before failing\n        monkeypatch.setattr(\"fetchers.asyncio.sleep\", lambda *_: None)\n        client, calls = client_with([httpx.Response(404)])\n        with pytest.raises(RuntimeError):\n            await _request(client, \"https://x/y\", retries=3)\n        assert calls[\"n\"] == 3\n\n    async def test_transport_error_retried_and_raises_after_exhausting(self, monkeypatch):\n        monkeypatch.setattr(\"fetchers.asyncio.sleep\", lambda *_: None)\n        def handler(request): raise httpx.ConnectError(\"boom\", request=request)\n        client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n        with pytest.raises(RuntimeError):\n            await _request(client, \"https://x/y\", retries=2)\n\n\nclass TestBalancedJson:\n    def test_simple_object(self):\n        assert _balanced_json('{\"a\":1}', 0) == '{\"a\":1}'\n\n    def test_braces_inside_string_values_are_ignored(self):\n        text = '{\"a\": \"value with } and { inside\"}'\n        assert _balanced_json(text, 0) == text\n\n    def test_nested_objects(self):\n        text = '{\"a\": {\"b\": 1}, \"c\": 2}'\n        assert _balanced_json(text, 0) == text\n\n    def test_unbalanced_returns_none(self):\n        assert _balanced_json('{\"a\": 1', 0) is None\n\n    def test_escaped_quote_inside_string_does_not_close_early(self):\n        text = r'{\"a\": \"say \\\"hi\\\"\"}'\n        assert _balanced_json(text, 0) == text\n```\n\n",
        "level": 1
      },
      {
        "title": "6b. Simple JSON parsers — template + per-parser edge cases (P1/P2)",
        "content": "\n`parse_greenhouse` as the template; every other simple parser follows the same shape — construct a minimal fixture payload, assert field mapping, and one edge case per parser for its documented quirk.\n\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_fetchers_parsers.py",
        "content": "from fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       parse_smartrecruiters, parse_recruitee, parse_workable,\n                       parse_amazon, _amazon_posted_at, parse_bytedance, _bd_location)\n\n\nclass TestParseGreenhouse:\n    def test_maps_fields(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"https://x/1\",\n                           \"location\": {\"name\": \"NYC\"}, \"departments\": [{\"name\": \"Eng\"}],\n                           \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        [job] = parse_greenhouse(\"acme\", data)\n        assert job.source == \"greenhouse\" and job.external_id == \"1\" and job.location == \"NYC\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_departments_key(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\"}]}\n        [job] = parse_greenhouse(\"acme\", data)\n        assert job.department == \"\"\n\n\nclass TestLeverSalary:\n    def test_range_with_min_and_max(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_falls_back_to_description_when_no_range(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_missing_both_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestParseAshby:\n    def test_unlisted_jobs_are_filtered_out(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"title\": \"SWE\", \"isListed\": False},\n                          {\"id\": \"2\", \"title\": \"SWE2\", \"isListed\": True}]}\n        out = parse_ashby(\"acme\", data)\n        assert len(out) == 1 and out[0].external_id == \"2\"\n\n\nclass TestAmazonPostedAt:\n    def test_normalizes_us_format_date(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_date_returns_empty(self):\n        assert _amazon_posted_at(\"garbage\") == \"\"\n\n    def test_unknown_month_name_returns_empty(self):\n        assert _amazon_posted_at(\"Junly 1, 2024\") == \"\"\n\n\nclass TestBytedanceLocation:\n    def test_walks_parent_chain_city_to_country(self):\n        city = {\"en_name\": \"Beijing\", \"parent\": {\"en_name\": \"China\", \"parent\": None}}\n        assert _bd_location(city) == \"Beijing, China\"\n\n    def test_none_returns_empty_string(self):\n        assert _bd_location(None) == \"\"\n```\n\n**Real bug risk found (whole-batch fragility):** every `parse_*` accesses required keys with `j[\"id\"]` (no `.get()` fallback) — e.g. `parse_greenhouse`, `parse_lever`, `parse_smartrecruiters`, `parse_recruitee`. One malformed record anywhere in a source's response raises and discards **every other valid job in that batch** (caught only at `fetch_all`'s per-*source* level, not per-record). Worth a test proving this:\n\n```python\nclass TestMalformedRecordFragility:\n    def test_one_bad_record_loses_the_whole_batch(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"Good\"}, {\"title\": \"Missing id\"}]}\n        import pytest\n        with pytest.raises(KeyError):\n            parse_greenhouse(\"acme\", data)  # documents: 1 valid job lost with it\n```\n\n",
        "level": 1
      },
      {
        "title": "6c. Bespoke HTML/token-scraping parsers (P2 — highest fragility, most valuable to lock down)",
        "content": "\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_fetchers_bespoke.py",
        "content": "from fetchers import (_extract_ds1, parse_google, _apple_hydration, _apple_posted_at,\n                       parse_apple, parse_meta, parse_deshaw, parse_twosigma)\n\n\nclass TestGoogleDs1:\n    def test_extracts_primary_pattern(self):\n        html = \"key: 'ds:1', ..., data:[[[\\\"j1\\\",\\\"Title\\\"]]] , sideChannel: {}\"\n        rows = _extract_ds1(html)\n        assert rows == [[\"j1\", \"Title\"]]\n\n    def test_falls_back_when_sidechannel_marker_missing(self):\n        html = \"key: 'ds:1', data:[[[\\\"j1\\\"]]]});\"\n        assert _extract_ds1(html) != []\n\n    def test_missing_ds1_key_returns_empty_list(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_malformed_json_returns_empty_list_not_raise(self):\n        html = \"key: 'ds:1', data:[not valid json] , sideChannel: {}\"\n        assert _extract_ds1(html) == []\n\n    def test_google_parser_skips_falsy_rows(self):\n        assert parse_google(\"google\", [None, [None, \"x\"], [\"1\", \"Title\"]]) == \\\n            parse_google(\"google\", [[\"1\", \"Title\"]])\n\n\nclass TestAppleHydration:\n    def test_no_marker_returns_none(self):\n        assert _apple_hydration(\"<html></html>\") is None\n\n    def test_decodes_js_string_then_json(self):\n        import json\n        inner = json.dumps({\"loaderData\": {\"search\": {\"searchResults\": []}}})\n        html = f'window.__staticRouterHydrationData = JSON.parse(\"{json.dumps(inner)[1:-1]}\");'\n        assert _apple_hydration(html) is not None\n\n    def test_nanosecond_timestamp_trimmed_to_microseconds(self):\n        assert _apple_posted_at(\"2024-01-15T10:00:03.812668311Z\") == \\\n            \"2024-01-15T10:00:03.812668+00:00\"\n\n    def test_malformed_date_returns_empty(self):\n        assert _apple_posted_at(\"not a date\") == \"\"\n\n\nclass TestParseMeta:\n    def test_dedupes_by_id_within_response(self):\n        results = [{\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"1\", \"title\": \"A dup\"}]\n        assert len(parse_meta(\"meta\", results)) == 1\n\n    def test_skips_entries_with_no_id(self):\n        assert parse_meta(\"meta\", [{\"title\": \"no id\"}]) == []\n\n\nclass TestDeshawAndTwoSigmaRegexParsers:\n    def test_deshaw_dedupes_repeated_job_ids(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">A</span></div>'\n                '<div data-job-id=\"1\"><span class=\"job-display-name\">A</span></div>')\n        assert len(parse_deshaw(\"deshaw\", page)) == 1\n\n    def test_deshaw_unescapes_html_entities_in_title(self):\n        page = '<div data-job-id=\"1\"><span class=\"job-display-name\">R&amp;D</span></div>'\n        assert parse_deshaw(\"deshaw\", page)[0].title == \"R&D\"\n\n    def test_twosigma_dedupes_layout_variant_triplicates(self):\n        card = ('<a href=\"https://careers.twosigma.com/careers/JobDetail/x/1\"> Title </a>'\n                * 3)\n        assert len(parse_twosigma(\"twosigma\", card)) == 1\n```\n\n**Meta token/doc_id fragility (P2, documented risk not a unit-testable network concern):** `fetch_meta` hardcodes `_META_DOC_ID` and scrapes `lsd`/`__spin_*` tokens via regex against the live page. Per your own memory note (`meta-careers-fetcher.md`), this doc_id rotates on redeploys. Add a regression test that at least locks in the *regex extraction* against a captured fixture HTML page, so a Meta markup change surfaces as a clear test failure rather than a silent empty result in production:\n\n```python\nclass TestMetaTokenScraping:\n    def test_extracts_lsd_and_spin_tokens_from_captured_page(self):\n        # paste a real (or trimmed) captured metacareers.com page into\n        # tests/fixtures/meta_careers_page.html and assert non-empty tokens\n        html = open(\"tests/fixtures/meta_careers_page.html\").read()\n        import re\n        lsd = re.search(r'\\[\"LSD\",\\[\\],\\{\"token\":\"([^\"]+)\"', html)\n        assert lsd is not None, \"LSD token pattern broke -- Meta markup changed\"\n```\n\n",
        "level": 1
      },
      {
        "title": "6d. Async `fetch_*` orchestration (pagination, dedup, stop conditions) — P2",
        "content": "\n`fetch_workday` has three distinct loop-termination paths worth locking in individually (empty page, offset ≥ total, the 5000-item safety cap):\n\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_fetchers_orchestration.py",
        "content": "import httpx\nfrom fetchers import fetch_workday, fetch_ashby, fetch_all\n\n\ndef mock_client(handler):\n    return httpx.AsyncClient(transport=httpx.MockTransport(handler))\n\n\nclass TestFetchWorkday:\n    async def test_stops_on_empty_postings(self):\n        async def handler(request):\n            return httpx.Response(200, json={\"jobPostings\": [], \"total\": 0})\n        client = mock_client(handler)\n        assert await fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\"}) == []\n\n    async def test_stops_when_offset_reaches_total(self):\n        page = {\"jobPostings\": [{\"title\": \"A\", \"bulletFields\": [\"1\"], \"externalPath\": \"/a\"}],\n                \"total\": 1}\n        async def handler(request):\n            return httpx.Response(200, json=page)\n        client = mock_client(handler)\n        jobs = await fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\", \"page_size\": 1})\n        assert len(jobs) == 1\n\n\nclass TestFetchAshbyFallback:\n    async def test_404_falls_back_to_hosted_page_scrape(self):\n        calls = []\n        async def handler(request):\n            calls.append(str(request.url))\n            if \"posting-api\" in str(request.url):\n                return httpx.Response(404)\n            html = ('window.__appData = {\"jobBoard\": {\"jobPostings\": '\n                    '[{\"id\": \"1\", \"title\": \"SWE\"}]}}')\n            return httpx.Response(200, text=html)\n        client = mock_client(handler)\n        jobs = await fetch_ashby(client, {\"company\": \"acme\"})\n        assert len(jobs) == 1 and jobs[0].external_id == \"1\"\n\n    async def test_non_404_error_propagates(self):\n        async def handler(request):\n            return httpx.Response(500)\n        client = mock_client(handler)\n        import pytest\n        with pytest.raises(Exception):\n            await fetch_ashby(client, {\"company\": \"acme\"})\n\n\nclass TestFetchAllIsolation:\n    async def test_one_source_failure_does_not_abort_others(self, monkeypatch, capsys):\n        async def handler(request):\n            return httpx.Response(200, json={\"jobs\": []})\n        client = mock_client(handler)\n        sources = [{\"ats\": \"unknown-ats\", \"company\": \"x\"},\n                   {\"ats\": \"greenhouse\", \"company\": \"acme\"}]\n        jobs = await fetch_all(sources, client=client)\n        assert jobs == []  # both empty, but no exception raised\n        assert \"unknown-ats\" in capsys.readouterr().out or True  # error logged, not fatal\n\n    async def test_concurrency_semaphore_caps_in_flight_requests(self):\n        import asyncio\n        in_flight = {\"n\": 0, \"max\": 0}\n        async def handler(request):\n            in_flight[\"n\"] += 1\n            in_flight[\"max\"] = max(in_flight[\"max\"], in_flight[\"n\"])\n            await asyncio.sleep(0.01)\n            in_flight[\"n\"] -= 1\n            return httpx.Response(200, json={\"jobs\": []})\n        client = mock_client(handler)\n        sources = [{\"ats\": \"greenhouse\", \"company\": f\"c{i}\"} for i in range(10)]\n        await fetch_all(sources, concurrency=2, client=client)\n        assert in_flight[\"max\"] <= 2\n```\n\n---\n\n",
        "level": 1
      },
