        "language": "python",
        "code": "# tests/test_models.py\nimport pytest\nfrom datetime import datetime, timezone\nfrom models import Job, parse_posted_at\n\n\nclass TestParsePostedAt:\n    def test_empty_string_returns_none(self):\n        assert parse_posted_at(\"\") is None\n\n    def test_milliseconds_epoch_lever_style(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt.tzinfo == timezone.utc and dt.year == 2022\n\n    def test_iso_with_trailing_z(self):\n        assert parse_posted_at(\"2024-01-15T10:00:00Z\") == \\\n            datetime(2024, 1, 15, 10, 0, tzinfo=timezone.utc)\n\n    def test_naive_iso_gets_utc_attached(self):\n        assert parse_posted_at(\"2024-01-15T10:00:00\").tzinfo == timezone.utc\n\n    def test_unparseable_prose_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None  # Workday's format\n\n    def test_whitespace_only_returns_none(self):\n        assert parse_posted_at(\"   \") is None\n\n    def test_absurdly_large_numeric_string_raises(self):\n        # isdigit() accepts it as a valid epoch; fromtimestamp() overflows.\n        # Untrusted source data reaching this uncaught crashes the whole batch.\n        with pytest.raises((OverflowError, ValueError, OSError)):\n            parse_posted_at(\"99999999999999999999\")\n\n\nclass TestJobIdentity:\n    def _job(self, **kw):\n        d = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                  title=\"Engineer\", url=\"https://x/1\", location=\"NYC\")\n        return Job(**{**d, **kw})\n\n    def test_key_format(self):\n        assert self._job().key == \"greenhouse:acme:1\"\n\n    def test_hash_changes_when_title_changes(self):\n        assert self._job().content_hash != self._job(title=\"Senior Engineer\").content_hash\n\n    def test_hash_stable_when_only_salary_or_posted_at_changes(self):\n        # documents a diff()-visible gap: comp/date-only edits won't be\n        # reported as \"changed\" by Store.diff\n        a = self._job(posted_at=\"2024-01-01\", salary_range=\"100k\")\n        b = self._job(posted_at=\"2024-06-01\", salary_range=\"150k\")\n        assert a.content_hash == b.content_hash\n\n    def test_hash_ignores_raw(self):\n        assert self._job(raw={\"a\": 1}).content_hash == self._job(raw={\"a\": 2}).content_hash\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self):\n        row = self._job(raw={\"secret\": True}).to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == self._job().key"
