        "code": "# tests/test_fetchers_orchestration.py\nimport httpx\nfrom fetchers import fetch_workday, fetch_ashby, fetch_all\n\n\ndef mock_client(handler):\n    return httpx.AsyncClient(transport=httpx.MockTransport(handler))\n\n\nclass TestFetchWorkday:\n    async def test_stops_on_empty_postings(self):\n        async def handler(request):\n            return httpx.Response(200, json={\"jobPostings\": [], \"total\": 0})\n        client = mock_client(handler)\n        assert await fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\"}) == []\n\n    async def test_stops_when_offset_reaches_total(self):\n        page = {\"jobPostings\": [{\"title\": \"A\", \"bulletFields\": [\"1\"], \"externalPath\": \"/a\"}],\n                \"total\": 1}\n        async def handler(request):\n            return httpx.Response(200, json=page)\n        client = mock_client(handler)\n        jobs = await fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\", \"page_size\": 1})\n        assert len(jobs) == 1\n\n\nclass TestFetchAshbyFallback:\n    async def test_404_falls_back_to_hosted_page_scrape(self):\n        calls = []\n        async def handler(request):\n            calls.append(str(request.url))\n            if \"posting-api\" in str(request.url):\n                return httpx.Response(404)\n            html = ('window.__appData = {\"jobBoard\": {\"jobPostings\": '\n                    '[{\"id\": \"1\", \"title\": \"SWE\"}]}}')\n            return httpx.Response(200, text=html)\n        client = mock_client(handler)\n        jobs = await fetch_ashby(client, {\"company\": \"acme\"})\n        assert len(jobs) == 1 and jobs[0].external_id == \"1\"\n\n    async def test_non_404_error_propagates(self):\n        async def handler(request):\n            return httpx.Response(500)\n        client = mock_client(handler)\n        import pytest\n        with pytest.raises(Exception):\n            await fetch_ashby(client, {\"company\": \"acme\"})\n\n\nclass TestFetchAllIsolation:\n    async def test_one_source_failure_does_not_abort_others(self, monkeypatch, capsys):\n        async def handler(request):\n            return httpx.Response(200, json={\"jobs\": []})\n        client = mock_client(handler)\n        sources = [{\"ats\": \"unknown-ats\", \"company\": \"x\"},\n                   {\"ats\": \"greenhouse\", \"company\": \"acme\"}]\n        jobs = await fetch_all(sources, client=client)\n        assert jobs == []  # both empty, but no exception raised\n        assert \"unknown-ats\" in capsys.readouterr().out or True  # error logged, not fatal\n\n    async def test_concurrency_semaphore_caps_in_flight_requests(self):\n        import asyncio\n        in_flight = {\"n\": 0, \"max\": 0}\n        async def handler(request):\n            in_flight[\"n\"] += 1\n            in_flight[\"max\"] = max(in_flight[\"max\"], in_flight[\"n\"])\n            await asyncio.sleep(0.01)\n            in_flight[\"n\"] -= 1\n            return httpx.Response(200, json={\"jobs\": []})\n        client = mock_client(handler)\n        sources = [{\"ats\": \"greenhouse\", \"company\": f\"c{i}\"} for i in range(10)]\n        await fetch_all(sources, concurrency=2, client=client)\n        assert in_flight[\"max\"] <= 2"
