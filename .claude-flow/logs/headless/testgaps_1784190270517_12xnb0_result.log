        "language": "python",
        "code": "# tests/test_filters.py\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nfrom filters import match, filter_jobs\nfrom models import Job\n\n\ndef make_job(**kw):\n    d = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n              title=\"Software Engineer\", url=\"https://x/1\",\n              location=\"New York, NY\", department=\"Engineering\")\n    return Job(**{**d, **kw})\n\n\nclass TestMatch:\n    def test_exclude_wins_over_include(self):\n        j = make_job(title=\"Senior Software Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"senior\"]) is False\n\n    def test_include_requires_word_boundary_not_substring(self):\n        assert match(make_job(title=\"Engineering Manager\"), include=[\"eng\"]) is False\n\n    def test_include_case_insensitive(self):\n        assert match(make_job(title=\"SOFTWARE ENGINEER\"), include=[\"software engineer\"])\n\n    def test_locations_is_substring_match_not_word_boundary(self):\n        j = make_job(location=\"San Francisco Bay Area\")\n        assert match(j, locations=[\"francisco\"]) is True\n\n    def test_cutoff_drops_confirmed_old_postings(self):\n        j = make_job(posted_at=\"2020-01-01T00:00:00Z\")\n        assert match(j, cutoff=datetime.now(timezone.utc) - timedelta(days=30)) is False\n\n    def test_cutoff_keeps_unparseable_dates(self):\n        j = make_job(posted_at=\"Posted 3 Days Ago\")\n        assert match(j, cutoff=datetime.now(timezone.utc)) is True\n\n    def test_cutoff_keeps_undated_jobs(self):\n        assert match(make_job(posted_at=\"\"), cutoff=datetime.now(timezone.utc)) is True\n\n    def test_cutoff_boundary_equal_timestamp_is_kept(self):\n        now = datetime.now(timezone.utc)\n        assert match(make_job(posted_at=now.isoformat()), cutoff=now) is True  # dt < cutoff, equal is kept\n\n\nclass TestFilterJobs:\n    def test_max_age_days_zero_silently_disables_filter(self):\n        old = make_job(posted_at=\"2000-01-01T00:00:00Z\")\n        # documents current behavior -- likely surprising if a user sets 0\n        # expecting \"today only\" instead of \"no cutoff\"\n        assert filter_jobs([old], {\"max_age_days\": 0}) == [old]\n\n    def test_max_age_days_as_yaml_string(self):\n        old = make_job(posted_at=\"2000-01-01T00:00:00Z\")\n        assert filter_jobs([old], {\"max_age_days\": \"1\"}) == []\n\n    def test_empty_rules_returns_all(self):\n        jobs = [make_job(), make_job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs"
