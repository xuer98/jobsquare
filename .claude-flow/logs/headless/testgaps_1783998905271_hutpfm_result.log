        "code": "import pytest\nfrom datetime import datetime, timezone\nimport agent\n\ndef test_normalize_ats_skips_style_and_tag_but_replaces_body_text():\n    html = '<style>content: \"\\u2014\";</style><p title=\"\\u2014\">He said \\u2014 hi</p>'\n    out, counts = agent._normalize_ats(html)\n    assert 'content: \"\\u2014\"' in out          # inside <style>, untouched\n    assert 'title=\"\\u2014\"' in out              # inside a tag attribute, untouched\n    assert \"He said - hi\" in out                # body text, replaced\n    assert counts[\"em-dash\"] == 1\n\ndef test_cmd_db_mark_rejects_non_iso(capsys):\n    rc = agent.cmd_db_mark([\"not-a-timestamp\"])\n    assert rc == 2\n    assert \"not an ISO timestamp\" in capsys.readouterr().err\n\ndef test_cmd_db_mark_requires_watermark_or_now(capsys):\n    rc = agent.cmd_db_mark([])\n    assert rc == 2\n\ndef test_cmd_db_new_truncates_at_group_boundary(tmp_path, monkeypatch, capsys):\n    from store import Store\n    from models import Job\n    cfg = tmp_path / \"sources.yaml\"\n    cfg.write_text(f\"sources: []\\ndb: {tmp_path / 'j.db'}\\n\")\n    with Store(tmp_path / \"j.db\") as s:\n        # simulate 3 pipeline runs -> 3 distinct first_seen groups of 2 rows each\n        for batch in range(3):\n            jobs = [Job(source=\"s\", company=\"c\", external_id=f\"{batch}-{i}\",\n                        title=\"T\", url=\"u\") for i in range(2)]\n            s.diff(jobs)\n    rc = agent.cmd_db_new([\"-c\", str(cfg), \"--limit\", \"3\"])  # limit falls mid-3rd-group\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"truncated\"] is True\n    assert out[\"count\"] == 4   # only first two complete groups kept"
