        "code": "# tests/test_fetchers_parsers.py\nfrom fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       _extract_ds1, parse_google, _ds1_posted_at, _apple_hydration,\n                       _apple_posted_at, parse_apple, _bd_location, parse_amazon,\n                       _amazon_posted_at, parse_microsoft, parse_netflix)\n\ndef test_parse_greenhouse_joins_multiple_departments():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\", \"absolute_url\": \"u\",\n                       \"location\": {\"name\": \"Remote\"},\n                       \"departments\": [{\"name\": \"A\"}, {\"name\": \"B\"}],\n                       \"updated_at\": \"2024-01-01\"}]}\n    out = parse_greenhouse(\"acme\", data)\n    assert out[0].department == \"A, B\"\n\ndef test_lever_salary_prefers_range_over_description():\n    j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"},\n         \"salaryDescriptionPlain\": \"ignored\"}\n    assert _lever_salary(j) == \"USD 100,000–150,000\"\n\ndef test_lever_salary_falls_back_to_description_when_no_range():\n    assert _lever_salary({\"salaryDescriptionPlain\": \"Competitive\"}) == \"Competitive\"\n\ndef test_parse_ashby_skips_unlisted_jobs():\n    data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"},\n                      {\"id\": \"2\", \"isListed\": True, \"title\": \"Visible\"}]}\n    out = parse_ashby(\"acme\", data)\n    assert len(out) == 1 and out[0].title == \"Visible\"\n\ndef test_extract_ds1_handles_missing_sidechannel_fallback():\n    html = 'AF_initDataCallback({key: \\'ds:1\\', data:[[[\"1\",\"Title\"]]]});'\n    assert _extract_ds1(html) == [[\"1\", \"Title\"]]\n\ndef test_extract_ds1_returns_empty_on_malformed_json():\n    html = \"key: 'ds:1', data:[not valid json], sideChannel:{}\"\n    assert _extract_ds1(html) == []\n\ndef test_ds1_posted_at_prefers_create_over_update_time():\n    job = [None]*15\n    job[12] = [1700000000]  # create\n    job[13] = [1800000000]  # update\n    result = _ds1_posted_at(job)\n    assert \"2023\" in result  # create-time year, not update-time\n\ndef test_ds1_posted_at_defensive_on_short_array():\n    assert _ds1_posted_at([1, 2]) == \"\"\n\ndef test_apple_hydration_none_when_marker_absent():\n    assert _apple_hydration(\"<html>no hydration here</html>\") is None\n\ndef test_apple_posted_at_trims_nanosecond_precision():\n    result = _apple_posted_at(\"2024-01-15T10:00:03.812668311Z\")\n    assert result == \"2024-01-15T10:00:03.812668+00:00\"\n\ndef test_apple_posted_at_empty_on_missing_value():\n    assert _apple_posted_at(\"\") == \"\"\n\ndef test_bd_location_walks_parent_chain():\n    city = {\"en_name\": \"Beijing\", \"parent\": {\"en_name\": \"China\", \"parent\": None}}\n    assert _bd_location(city) == \"Beijing, China\"\n\ndef test_bd_location_none_returns_empty_string():\n    assert _bd_location(None) == \"\"\n\ndef test_amazon_posted_at_parses_us_format():\n    assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\ndef test_amazon_posted_at_unknown_month_returns_empty():\n    assert _amazon_posted_at(\"Frobnary 26, 2026\") == \"\"\n\ndef test_amazon_posted_at_malformed_returns_empty():\n    assert _amazon_posted_at(\"not a date\") == \"\"\n\ndef test_parse_amazon_falls_back_to_id_icims():\n    out = parse_amazon(\"amazon\", [{\"id_icims\": \"123\", \"title\": \"Eng\", \"job_path\": \"/p\"}])\n    assert out[0].external_id == \"123\"\n\ndef test_parse_microsoft_missing_posted_ts_is_empty_string():\n    out = parse_microsoft(\"microsoft\", [{\"id\": \"1\", \"name\": \"Eng\"}])\n    assert out[0].posted_at == \"\"\n\ndef test_parse_netflix_falls_back_to_single_location_field():\n    out = parse_netflix(\"netflix\", [{\"id\": \"1\", \"name\": \"Eng\", \"location\": \"SF,CA,US\"}])\n    assert out[0].location == \"SF, CA, US\""
