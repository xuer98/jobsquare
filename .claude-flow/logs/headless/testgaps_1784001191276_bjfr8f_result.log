        "language": "python",
        "code": "# tests/test_models.py\nimport pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\n\nclass TestParsePostedAt:\n    def test_empty_returns_none(self):\n        assert parse_posted_at(\"\") is None\n        assert parse_posted_at(None) is None\n\n    def test_epoch_seconds(self):\n        dt = parse_posted_at(\"1700000000\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_epoch_milliseconds(self):\n        # Lever-style 13-digit ms epoch\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt.year == 2022\n\n    @pytest.mark.parametrize(\"digits\", [\"999999999999\", \"1000000000000\"])\n    def test_seconds_vs_milliseconds_boundary(self, digits):\n        # 1e12 - 1 must be treated as seconds; 1e12 as milliseconds\n        dt = parse_posted_at(digits)\n        assert dt is not None  # pin down expected year per branch\n\n    def test_iso8601_with_z_suffix(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso8601_naive_defaults_to_utc(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso8601_with_explicit_offset_preserved(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00+05:00\")\n        assert dt.utcoffset().total_seconds() == 5 * 3600\n\n    def test_unparseable_prose_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_whitespace_only_stripped(self):\n        assert parse_posted_at(\"   \") is None  # currently: strip() -> \"\" -> falsy? verify\n\n\nclass TestJob:\n    def _job(self, **over):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                    title=\"Engineer\", url=\"https://x/1\")\n        return Job(**{**base, **over})\n\n    def test_key_ignores_mutable_fields(self):\n        j1 = self._job(title=\"Engineer I\")\n        j2 = self._job(title=\"Engineer II\")\n        assert j1.key == j2.key  # same source/company/external_id\n\n    def test_content_hash_changes_on_title(self):\n        j1 = self._job(title=\"Engineer\")\n        j2 = self._job(title=\"Senior Engineer\")\n        assert j1.content_hash != j2.content_hash\n\n    def test_content_hash_stable_across_unrelated_fields(self):\n        j1 = self._job(posted_at=\"2024-01-01\")\n        j2 = self._job(posted_at=\"2024-06-01\")\n        assert j1.content_hash == j2.content_hash  # posted_at not in hash blob\n\n    def test_to_row_drops_raw_adds_key_and_hash(self):\n        j = self._job(raw={\"secret\": 1})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash"
