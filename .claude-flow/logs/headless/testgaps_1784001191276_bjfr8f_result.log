s TestNotifySms:\n    def test_noop_when_partial_twilio_config(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        notify.notify_sms([_job()], [])  # missing token -> no-op, no crash\n\n    @respx.mock\n    def test_raises_on_twilio_error(self, monkeypatch):\n        for k, v in dict(TWILIO_ACCOUNT_SID=\"sid\", TWILIO_AUTH_TOKEN=\"tok\",\n                          TWILIO_FROM=\"+1\", TWILIO_TO=\"+2\").items():\n            monkeypatch.setenv(k, v)\n        respx.post(url__regex=r\".*Messages\\.json\").mock(\n            return_value=httpx.Response(401, json={\"message\": \"bad auth\"}))\n        with pytest.raises(httpx.HTTPStatusError):\n            notify.notify_sms([_job()], [])\n\n\nclass TestSmsBody:\n    def test_truncates_at_limit_with_suffix(self):\n        jobs = [_job(title=f\"Job {i}\") for i in range(12)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+4 more\" in body\n        assert body.count(\"\\n- \") == 8\n\n    def test_no_suffix_when_under_limit(self):\n        jobs = [_job(title=\"Job 1\")]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"more\" not in body\n\n\nclass TestDispatch:\n    def test_one_notifier_failure_does_not_block_others(self, monkeypatch, capsys):\n        def boom(new, changed):\n            raise RuntimeError(\"slack is down\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [notify.notify_console, boom])\n        notify.dispatch([_job()], [])  # must not raise\n        out = capsys.readouterr().out\n        assert \"NEW listing\" in out  # console still ran\n```\n\n---\n\n### 5. `pipeline.py` — `load_config`, `run`, `run_sync`\n\n**Gaps:**\n- `load_config` defaulting: missing `sources`/`filters`/`db`/`concurrency` keys all filled in\n- `run(dry_run=True)` — no `Store` touched, no `dispatch` called, returns `{new:0, changed:0}` regardless of matches\n- `run(dry_run=False)` — full path: `fetch_all` → `filter_jobs` → `Store.diff` → `dispatch`, correct counts in return dict\n- **Missing**: `load_config` on a malformed YAML file (should raise, but no test proves what)\n- **Missing**: `run` when `fetch_all` returns zero jobs (empty `sources` list) — should still complete cleanly\n\n```python\n# tests/test_pipeline.py\nimport pytest\nfrom unittest.mock import AsyncMock, patch\nimport yaml\nimport pipeline\n\n\nclass TestLoadConfig:\n    def test_defaults_filled_in(self, tmp_path):\n        p = tmp_path / \"sources.yaml\"\n        p.write_text(yaml.dump({\"sources\": [{\"ats\": \"greenhouse\", \"company\": \"x\"}]}))\n        cfg = pipeline.load_config(p)\n        assert cfg[\"filters\"] == {}\n        assert cfg[\"db\"] == \"jobs.db\"\n        assert cfg[\"concurrency\"] == 8\n\n    def test_explicit_values_preserved(self, tmp_path):\n        p = tmp_path / \"sources.yaml\"\n        p.write_text(yaml.dump({\"sources\": [], \"db\": \"custom.db\", \"concurrency\": 3}))\n        cfg = pipeline.load_config(p)\n        assert cfg[\"db\"] == \"custom.db\"\n        assert cfg[\"concurrency\"] == 3\n\n\nclass TestRun:\n    @pytest.mark.asyncio\n    async def test_dry_run_skips_store_and_dispatch(self, tmp_path):\n        p = tmp_path / \"sources.yaml\"\n        p.write_text(yaml.dump({\"sources\": []}))\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n             patch(\"pipeline.Store\") as store_cls, \\\n             patch(\"pipeline.dispatch\") as dispatch_fn:\n            result = await pipeline.run(p, dry_run=True)\n            store_cls.assert_not_called()\n            dispatch_fn.assert_not_called()\n            assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n\n    @pytest.mark.asyncio\n    async def test_full_run_calls_diff_and_dispatch(self, tmp_path):\n        p = tmp_path / \"sources.yaml\"\n        p.write_text(yaml.dump({\"sources\": [], \"db\": str(tmp_path / \"j.db\")}))\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n             patch(\"pipeline.dispatch\") as dispatch_fn:\n            result = await pipeline.run(p, dry_run=False)\n            dispatch_fn.assert_called_once()\n            assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n```\n\n---\n\n### 6. `fetchers.py` — the biggest gap (788 lines, 15 ATS integrations, zero tests)\n\nSplit into two concerns: **pure parsers** (easy, no network) and **fetch_* orchestration** (needs `respx`).\n\n#### 6a. Parsers — highest ROI, pure functions, no mocking needed\nEvery `parse_*` function needs at least: happy path, missing/optional fields, empty input list.\n\n```python\n# tests/test_fetchers_parsers.py\nfrom fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       _ashby_salary, parse_smartrecruiters, parse_recruitee,\n                       parse_workable, _extract_ds1, _ds1_posted_at, parse_google,\n                       parse_deshaw, parse_twosigma, parse_optiver, parse_meta,\n                       parse_microsoft, parse_netflix, parse_amazon, _amazon_posted_at)\n\n\nclass TestParseGreenhouse:\n    def test_happy_path(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"https://x\",\n                           \"location\": {\"name\": \"NYC\"},\n                           \"departments\": [{\"name\": \"Eng\"}], \"updated_at\": \"2024-01-01\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].external_id == \"1\" and jobs[0].location == \"NYC\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_optional_fields(self):\n        jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 2}]})\n        assert jobs[0].title == \"\" and jobs[0].location == \"\"\n\n\nclass TestLeverSalary:\n    def test_min_max_formatted_with_currency(self):\n        j = {\"salaryRange\": {\"min\": 100