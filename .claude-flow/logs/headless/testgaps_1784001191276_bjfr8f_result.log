await _request(client, \"https://x/api\", retries=3)\n            assert r.status_code == 200\n            assert route.call_count == 2\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_exhausts_retries_raises_runtime_error(self):\n        respx.get(\"https://x/api\").mock(return_value=httpx.Response(500))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n                await _request(client, \"https://x/api\", retries=2)\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_non_retryable_4xx_raises_immediately(self):\n        respx.get(\"https://x/api\").mock(return_value=httpx.Response(404))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError):\n                await _request(client, \"https://x/api\", retries=4)\n            # ideally: assert only 1 attempt made (404 isn't in the retry set)\n```\n\n#### 6c. Pagination fetchers — `fetch_google`, `fetch_twosigma`, `fetch_optiver`, `fetch_microsoft`, `fetch_netflix`, `fetch_amazon`, `fetch_workday`\n\n**Gaps common to all of these — currently zero coverage of the stop conditions, which is where real bugs hide:**\n- Stops when a page returns no *fresh* items (dedup against `seen`) — not just \"no items\"\n- Respects `max_pages` safety cap even if the server never returns empty\n- `fetch_workday`'s stop condition (`offset >= total or offset > 5000`) — the 5000 safety cap is untested and would silently truncate a huge board\n- `fetch_meta` — raises `RuntimeError` with the GraphQL error message when `doc_id` is stale (this is the exact failure mode the module docstring warns about — should be tested so a doc_id rotation fails loudly in CI rather than silently returning `[]`)\n- `fetch_meta` — `\"for (;;);\"` XSSI-prefix stripping\n\n```python\n# tests/test_fetchers_fetch.py\nimport httpx\nimport pytest\nimport respx\nfrom fetchers import fetch_optiver, fetch_workday, fetch_meta, fetch_all\n\n\nclass TestFetchOptiverPagination:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_stops_when_no_fresh_items(self):\n        respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n            side_effect=[\n                httpx.Response(200, json={\"items\": [{\"href\": \"/join-us/jobs/a\", \"title\": \"A\"}]}),\n                httpx.Response(200, json={\"items\": []}),\n            ])\n        jobs = await fetch_optiver(httpx.AsyncClient(), {\"company\": \"optiver\"})\n        assert len(jobs) == 1\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_respects_max_pages_cap(self):\n        respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n            return_value=httpx.Response(200, json={\"items\": [\n                {\"href\": \"/join-us/jobs/x\", \"title\": \"same-every-page\"}]}))\n        jobs = await fetch_optiver(httpx.AsyncClient(),\n                                    {\"company\": \"optiver\", \"max_pages\": 2})\n        # same id every page -> \"fresh\" empty after page 1, loop should stop early\n        assert len(jobs) <= 1\n\n\nclass TestFetchWorkday:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_stops_at_total(self):\n        respx.post(url__regex=r\".*/wday/cxs/.*/jobs\").mock(\n            return_value=httpx.Response(200, json={\n                \"jobPostings\": [{\"title\": \"A\", \"bulletFields\": [\"R123\"]}], \"total\": 1}))\n        jobs = await fetch_workday(httpx.AsyncClient(),\n                                    {\"host\": \"x.wd5.myworkdayjobs.com\", \"tenant\": \"x\", \"site\": \"S\"})\n        assert len(jobs) == 1\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_safety_cap_at_5000_offset(self):\n        # server claims total=999999 and never stops -> loop must bail at offset>5000\n        respx.post(url__regex=r\".*/wday/cxs/.*/jobs\").mock(\n            return_value=httpx.Response(200, json={\n                \"jobPostings\": [{\"title\": \"A\", \"bulletFields\": [\"R1\"]}], \"total\": 999999}))\n        jobs = await fetch_workday(httpx.AsyncClient(),\n                                    {\"host\": \"x.wd5.myworkdayjobs.com\", \"tenant\": \"x\",\n                                     \"site\": \"S\", \"page_size\": 1000})\n        assert len(jobs) <= 6  # bounded by the 5000-offset safety cap, not \"total\"\n\n\nclass TestFetchMeta:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_stale_doc_id_raises_with_message(self):\n        respx.get(\"https://www.metacareers.com/jobs\").mock(\n            return_value=httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok\"}]'))\n        respx.post(\"https://www.metacareers.com/graphql\").mock(\n            return_value=httpx.Response(200, text='for (;;);{\"errors\":[{\"message\":\"doc_id invalid\"}]}'))\n        with pytest.raises(RuntimeError, match=\"doc_id invalid\"):\n            await fetch_meta(httpx.AsyncClient(), {\"company\": \"meta\"})\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_xssi_prefix_stripped(self):\n        respx.get(\"https://www.metacareers.com/jobs\").mock(\n            return_value=httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok\"}]'))\n        respx.post(\"https://www.metacareers.com/graphql\").mock(\n            return_value=httpx.Response(200, text=(\n                'for (;;);{\"data\":{\"job_search_with_featured_jobs_v2\":'\n                '{\"all_jobs\":[{\"id\":\"1\",\"title\":\"SWE\"}]}}}')))\n        jobs = await fetch_meta(httpx.AsyncClient(), {\"company\": \"meta\"})\n        assert jobs[0].external_id == \"1\"\n\n\nclass TestFetchAll:\n    @pytest.mark.asyncio\n    async def test_one_source_failure_does_not_abort_others(self, monkeypatch):\n        async def ok(client, src): return [object()]\n        async def fail(client, src): raise RuntimeError(\"boom\")\n        monkeypatch.setattr(\"fetchers.FETCHERS\", {\"ok\": ok, \"fail\": fail})\n        jobs = await fetch_all([{\"ats\": \"ok\"}, {\"ats\": \"fail\"}])\n        assert len(jobs) == 1  # the failing source is logged, not fatal\n\n    @pytest.mark.asyncio\n    async def test_unknown_ats_raises_valueerror(self):\n        from fetchers import fetch_source\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            await fetch_source(httpx.AsyncClient(), {\"ats\": \"carrier-pigeon\"})\n```\n\n---\n\n### 7. `agent.py` — deterministic helpers (LLM-free, fully testable)\n\n**Gaps — this is the second-highest-risk module** because `cmd_db_new`'s group-boundary truncation logic and the watermark contract have subtle invariants that a naive test would miss:\n\n- `cmd_db_new` first run (no marker) uses `--since-days` window\n- `cmd_db_new` truncation happens **only at `first_seen` group boundaries** — never splits a batch (this is the core untested invariant; a naive `LIMIT`-style truncation would silently drop half a batch)\n- `cmd_db_new` watermark returned is the *last included group's* timestamp, not `--now`\n- `cmd_db_mark` rejects a non-ISO watermark (exit code 2, stderr message)\n- `cmd_db_mark --now` vs explicit watermark — mutually exclusive-ish handling; neither given → exit code 2\n- `_normalize_ats` — replacements happen in text nodes only, **not** inside tags/`<style>`/`<script>` (explicit design invariant, zero test proof)\n- `_normalize_ats` — counts dict tallies per rule label correctly\n- `cmd_pdf_render` — missing input file → exit code 2, no crash\n- `cmd_pdf_render` — PDF magic-byte check catches a failed render (mock `subprocess.run`)\n- `main()` argv dispatch: bare invocation → interactive; `-i` flag anywhere → interactive; mode words stop at first flag\n\n```python\n# tests/test_agent.py\nimport json\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nimport agent\nfrom store import Store\nfrom models import Job\n\n\n@pytest.fixture\ndef sources_yaml(tmp_path):\n    db = tmp_path / \"jobs.db\"\n    p = tmp_path / \"sources.yaml\"\n    p.write_text(f\"sources: []\\ndb: {db}\\n\")\n    return p\n\n\nclass TestCmdDbNew:\n    def test_first_run_uses_since_days_window(self, sources_yaml, capsys):\n        with Store(agent.load_config(sources_yaml)[\"db\"]) as s:\n            s.diff([Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                         title=\"A\", url=\"https://x/1\")])\n        agent.cmd_db_new([\"-c\", str(sources_yaml), \"--since-days\", \"7\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n        assert out[\"count\"] == 1\n\n    def test_truncation_never_splits_a_first_seen_group(self, sources_yaml, capsys):\n        # two jobs inserted in the same diff() call share one first_seen timestamp;\n        # limit=1 must still include both (or neither) — never just one.\n        with Store(agent.load_config(sources_yaml)[\"db\"]) as s:\n            s.diff([Job(source=\"greenhouse\", company=\"acme\", external_id=str(i),\n                         title=f\"J{i}\", url=f\"https://x/{i}\") for i in range(2)])\n        agent.cmd_db_new([\"-c\", str(sources_yaml), \"--since-days\", \"7\", \"--limit\", \"1\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"count\"] in (0, 2)  # never 1\n        if out[\"count\"] == 0:\n            assert out[\"truncated\"] is True\n\n    def test_watermark_is_last_included_group_not_now(self, sources_yaml, capsys):\n        ...  # insert two batches at different times, assert watermark == first batch's ts\n             # when the second batch is truncated out\n\n\nclass TestCmdDbMark:\n    def test_rejects_non_iso_watermark(self, sources_yaml, capsys):\n        rc = agent.cmd_db_mark([\"not-a-date\", \"-c\", str(sources_yaml)])\n        assert rc == 2\n\n    def test_now_flag_sets_current_timestamp(self, sources_yaml):\n        rc = agent.cmd_db_mark([\"--now\", \"-c\", str(sources_yaml)])\n        assert rc == 0\n        with Store(agent.load_config(sources_yaml)[\"db\"]) as s:\n            assert s.get_meta(agent.MARK_KEY) is not None\n\n    def test_no_args_returns_error(self, sources_yaml):\n        rc = agent.cmd_db_mark([\"-c\", str(sources_yaml)])\n        assert rc == 2\n\n\nclass TestNormalizeAts:\n    def test_smart_quotes_replaced_in_text(self):\n        html, counts = agent._normalize_ats(\"<p>\\u201cHello\\u201d</p>\")\n        assert html == '<p>\"Hello\"</p>'\n        assert counts[\"smart-double-quote\"] == 2\n\n    def test_tag_attributes_untouched(self):\n        html, _ = agent._normalize_ats('<div data-x=\"\\u2014\">text</div>')\n        assert 'data-x=\"\\u2014\"' in html  # inside a tag, must not be replaced\n\n    def test_style_block_content_untouched(self):\n        html, counts = agent._normalize_ats(\n            \"<style>.x::before{content:'\\u2014'}</style><p>a\\u2014b</p>\")\n        assert \"content:'\\u2014'\" in html  # style block preserved verbatim\n        assert counts.get(\"em-dash\") == 1  # only the <p> occurrence counted\n\n    def test_no_replacements_needed_empty_counts(self):\n        html, counts = agent._normalize_ats(\"<p>plain ascii text</p>\")\n        assert counts == {}\n\n\nclass TestCmdPdfRender:\n    def test_missing_input_file_returns_2(self, tmp_path, capsys):\n        rc = agent.cmd_pdf_render([str(tmp_path / \"nope.html\")])\n        assert rc == 2\n\n    def test_failed_render_detected_by_missing_pdf_magic(self, tmp_path, monkeypatch):\n        src = tmp_path / \"in.html\"\n        src.write_text(\"<html><body>x</body></html>\")\n        monkeypatch.setattr(agent, \"_chrome_bin\", lambda: \"/bin/true\")\n        class FakeResult:\n            stderr = \"chrome crashed\"\n        monkeypatch.setattr(agent.subprocess, \"run\", lambda *a, **k: FakeResult())\n        rc = agent.cmd_pdf_render([str(src)])\n        assert rc == 1  # out file never written -> no %PDF magic bytes\n```\n\n---\n\n### 8. `cli.py` — argparse wiring\n\nThin, but currently zero coverage of the one behavior that matters: `--dry-run` actually reaching `run_sync`.\n\n```python\n# tests/test_cli.py\nfrom unittest.mock import patch\nimport cli\n\n\ndef test_dry_run_flag_passed_through(monkeypatch):\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\", \"--dry-run\"])\n    with patch(\"cli.run_sync\") as run_sync:\n        cli.main()\n        run_sync.assert_called_once()\n        assert run_sync.call_args.kwargs.get(\"dry_run\") is True\n```\n\n---\n\n### 9. Integration test gaps (no per-function test currently exercises the seams between modules)\n\n```python\n# tests/test_integration.py\nimport httpx\nimport pytest\nimport respx\nimport yaml\nimport pipeline\n\n\nclass TestEndToEndPipeline:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_fetch_filter_dedup_notify_roundtrip(self, tmp_path):\n        respx.get(\"https://boards-api.greenhouse.io/v1/boards/acme/jobs\").mock(\n            return_value=httpx.Response(200, json={\"jobs\": [\n                {\"id\": 1, \"title\": \"Senior Backend Engineer\",\n                 \"absolute_url\": \"https://x/1\", \"location\": {\"name\": \"Remote\"}}]}))\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(yaml.dump({\n            \"sources\": [{\"ats\": \"greenhouse\", \"company\": \"acme\"}],\n            \"filters\": {\"include_keywords\": [\"engineer\"]},\n            \"db\": str(tmp_path / \"jobs.db\"),\n        }))\n        result = await pipeline.run(cfg, dry_run=False)\n        assert result == {\"matched\": 1, \"new\": 1, \"changed\": 0}\n\n        # second run: same listing, no notification-worthy change\n        result2 = await pipeline.run(cfg, dry_run=False)\n        assert result2 == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_filters_exclude_listing_before_it_ever_hits_store(self, tmp_path):\n        respx.get(\"https://boards-api.greenhouse.io/v1/boards/acme/jobs\").mock(\n            return_value=httpx.Response(200, json={\"