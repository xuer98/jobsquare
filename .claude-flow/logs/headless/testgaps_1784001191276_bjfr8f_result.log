        "content": "from datetime import datetime, timedelta, timezone\nimport pytest\nfrom models import Job\nfrom filters import match, filter_jobs\n\n\ndef _job(title=\"Senior Engineer\", location=\"Remote - USA\", department=\"\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=title, url=\"https://x/1\", location=location, department=department)\n\n\nclass TestMatch:\n    def test_no_filters_passes(self):\n        assert match(_job()) is True\n\n    def test_exclude_wins_over_include(self):\n        j = _job(title=\"Senior Sales Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"sales\"]) is False\n\n    def test_include_keyword_required(self):\n        assert match(_job(title=\"Product Manager\"), include=[\"engineer\"]) is False\n\n    def test_include_word_boundary_no_partial_match(self):\n        # \"eng\" should not match inside \"Engineering\" due to \\b\\bEND\n        assert match(_job(title=\"Engineering Lead\"), include=[\"eng\"]) is False\n\n    def test_location_substring_case_insensitive(self):\n        assert match(_job(location=\"San Francisco, CA\"), locations=[\"san francisco\"]) is True\n\n    def test_location_no_match_excluded(self):\n        assert match(_job(location=\"London, UK\"), locations=[\"USA\"]) is False\n\n    def test_recency_cutoff_drops_old_job(self):\n        j = _job()\n        j.posted_at = (datetime.now(timezone.utc) - timedelta(days=30)).isoformat()\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(j, cutoff=cutoff) is False\n\n    def test_recency_cutoff_keeps_unparseable_posted_at(self):\n        j = _job()\n        j.posted_at = \"Posted 3 Days Ago\"  # Workday prose, unparseable\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(j, cutoff=cutoff) is True  # must not be nuked\n\n\nclass TestFilterJobs:\n    def test_max_age_days_filters_list(self):\n        fresh = _job(title=\"A\")\n        stale = _job(title=\"B\")\n        stale.posted_at = (datetime.now(timezone.utc) - timedelta(days=100)).isoformat()\n        result = filter_jobs([fresh, stale], {\"max_age_days\": 7})\n        assert stale not in result\n\n    def test_no_rules_returns_all(self):\n        jobs = [_job(title=\"A\"), _job(title=\"B\")]\n        assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n",
