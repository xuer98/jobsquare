 = agent.cmd_db_mark([\"not-a-date\", \"-c\", str(sources_yaml)])\n        assert rc == 2\n\n    def test_now_flag_sets_current_timestamp(self, sources_yaml):\n        rc = agent.cmd_db_mark([\"--now\", \"-c\", str(sources_yaml)])\n        assert rc == 0\n        with Store(agent.load_config(sources_yaml)[\"db\"]) as s:\n            assert s.get_meta(agent.MARK_KEY) is not None\n\n    def test_no_args_returns_error(self, sources_yaml):\n        rc = agent.cmd_db_mark([\"-c\", str(sources_yaml)])\n        assert rc == 2\n\n\nclass TestNormalizeAts:\n    def test_smart_quotes_replaced_in_text(self):\n        html, counts = agent._normalize_ats(\"<p>\\u201cHello\\u201d</p>\")\n        assert html == '<p>\"Hello\"</p>'\n        assert counts[\"smart-double-quote\"] == 2\n\n    def test_tag_attributes_untouched(self):\n        html, _ = agent._normalize_ats('<div data-x=\"\\u2014\">text</div>')\n        assert 'data-x=\"\\u2014\"' in html  # inside a tag, must not be replaced\n\n    def test_style_block_content_untouched(self):\n        html, counts = agent._normalize_ats(\n            \"<style>.x::before{content:'\\u2014'}</style><p>a\\u2014b</p>\")\n        assert \"content:'\\u2014'\" in html  # style block preserved verbatim\n        assert counts.get(\"em-dash\") == 1  # only the <p> occurrence counted\n\n    def test_no_replacements_needed_empty_counts(self):\n        html, counts = agent._normalize_ats(\"<p>plain ascii text</p>\")\n        assert counts == {}\n\n\nclass TestCmdPdfRender:\n    def test_missing_input_file_returns_2(self, tmp_path, capsys):\n        rc = agent.cmd_pdf_render([str(tmp_path / \"nope.html\")])\n        assert rc == 2\n\n    def test_failed_render_detected_by_missing_pdf_magic(self, tmp_path, monkeypatch):\n        src = tmp_path / \"in.html\"\n        src.write_text(\"<html><body>x</body></html>\")\n        monkeypatch.setattr(agent, \"_chrome_bin\", lambda: \"/bin/true\")\n        class FakeResult:\n            stderr = \"chrome crashed\"\n        monkeypatch.setattr(agent.subprocess, \"run\", lambda *a, **k: FakeResult())\n        rc = agent.cmd_pdf_render([str(src)])\n        assert rc == 1  # out file never written -> no %PDF magic bytes"
