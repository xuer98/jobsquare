:\n        jobs = [_job(title=f\"Job {i}\") for i in range(12)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+4 more\" in body\n        assert body.count(\"\\n- \") == 8\n\n    def test_no_suffix_when_under_limit(self):\n        jobs = [_job(title=\"Job 1\")]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"more\" not in body\n\n\nclass TestDispatch:\n    def test_one_notifier_failure_does_not_block_others(self, monkeypatch, capsys):\n        def boom(new, changed):\n            raise RuntimeError(\"slack is down\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [notify.notify_console, boom])\n        notify.dispatch([_job()], [])  # must not raise\n        out = capsys.readouterr().out\n        assert \"NEW listing\" in out  # console still ran"
