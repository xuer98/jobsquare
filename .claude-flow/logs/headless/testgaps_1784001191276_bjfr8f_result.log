ct_ds1(\"<html>no data here</html>\") == []\n\n    def test_malformed_json_in_blob_returns_empty(self):\n        html = \"key: 'ds:1', ..., data:[not valid json], sideChannel\"\n        assert _extract_ds1(html) == []\n\n    def test_valid_blob_extracted(self):\n        html = \"key: 'ds:1', data:[[{\\\"a\\\":1}]], sideChannel:{}\"\n        # exercise both regex branches (primary + fallback)\n\n\nclass TestDs1PostedAt:\n    def test_no_timestamp_indices_returns_empty(self):\n        assert _ds1_posted_at([1, 2, 3]) == \"\"\n\n    def test_prefers_index_12_over_13_14(self):\n        job = [None] * 15\n        job[12] = [1700000000]\n        job[13] = [1600000000]\n        assert \"2023\" in _ds1_posted_at(job)  # index 12 wins\n\n\nclass TestParseDeshaw:\n    def test_dedupes_repeated_job_ids(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">SWE</span>'\n                '<span class=\"location\">NYC</span></div>' * 2)  # rendered twice\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert len(jobs) == 1\n\n    def test_html_entities_unescaped_in_title(self):\n        page = '<div data-job-id=\"1\"><span class=\"job-display-name\">R&amp;D Engineer</span></div>'\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert jobs[0].title == \"R&D Engineer\"\n\n\nclass TestParseTwosigma:\n    def test_dedupes_triplicated_cards(self):\n        # per the comment: each role renders 3x in layout variants\n        ...\n\n\nclass TestAmazonPostedAt:\n    def test_valid_us_date_format(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_invalid_format_returns_empty(self):\n        assert _amazon_posted_at(\"garbage\") == \"\"\n\n    def test_unknown_month_returns_empty(self):\n        assert _amazon_posted_at(\"Frobtember 1, 2026\") == \"\"\n\n\nclass TestParseMeta:\n    def test_dedupes_by_id(self):\n        results = [{\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"1\", \"title\": \"A dup\"}]\n        assert len(parse_meta(\"meta\", results)) == 1\n\n    def test_missing_id_skipped(self):\n        assert parse_meta(\"meta\", [{\"title\": \"no id\"}]) == []"
