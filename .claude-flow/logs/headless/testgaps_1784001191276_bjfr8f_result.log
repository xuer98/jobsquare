        "content": "import sqlite3\nimport pytest\nfrom store import Store\nfrom models import Job\n\n\ndef _job(ext_id=\"1\", title=\"Engineer\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id,\n               title=title, url=f\"https://x/{ext_id}\")\n\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\n\nclass TestDiff:\n    def test_new_job_returned_and_inserted(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and not changed\n        assert store.count() == 1\n\n    def test_unchanged_job_not_in_either_list(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert not new and not changed\n        assert store.count() == 1  # no duplicate row\n\n    def test_changed_content_updates_row_not_insert(self, store):\n        store.diff([_job(title=\"Engineer I\")])\n        new, changed = store.diff([_job(title=\"Engineer II\")])\n        assert not new\n        assert len(changed) == 1\n        assert store.count() == 1\n\n    def test_last_seen_bumps_on_rerun(self, store):\n        store.diff([_job()])\n        row1 = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        store.diff([_job()])\n        row2 = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        assert row2[\"last_seen\"] >= row1[\"last_seen\"]\n\n\nclass TestMigration:\n    def test_adds_salary_range_column_to_legacy_db(self, tmp_path):\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(str(path))\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n            CREATE TABLE meta (k TEXT PRIMARY KEY, v TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n\n        with Store(path) as s:\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\n\nclass TestMeta:\n    def test_set_meta_upserts_not_duplicates(self, store):\n        store.set_meta(\"last_scan\", \"2024-01-01T00:00:00+00:00\")\n        store.set_meta(\"last_scan\", \"2024-02-01T00:00:00+00:00\")\n        assert store.get_meta(\"last_scan\") == \"2024-02-01T00:00:00+00:00\"\n        n = store.conn.execute(\"SELECT COUNT(*) FROM meta WHERE k='last_scan'\").fetchone()[0]\n        assert n == 1\n\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n\nclass TestAddedSince:\n    def test_strict_greater_than_excludes_boundary(self, store):\n        store.diff([_job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[\"first_seen\"]\n        assert store.added_since(ts) == []  # boundary itself excluded\n\n    def test_ordering_oldest_first(self, store):\n        store.diff([_job(\"1\"), _job(\"2\")])\n        rows = store.added_since(\"2000-01-01T00:00:00+00:00\")\n        assert [r[\"first_seen\"] for r in rows] == sorted(r[\"first_seen\"] for r in rows)\n```\n\n---\n\n",
