        "content": "import httpx\nimport pytest\nimport respx\nfrom fetchers import fetch_optiver, fetch_workday, fetch_meta, fetch_all\n\n\nclass TestFetchOptiverPagination:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_stops_when_no_fresh_items(self):\n        respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n            side_effect=[\n                httpx.Response(200, json={\"items\": [{\"href\": \"/join-us/jobs/a\", \"title\": \"A\"}]}),\n                httpx.Response(200, json={\"items\": []}),\n            ])\n        jobs = await fetch_optiver(httpx.AsyncClient(), {\"company\": \"optiver\"})\n        assert len(jobs) == 1\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_respects_max_pages_cap(self):\n        respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n            return_value=httpx.Response(200, json={\"items\": [\n                {\"href\": \"/join-us/jobs/x\", \"title\": \"same-every-page\"}]}))\n        jobs = await fetch_optiver(httpx.AsyncClient(),\n                                    {\"company\": \"optiver\", \"max_pages\": 2})\n        # same id every page -> \"fresh\" empty after page 1, loop should stop early\n        assert len(jobs) <= 1\n\n\nclass TestFetchWorkday:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_stops_at_total(self):\n        respx.post(url__regex=r\".*/wday/cxs/.*/jobs\").mock(\n            return_value=httpx.Response(200, json={\n                \"jobPostings\": [{\"title\": \"A\", \"bulletFields\": [\"R123\"]}], \"total\": 1}))\n        jobs = await fetch_workday(httpx.AsyncClient(),\n                                    {\"host\": \"x.wd5.myworkdayjobs.com\", \"tenant\": \"x\", \"site\": \"S\"})\n        assert len(jobs) == 1\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_safety_cap_at_5000_offset(self):\n        # server claims total=999999 and never stops -> loop must bail at offset>5000\n        respx.post(url__regex=r\".*/wday/cxs/.*/jobs\").mock(\n            return_value=httpx.Response(200, json={\n                \"jobPostings\": [{\"title\": \"A\", \"bulletFields\": [\"R1\"]}], \"total\": 999999}))\n        jobs = await fetch_workday(httpx.AsyncClient(),\n                                    {\"host\": \"x.wd5.myworkdayjobs.com\", \"tenant\": \"x\",\n                                     \"site\": \"S\", \"page_size\": 1000})\n        assert len(jobs) <= 6  # bounded by the 5000-offset safety cap, not \"total\"\n\n\nclass TestFetchMeta:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_stale_doc_id_raises_with_message(self):\n        respx.get(\"https://www.metacareers.com/jobs\").mock(\n            return_value=httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok\"}]'))\n        respx.post(\"https://www.metacareers.com/graphql\").mock(\n            return_value=httpx.Response(200, text='for (;;);{\"errors\":[{\"message\":\"doc_id invalid\"}]}'))\n        with pytest.raises(RuntimeError, match=\"doc_id invalid\"):\n            await fetch_meta(httpx.AsyncClient(), {\"company\": \"meta\"})\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_xssi_prefix_stripped(self):\n        respx.get(\"https://www.metacareers.com/jobs\").mock(\n            return_value=httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok\"}]'))\n        respx.post(\"https://www.metacareers.com/graphql\").mock(\n            return_value=httpx.Response(200, text=(\n                'for (;;);{\"data\":{\"job_search_with_featured_jobs_v2\":'\n                '{\"all_jobs\":[{\"id\":\"1\",\"title\":\"SWE\"}]}}}')))\n        jobs = await fetch_meta(httpx.AsyncClient(), {\"company\": \"meta\"})\n        assert jobs[0].external_id == \"1\"\n\n\nclass TestFetchAll:\n    @pytest.mark.asyncio\n    async def test_one_source_failure_does_not_abort_others(self, monkeypatch):\n        async def ok(client, src): return [object()]\n        async def fail(client, src): raise RuntimeError(\"boom\")\n        monkeypatch.setattr(\"fetchers.FETCHERS\", {\"ok\": ok, \"fail\": fail})\n        jobs = await fetch_all([{\"ats\": \"ok\"}, {\"ats\": \"fail\"}])\n        assert len(jobs) == 1  # the failing source is logged, not fatal\n\n    @pytest.mark.asyncio\n    async def test_unknown_ats_raises_valueerror(self):\n        from fetchers import fetch_source\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            await fetch_source(httpx.AsyncClient(), {\"ats\": \"carrier-pigeon\"})\n```\n\n---\n\n",
