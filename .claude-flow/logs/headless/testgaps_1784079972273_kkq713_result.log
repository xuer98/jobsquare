        "title": "3. `filters.py` (54 lines, 0% covered)",
        "content": "\n**`match`** — word-boundary regex behavior, exclude-precedence-over-include, cutoff with unparseable dates.\n```python\nfrom filters import match, filter_jobs\nfrom models import Job\nfrom datetime import datetime, timedelta, timezone\n\ndef _job(title=\"Software Engineer\", dept=\"\", loc=\"\", posted=\"\"):\n    return Job(source=\"x\", company=\"c\", external_id=\"1\", title=title, url=\"u\",\n               department=dept, location=loc, posted_at=posted)\n\ndef test_match_include_keyword_hits_word_boundary_not_substring():\n    # \"eng\" should not match \"engineering\" as substring — \\b enforces whole word\n    assert match(_job(title=\"Engineering Manager\"), include=[\"eng\"]) is False\n    assert match(_job(title=\"Eng Lead\"), include=[\"eng\"]) is True\n\ndef test_match_exclude_takes_precedence_over_include():\n    j = _job(title=\"Senior Recruiter Engineer\")\n    assert match(j, include=[\"engineer\"], exclude=[\"recruiter\"]) is False\n\ndef test_match_locations_case_insensitive_substring():\n    assert match(_job(loc=\"San Francisco, CA\"), locations=[\"san francisco\"]) is True\n\ndef test_match_cutoff_drops_old_confirmed_date():\n    old = _job(posted=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n    cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n    assert match(old, cutoff=cutoff) is False\n\ndef test_match_cutoff_keeps_unparseable_posted_at():\n    # explicit design choice per comment: don't nuke jobs whose date we can't parse\n    j = _job(posted=\"Posted Recently\")\n    cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n    assert match(j, cutoff=cutoff) is True\n\ndef test_match_no_rules_matches_everything():\n    assert match(_job()) is True\n\ndef test_filter_jobs_max_age_days_builds_cutoff():\n    old = _job(posted=(datetime.now(timezone.utc) - timedelta(days=100)).isoformat())\n    new = _job(posted=datetime.now(timezone.utc).isoformat())\n    result = filter_jobs([old, new], {\"max_age_days\": 10})\n    assert result == [new]\n\ndef test_filter_jobs_empty_rules_returns_all():\n    jobs = [_job(), _job(title=\"Other\")]\n    assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n",
