h = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(\"sources: []\\n\")\n    cfg = load_config(cfg_path)\n    assert cfg[\"db\"] == \"jobs.db\"\n    assert cfg[\"concurrency\"] == 8\n    assert cfg[\"filters\"] == {}\n\ndef test_load_config_preserves_explicit_values(tmp_path):\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(\"sources: []\\ndb: custom.db\\nconcurrency: 3\\n\")\n    cfg = load_config(cfg_path)\n    assert cfg[\"db\"] == \"custom.db\"\n    assert cfg[\"concurrency\"] == 3\n\n@pytest.mark.asyncio\nasync def test_run_dry_run_does_not_touch_store(tmp_path, monkeypatch):\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(f\"sources: []\\ndb: {tmp_path/'j.db'}\\n\")\n    monkeypatch.setattr(\"pipeline.fetch_all\", lambda *a, **k: _async_return([]))\n    result = await run(cfg_path, dry_run=True)\n    assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n    assert not (tmp_path / \"j.db\").exists()  # dry-run must not create/persist state\n\n@pytest.mark.asyncio\nasync def test_run_full_pipeline_persists_and_dispatches(tmp_path, monkeypatch):\n    # end-to-end: fetch -> filter -> store.diff -> dispatch, with fetch_all and\n    # notify.dispatch monkeypatched — verifies the wiring, not each stage's logic\n    ...\n\ndef _async_return(v):\n    async def f(*a, **k): return v\n    return f()\n```\n\n**Integration gap:** there is no test exercising the full `run()` orchestration (fetch → filter → dedup → notify) even with fakes/mocks at the seams. This is the one function that ties every other module together and is entirely unverified.\n\n---\n\n### 6. `notify.py` (109 lines, 0% covered)\n\n**Env-var gating** — each notifier's \"activate only if env var(s) set\" branch is untested, as is `dispatch`'s per-notifier exception isolation.\n\n```python\nimport notify\nfrom models import Job\nimport httpx\n\ndef _job():\n    return Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"SWE\", url=\"u\")\n\ndef test_notify_slack_noop_without_env_var(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify.notify_slack([_job()], [])\n    assert calls == []\n\ndef test_notify_slack_noop_when_no_jobs(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hook\")\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify.notify_slack([], [])\n    assert calls == []\n\ndef test_notify_slack_posts_when_configured(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hook\")\n    captured = {}\n    def fake_post(url, json, timeout):\n        captured[\"json\"] = json\n    monkeypatch.setattr(httpx, \"post\", fake_post)\n    notify.notify_slack([_job()], [])\n    assert \"1 new job(s)\" in captured[\"json\"][\"text\"]\n\ndef test_notify_sms_requires_all_four_twilio_vars(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n    monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify.notify_sms([_job()], [])\n    assert calls == []  # partial config must not fire\n\ndef test_notify_sms_raises_on_http_error(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"s\")\n    monkeypatch.setenv(\"TWILIO_AUTH_TOKEN\", \"t\")\n    monkeypatch.setenv(\"TWILIO_FROM\", \"+1\")\n    monkeypatch.setenv(\"TWILIO_TO\", \"+2\")\n    def fake_post(*a, **k):\n        r = httpx.Response(400, request=httpx.Request(\"POST\", \"https://x\"))\n        return r\n    monkeypatch.setattr(httpx, \"post\", fake_post)\n    import pytest\n    with pytest.raises(httpx.HTTPStatusError):\n        notify.notify_sms([_job()], [])\n\ndef test_sms_body_truncates_and_counts_remainder():\n    jobs = [_job() for _ in range(12)]\n    body = notify._sms_body(jobs, [], limit=8)\n    assert \"+4 more\" in body\n\ndef test_dispatch_continues_after_one_notifier_raises(monkeypatch, capsys):\n    def boom(new, changed): raise RuntimeError(\"smtp down\")\n    monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, notify.notify_console])\n    notify.dispatch([], [])  # must not raise, must print the failure\n    out = capsys.readouterr().out\n    assert \"notifier boom failed\" in out\n\ndef test_notify_console_prints_no_fresh_listings_when_empty(capsys):\n    notify.notify_console([], [])\n    assert \"No fresh listings\" in capsys.readouterr().out\n```\n\n**Missing entirely:** `notify_email` (SMTP flow — `smtplib.SMTP` context manager, `starttls`, conditional `login`) has zero test coverage and is the most complex notifier to get wrong (e.g., silently not logging in if `SMTP_USER` unset but `SMTP_PASS` is — that mismatch would currently raise `KeyError` uncaught inside `dispatch`'s try/except, silently swallowed).\n\n```python\ndef test_notify_email_smtp_user_without_pass_raises_keyerror_swallowed_by_dispatch(monkeypatch, capsys):\n    monkeypatch.setenv(\"SMTP_HOST\", \"smtp.x\")\n    monkeypatch.setenv(\"EMAIL_TO\", \"a@b.com\")\n    monkeypatch.setenv(\"SMTP_USER\", \"user\")\n    monkeypatch.delenv(\"SMTP_PASS\", raising=False)\n    # SMTP_USER set but SMTP_PASS missing -> os.environ[\"SMTP_PASS\"] KeyError\n    # exercised through dispatch() to confirm it's caught, not through direct call\n    ...\n```\n\n---\n\n### 7. `cli.py` (18 lines, 0% covered)\n\n```python\nimport cli\n\ndef test_main_invokes_run_sync_with_parsed_args(monkeypatch):\n    captured = {}\n    monkeypatch.setattr(\"cli.run_sync\", lambda path, dry_run: captured.update(path=path, dry_run=dry_run))\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\", \"-c\", \"custom.yaml\", \"--dry-run\"])\n    cli.main()\n    assert captured == {\"path\": \"custom.yaml\", \"dry_run\": True}\n\ndef test_main_defaults_config_path(monkeypatch):\n    captured = {}\n    monkeypatch.setattr(\"cli.run_sync\", lambda path, dry_run: captured.update(path=path))\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\"])\n    cli.main()\n    assert captured[\"path\"] == \"sources.yaml\"\n```\n\n---\n\n### 8. `agent.py` (289 lines, 0% covered)\n\n**`cmd_db_new`** — the groupby/truncation logic is the trickiest part of the whole codebase (explicit comment about not splitting a `first_seen` group) and has zero coverage.\n```python\ndef test_db_new_first_run_uses_since_days_window(tmp_path, capsys, monkeypatch):\n    # no marker set yet -> first_run True, since = now - since_days\n    ...\n\ndef test_db_new_never_advances_marker(tmp_path):\n    # confirm get_meta(MARK_KEY) unchanged after cmd_db_new call\n    ...\n\ndef test_db_new_truncates_at_group_boundary_not_mid_group(tmp_path):\n    # two first_seen groups where group 2 alone exceeds --limit:\n    # jobs list must include group 1 fully and stop before group 2 entirely,\n    # watermark must equal group 1's ts, truncated must be True\n    ...\n\ndef test_db_new_keeps_oversized_first_group_even_over_limit(tmp_path):\n    # if jobs is still empty and the very first group already exceeds limit,\n    # current code appends it anyway (jobs and ... guard) -- verify that's intentional\n    ...\n```\n\n**`cmd_db_mark`**\n```python\ndef test_db_mark_rejects_non_iso_watermark(capsys):\n    rc = cmd_db_mark([\"not-a-date\"])\n    assert rc == 2\n\ndef test_db_mark_requires_watermark_or_now(capsys):\n    assert cmd_db_mark([]) == 2\n\ndef test_db_mark_now_sets_current_timestamp(tmp_path):\n    ...\n```\n\n**`_normalize_ats`** — regex-based HTML normalization with a \"never touch tags/style/script\" invariant; no test confirms that invariant holds.\n```python\nfrom agent import _normalize_ats\n\ndef test_normalize_ats_replaces_smart_quotes_in_body_text():\n    html, counts = _normalize_ats(\"<p>\\u201cHello\\u201d</p>\")\n    assert html == '<p>\"Hello\"</p>'\n    assert counts[\"smart-double-quote\"] == 2\n\ndef test_normalize_ats_does_not_touch_style_block_contents():\n    html, counts = _normalize_ats('<style>.x::before{content:\"\\u2014\"}</style><p>\\u2014</p>')\n    assert '\\u2014' in html  # inside <style>, untouched\n    assert counts[\"em-dash\"] == 1  # only the <p> occurrence counted\n\ndef test_normalize_ats_does_not_touch_attribute_values():\n    html, counts = _normalize_ats('<a title=\"caf\\u00e9\\u2014bar\">x</a>')\n    assert 'title=\"caf\\u00e9\\u2014bar\"' in html  # tag attrs untouched\n    assert \"em-dash\" not in counts\n\ndef test_normalize_ats_no_replacements_needed_returns_empty_counts():\n    html, counts = _normalize_ats(\"<p>plain ascii</p>\")\n    assert counts == {}\n```\n\n**`_chrome_bin`** — discovery order (env var → PATH → hardcoded macOS paths → `sys.exit`) untested.\n```python\ndef test_chrome_bin_prefers_env_var(monkeypatch, tmp_path):\n    fake = tmp_path / \"chrome\"\n    fake.write_text(\"\")\n    monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n    assert agent._chrome_bin() == str(fake)\n\ndef test_chrome_bin_exits_when_nothing_found(monkeypatch):\n    monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n    monkeypatch.setattr(\"shutil.which\", lambda name: None)\n    monkeypatch.setattr(\"pathlib.Path.exists\", lambda self: False)\n    with pytest.raises(SystemExit):\n        agent._chrome_bin()\n```\n\n**`cmd_pdf_render`** — currently untestable without a real Chrome binary; needs `subprocess.run` mocked.\n```python\ndef test_pdf_render_missing_input_file_returns_2(tmp_path):\n    rc = cmd_pdf_render([str(tmp_path / \"missing.html\")])\n    assert rc == 2\n\ndef test_pdf_render_fails_cleanly_when_output_not_valid_pdf(tmp_path, monkeypatch):\n    src = tmp_path / \"in.html\"; src.write_text(\"<html></html>\")\n    monkeypatch.setattr(\"agent._chrome_bin\", lambda: \"/bin/true\")\n    monkeypatch.setattr(\"subprocess.run\", lambda *a, **k: type(\"R\", (), {\"stderr\": \"\", \"returncode\": 0})())\n    rc = cmd_pdf_render([str(src)])\n    assert rc == 1  # no %PDF magic bytes written -> failure path\n```\n\n**`main()` argument routing** — mode-word vs. flag-passthrough split logic (`mode_words, extra = words[:i], words[i:]`) has no test.\n```python\ndef test_main_routes_db_new_subcommand(monkeypatch):\n    called = {}\n    monkeypatch.setattr(\"agent.cmd_db_new\", lambda argv: called.setdefault(\"argv\", argv) or 0)\n    monkeypatch.setattr(\"sys.argv\", [\"agent.py\", \"db-new\", \"--limit\", \"5\"])\n    assert agent.main() == 0\n    assert called[\"argv\"] == [\"--limit\", \"5\"]\n\ndef test_main_splits_mode_words_from_flags(monkeypatch):\n    captured = {}\n    monkeypatch.setattr(\"agent.run_claude\", lambda mw, i, e: captured.update(mw=mw, extra=e) or 0)\n    monkeypatch.setattr(\"sys.argv\", [\"agent.py\", \"scan\", \"--foo\", \"bar\"])\n    agent.main()\n    assert captured[\"mw\"] == [\"scan\"]\n    assert captured[\"extra\"] == [\"--foo\", \"bar\"]\n\ndef test_main_bare_invocation_is_interactive(monkeypatch):\n    captured = {}\n    monkeypatch.setattr(\"agent.run_claude\", lambda mw, i, e: captured.update(interactive=i) or 0)\n    monkeypatch.setattr(\"sys.argv\", [\"agent.py\"])\n    agent.main()\n    assert captured[\"interactive\"] is True\n```\n\n---\n\n### Summary table\n\n| Module | Lines | Tests | Priority gaps |\n|---|---|---|---|\n| `fetchers.py` | 787 | 0 | Retry/backoff, all 15 `parse_*` normalizers, pagination termination, Meta token/error handling, `fetch_all` failure isolation |\n| `agent.py` | 289 | 0 | `cmd_db_new` group-truncation boundary logic, `_normalize_ats` tag/attr invariant, CLI routing |\n| `notify.py` | 109 | 0 | Env-var gating per notifier, `dispatch` error isolation, SMTP auth edge case |\n| `store.py` | 121 | 0 | `diff` new/changed/unchanged branches, additive migration on legacy schema, `added_since` boundary |\n| `models.py` | 75 | 0 | `parse_posted_at`'s three source formats, hash stability vs. key stability |\n| `pipeline.py` | 52 | 0 | Full orchestration integration test, config defaulting |\n| `filters.py` | 54 | 0 | Word-boundary matching, exclude precedence, cutoff with unparseable dates |\n| `cli.py` | 18 | 0 | Arg parsing → `run_sync` wiring |\n\n**Biggest structural gap:** there is no integration test anywhere that exercises `pipeline.run()` end-to-end (even with fakes at the network/notify boundary), so a wiring regression between fetch → filter → store → notify would currently be invisible until it hits production. Recommend adding `tests/test_pipeline_integration.py` as described in §5 as the first test written, since it's the one place that would catch cross-module breakage that unit tests on individual modules can't.\n",
