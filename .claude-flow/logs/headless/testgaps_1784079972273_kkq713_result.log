        "content": "\n**`parse_posted_at`** — the docstring itself enumerates three incompatible source formats; none are tested.\n```python\nfrom models import parse_posted_at, Job\n\ndef test_parse_posted_at_empty_returns_none():\n    assert parse_posted_at(\"\") is None\n    assert parse_posted_at(None) is None\n\ndef test_parse_posted_at_epoch_milliseconds():\n    dt = parse_posted_at(\"1643241332430\")\n    assert dt.year == 2022\n\ndef test_parse_posted_at_epoch_seconds():\n    dt = parse_posted_at(\"1643241332\")\n    assert dt.year == 2022\n\ndef test_parse_posted_at_negative_epoch():\n    # s.lstrip(\"-\").isdigit() branch — currently untested, verify it doesn't crash\n    assert parse_posted_at(\"-5\") is not None\n\ndef test_parse_posted_at_iso8601_with_z_suffix():\n    dt = parse_posted_at(\"2026-01-01T00:00:00Z\")\n    assert dt.tzinfo is not None\n\ndef test_parse_posted_at_iso8601_naive_gets_utc():\n    dt = parse_posted_at(\"2026-01-01T00:00:00\")\n    assert dt.tzinfo is not None\n\ndef test_parse_posted_at_unparseable_prose_returns_none():\n    # Workday sends \"Posted 3 Days Ago\" — must not raise\n    assert parse_posted_at(\"Posted 3 Days Ago\") is None\n```\n\n**`Job.key` / `Job.content_hash` / `Job.to_row`**\n```python\ndef _job(**over):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"SWE\", url=\"https://x/1\")\n    return Job(**{**base, **over})\n\ndef test_job_key_is_stable_identity():\n    assert _job().key == \"greenhouse:acme:1\"\n\ndef test_content_hash_changes_on_title_change_but_not_id():\n    j1, j2 = _job(), _job(title=\"Senior SWE\")\n    assert j1.content_hash != j2.content_hash\n    assert j1.key == j2.key\n\ndef test_content_hash_stable_for_identical_material_fields():\n    assert _job().content_hash == _job().content_hash\n\ndef test_to_row_excludes_raw_and_includes_derived_fields():\n    row = _job(raw={\"secret\": \"blob\"}).to_row()\n    assert \"raw\" not in row\n    assert row[\"key\"] == \"greenhouse:acme:1\"\n    assert \"content_hash\" in row\n```\n\n---\n\n",
