        "content": "\n**Env-var gating** — each notifier's \"activate only if env var(s) set\" branch is untested, as is `dispatch`'s per-notifier exception isolation.\n\n```python\nimport notify\nfrom models import Job\nimport httpx\n\ndef _job():\n    return Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"SWE\", url=\"u\")\n\ndef test_notify_slack_noop_without_env_var(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify.notify_slack([_job()], [])\n    assert calls == []\n\ndef test_notify_slack_noop_when_no_jobs(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hook\")\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify.notify_slack([], [])\n    assert calls == []\n\ndef test_notify_slack_posts_when_configured(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hook\")\n    captured = {}\n    def fake_post(url, json, timeout):\n        captured[\"json\"] = json\n    monkeypatch.setattr(httpx, \"post\", fake_post)\n    notify.notify_slack([_job()], [])\n    assert \"1 new job(s)\" in captured[\"json\"][\"text\"]\n\ndef test_notify_sms_requires_all_four_twilio_vars(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n    monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify.notify_sms([_job()], [])\n    assert calls == []  # partial config must not fire\n\ndef test_notify_sms_raises_on_http_error(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"s\")\n    monkeypatch.setenv(\"TWILIO_AUTH_TOKEN\", \"t\")\n    monkeypatch.setenv(\"TWILIO_FROM\", \"+1\")\n    monkeypatch.setenv(\"TWILIO_TO\", \"+2\")\n    def fake_post(*a, **k):\n        r = httpx.Response(400, request=httpx.Request(\"POST\", \"https://x\"))