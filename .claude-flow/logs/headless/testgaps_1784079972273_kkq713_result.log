        "title": "1. `fetchers.py` (787 lines, 0% covered) — highest risk, highest complexity",
        "content": "\n**Untested: `_request` retry/backoff logic**\nGaps: retryable status codes (429/500/502/503/504) vs. non-retryable (404/401), exhausting all retries, transport errors (`httpx.ConnectError`), success on a later attempt, backoff timing not blocking tests.\n\n```python\nimport httpx\nimport pytest\nfrom fetchers import _request\n\n@pytest.mark.asyncio\nasync def test_request_retries_on_503_then_succeeds(monkeypatch):\n    calls = {\"n\": 0}\n    async def handler(request):\n        calls[\"n\"] += 1\n        if calls[\"n\"] < 3:\n            return httpx.Response(503)\n        return httpx.Response(200, json={\"ok\": True})\n    monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)  # skip backoff delay\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    r = await _request(client, \"https://x/test\")\n    assert r.status_code == 200\n    assert calls[\"n\"] == 3\n\n@pytest.mark.asyncio\nasync def test_request_raises_after_exhausting_retries(monkeypatch):\n    async def handler(request):\n        return httpx.Response(500)\n    monkeypatch.setattr(\"asyncio.sleep\", lambda *_: None)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n        await _request(client, \"https://x/test\", retries=2)\n\n@pytest.mark.asyncio\nasync def test_request_does_not_retry_on_404(monkeypatch):\n    calls = {\"n\": 0}\n    async def handler(request):\n        calls[\"n\"] += 1\n        return httpx.Response(404)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    with pytest.raises(RuntimeError):\n        await _request(client, \"https://x/test\")\n    assert calls[\"n\"] == 1  # 404 isn't in the retryable set — should fail fast\n```\n\n**Untested: every `parse_*` normalizer** (greenhouse, lever, ashby, smartrecruiters, recruitee, workable, google, deshaw, twosigma, optiver, workday, meta, microsoft, netflix, amazon)\nThese are pure functions — the docstring explicitly says they're meant to be unit-tested against fixture payloads without network. None are tested. Key edge cases per fetcher:\n\n```python\nfrom fetchers import parse_greenhouse, parse_lever, _lever_salary, parse_amazon, _amazon_posted_at\n\ndef test_parse_greenhouse_maps_fields():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"https://x/1\",\n                       \"location\": {\"name\": \"Remote\"}, \"departments\": [{\"name\": \"Eng\"}],\n                       \"updated_at\": \"2026-01-01T00:00:00Z\"}]}\n    jobs = parse_greenhouse(\"acme\", data)\n    assert jobs[0].key == \"greenhouse:acme:1\"\n    assert jobs[0].department == \"Eng\"\n\ndef test_parse_greenhouse_empty_jobs_list():\n    assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\ndef test_parse_greenhouse_missing_location_key():\n    # location can be None in the payload, not just absent\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\", \"location\": None}]}\n    assert parse_greenhouse(\"acme\", data)[0].location == \"\"\n\ndef test_lever_salary_formats_range_with_currency():\n    j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n    assert _lever_salary(j) == \"USD 100,000–150,000\"\n\ndef test_lever_salary_falls_back_to_plain_description():\n    j = {\"salaryDescriptionPlain\": \"Competitive\"}\n    assert _lever_salary(j) == \"Competitive\"\n\ndef test_lever_salary_no_data_returns_empty():\n    assert _lever_salary({}) == \"\"\n\ndef test_amazon_posted_at_parses_us_date():\n    assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\ndef test_amazon_posted_at_handles_garbage():\n    assert _amazon_posted_at(\"not a date\") == \"\"\n    assert _amazon_posted_at(\"\") == \"\"\n```\n\nNotably absent test scenarios worth calling out explicitly per bespoke fetcher:\n- `parse_google` / `_extract_ds1`: malformed `ds:1` blob, missing `sideChannel` fallback regex, empty `data[0]`, `json.JSONDecodeError` path — **zero coverage of the regex fallback branch**.\n- `parse_deshaw`: dedup via `seen` set (duplicate `data-job-id`), missing title/id (skip), missing href fallback URL.\n- `parse_twosigma`: triplicate-card dedup, location lookup window bounded by next anchor vs. end-of-page (`m.end() + 800`) fallback.\n- `parse_optiver`: `href.removeprefix(\"join-us/jobs/\")` normalization, relative vs. absolute href.\n- `_ds1_posted_at`: index-out-of-range guards (job array shorter than expected), all three fallback indices (12/13/14) missing.\n- `_amazon_posted_at`: `ValueError` from malformed strings AND `KeyError` from unrecognized month names — both caught by the same except, but only one is currently exercised even informally.\n\n**Untested: paginating fetchers' loop-termination conditions** (`fetch_google`, `fetch_twosigma`, `fetch_optiver`, `fetch_microsoft`, `fetch_netflix`, `fetch_amazon`, `fetch_workday`)\nThese all have \"stop when a page returns nothing new\" logic plus a `max_pages` safety cap — the most bug-prone part of the file (off-by-one on `offset`, infinite loop if server never returns empty). None tested.\n\n```python\n@pytest.mark.asyncio\nasync def test_fetch_optiver_stops_when_page_returns_no_items():\n    calls = {\"n\": 0}\n    async def handler(request):\n        calls[\"n\"] += 1\n        items = [{\"title\": \"A\", \"href\": \"/join-us/jobs/a\"}] if calls[\"n\"] == 1 else []\n        return httpx.Response(200, json={\"items\": items})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetch_optiver(client, {\"company\": \"optiver\"})\n    assert len(jobs) == 1\n    assert calls[\"n\"] == 2  # one real page + one empty page to confirm stop\n\n@pytest.mark.asyncio\nasync def test_fetch_optiver_respects_max_pages_cap():\n    # server keeps returning fresh items forever — must not loop past max_pages\n    async def handler(request):\n        n = int(request.url.params.get(\"from\", 0))\n        return httpx.Response(200, json={\"items\": [{\"title\": f\"J{n}\", \"href\": f\"/join-us/jobs/{n}\"}]})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetch_optiver(client, {\"company\": \"optiver\", \"max_pages\": 3})\n    assert len(jobs) == 3\n\n@pytest.mark.asyncio\nasync def test_fetch_workday_stops_at_total_and_at_safety_cap():\n    # verify offset >= total termination, and the offset > 5000 safety cap separately\n    ...\n```\n\n**Untested: `fetch_meta`'s token scraping**\n`lsd`/`__spin_*` token extraction via regex against the HTML page, the `\"for (;;);\"` XSSI-prefix strip, and the `data.get(\"errors\")` → `RuntimeError` path when Meta rotates `doc_id` (this is explicitly called out in a comment as the most likely real-world failure mode, and has no test).\n\n```python\n@pytest.mark.asyncio\nasync def test_fetch_meta_strips_xssi_prefix_and_parses(monkeypatch):\n    async def handler(request):\n        if request.url.path == \"/jobs\":\n            return httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok123\"}]\"__spin_r\":42')\n        return httpx.Response(200, text='for (;;);{\"data\":{\"job_search_with_featured_jobs_v2\":'\n                                         '{\"all_jobs\":[{\"id\":\"1\",\"title\":\"SWE\",\"locations\":[\"Remote\"],\"teams\":[]}]}}}')\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetch_meta(client, {\"company\": \"meta\"})\n    assert jobs[0].external_id == \"1\"\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_raises_on_graphql_error_payload(monkeypatch):\n    # simulates a rotated doc_id — must surface as RuntimeError, not silently return []\n    async def handler(request):\n        if request.url.path == \"/jobs\":\n            return httpx.Response(200, text=\"\")\n        return httpx.Response(200, text='{\"errors\":[{\"message\":\"Unknown doc_id\"}]}')\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    with pytest.raises(RuntimeError, match=\"Unknown doc_id\"):\n        await fetch_meta(client, {\"company\": \"meta\"})\n```\n\n**Untested: `fetch_source` / `fetch_all`**\n- Unknown ATS → `ValueError` (message content, sorted key list).\n- `fetch_all`'s per-source exception isolation — one failing source must not abort the batch (this \"keep the run alive\" behavior is core to reliability and completely unverified).\n- Semaphore concurrency bound actually enforced.\n\n```python\n@pytest.mark.asyncio\nasync def test_fetch_all_isolates_single_source_failure(monkeypatch):\n    async def ok(client, source): return [Job(source=\"x\", company=\"ok\", external_id=\"1\", title=\"t\", url=\"u\")]\n    async def boom(client, source): raise RuntimeError(\"network down\")\n    monkeypatch.setitem(fetchers.FETCHERS, \"ok_ats\", ok)\n    monkeypatch.setitem(fetchers.FETCHERS, \"bad_ats\", boom)\n    jobs = await fetch_all([{\"ats\": \"ok_ats\"}, {\"ats\": \"bad_ats\"}])\n    assert len(jobs) == 1  # the failing source is dropped, not fatal\n\ndef test_fetch_source_unknown_ats_raises():\n    with pytest.raises(ValueError, match=\"unknown ATS\"):\n        asyncio.run(fetch_source(None, {\"ats\": \"not-a-real-ats\"}))\n```\n\n---\n\n",
