        "title": "4. `store.py` (121 lines, 0% covered) — needs a real sqlite fixture, no mocking needed",
        "content": "\n```python\nimport pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"test.db\")\n    yield s\n    s.close()\n\ndef _job(ext_id=\"1\", title=\"SWE\", loc=\"Remote\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id,\n               title=title, url=\"u\", location=loc)\n\ndef test_diff_new_job_returns_in_new_not_changed(store):\n    new, changed = store.diff([_job()])\n    assert len(new) == 1 and changed == []\n    assert store.count() == 1\n\ndef test_diff_unchanged_job_returns_neither(store):\n    store.diff([_job()])\n    new, changed = store.diff([_job()])\n    assert new == [] and changed == []\n\ndef test_diff_material_change_returns_in_changed(store):\n    store.diff([_job(title=\"SWE\")])\n    new, changed = store.diff([_job(title=\"Senior SWE\")])\n    assert new == []\n    assert len(changed) == 1\n\ndef test_diff_updates_last_seen_on_reseen_unchanged_job(store):\n    store.diff([_job()])\n    before = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()[\"last_seen\"]\n    import time; time.sleep(1.1)\n    store.diff([_job()])\n    after = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()[\"last_seen\"]\n    assert after >= before\n\ndef test_diff_empty_list_is_noop(store):\n    assert store.diff([]) == ([], [])\n\ndef test_meta_roundtrip(store):\n    assert store.get_meta(\"missing\") is None\n    store.set_meta(\"last_scan\", \"2026-01-01T00:00:00+00:00\")\n    assert store.get_meta(\"last_scan\") == \"2026-01-01T00:00:00+00:00\"\n\ndef test_set_meta_upserts_existing_key(store):\n    store.set_meta(\"k\", \"v1\")\n    store.set_meta(\"k\", \"v2\")\n    assert store.get_meta(\"k\") == \"v2\"\n\ndef test_added_since_excludes_boundary_timestamp(store):\n    # \">\" not \">=\" — first_seen equal to ts must be excluded\n    store.diff([_job()])\n    ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[\"first_seen\"]\n    assert store.added_since(ts) == []\n\ndef test_added_since_orders_by_first_seen_then_company_then_title(store):\n    ...\n\ndef test_migrate_adds_salary_range_to_legacy_schema(tmp_path):\n    # simulate a pre-salary_range DB and confirm _migrate adds the column without data loss\n    import sqlite3\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n        external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n        employment_type TEXT, posted_at TEXT, content_hash TEXT,\n        first_seen TEXT, last_seen TEXT)\"\"\")\n    conn.execute(\"INSERT INTO jobs VALUES ('k','s','c','1','t','u','l','d','e','p','h','f','l')\")\n    conn.commit(); conn.close()\n    s = Store(path)\n    cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n    assert \"salary_range\" in cols\n    assert s.count() == 1  # existing row survived\n\ndef test_context_manager_closes_connection(tmp_path):\n    with Store(tmp_path / \"t.db\") as s:\n        pass\n    with pytest.raises(Exception):\n        s.conn.execute(\"SELECT 1\")\n```\n\n**Highest-value gap here:** the `_migrate` additive-migration path is a real-world footgun — an existing `jobs.db` (there's one checked into the repo root!) created before `salary_range` existed must upgrade cleanly. This has no coverage at all.\n\n---\n\n",
