      {
        "title": "tests/test_fetchers_parsers.py",
        "content": "from fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       parse_amazon, _amazon_posted_at, parse_deshaw,\n                       _apple_hydration, _apple_posted_at, _extract_ds1, parse_google)\n\nclass TestParseGreenhouse:\n    def test_maps_fields_and_joins_multiple_departments(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\",\n                           \"location\": {\"name\": \"Remote\"},\n                           \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Platform\"}],\n                           \"updated_at\": \"2024-01-01\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].department == \"Eng, Platform\"\n\n    def test_missing_location_key_defaults_empty(self):\n        jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1, \"title\": \"x\", \"absolute_url\": \"u\"}]})\n        assert jobs[0].location == \"\"\n\n\nclass TestLeverSalary:\n    def test_full_range_formats_with_thousands_separator(self):\n        j = {\"salaryRange\": {\"min\": 150000, \"max\": 200000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 150,000–200,000\"\n\n    def test_falls_back_to_plain_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_data_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestParseAshby:\n    def test_unlisted_jobs_are_filtered_out(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"hidden\"}]}\n        assert parse_ashby(\"acme\", data) == []\n\n    def test_id_falls_back_to_jobid(self):\n        data = {\"jobs\": [{\"jobId\": \"abc\", \"title\": \"x\"}]}\n        assert parse_ashby(\"acme\", data)[0].external_id == \"abc\"\n\n\nclass TestAmazonPostedAt:\n    def test_parses_us_format_date(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_string_returns_empty(self):\n        assert _amazon_posted_at(\"garbage\") == \"\"\n\n    def test_unknown_month_name_returns_empty(self):\n        assert _amazon_posted_at(\"Junee 26, 2026\") == \"\"\n\n\nclass TestParseDeshaw:\n    def test_extracts_cards_and_dedupes_repeated_ids(self):\n        html = '''\n        <div data-job-id=\"100\"><span class=\"job-display-name\">SWE</span>\n        <span class=\"location\">NYC</span></div>\n        <div data-job-id=\"100\"><span class=\"job-display-name\">SWE</span></div>\n        '''\n        jobs = parse_deshaw(\"deshaw\", html)\n        assert len(jobs) == 1\n\n    def test_html_entities_are_unescaped_in_title(self):\n        html = '<div data-job-id=\"1\"><span class=\"job-display-name\">R&amp;D Eng</span></div>'\n        assert parse_deshaw(\"deshaw\", html)[0].title == \"R&D Eng\"\n\n\nclass TestAppleHydration:\n    def test_extracts_escaped_json_string(self):\n        html = 'window.__staticRouterHydrationData = JSON.parse(\"{\\\\\"a\\\\\":1}\");'\n        assert _apple_hydration(html) == {\"a\": 1}\n\n    def test_missing_marker_returns_none(self):\n        assert _apple_hydration(\"<html></html>\") is None\n\n    def test_apple_posted_at_truncates_nanoseconds(self):\n        assert _apple_posted_at(\"2024-01-15T10:00:03.812668311Z\") == \\\n            \"2024-01-15T10:00:03.812668+00:00\"\n\n    def test_apple_posted_at_no_fraction(self):\n        assert _apple_posted_at(\"2024-01-15T10:00:03Z\") == \"2024-01-15T10:00:03+00:00\"\n\n\nclass TestGoogleDs1:\n    def test_extracts_data_before_sidechannel(self):\n        html = \"key: 'ds:1', ..., data:[[[\\\"1\\\",\\\"Title\\\"]]], sideChannel:{}})\"\n        assert _extract_ds1(html) == [[\"1\", \"Title\"]]\n\n    def test_malformed_json_returns_empty_list(self):\n        html = \"key: 'ds:1', data:[not valid json], sideChannel:{}\"\n        assert _extract_ds1(html) == []\n\n    def test_parse_google_skips_falsy_job_entries(self):\n        assert parse_google(\"google\", [None, [\"\"]]) == []\n```\n\n**Remaining `parse_*`/`fetch_*` functions still needing dedicated tests** (each is currently 0% covered):\n\n| Function | Key edge case to assert |\n|---|---|\n| `parse_smartrecruiters` | location string assembled from city/region/country with `None`s filtered |\n| `parse_recruitee` | flat `location` string vs assembled from city/country |\n| `parse_workable` | dict-vs-string `location` shape branch |\n| `parse_twosigma` | dedupe of the documented \"each role renders 3x\"; location lookup bounded to the next anchor |\n| `fetch_twosigma`/`fetch_optiver`/`fetch_eightfold`/`fetch_amazon`/`fetch_netflix`/`fetch_microsoft` | pagination stop condition (empty `fresh` list breaks loop); `seen` set prevents duplicate ids across pages |\n| `parse_eightfold` | `location` singular vs `locations` list fallback |\n| `_bd_location` | walks `parent` chain to root; `en_name` vs `name` fallback |\n| `parse_bytedance`/`fetch_bytedance` | per-site body/header differences (bytedance vs tiktok); stop when `len(jobs) >= count` |\n| `parse_phenom`/`fetch_phenom` | `jobId` vs `jobSeqNo` fallback; stop at `totalHits` |\n| `fetch_workday` | safety cap `offset > 5000`; `bulletFields[0]` fallback to `externalPath` when empty |\n| `parse_meta`/`fetch_meta` | dedupes by id; `\"for (;;);\"` prefix stripped before JSON parse; `data.get(\"errors\")` raises `RuntimeError` (rotated `doc_id` case — this is the exact failure mode noted in your [[meta-careers-fetcher]] memory) |\n| `parse_microsoft` | `postedTs` missing → empty `posted_at`; `standardizedLocations` vs `locations` fallback |\n| `parse_netflix` | `t_create` vs `t_update` fallback; comma-to-comma-space location reformatting |\n| `fetch_ashby` | 200 → posting-api path; 404 → HTML fallback; other 4xx/5xx → raises; fallback with no `__appData` → `RuntimeError` |\n| `fetch_source` | unknown `ats` raises `ValueError` listing known ATS names |\n| `fetch_all` | one source raising doesn't kill `gather`; semaphore actually bounds concurrency (assert via a counter fixture); injected `client` is *not* closed by `fetch_all` (only self-owned clients are) |\n\n---\n\n",
