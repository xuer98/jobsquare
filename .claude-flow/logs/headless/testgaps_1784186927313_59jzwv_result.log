").fetchone()[0]\n        assert first == after\n\n    def test_empty_list_is_noop(self, store):\n        assert store.diff([]) == ([], [])\n\n\nclass TestMeta:\n    def test_get_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_roundtrip(self, store):\n        store.set_meta(\"k\", \"v1\")\n        assert store.get_meta(\"k\") == \"v1\"\n\n    def test_set_meta_upserts(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n\nclass TestNextSeq:\n    def test_increments_from_one(self, store):\n        assert store.next_seq(\"report_seq\") == 1\n        assert store.next_seq(\"report_seq\") == 2\n\n    def test_independent_counters(self, store):\n        assert store.next_seq(\"a\") == 1\n        assert store.next_seq(\"b\") == 1\n\n\nclass TestAddedSince:\n    def test_strictly_after_excludes_exact_match(self, store):\n        store.diff([_job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n        assert store.added_since(ts) == []\n\n    def test_ordered_by_first_seen_company_title(self, store):\n        store.diff([_job(ext_id=\"2\", title=\"B Role\")])\n        store.diff([_job(ext_id=\"1\", title=\"A Role\")])\n        rows = store.added_since(\"2000-01-01T00:00:00\")\n        assert [r[\"title\"] for r in rows] == [\"B Role\", \"A Role\"]\n\n\nclass TestMigration:\n    def test_migrate_adds_salary_range_to_legacy_schema(self, tmp_path):\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(path)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n              external_id TEXT, title TEXT, url TEXT, location TEXT,\n              department TEXT, employment_type TEXT, posted_at TEXT,\n              content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        s = Store(path)  # should not raise\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n        s.close()\n```\n\n*Integration gap:* no test exercises `next_seq`'s claimed atomicity under real concurrent writers (the docstring explicitly calls out \"parallel pipeline workers\"). Worth a `ThreadPoolExecutor`-based test hitting the same DB file from N threads and asserting the returned sequence is a permutation of `1..N` with no duplicates.\n\n---\n\n## P1 — `notify.py`\n\n**Gaps:** every notifier's env-var gating, `dispatch`'s per-notifier exception isolation, `_sms_body` truncation.\n\n```python\n# tests/test_notify.py\nimport pytest\nimport respx\nimport httpx\nfrom models import Job\nimport notify\n\ndef _job(**kw):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Engineer\",\n               url=\"https://x\", **kw)\n\nclass TestNotifySlack:\n    def test_noop_without_env_var(self, monkeypatch, respx_mock):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        notify.notify_slack([_job()], [])\n        assert not respx_mock.calls  # no HTTP call made\n\n    def test_noop_with_no_jobs_even_if_configured(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n        notify.notify_slack([], [])  # respx not needed; httpx.post should not fire\n\n    @respx.mock\n    def test_posts_when_configured_and_has_new(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n        route = respx.post(\"https://hooks.slack.com/x\").mock(\n            return_value=httpx.Response(200))\n        notify.notify_slack([_job()], [])\n        assert route.called\n\n\nclass TestNotifySms:\n    def test_requires_all_four_twilio_vars(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        notify.notify_sms([_job()], [])  # missing token -> no-op, no crash\n\n    def test_sms_body_truncates_at_limit_and_shows_remainder(self):\n        jobs = [_job(title=f\"Role {i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n        assert body.count(\"- Role\") == 8\n\n    @respx.mock\n    def test_raises_on_bad_twilio_response(self, monkeypatch):\n        for k, v in dict(TWILIO_ACCOUNT_SID=\"sid\", TWILIO_AUTH_TOKEN=\"tok\",\n                          TWILIO_FROM=\"+1\", TWILIO_TO=\"+2\").items():\n            monkeypatch.setenv(k, v)\n        respx.post(url__regex=r\".*Messages\\.json\").mock(\n            return_value=httpx.Response(401))\n        with pytest.raises(httpx.HTTPStatusError):\n            notify.notify_sms([_job()], [])\n\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch, capsys):\n        def boom(new, changed): raise RuntimeError(\"smtp down\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, notify.notify_console])\n        notify.dispatch([_job()], [])  # must not raise\n        assert \"notifier boom failed\" in capsys.readouterr().out\n```\n\n*Untested entirely:* `notify_webhook`, `notify_email` (SMTP mocking via `unittest.mock.patch(\"smtplib.SMTP\")`, verifying `login()` is only called when `SMTP_USER` is set).\n\n---\n\n## P1 — `fetchers.py` (biggest surface, highest bug density — regex/HTML scraping for 6 bespoke sites)\n\n**Shared retry/HTTP layer — test this first, it underlies every fetcher:**\n\n```python\n# tests/test_fetchers_request.py\nimport httpx, pytest, respx\nfrom fetchers import _request\n\nclass TestRequestRetry:\n    @respx.mock\n    async def test_retries_on_503_then_succeeds(self):\n        route = respx.get(\"https://x\").mock(side_effect=[\n            httpx.Response(503), httpx.Response(200, json={\"ok\": True})])\n        async with httpx.AsyncClient() as c:\n            r = await _request(c, \"https://x\", retries=3)\n        assert r.status_code == 200 and route.call_count == 2\n\n    @respx.mock\n    async def test_exhausts_retries_raises_runtime_error(self):\n        respx.get(\"https://x\").mock(return_value=httpx.Response(500))\n        async with httpx.AsyncClient() as c:\n            with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n                await _request(c, \"https://x\", retries=2)\n\n    @respx.mock\n    async def test_404_is_retried_pointlessly_then_raises(self):\n        # GAP/edge case: raise_for_status() on a 404 raises HTTPStatusError,\n        # which the except clause catches generically alongside the retryable\n        # 429/5xx set — a permanent 404 gets retried `retries` times before\n        # failing instead of failing fast. Assert current behavior so a fix\n        # doesn't regress silently, and flag as a possible efficiency bug.\n        route = respx.get(\"https://x\").mock(return_value=httpx.Response(404))\n        async with httpx.AsyncClient() as c:\n            with pytest.raises(RuntimeError):\n                await _request(c, \"https://x\", retries=2)\n        assert route.call_count == 2\n```\n\n**`_balanced_json` — pure string scanner, easy to unit test in isolation:**\n\n```python\n# tests/test_fetchers_balanced_json.py\nfrom fetchers import _balanced_json\n\ndef test_simple_object():\n    assert _balanced_json('{\"a\": 1}', 0) == '{\"a\": 1}'\n\ndef test_nested_braces():\n    text = '{\"a\": {\"b\": 1}}extra'\n    assert _balanced_json(text, 0) == '{\"a\": {\"b\": 1}}'\n\ndef test_brace_inside_string_is_ignored():\n    text = '{\"a\": \"}\"}tail'\n    assert _balanced_json(text, 0) == '{\"a\": \"}\"}'\n\ndef test_escaped_quote_inside_string():\n    text = r'{\"a\": \"\\\"\"}' + \"tail\"\n    assert _balanced_json(text, 0) == r'{\"a\": \"\\\"\"}'\n\ndef test_unbalanced_returns_none():\n    assert _balanced_json('{\"a\": 1', 0) is None\n```\n\n**Parser normalization — representative tests per distinct pattern.** Every `parse_*` needs the same treatment; below covers the shapes (simple dict, list, HTML regex-scrape, GraphQL/token, date-string normalization). The remaining parsers are listed after with the specific edge case each needs.\n\n```python\n# tests/test_fetchers_parsers.py\nfrom fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       parse_amazon, _amazon_posted_at, parse_deshaw,\n                       _apple_hydration, _apple_posted_at, _extract_ds1, parse_google)\n\nclass TestParseGreenhouse:\n    def test_maps_fields_and_joins_multiple_departments(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\",\n                           \"location\": {\"name\": \"Remote\"},\n                           \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Platform\"}],\n                           \"updated_at\": \"2024-01-01\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].department == \"Eng, Platform\"\n\n    def test_missing_location_key_defaults_empty(self):\n        jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1, \"title\": \"x\", \"absolute_url\": \"u\"}]})\n        assert jobs[0].location == \"\"\n\n\nclass TestLeverSalary:\n    def test_full_range_formats_with_thousands_separator(self):\n        j = {\"salaryRange\": {\"min\": 150000, \"max\": 200000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 150,000–200,000\"\n\n    def test_falls_back_to_plain_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_data_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestParseAshby:\n    def test_unlisted_jobs_are_filtered_out(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"hidden\"}]}\n        assert parse_ashby(\"acme\", data) == []\n\n    def test_id_falls_back_to_jobid(self):\n        data = {\"jobs\": [{\"jobId\": \"abc\", \"title\": \"x\"}]}\n        assert parse_ashby(\"acme\", data)[0].external_id == \"abc\"\n\n\nclass TestAmazonPostedAt:\n    def test_parses_us_format_date(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_string_returns_empty(self):\n        assert _amazon_posted_at(\"garbage\") == \"\"\n\n    def test_unknown_month_name_returns_empty(self):\n        assert _amazon_posted_at(\"Junee 26, 2026\") == \"\"\n\n\nclass TestParseDeshaw:\n    def test_extracts_cards_and_dedupes_repeated_ids(self):\n        html = '''\n        <div data-job-id=\"100\"><span class=\"job-display-name\">SWE</span>\n        <span class=\"location\">NYC</span></div>\n        <div data-job-id=\"100\"><span class=\"job-display-name\">SWE</span></div>\n        '''\n        jobs = parse_deshaw(\"deshaw\", html)\n        assert len(jobs) == 1\n\n    def test_html_entities_are_unescaped_in_title(self):\n        html = '<div data-job-id=\"1\"><span class=\"job-display-name\">R&amp;D Eng</span></div>'\n        assert parse_deshaw(\"deshaw\", html)[0].title == \"R&D Eng\"\n\n\nclass TestAppleHydration:\n    def test_extracts_escaped_json_string(self):\n        html = 'window.__staticRouterHydrationData = JSON.parse(\"{\\\\\"a\\\\\":1}\");'\n        assert _apple_hydration(html) == {\"a\": 1}\n\n    def test_missing_marker_returns_none(self):\n        assert _apple_hydration(\"<html></html>\") is None\n\n    def test_apple_posted_at_truncates_nanoseconds(self):\n        assert _apple_posted_at(\"2024-01-15T10:00:03.812668311Z\") == \\\n            \"2024-01-15T10:00:03.812668+00:00\"\n\n    def test_apple_posted_at_no_fraction(self):\n        assert _apple_posted_at(\"2024-01-15T10:00:03Z\") == \"2024-01-15T10:00:03+00:00\"\n\n\nclass TestGoogleDs1:\n    def test_extracts_data_before_sidechannel(self):\n        html = \"key: 'ds:1', ..., data:[[[\\\"1\\\",\\\"Title\\\"]]], sideChannel:{}})\"\n        assert _extract_ds1(html) == [[\"1\", \"Title\"]]\n\n    def test_malformed_json_returns_empty_list(self):\n        html = \"key: 'ds:1', data:[not valid json], sideChannel:{}\"\n        assert _extract_ds1(html) == []\n\n    def test_parse_google_skips_falsy_job_entries(self):\n        assert parse_google(\"google\", [None, [\"\"]]) == []\n```\n\n**Remaining `parse_*`/`fetch_*` functions still needing dedicated tests** (each is currently 0% covered):\n\n| Function | Key edge case to assert |\n|---|---|\n| `parse_smartrecruiters` | location string assembled from city/region/country with `None`s filtered |\n| `parse_recruitee` | flat `location` string vs assembled from city/country |\n| `parse_workable` | dict-vs-string `location` shape branch |\n| `parse_twosigma` | dedupe of the documented \"each role renders 3x\"; location lookup bounded to the next anchor |\n| `fetch_twosigma`/`fetch_optiver`/`fetch_eightfold`/`fetch_amazon`/`fetch_netflix`/`fetch_microsoft` | pagination stop condition (empty `fresh` list breaks loop); `seen` set prevents duplicate ids across pages |\n| `parse_eightfold` | `location` singular vs `locations` list fallback |\n| `_bd_location` | walks `parent` chain to root; `en_name` vs `name` fallback |\n| `parse_bytedance`/`fetch_bytedance` | per-site body/header differences (bytedance vs tiktok); stop when `len(jobs) >= count` |\n| `parse_phenom`/`fetch_phenom` | `jobId` vs `jobSeqNo` fallback; stop at `totalHits` |\n| `fetch_workday` | safety cap `offset > 5000`; `bulletFields[0]` fallback to `externalPath` when empty |\n| `parse_meta`/`fetch_meta` | dedupes by id; `\"for (;;);\"` prefix stripped before JSON parse; `data.get(\"errors\")` raises `RuntimeError` (rotated `doc_id` case — this is the exact failure mode noted in your [[meta-careers-fetcher]] memory) |\n| `parse_microsoft` | `postedTs` missing → empty `posted_at`; `standardizedLocations` vs `locations` fallback |\n| `parse_netflix