        "code": "# tests/test_filters.py\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(title=\"Backend Engineer\", dept=\"\", loc=\"Remote\", posted_at=\"\"):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=title,\n               url=\"u\", department=dept, location=loc, posted_at=posted_at)\n\nclass TestMatch:\n    def test_exclude_wins_even_if_include_also_matches(self):\n        j = _job(title=\"Senior Staff Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"staff\"]) is False\n\n    def test_include_keyword_with_regex_special_chars_does_not_crash(self):\n        j = _job(title=\"C++ Developer\")\n        assert match(j, include=[\"C++\"]) is True\n\n    def test_include_requires_word_boundary_not_substring(self):\n        j = _job(title=\"Engineering Manager\")\n        assert match(j, include=[\"eng\"]) is False  # \"eng\" alone shouldn't match \"Engineering\"\n\n    def test_case_insensitive(self):\n        assert match(_job(title=\"ENGINEER\"), include=[\"engineer\"]) is True\n\n    def test_location_substring_case_insensitive(self):\n        assert match(_job(loc=\"San Francisco, CA\"), locations=[\"san francisco\"]) is True\n\n    def test_location_no_match_excludes(self):\n        assert match(_job(loc=\"London\"), locations=[\"new york\"]) is False\n\n    def test_cutoff_drops_older_confirmed_dates(self):\n        old = _job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n        assert match(old, cutoff=datetime.now(timezone.utc) - timedelta(days=7)) is False\n\n    def test_cutoff_keeps_jobs_with_unparseable_dates(self):\n        j = _job(posted_at=\"Posted 30 Days Ago\")  # can't parse -> kept, not nuked\n        assert match(j, cutoff=datetime.now(timezone.utc)) is True\n\n    def test_no_filters_passes_everything(self):\n        assert match(_job()) is True\n\n\nclass TestFilterJobs:\n    def test_max_age_days_zero_is_falsy_and_disables_cutoff(self):\n        # rules.get(\"max_age_days\") -> 0 is falsy in `if max_age:`, so an\n        # explicit \"0 days\" setting silently becomes \"no age filter\" —\n        # verify current behavior and flag if this surprises callers.\n        old = _job(posted_at=\"2000-01-01T00:00:00+00:00\")\n        result = filter_jobs([old], {\"max_age_days\": 0})\n        assert result == [old]\n\n    def test_combines_include_exclude_location(self):\n        jobs = [_job(title=\"Backend Engineer\", loc=\"Remote\"),\n                _job(title=\"Sales Rep\", loc=\"Remote\")]\n        result = filter_jobs(jobs, {\"include_keywords\": [\"engineer\"]})\n        assert len(result) == 1"
