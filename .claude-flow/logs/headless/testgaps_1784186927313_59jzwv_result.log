        "language": "python",
        "code": "# tests/test_models.py\nfrom datetime import datetime, timezone\nimport pytest\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_and_none_return_none(self):\n        assert parse_posted_at(\"\") is None\n        assert parse_posted_at(None) is None\n\n    def test_milliseconds_epoch_lever_style(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt == datetime.fromtimestamp(1643241332.430, tz=timezone.utc)\n\n    def test_seconds_epoch(self):\n        dt = parse_posted_at(\"1643241332\")\n        assert dt.year == 2022\n\n    def test_negative_epoch(self):\n        assert parse_posted_at(\"-100\") is not None  # pre-1970, still parses\n\n    def test_iso8601_with_trailing_z(self):\n        assert parse_posted_at(\"2024-01-15T10:00:00Z\").tzinfo is not None\n\n    def test_iso8601_naive_assumed_utc(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_workday_prose_is_unparseable(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_decimal_string_falls_through_to_iso_and_fails(self):\n        assert parse_posted_at(\"12.5\") is None  # not .isdigit(), not valid ISO\n\n\nclass TestJob:\n    def _job(self, **kw):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                    title=\"Engineer\", url=\"https://x/1\")\n        return Job(**{**base, **kw})\n\n    def test_key_is_stable_identity(self):\n        assert self._job().key == \"greenhouse:acme:1\"\n\n    def test_content_hash_ignores_posted_at_and_salary(self):\n        a = self._job(posted_at=\"2024-01-01\", salary_range=\"\")\n        b = self._job(posted_at=\"2025-06-01\", salary_range=\"150k-200k\")\n        assert a.content_hash == b.content_hash\n\n    def test_content_hash_changes_on_title_change(self):\n        a = self._job(title=\"Engineer\")\n        b = self._job(title=\"Senior Engineer\")\n        assert a.content_hash != b.content_hash\n\n    def test_posted_dt_delegates_to_parse_posted_at(self):\n        assert self._job(posted_at=\"\").posted_dt is None\n\n    def test_to_row_drops_raw_adds_key_and_hash(self):\n        row = self._job(raw={\"secret\": 1}).to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == \"greenhouse:acme:1\"\n        assert \"content_hash\" in row"
