\.json\").mock(\n            return_value=httpx.Response(401))\n        with pytest.raises(httpx.HTTPStatusError):\n            notify.notify_sms([_job()], [])\n\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch, capsys):\n        def boom(new, changed): raise RuntimeError(\"smtp down\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, notify.notify_console])\n        notify.dispatch([_job()], [])  # must not raise\n        assert \"notifier boom failed\" in capsys.readouterr().out"
