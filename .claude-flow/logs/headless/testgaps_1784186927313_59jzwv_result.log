        "title": "tests/test_pipeline.py",
        "content": "import pytest\nfrom unittest.mock import AsyncMock, patch\nimport pipeline\n\nclass TestLoadConfig:\n    def test_fills_in_defaults_for_missing_keys(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"sources: []\\n\")\n        cfg = pipeline.load_config(p)\n        assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\n    def test_explicit_values_are_not_overridden(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"sources: []\\nconcurrency: 2\\ndb: other.db\\n\")\n        cfg = pipeline.load_config(p)\n        assert cfg[\"concurrency\"] == 2 and cfg[\"db\"] == \"other.db\"\n\n\nclass TestRun:\n    async def test_dry_run_never_touches_store_or_notifies(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"sources: []\\n\")\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n             patch(\"pipeline.Store\") as MockStore, \\\n             patch(\"pipeline.dispatch\") as mock_dispatch:\n            result = await pipeline.run(p, dry_run=True)\n        MockStore.assert_not_called()\n        mock_dispatch.assert_not_called()\n        assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n\n    async def test_normal_run_persists_and_dispatches(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(f\"sources: []\\ndb: {tmp_path/'j.db'}\\n\")\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n             patch(\"pipeline.dispatch\") as mock_dispatch:\n            result = await pipeline.run(p)\n        assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n        mock_dispatch.assert_called_once()\n```\n\n*Fully untested integration path:* the real end-to-end `run()` against a live `Store` with actual `Job` objects flowing through `filter_jobs` → `store.diff` → `dispatch` — worth one test that patches only `fetch_all` and lets everything else run for real against a `tmp_path` DB.\n\n---\n\n",
