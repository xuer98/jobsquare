        "title": "tests/test_pipeline.py",
        "content": "import pytest\nfrom pipeline import load_config, run\n\ndef test_load_config_defaults(tmp_path):\n    cfg_file = tmp_path / \"cfg.yaml\"\n    cfg_file.write_text(\"sources: []\\n\")\n    cfg = load_config(cfg_file)\n    assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\n@pytest.mark.asyncio\nasync def test_run_dry_run_does_not_touch_store(tmp_path, monkeypatch):\n    cfg_file = tmp_path / \"cfg.yaml\"\n    cfg_file.write_text(f\"sources: []\\ndb: {tmp_path / 'jobs.db'}\\n\")\n    monkeypatch.setattr(\"pipeline.fetch_all\", lambda *a, **k: [])\n    result = await run(cfg_file, dry_run=True)\n    assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n    assert not (tmp_path / \"jobs.db\").exists()\n\n@pytest.mark.asyncio\nasync def test_run_persists_and_dispatches(tmp_path, monkeypatch):\n    from models import Job\n    j = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"Eng\", url=\"u\")\n    cfg_file = tmp_path / \"cfg.yaml\"\n    cfg_file.write_text(f\"sources: []\\ndb: {tmp_path / 'jobs.db'}\\n\")\n    monkeypatch.setattr(\"pipeline.fetch_all\", lambda *a, **k: [j])\n    dispatched = {}\n    monkeypatch.setattr(\"pipeline.dispatch\", lambda new, changed: dispatched.update(new=new))\n    result = await run(cfg_file, dry_run=False)\n    assert result[\"new\"] == 1 and dispatched[\"new\"] == [j]\n```\n\n```python\n",
