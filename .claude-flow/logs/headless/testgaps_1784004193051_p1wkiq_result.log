        "code": "# tests/test_agent.py\nimport pytest\nfrom agent import cmd_db_mark, cmd_db_new, _normalize_ats\nfrom store import Store\nfrom models import Job\n\nclass TestDbMark:\n    def test_rejects_non_iso_watermark(self, tmp_path, capsys):\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {tmp_path/'x.db'}\\n\")\n        rc = cmd_db_mark([\"not-a-date\", \"-c\", str(cfg)])\n        assert rc == 2\n        assert \"not an ISO timestamp\" in capsys.readouterr().err\n\n    def test_requires_watermark_or_now(self, tmp_path, capsys):\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {tmp_path/'x.db'}\\n\")\n        rc = cmd_db_mark([\"-c\", str(cfg)])\n        assert rc == 2\n\n    def test_now_flag_sets_current_timestamp(self, tmp_path):\n        cfg = tmp_path / \"sources.yaml\"\n        db_path = tmp_path / \"x.db\"\n        cfg.write_text(f\"db: {db_path}\\n\")\n        cmd_db_mark([\"--now\", \"-c\", str(cfg)])\n        with Store(db_path) as s:\n            assert s.get_meta(\"last_scan\") is not None\n\n\nclass TestDbNewTruncation:\n    def test_does_not_split_a_first_seen_group(self, tmp_path, capsys):\n        cfg = tmp_path / \"sources.yaml\"\n        db_path = tmp_path / \"x.db\"\n        cfg.write_text(f\"db: {db_path}\\n\")\n        with Store(db_path) as s:\n            jobs = [Job(source=\"s\", company=\"c\", external_id=str(i),\n                        title=f\"T{i}\", url=\"u\") for i in range(5)]\n            s.diff(jobs)  # all share one first_seen timestamp\n        import json\n        cmd_db_new([\"--limit\", \"3\", \"-c\", str(cfg), \"--since-days\", \"9999\"])\n        out = json.loads(capsys.readouterr().out)\n        # limit=3 but the whole group of 5 shares first_seen -> either all-or-none\n        assert out[\"count\"] in (0, 5)\n\n\nclass TestNormalizeAts:\n    def test_skips_style_block(self):\n        html = \"<style>content: '\\u2014';</style><p>text\\u2014here</p>\"\n        out, counts = _normalize_ats(html)\n        assert \"\\u2014\" not in out.split(\"</style>\")[1] or True\n        assert \"text-here\" in out  # body dash replaced\n        assert \"content: '\\u2014'\" in out  # style block untouched\n\n    def test_counts_by_label(self):\n        html = \"<p>a\\u2014b\\u2014c</p>\"\n        _, counts = _normalize_ats(html)\n        assert counts[\"em-dash\"] == 2\n\n    def test_skips_inside_tag_attributes(self):\n        html = '<a title=\"quo\\u201Cte\">text</a>'\n        out, _ = _normalize_ats(html)\n        assert '\\u201C' in out  # attribute untouched"
