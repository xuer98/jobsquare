        "code": "# tests/test_filters.py\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(title=\"Software Engineer\", dept=\"Eng\", loc=\"Remote\", posted_at=\"\"):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=title,\n                url=\"u\", department=dept, location=loc, posted_at=posted_at)\n\nclass TestMatch:\n    def test_no_rules_passes(self):\n        assert match(_job()) is True\n\n    def test_exclude_wins_over_include(self):\n        j = _job(title=\"Senior Manager Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"manager\"]) is False\n\n    def test_word_boundary_not_substring(self):\n        # \"go\" must not match inside \"Django\"\n        j = _job(title=\"Django Developer\")\n        assert match(j, include=[\"go\"]) is False\n\n    def test_include_case_insensitive(self):\n        j = _job(title=\"SOFTWARE ENGINEER\")\n        assert match(j, include=[\"software engineer\"]) is True\n\n    def test_location_substring_case_insensitive(self):\n        j = _job(loc=\"San Francisco, CA\")\n        assert match(j, locations=[\"san francisco\"]) is True\n\n    def test_location_no_match_excludes(self):\n        j = _job(loc=\"Austin, TX\")\n        assert match(j, locations=[\"san francisco\"]) is False\n\n    def test_cutoff_drops_older_job(self):\n        old = _job(posted_at=\"2020-01-01T00:00:00Z\")\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(old, cutoff=cutoff) is False\n\n    def test_cutoff_keeps_job_with_unparseable_date(self):\n        j = _job(posted_at=\"Posted 3 Days Ago\")  # workday prose, unparseable\n        cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n        assert match(j, cutoff=cutoff) is True  # documented \"don't nuke\" behavior\n\n    def test_cutoff_keeps_job_with_no_posted_at(self):\n        j = _job(posted_at=\"\")\n        cutoff = datetime.now(timezone.utc)\n        assert match(j, cutoff=cutoff) is True\n\n\nclass TestFilterJobs:\n    def test_max_age_days_builds_cutoff(self):\n        fresh = _job(posted_at=datetime.now(timezone.utc).isoformat())\n        stale = _job(posted_at=\"2020-01-01T00:00:00Z\")\n        result = filter_jobs([fresh, stale], {\"max_age_days\": 7})\n        assert fresh in result and stale not in result\n\n    def test_empty_rules_returns_all(self):\n        jobs = [_job(), _job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs"
