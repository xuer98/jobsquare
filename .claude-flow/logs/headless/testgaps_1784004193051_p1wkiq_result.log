ock\nfrom pipeline import load_config, run\nfrom models import Job\n\ndef test_load_config_fills_defaults(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(\"sources: []\\n\")\n    cfg = load_config(cfg_file)\n    assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\n@pytest.mark.asyncio\nasync def test_dry_run_does_not_touch_store_or_notify(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(f\"sources: []\\ndb: {tmp_path/'x.db'}\\n\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n         patch(\"pipeline.Store\") as MockStore, \\\n         patch(\"pipeline.dispatch\") as mock_dispatch:\n        result = await run(cfg_file, dry_run=True)\n        MockStore.assert_not_called()\n        mock_dispatch.assert_not_called()\n        assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n\n@pytest.mark.asyncio\nasync def test_full_run_dispatches_and_reports_counts(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(f\"sources: []\\ndb: {tmp_path/'x.db'}\\n\")\n    job = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[job])), \\\n         patch(\"pipeline.dispatch\") as mock_dispatch:\n        result = await run(cfg_file, dry_run=False)\n        mock_dispatch.assert_called_once()\n        assert result[\"new\"] == 1\n```\n\n---\n\n### 6. `notify.py` — zero coverage; the sensitive one is silent-failure behavior\n\n**Untested:** all 5 notifiers + `dispatch` + `_line`/`_sms_body`\n\n**Edge cases missed:**\n- Each channel notifier is a no-op when its env var(s) are unset (`notify_slack`/`notify_webhook`/`notify_email`/`notify_sms`)\n- Each channel notifier is a no-op when there's nothing to report (`new=[]`, `changed=[]`), **even if configured** — easy to break silently\n- `notify_sms` requires **all four** `TWILIO_*` vars; missing any one is a no-op\n- `notify_sms` calls `resp.raise_for_status()` — a Twilio 4xx must propagate (this is the one that's supposed to surface, per the comment)\n- `_sms_body` truncates at `limit` and appends a \"+N more\" line\n- `_sms_body` avoids non-ASCII chars (regression test: no `•`/`…` in output)\n- **`dispatch` isolates failures**: one notifier raising must not stop the others, and should print `! notifier <name> failed: ...`\n\n```python\n# tests/test_notify.py\nimport os\nimport pytest\nfrom unittest.mock import patch, MagicMock\nfrom models import Job\nfrom notify import (notify_slack, notify_webhook, notify_sms, _sms_body,\n                     dispatch, NOTIFIERS)\n\ndef _job(title=\"SWE\", company=\"acme\"):\n    return Job(source=\"s\", company=company, external_id=\"1\", title=title, url=\"u\")\n\nclass TestNotifySlack:\n    def test_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with patch(\"notify.httpx.post\") as mock_post:\n            notify_slack([_job()], [])\n            mock_post.assert_not_called()\n\n    def test_noop_when_nothing_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n        with patch(\"notify.httpx.post\") as mock_post:\n            notify_slack([], [])\n            mock_post.assert_not_called()\n\n    def test_posts_when_configured_and_new_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n        with patch(\"notify.httpx.post\") as mock_post:\n            notify_slack([_job()], [])\n            mock_post.assert_called_once()\n\n\nclass TestNotifySms:\n    def test_noop_missing_any_one_twilio_var(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.setenv(\"TWILIO_AUTH_TOKEN\", \"tok\")\n        monkeypatch.setenv(\"TWILIO_FROM\", \"+1\")\n        monkeypatch.delenv(\"TWILIO_TO\", raising=False)\n        with patch(\"notify.httpx.post\") as mock_post:\n            notify_sms([_job()], [])\n            mock_post.assert_not_called()\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        for k, v in {\"TWILIO_ACCOUNT_SID\": \"sid\", \"TWILIO_AUTH_TOKEN\": \"tok\",\n                     \"TWILIO_FROM\": \"+1\", \"TWILIO_TO\": \"+2\"}.items():\n            monkeypatch.setenv(k, v)\n        import httpx\n        fail_resp = MagicMock()\n        fail_resp.raise_for_status.side_effect = httpx.HTTPStatusError(\n            \"bad\", request=MagicMock(), response=MagicMock(status_code=400))\n        with patch(\"notify.httpx.post\", return_value=fail_resp):\n            with pytest.raises(httpx.HTTPStatusError):\n                notify_sms([_job()], [])\n\n\nclass TestSmsBody:\n    def test_truncates_at_limit_with_more_count(self):\n        jobs = [_job(title=f\"T{i}\") for i in range(10)]\n        body = _sms_body(jobs, [], limit=3)\n        assert \"+7 more\" in body\n        assert body.count(\"T\") <= 4  # 3 lines + possible substring in header\n\n    def test_ascii_only_no_bullet_or_ellipsis(self):\n        body = _sms_body([_job()], [])\n        assert \"•\" not in body and \"…\" not in body\n\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, capsys):\n        boom = MagicMock(side_effect=RuntimeError(\"boom\"), __name__=\"boom_notifier\")\n        ok = MagicMock(__name__=\"ok_notifier\")\n        with patch(\"notify.NOTIFIERS\", [boom, ok]):\n            dispatch([_job()], [])\n        ok.assert_called_once()\n        assert \"boom_notifier failed\" in capsys.readouterr().out\n```\n\n---\n\n### 7. `agent.py` — CLI/agent glue, zero coverage\n\n**Untested:** `cmd_db_new` (watermark truncation logic — the trickiest bit in this file), `cmd_db_mark`, `_normalize_ats`, `_chrome_bin`, `cmd_pdf_render`, `main` argv routing\n\n**Edge cases missed:**\n- `cmd_db_new` truncation: must break at `first_seen` **group boundaries**, never split a group even if it pushes past `--limit`\n- `cmd_db_new` first run (no marker) uses `since_days` window; subsequent runs use the marker\n- `cmd_db_mark` rejects a non-ISO watermark (exit code 2) unless `--now`\n- `cmd_db_mark` with neither `watermark` nor `--now` → exit code 2\n- `_normalize_ats`: replacements skip `<style>`/`<script>` blocks and skip inside tag attributes, only touch body text between tags\n- `_normalize_ats`: counts dict shape (aggregates by rule label)\n- `cmd_pdf_render`: missing input file → prints error, returns 2\n- `main()`: argv routing — `db-new`, `db-mark`, `pdf-render`, `-h/--help`, bare invocation (interactive), `<mode> [words]` pass-through, `-i` flag detection\n\n```python\n# tests/test_agent.py\nimport pytest\nfrom agent import cmd_db_mark, cmd_db_new, _normalize_ats\nfrom store import Store\nfrom models import Job\n\nclass TestDbMark:\n    def test_rejects_non_iso_watermark(self, tmp_path, capsys):\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {tmp_path/'x.db'}\\n\")\n        rc = cmd_db_mark([\"not-a-date\", \"-c\", str(cfg)])\n        assert rc == 2\n        assert \"not an ISO timestamp\" in capsys.readouterr().err\n\n    def test_requires_watermark_or_now(self, tmp_path, capsys):\n        cfg = tmp_path / \"sources.yaml\"\n        cfg.write_text(f\"db: {tmp_path/'x.db'}\\n\")\n        rc = cmd_db_mark([\"-c\", str(cfg)])\n        assert rc == 2\n\n    def test_now_flag_sets_current_timestamp(self, tmp_path):\n        cfg = tmp_path / \"sources.yaml\"\n        db_path = tmp_path / \"x.db\"\n        cfg.write_text(f\"db: {db_path}\\n\")\n        cmd_db_mark([\"--now\", \"-c\", str(cfg)])\n        with Store(db_path) as s:\n            assert s.get_meta(\"last_scan\") is not None\n\n\nclass TestDbNewTruncation:\n    def test_does_not_split_a_first_seen_group(self, tmp_path, capsys):\n        cfg = tmp_path / \"sources.yaml\"\n        db_path = tmp_path