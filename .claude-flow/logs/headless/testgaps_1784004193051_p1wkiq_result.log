        "code": "# tests/fetchers/test_async.py — network layer via respx / MockTransport\nimport httpx, pytest, respx\nfrom fetchers import _request, fetch_all, fetch_source, FETCHERS\n\n@pytest.mark.asyncio\nclass TestRequestRetry:\n    async def test_retries_on_503_then_succeeds(self):\n        route = respx.get(\"https://x/test\").mock(side_effect=[\n            httpx.Response(503), httpx.Response(200, json={\"jobs\": []})])\n        async with httpx.AsyncClient() as client:\n            with respx.mock:\n                respx.get(\"https://x/test\").mock(side_effect=[\n                    httpx.Response(503), httpx.Response(200, json={\"jobs\": []})])\n                r = await _request(client, \"https://x/test\", retries=2)\n                assert r.status_code == 200\n\n    async def test_exhausts_retries_raises_runtimeerror(self):\n        async with httpx.AsyncClient() as client:\n            with respx.mock:\n                respx.get(\"https://x/test\").mock(return_value=httpx.Response(500))\n                with pytest.raises(RuntimeError):\n                    await _request(client, \"https://x/test\", retries=2)\n\n    async def test_does_not_retry_on_404(self):\n        async with httpx.AsyncClient() as client:\n            with respx.mock:\n                route = respx.get(\"https://x/test\").mock(return_value=httpx.Response(404))\n                with pytest.raises(RuntimeError):\n                    await _request(client, \"https://x/test\", retries=3)\n                assert route.call_count == 1  # no retry attempted\n\n\n@pytest.mark.asyncio\nclass TestFetchAll:\n    async def test_one_source_failure_does_not_kill_others(self):\n        sources = [{\"ats\": \"unknown_ats\", \"company\": \"x\"},\n                   {\"ats\": \"greenhouse\", \"company\": \"acme\"}]\n        with respx.mock:\n            respx.get(\"https://boards-api.greenhouse.io/v1/boards/acme/jobs\",\n                       params={\"content\": \"false\"}).mock(\n                return_value=httpx.Response(200, json={\"jobs\": []}))\n            jobs = await fetch_all(sources, concurrency=2)\n            assert jobs == []  # both \"succeeded\" (empty), no exception propagated\n\n\nclass TestFetchSourceUnknownAts:\n    @pytest.mark.asyncio\n    async def test_raises_valueerror(self):\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(ValueError, match=\"unknown ATS\"):\n                await fetch_source(client, {\"ats\": \"bogus\"})\n\n\n@pytest.mark.asyncio\nclass TestPaginationStopConditions:\n    async def test_optiver_stops_when_no_new_items(self):\n        from fetchers import fetch_optiver\n        with respx.mock:\n            respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n                return_value=httpx.Response(200, json={\"items\": []}))\n            jobs = await fetch_optiver(httpx.AsyncClient(), {\"company\": \"optiver\"})\n            assert jobs == []\n\n    async def test_workday_stops_at_offset_ge_total(self):\n        from fetchers import fetch_workday\n        with respx.mock:\n            respx.post(url__regex=r\".*/wday/cxs/.*\").mock(\n                return_value=httpx.Response(200, json={\n                    \"jobPostings\": [{\"externalPath\": \"/job/1\", \"title\": \"A\",\n                                     \"bulletFields\": [\"R-1\"]}],\n                    \"total\": 1}))\n            jobs = await fetch_workday(httpx.AsyncClient(), {\n                \"host\": \"acme.wd5.myworkdayjobs.com\", \"tenant\": \"acme\", \"site\": \"External\"})\n            assert len(jobs) == 1"
