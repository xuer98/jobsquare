        "title": "tests/fetchers/test_parsers.py",
        "content": "from fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       _ashby_salary, parse_amazon, _amazon_posted_at,\n                       _extract_ds1, _ds1_posted_at, parse_google, parse_deshaw,\n                       parse_workday_positions if False else None)  # see note below\n\nclass TestParseGreenhouse:\n    def test_minimal_payload(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].location == \"\"  # missing location dict handled\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n\nclass TestLeverSalary:\n    def test_min_max_present_formats_range(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_falls_back_to_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_data_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestParseAshby:\n    def test_unlisted_job_is_skipped(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"}]}\n        assert parse_ashby(\"acme\", data) == []\n\n\nclass TestAmazonPostedAt:\n    def test_valid_date(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_returns_empty_not_raise(self):\n        assert _amazon_posted_at(\"garbage\") == \"\"\n\n    def test_empty_string(self):\n        assert _amazon_posted_at(\"\") == \"\"\n\n\nclass TestExtractDs1:\n    def test_no_ds1_blob_returns_empty_list(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_malformed_json_returns_empty_list(self):\n        html = \"key: 'ds:1', data:[not valid json], sideChannel\"\n        assert _extract_ds1(html) == []\n\n\nclass TestDsPostedAt:\n    def test_short_job_array_no_indexerror(self):\n        assert _ds1_posted_at([1, 2, 3]) == \"\"  # no IndexError\n\n\nclass TestParseDeshaw:\n    def test_dedupes_repeated_job_id(self):\n        page = ('data-job-id=\"1\"><span class=\"job-display-name\">A</span>'\n                'data-job-id=\"1\"><span class=\"job-display-name\">A</span>')\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert len(jobs) == 1\n```\n\n```python\n",
