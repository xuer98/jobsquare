        "title": "tests/test_pipeline.py",
        "content": "import pytest\nfrom unittest.mock import patch, AsyncMock\nfrom pipeline import load_config, run\nfrom models import Job\n\ndef test_load_config_fills_defaults(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(\"sources: []\\n\")\n    cfg = load_config(cfg_file)\n    assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\n@pytest.mark.asyncio\nasync def test_dry_run_does_not_touch_store_or_notify(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(f\"sources: []\\ndb: {tmp_path/'x.db'}\\n\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n         patch(\"pipeline.Store\") as MockStore, \\\n         patch(\"pipeline.dispatch\") as mock_dispatch:\n        result = await run(cfg_file, dry_run=True)\n        MockStore.assert_not_called()\n        mock_dispatch.assert_not_called()\n        assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n\n@pytest.mark.asyncio\nasync def test_full_run_dispatches_and_reports_counts(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(f\"sources: []\\ndb: {tmp_path/'x.db'}\\n\")\n    job = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[job])), \\\n         patch(\"pipeline.dispatch\") as mock_dispatch:\n        result = await run(cfg_file, dry_run=False)\n        mock_dispatch.assert_called_once()\n        assert result[\"new\"] == 1\n```\n\n---\n\n",
