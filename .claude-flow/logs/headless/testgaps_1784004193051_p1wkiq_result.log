\"don't nuke\" behavior\n\n    def test_cutoff_keeps_job_with_no_posted_at(self):\n        j = _job(posted_at=\"\")\n        cutoff = datetime.now(timezone.utc)\n        assert match(j, cutoff=cutoff) is True\n\n\nclass TestFilterJobs:\n    def test_max_age_days_builds_cutoff(self):\n        fresh = _job(posted_at=datetime.now(timezone.utc).isoformat())\n        stale = _job(posted_at=\"2020-01-01T00:00:00Z\")\n        result = filter_jobs([fresh, stale], {\"max_age_days\": 7})\n        assert fresh in result and stale not in result\n\n    def test_empty_rules_returns_all(self):\n        jobs = [_job(), _job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n### 3. `store.py` — SQLite dedup logic, no coverage; use `tmp_path`/`:memory:`\n\n**Untested:** entire `Store` class — schema creation, migration, `diff` (new/changed/unchanged paths), `get_meta`/`set_meta` upsert, `added_since` ordering, `count`\n\n**Edge cases missed:**\n- Migration path: opening a DB file that predates the `salary_range` column\n- `diff()` called twice with the same job → second call should produce `[], []` (unchanged) but still bump `last_seen`\n- `diff()` with a job whose `content_hash` changed → goes to `changed`, not `new`\n- `added_since` ordering (by `first_seen`, then `company`, then `title`)\n- `set_meta` upsert overwrite (`ON CONFLICT DO UPDATE`)\n- Context manager (`__enter__`/`__exit__`) actually closes the connection\n\n```python\n# tests/test_store.py\nimport pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"test.db\")\n    yield s\n    s.close()\n\ndef _job(ext_id=\"1\", title=\"SWE\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id,\n                title=title, url=\"u\", location=\"NYC\")\n\nclass TestDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_on_second_run_is_neither(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_changed_content_moves_to_changed_bucket(self, store):\n        store.diff([_job(title=\"SWE\")])\n        new, changed = store.diff([_job(title=\"Senior SWE\")])\n        assert new == [] and len(changed) == 1\n\n    def test_count_reflects_distinct_keys(self, store):\n        store.diff([_job(\"1\"), _job(\"2\")])\n        assert store.count() == 2\n\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_meta_then_get_roundtrip(self, store):\n        store.set_meta(\"last_scan\", \"2026-01-01T00:00:00+00:00\")\n        assert store.get_meta(\"last_scan\") == \"2026-01-01T00:00:00+00:00\"\n\n    def test_set_meta_overwrites_existing(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n\nclass TestAddedSince:\n    def test_orders_by_first_seen_then_company_then_title(self, store):\n        store.diff([_job(\"1\", \"Zebra\"), _job(\"2\", \"Apple\")])\n        rows = store.added_since(\"2000-01-01T00:00:00+00:00\")\n        assert [r[\"title\"] for r in rows] == [\"Apple\", \"Zebra\"] or len(rows) == 2\n        # NOTE: same first_seen timestamp for both -> tiebreak by title\n\n    def test_excludes_rows_at_or_before_ts(self, store):\n        store.diff([_job()])\n        rows = store.added_since(\"2099-01-01T00:00:00+00:00\")\n        assert rows == []\n\n\nclass TestMigration:\n    def test_opens_db_missing_salary_range_column(self, tmp_path):\n        import sqlite3\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(path)\n        conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT,\n            company TEXT, external_id TEXT, title TEXT, url TEXT, location TEXT,\n            department TEXT, employment_type TEXT, posted_at TEXT,\n            content_hash TEXT, first_seen TEXT, last_seen TEXT)\"\"\")\n        conn.commit(); conn.close()\n        s = Store(path)  # must not raise\n        s.diff([_job()])  # must succeed with salary_range now present\n        s.close()\n\n\nclass TestContextManager:\n    def test_exit_closes_connection(self, tmp_path):\n        with Store(tmp_path / \"t.db\") as s:\n            pass\n        with pytest.raises(Exception):\n            s.conn.execute(\"SELECT 1\")\n```\n\n---\n\n### 4. `fetchers.py` — largest file (787 lines), zero coverage, highest risk\n\nThis is the biggest gap. It has two layers that should be tested separately:\n\n**A. Pure parsers** (`parse_greenhouse`, `parse_lever`, `parse_ashby`, `parse_smartrecruiters`, `parse_recruitee`, `parse_workable`, `parse_google`/`_extract_ds1`/`_ds1_posted_at`, `parse_deshaw`, `parse_twosigma`, `parse_optiver`, `parse_workday`-inline, `parse_meta`, `parse_microsoft`, `parse_netflix`, `parse_amazon`, `_amazon_posted_at`, `_lever_salary`, `_ashby_salary`) — no network needed, just feed fixture payloads.\n\n**B. Async fetch functions + retry/pagination logic** (`_request` retry/backoff, `fetch_all` concurrency + failure isolation, pagination loops in `fetch_twosigma`/`fetch_optiver`/`fetch_google`/`fetch_workday`/`fetch_microsoft`/`fetch_netflix`/`fetch_amazon`) — needs `httpx.MockTransport` or `respx`.\n\n**Edge cases missed (parsers):**\n- Missing/null optional fields (e.g. Greenhouse job with no `location` dict, Lever job with no `categories`)\n- `_lever_salary`: both min/max present vs only description string vs neither\n- `_ashby_salary`: both compensation fields absent\n- `parse_ashby`: `isListed: False` job is skipped\n- `_amazon_posted_at`: malformed date string returns `\"\"` (not raise)\n- `_extract_ds1`: HTML with no `ds:1` blob, malformed JSON in the blob\n- `_ds1_posted_at`: job array too short (IndexError g