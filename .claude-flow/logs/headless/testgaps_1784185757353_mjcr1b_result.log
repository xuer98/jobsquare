        "content": "import pytest\nimport sqlite3\nfrom datetime import datetime, timezone\nfrom models import Job\nfrom store import Store\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"jobs.db\")\n    yield s\n    s.close()\n\ndef _job(external_id=\"1\", title=\"Engineer\", company=\"acme\"):\n    return Job(source=\"greenhouse\", company=company, external_id=external_id,\n               title=title, url=\"https://x\", location=\"NYC\")\n\nclass TestDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_on_second_run_is_neither_new_nor_changed(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_content_change_reports_as_changed_not_new(self, store):\n        store.diff([_job(title=\"Engineer\")])\n        new, changed = store.diff([_job(title=\"Senior Engineer\")])\n        assert new == []\n        assert len(changed) == 1\n\n    def test_diff_persists_across_store_instances(self, tmp_path):\n        path = tmp_path / \"jobs.db\"\n        with Store(path) as s1:\n            s1.diff([_job()])\n        with Store(path) as s2:\n            new, _ = s2.diff([_job()])\n            assert new == []  # still known\n\nclass TestMigration:\n    def test_opens_pre_salary_range_schema_without_error(self, tmp_path):\n        path = tmp_path / \"old.db\"\n        conn = sqlite3.connect(path)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        s = Store(path)  # must not raise\n        cols = {r[\"name\