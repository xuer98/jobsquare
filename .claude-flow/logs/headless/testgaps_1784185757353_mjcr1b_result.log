        "content": "import pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_returns_none(self):\n        assert parse_posted_at(\"\") is None\n        assert parse_posted_at(None) is None  # type: ignore[arg-type]\n\n    def test_lever_millisecond_epoch(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt.tzinfo == timezone.utc\n        assert dt.year == 2022\n\n    def test_second_epoch_boundary_not_misread_as_ms(self):\n        # just under 1e12 -> must be treated as seconds, not ms\n        dt = parse_posted_at(\"999999999\")\n        assert dt.year == 2001\n\n    def test_iso8601_with_trailing_z(self):\n        dt = parse_posted_at(\"2024-01-15T00:00:00Z\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso8601_naive_gets_utc_attached(self):\n        dt = parse_posted_at(\"2024-01-15T00:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_unparseable_prose_returns_none(self):\n        # Workday's \"Posted 3 Days Ago\" ã must not raise\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_garbage_string_returns_none_not_raise(self):\n        assert parse_posted_at(\"not-a-date\") is None\n\n\nclass TestJob:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                    title=\"Engineer\", url=\"https://x\", location=\"NYC\")\n        return Job(**{**base, **overrides})\n\n    def test_key_is_stable_and_distinguishes_source(self):\n        a = self._job(source=\"greenhouse\")\n        b = self._job(source=\"lever\")\n        assert a.key != b.key\n\n    def test_content_hash_ignores_posted_at_and_salary(self):\n        a = self._job(posted_at=\"2024-01-01\", salary_range=\"100k\")\n        b = self._job(posted_at=\"2025-06-01\", salary_range=\"200k\")\n        assert a.content_hash == b.content_hash\n\n    def test_content_hash_changes_on_title_change(self):\n        a = self._job(title=\"Engineer\")\n        b = self._job(title=\"Senior Engineer\")\n        assert a.content_hash != b.content_hash\n\n    def test_to_row_drops_raw_and_adds_key_and_hash(self):\n        row = self._job(raw={\"secret\": 1}).to_row()\n        assert \"raw\" not in row\n        assert \"key\" in row and \"content_hash\" in row\n```\n\n---\n\n",
