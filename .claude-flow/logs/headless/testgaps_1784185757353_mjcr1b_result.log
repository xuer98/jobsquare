        "code": "# tests/test_store.py\nimport pytest\nimport sqlite3\nfrom datetime import datetime, timezone\nfrom models import Job\nfrom store import Store\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"jobs.db\")\n    yield s\n    s.close()\n\ndef _job(external_id=\"1\", title=\"Engineer\", company=\"acme\"):\n    return Job(source=\"greenhouse\", company=company, external_id=external_id,\n               title=title, url=\"https://x\", location=\"NYC\")\n\nclass TestDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_on_second_run_is_neither_new_nor_changed(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_content_change_reports_as_changed_not_new(self, store):\n        store.diff([_job(title=\"Engineer\")])\n        new, changed = store.diff([_job(title=\"Senior Engineer\")])\n        assert new == []\n        assert len(changed) == 1\n\n    def test_diff_persists_across_store_instances(self, tmp_path):\n        path = tmp_path / \"jobs.db\"\n        with Store(path) as s1:\n            s1.diff([_job()])\n        with Store(path) as s2:\n            new, _ = s2.diff([_job()])\n            assert new == []  # still known\n\nclass TestMigration:\n    def test_opens_pre_salary_range_schema_without_error(self, tmp_path):\n        path = tmp_path / \"old.db\"\n        conn = sqlite3.connect(path)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        s = Store(path)  # must not raise\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n        s.close()\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta_roundtrips(self, store):\n        store.set_meta(\"k\", \"v1\")\n        assert store.get_meta(\"k\") == \"v1\"\n\n    def test_set_meta_overwrites(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\nclass TestNextSeq:\n    def test_starts_at_one_and_increments(self, store):\n        assert store.next_seq(\"seq\") == 1\n        assert store.next_seq(\"seq\") == 2\n\n    def test_independent_keys_dont_interfere(self, store):\n        store.next_seq(\"a\")\n        assert store.next_seq(\"b\") == 1\n\nclass TestAddedSince:\n    def test_excludes_rows_at_exact_boundary(self, store):\n        store.diff([_job()])\n        row = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()\n        assert store.added_since(row[\"first_seen\"]) == []\n\n    def test_orders_oldest_first(self, store):\n        store.diff([_job(external_id=\"1\")])\n        store.conn.execute(\"UPDATE jobs SET first_seen = '2020-01-01T00:00:00+00:00'\")\n        store.diff([_job(external_id=\"2\")])\n        rows = store.added_since(\"2019-01-01T00:00:00+00:00\")\n        assert [r[\"external_id\"] for r in rows] == [\"1\", \"2\"]\n\nclass TestCount:\n    def test_empty_store_is_zero(self, store):\n        assert store.count() == 0\n\n    def test_reflects_inserted_rows(self, store):\n        store.diff([_job(\"1\"), _job(\"2\")])\n        assert store.count() == 2"
