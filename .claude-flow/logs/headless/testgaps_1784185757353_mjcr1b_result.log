        "code": "# tests/test_fetchers_pagination.py\nimport pytest\nimport respx\nimport httpx\nfrom fetchers import fetch_optiver, fetch_ashby, fetch_meta, fetch_workday\n\n@pytest.mark.asyncio\nclass TestFetchOptiverPagination:\n    @respx.mock\n    async def test_stops_when_page_has_no_fresh_ids(self):\n        respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(side_effect=[\n            httpx.Response(200, json={\"items\": [{\"href\": \"/join-us/jobs/a\", \"title\": \"A\"}]}),\n            httpx.Response(200, json={\"items\": []}),\n        ])\n        async with httpx.AsyncClient() as client:\n            jobs = await fetch_optiver(client, {\"company\": \"optiver\", \"max_pages\": 5})\n        assert len(jobs) == 1\n\n    @respx.mock\n    async def test_respects_max_pages_cap(self):\n        route = respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n            return_value=httpx.Response(200, json={\"items\": [\n                {\"href\": \"/join-us/jobs/x\", \"title\": \"Always fresh\"}]}))\n        # server pretends to always have (the same, so actually not-fresh) data;\n        # verify loop terminates via the not-fresh check well before max_pages\n        async with httpx.AsyncClient() as client:\n            await fetch_optiver(client, {\"company\": \"optiver\", \"max_pages\": 100})\n        assert route.call_count <= 2  # first page + one confirming empty\n\n\n@pytest.mark.asyncio\nclass TestFetchAshby:\n    @respx.mock\n    async def test_uses_posting_api_when_available(self):\n        respx.get(url__regex=r\".*api\\.ashbyhq\\.com.*\").mock(\n            return_value=httpx.Response(200, json={\"jobs\": [{\"id\": \"1\", \"title\": \"Eng\"}]}))\n        async with httpx.AsyncClient() as client:\n            jobs = await fetch_ashby(client, {\"company\": \"acme\"})\n        assert len(jobs) == 1\n\n    @respx.mock\n    async def test_falls_back_to_hosted_page_on_404(self):\n        respx.get(url__regex=r\".*api\\.ashbyhq\\.com.*\").mock(return_value=httpx.Response(404))\n        html = ('<script>window.__appData = {\"jobBoard\":{\"jobPostings\":'\n                '[{\"id\":\"2\",\"title\":\"Eng\"}]}};</script>')\n        respx.get(url__regex=r\".*jobs\\.ashbyhq\\.com.*\").mock(\n            return_value=httpx.Response(200, text=html))\n        async with httpx.AsyncClient() as client:\n            jobs = await fetch_ashby(client, {\"company\": \"acme\"})\n        assert jobs[0].external_id == \"2\"\n\n    @respx.mock\n    async def test_raises_when_neither_source_available(self):\n        respx.get(url__regex=r\".*api\\.ashbyhq\\.com.*\").mock(return_value=httpx.Response(404))\n        respx.get(url__regex=r\".*jobs\\.ashbyhq\\.com.*\").mock(\n            return_value=httpx.Response(200, text=\"<html>no appdata here</html>\"))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError, match=\"no posting-api\"):\n                await fetch_ashby(client, {\"company\": \"acme\"})\n\n\n@pytest.mark.asyncio\nclass TestFetchMeta:\n    @respx.mock\n    async def test_raises_runtime_error_when_graphql_errors_present(self):\n        # simulates the doc_id-rotation failure the module docstring warns about\n        respx.get(\"https://www.metacareers.com/jobs\").mock(\n            return_value=httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok\"}]'))\n        respx.post(\"https://www.metacareers.com/graphql\").mock(\n            return_value=httpx.Response(200, text='for (;;);{\"errors\":[{\"message\":\"bad doc_id\"}]}'))\n        async with httpx.AsyncClient() as client:\n            with pytest.raises(RuntimeError, match=\"bad doc_id\"):\n                await fetch_meta(client, {\"company\": \"meta\"})\n\n\n@pytest.mark.asyncio\nclass TestFetchWorkday:\n    @respx.mock\n    async def test_stops_at_total_offset(self):\n        respx.post(url__regex=r\".*wday/cxs.*\").mock(side_effect=[\n            httpx.Response(200, json={\"jobPostings\": [{\"title\": \"A\", \"bulletFields\": [\"R1\"]}],\n                                       \"total\": 1}),\n        ])\n        async with httpx.AsyncClient() as client:\n            jobs = await fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\"})\n        assert len(jobs) == 1"
