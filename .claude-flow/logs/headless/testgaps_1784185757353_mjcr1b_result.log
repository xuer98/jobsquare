        "code": "# tests/test_fetchers_parsers.py\nfrom fetchers import (parse_greenhouse, parse_lever, _lever_salary,\n                       parse_ashby, _amazon_posted_at, _apple_hydration,\n                       _apple_posted_at, _ds1_posted_at, _bd_location,\n                       parse_google, parse_apple)\n\nclass TestParseGreenhouse:\n    def test_maps_fields(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\", \"absolute_url\": \"https://x\",\n                           \"location\": {\"name\": \"NYC\"},\n                           \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Infra\"}],\n                           \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].department == \"Eng, Infra\"\n        assert jobs[0].location == \"NYC\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_location_defaults_empty(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\", \"absolute_url\": \"u\"}]}\n        assert parse_greenhouse(\"acme\", data)[0].location == \"\"\n\n    def test_job_missing_id_raises(self):\n        # documents current (crash) behavior ã a source dropping `id` kills fetch_source\n        import pytest\n        with pytest.raises(KeyError):\n            parse_greenhouse(\"acme\", {\"jobs\": [{\"title\": \"Eng\"}]})\n\n\nclass TestLeverSalary:\n    def test_min_and_max_formatted_with_commas(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000ã150,000\"\n\n    def test_falls_back_to_description_when_no_range(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestParseAshby:\n    def test_skips_unlisted_jobs(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"},\n                          {\"id\": \"2\", \"title\": \"Visible\"}]}\n        jobs = parse_ashby(\"acme\", data)\n        assert [j.external_id for j in jobs] == [\"2\"]\n\n\nclass TestAmazonPostedAt:\n    def test_valid_date_normalizes_to_iso(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_string_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_unknown_month_returns_empty(self):\n        assert _amazon_posted_at(\"Marchember 1, 2026\") == \"\"\n\n    def test_empty_input_returns_empty(self):\n        assert _amazon_posted_at(\"\") == \"\"\n\n\nclass TestApplePostedAt:\n    def test_trims_nanosecond_precision_to_microseconds(self):\n        result = _apple_posted_at(\"2024-01-15T10:30:00.812668311Z\")\n        assert result == \"2024-01-15T10:30:00.812668+00:00\"\n\n    def test_no_fractional_seconds(self):\n        assert _apple_posted_at(\"2024-01-15T10:30:00Z\") == \"2024-01-15T10:30:00+00:00\"\n\n    def test_empty_or_none_returns_empty(self):\n        assert _apple_posted_at(\"\") == \"\"\n        assert _apple_posted_at(None) == \"\"\n\n\nclass TestAppleHydration:\n    def test_extracts_and_double_decodes_json(self):\n        html = ('window.__staticRouterHydrationData = JSON.parse(\"'\n                r'{\\\"loaderData\\\":{\\\"a\\\":1}}' + '\");')\n        assert _apple_hydration(html) == {\"loaderData\": {\"a\": 1}}\n\n    def test_missing_marker_returns_none(self):\n        assert _apple_hydration(\"<html></html>\") is None\n\n    def test_malformed_json_returns_none_not_raise(self):\n        html = 'window.__staticRouterHydrationData = JSON.parse(\"{not json\");'\n        assert _apple_hydration(html) is None\n\n    def test_escaped_quote_inside_blob_does_not_truncate_early(self):\n        html = (r'window.__staticRouterHydrationData = JSON.parse(\"{\\\"a\\\":\\\"esc\\\\\\\"aped\\\"}\"'\n                 ');')\n        assert _apple_hydration(html) == {\"a\": 'esc\"aped'}\n\n\nclass TestDs1PostedAt:\n    def test_prefers_create_time_index_12_over_later_indices(self):\n        job = [None] * 15\n        job[12] = [1700000000]\n        job[13] = [1800000000]\n        result = _ds1_posted_at(job)\n        assert \"2023\" in result  # index 12's timestamp wins\n\n    def test_short_array_no_timestamp_indices_returns_empty(self):\n        assert _ds1_posted_at([1, \"title\"]) == \"\"\n\n    def test_falls_back_to_index_13_when_12_empty(self):\n        job = [None] * 15\n        job[13] = [1700000000]\n        assert _ds1_posted_at(job) != \"\"\n\n\nclass TestBdLocation:\n    def test_walks_parent_chain_city_to_country(self):\n        city = {\"en_name\": \"Seattle\", \"parent\": {\"en_name\": \"Washington\",\n                 \"parent\": {\"en_name\": \"USA\", \"parent\": None}}}\n        assert _bd_location(city) == \"Seattle, Washington, USA\"\n\n    def test_none_returns_empty_string(self):\n        assert _bd_location(None) == \"\"\n\n    def test_falls_back_to_name_when_no_en_name(self):\n        assert _bd_location({\"name\": \"Tokyo\", \"parent\": None}) == \"Tokyo\"\n\n\nclass TestParseGoogle:\n    def test_skips_falsy_first_element(self):\n        # j[0] falsy is an explicit skip-guard in the source\n        assert parse_google(\"google\", [[None, \"title\"], [0, \"title\"]]) == []\n\n    def test_short_array_defensive_indexing(self):\n        # only index 0 present; title/locations/posted_at must all default safely\n        jobs = parse_google(\"google\", [[\"id123\"]])\n        assert jobs[0].title == \"\"\n        assert jobs[0].location == \"\"\n\n\nclass TestParseApple:\n    def test_dedupes_repeated_location_strings(self):\n        results = [{\"id\": \"1-0001\", \"positionId\": \"1\", \"postingTitle\": \"Eng\",\n                    \"locations\": [{\"city\": \"Cupertino\", \"countryName\": \"USA\"},\n                                  {\"city\": \"Cupertino\", \"countryName\": \"USA\"}]}]\n        jobs = parse_apple(\"apple\", results)\n        assert jobs[0].location == \"Cupertino, USA\"\n\n    def test_missing_position_id_yields_empty_url(self):\n        jobs = parse_apple(\"apple\", [{\"id\": \"1\", \"postingTitle\": \"Eng\"}])\n        assert jobs[0].url == \"\""
