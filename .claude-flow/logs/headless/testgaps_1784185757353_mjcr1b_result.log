        "content": "from datetime import datetime, timedelta, timezone\nfrom unittest.mock import MagicMock\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(title=\"\", department=\"\", location=\"\", posted_at=\"\"):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=title,\n               url=\"u\", department=department, location=location, posted_at=posted_at)\n\nclass TestMatch:\n    def test_include_word_boundary_does_not_match_substring(self):\n        # \"go\" must not match inside \"Django\"/\"Google\"\n        assert match(_job(title=\"Django Developer\"), include=[\"go\"]) is False\n\n    def test_include_matches_whole_word_case_insensitive(self):\n        assert match(_job(title=\"Senior Go Engineer\"), include=[\"go\"]) is True\n\n    def test_exclude_wins_even_if_include_also_matches(self):\n        j = _job(title=\"Senior Python Intern\")\n        assert match(j, include=[\"python\"], exclude=[\"intern\"]) is False\n\n    def test_no_filters_passes_everything(self):\n        assert match(_job(title=\"Anything\")) is True\n\n    def test_locations_substring_case_insensitive(self):\n        assert match(_job(location=\"Remote - New York, NY\"),\n                     locations=[\"new york\"]) is True\n\n    def test_locations_no_match_excludes(self):\n        assert match(_job(location=\"London\"), locations=[\"new york\"]) is False\n\n    def test_cutoff_drops_confirmed_old_posting(self):\n        old = (datetime.now(timezone.utc) - timedelta(days=30)).isoformat()\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(_job(posted_at=old), cutoff=cutoff) is False\n\n    def test_cutoff_keeps_unparseable_posted_at(self):\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(_job(posted_at=\"not a date\"), cutoff=cutoff) is True\n\n    def test_cutoff_keeps_fresh_posting(self):\n        recent = datetime.now(timezone.utc).isoformat()\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(_job(posted_at=recent), cutoff=cutoff) is True\n\n\nclass TestFilterJobs:\n    def test_max_age_days_builds_cutoff(self):\n        old = _job(title=\"A\", posted_at=(datetime.now(timezone.utc)\n                    - timedelta(days=100)).isoformat())\n        new = _job(title=\"B\", posted_at=datetime.now(timezone.utc).isoformat())\n        result = filter_jobs([old, new], {\"max_age_days\": 7})\n        assert result == [new]\n\n    def test_empty_rules_returns_all(self):\n        jobs = [_job(title=\"A\"), _job(title=\"B\")]\n        assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n",
