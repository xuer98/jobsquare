        "title": "tests/test_models.py",
        "content": "import pytest\nfrom datetime import datetime, timezone\nfrom models import Job, parse_posted_at\n\n\nclass TestParsePostedAt:\n    def test_none_and_empty_return_none(self):\n        assert parse_posted_at(\"\") is None\n        assert parse_posted_at(None) is None  # type: ignore[arg-type]\n\n    def test_garbage_string_returns_none(self):\n        assert parse_posted_at(\"not a date\") is None\n\n    @pytest.mark.parametrize(\"epoch_ms,expected_year\", [\n        (\"1643241332430\", 2022),\n    ])\n    def test_lever_millisecond_epoch(self, epoch_ms, expected_year):\n        dt = parse_posted_at(epoch_ms)\n        assert dt.year == expected_year\n        assert dt.tzinfo == timezone.utc\n\n    def test_second_epoch_boundary_just_under_ms_cutoff(self):\n        # 999_999_999_999 is 12 digits -> should be treated as seconds\n        dt = parse_posted_at(\"999999999999\")\n        assert dt is not None\n\n    def test_iso8601_with_z_suffix(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n        assert dt == datetime(2024, 1, 15, 10, 0, tzinfo=timezone.utc)\n\n    def test_iso8601_naive_gets_utc_attached(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso8601_with_explicit_offset_preserved(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00+05:00\")\n        assert dt.utcoffset().total_seconds() == 5 * 3600\n\n    def test_workday_prose_string_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_negative_epoch(self):\n        # lstrip(\"-\").isdigit() branch — pre-1970 dates\n        dt = parse_posted_at(\"-100\")\n        assert dt is not None\n\n\nclass TestJobKey:\n    def test_key_is_stable_across_field_edits(self):\n        j = Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\", title=\"A\", url=\"u\")\n        key = j.key\n        j.title = \"B\"\n        assert j.key == key\n\n    def test_key_differs_by_source_company_or_id(self):\n        base = dict(title=\"A\", url=\"u\")\n        a = Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\", **base)\n        b = Job(source=\"lever\", company=\"acme\", external_id=\"1\", **base)\n        assert a.key != b.key\n\n\nclass TestContentHash:\n    def test_changes_when_title_changes(self):\n        j = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"A\", url=\"u\")\n        h1 = j.content_hash\n        j.title = \"B\"\n        assert j.content_hash != h1\n\n    def test_stable_when_posted_at_or_salary_changes(self):\n        j = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"A\", url=\"u\")\n        h1 = j.content_hash\n        j.posted_at = \"2024-01-01\"\n        j.salary_range = \"$100k\"\n        assert j.content_hash == h1\n\n\nclass TestToRow:\n    def test_drops_raw_and_adds_key_and_hash(self):\n        j = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"A\", url=\"u\",\n                raw={\"secret\": True})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash\n```\n\n---\n\n",
