        "title": "tests/test_notify.py",
        "content": "import httpx\nimport pytest\nimport respx\nfrom models import Job\nimport notify\n\n\ndef _job(title=\"Eng\", company=\"acme\"):\n    return Job(source=\"s\", company=company, external_id=\"1\", title=title, url=\"u\")\n\n\nclass TestNotifyConsole:\n    def test_prints_no_fresh_listings_when_empty(self, capsys):\n        notify.notify_console([], [])\n        assert \"No fresh listings\" in capsys.readouterr().out\n\n    def test_prints_new_and_changed_sections(self, capsys):\n        notify.notify_console([_job()], [_job(title=\"Updated\")])\n        out = capsys.readouterr().out\n        assert \"NEW\" in out and \"UPDATED\" in out\n\n\nclass TestNotifySlack:\n    def test_noop_when_env_var_missing(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        notify.notify_slack([_job()], [])  # must not raise / must not need network\n\n    @respx.mock\n    def test_noop_when_no_new_or_changed_even_if_configured(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        route = respx.post(\"https://hooks.slack.test/x\")\n        notify.notify_slack([], [])\n        assert not route.called\n\n    @respx.mock\n    def test_posts_when_configured_and_has_new(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        route = respx.post(\"https://hooks.slack.test/x\").mock(\n            return_value=httpx.Response(200))\n        notify.notify_slack([_job()], [])\n        assert route.called\n\n\nclass TestSmsBody:\n    def test_truncates_at_limit_with_more_count(self):\n        jobs = [_job(title=f\"T{i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n\n    def test_no_more_line_when_under_limit(self):\n        body = notify._sms_body([_job()], [], limit=8)\n        assert \"more\" not in body\n\n\nclass TestNotifySms:\n    def test_noop_when_any_of_four_env_vars_missing(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        notify.notify_sms([_job()], [])  # must not raise\n\n    @respx.mock\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        for k, v in dict(TWILIO_ACCOUNT_SID=\"sid\", TWILIO_AUTH_TOKEN=\"tok\",\n                          TWILIO_FROM=\"+1\", TWILIO_TO=\"+2\").items():\n            monkeypatch.setenv(k, v)\n        respx.post(url__regex=r\".*Messages\\.json\").mock(\n            return_value=httpx.Response(401))\n        with pytest.raises(httpx.HTTPStatusError):\n            notify.notify_sms([_job()], [])\n\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch, capsys):\n        def boom(new, changed):\n            raise RuntimeError(\"boom\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, notify.notify_console])\n        notify.dispatch([], [])\n        out = capsys.readouterr().out\n        assert \"notifier boom failed\" in out\n        assert \"No fresh listings\" in out\n```\n\n---\n\n",
