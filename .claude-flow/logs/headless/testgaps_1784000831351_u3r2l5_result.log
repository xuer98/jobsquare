        "code": "# tests/test_store.py\nimport sqlite3\nimport pytest\nfrom models import Job\nfrom store import Store\n\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"jobs.db\") as s:\n        yield s\n\n\ndef _job(ext_id=\"1\", title=\"A\", loc=\"Remote\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id,\n               title=title, url=\"u\", location=loc)\n\n\nclass TestDiff:\n    def test_new_job_is_inserted_and_returned_as_new(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n        assert store.count() == 1\n\n    def test_unchanged_job_on_second_run_is_neither_new_nor_changed(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_changed_content_updates_and_is_reported(self, store):\n        store.diff([_job(title=\"Old Title\")])\n        new, changed = store.diff([_job(title=\"New Title\")])\n        assert new == []\n        assert len(changed) == 1\n        row = store.conn.execute(\"SELECT title FROM jobs WHERE key=?\",\n                                  (changed[0].key,)).fetchone()\n        assert row[\"title\"] == \"New Title\"\n\n    def test_posted_at_only_change_does_not_trigger_changed(self, store):\n        j1 = _job()\n        store.diff([j1])\n        j2 = _job()\n        j2.posted_at = \"2024-01-01\"  # not part of content_hash\n        new, changed = store.diff([j2])\n        assert new == [] and changed == []\n\n    def test_duplicate_key_within_same_batch(self, store):\n        new, changed = store.diff([_job(), _job()])\n        # document actual behavior: second occurrence treated as already-seen\n        assert store.count() == 1\n\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta_roundtrip(self, store):\n        store.set_meta(\"last_scan\", \"2024-01-01T00:00:00\")\n        assert store.get_meta(\"last_scan\") == \"2024-01-01T00:00:00\"\n\n    def test_set_meta_overwrites_existing(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\n\nclass TestAddedSince:\n    def test_orders_by_first_seen_company_title(self, store):\n        store.diff([_job(ext_id=\"1\", title=\"Z\"), _job(ext_id=\"2\", title=\"A\")])\n        rows = store.added_since(\"1970-01-01T00:00:00\")\n        assert [r[\"title\"] for r in rows] == sorted(r[\"title\"] for r in rows)\n\n    def test_excludes_rows_at_or_before_timestamp(self, store):\n        store.diff([_job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n        assert store.added_since(ts) == []\n\n\nclass TestMigration:\n    def test_opens_legacy_db_missing_salary_range_column(self, tmp_path):\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(path)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit()\n        conn.close()\n        with Store(path) as s:\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\n\nclass TestContextManager:\n    def test_exit_closes_connection(self, tmp_path):\n        s = Store(tmp_path / \"j.db\")\n        with s:\n            pass\n        with pytest.raises(sqlite3.ProgrammingError):\n            s.conn.execute(\"SELECT 1\")"
      },
