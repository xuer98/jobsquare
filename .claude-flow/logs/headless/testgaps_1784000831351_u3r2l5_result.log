        "code": "# tests/test_fetchers_resilience.py\nimport httpx\nimport pytest\nimport respx\nfrom fetchers import _request, fetch_source, fetch_all\n\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_request_retries_on_503_then_succeeds():\n    route = respx.get(\"https://x.test\").mock(side_effect=[\n        httpx.Response(503), httpx.Response(200, json={})])\n    async with httpx.AsyncClient() as client:\n        r = await _request(client, \"https://x.test\", retries=3)\n    assert r.status_code == 200\n    assert route.call_count == 2\n\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_request_exhausts_retries_and_raises_runtime_error():\n    respx.get(\"https://x.test\").mock(return_value=httpx.Response(500))\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(client, \"https://x.test\", retries=2)\n\n\n@pytest.mark.asyncio\nasync def test_fetch_source_unknown_ats_raises_value_error():\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            await fetch_source(client, {\"ats\": \"bogus\"})\n\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_all_isolates_one_source_failure(monkeypatch, capsys):\n    respx.get(url__regex=r\".*boards-api\\.greenhouse\\.io.*\").mock(\n        return_value=httpx.Response(200, json={\"jobs\": [{\"id\": 1, \"title\": \"A\",\n                                                           \"absolute_url\": \"u\"}]}))\n    respx.get(url__regex=r\".*api\\.lever\\.co.*\").mock(return_value=httpx.Response(500))\n    sources = [{\"ats\": \"greenhouse\", \"company\": \"good\"},\n               {\"ats\": \"lever\", \"company\": \"bad\"}]\n    jobs = await fetch_all(sources, concurrency=2)\n    assert len(jobs) == 1\n    assert \"failed\" in capsys.readouterr().out\n\n\n@pytest.mark.asyncio\nasync def test_fetch_all_closes_owned_client_but_not_injected_one():\n    client = 