        "language": "python",
        "code": "# tests/test_fetchers_parsers.py\nfrom fetchers import (parse_greenhouse, parse_lever, parse_ashby, parse_google,\n                       parse_deshaw, parse_twosigma, parse_optiver, parse_meta,\n                       parse_microsoft, parse_netflix, parse_amazon, _extract_ds1,\n                       _amazon_posted_at, _lever_salary, _ashby_salary)\n\n\nclass TestParseGreenhouse:\n    def test_maps_core_fields(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\",\n                           \"location\": {\"name\": \"NYC\"},\n                           \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Core\"}],\n                           \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        [job] = parse_greenhouse(\"acme\", data)\n        assert job.department == \"Eng, Core\"\n        assert job.external_id == \"1\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_location_object(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\"}]}\n        [job] = parse_greenhouse(\"acme\", data)\n        assert job.location == \"\"\n\n\nclass TestLeverSalary:\n    def test_range_present_formats_with_commas(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_falls_back_to_description_plain(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestParseAshby:\n    def test_filters_unlisted_jobs(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"},\n                          {\"id\": \"2\", \"isListed\": True, \"title\": \"Visible\"}]}\n        result = parse_ashby(\"acme\", data)\n        assert len(result) == 1 and result[0].title == \"Visible\"\n\n\nclass TestExtractDs1AndParseGoogle:\n    def test_extract_ds1_missing_key_returns_empty(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_extract_ds1_malformed_json_returns_empty(self):\n        html = \"key: 'ds:1', data:[not valid json] , sideChannel\"\n        assert _extract_ds1(html) == []\n\n    def test_parse_google_skips_falsy_entries(self):\n        assert parse_google(\"google\", [None, [None]]) == []\n\n    def test_parse_google_short_arrays_dont_crash(self):\n        # array shorter than index 9/12 must not IndexError\n        result = parse_google(\"google\", [[\"id1\"]])\n        assert result[0].location == \"\"\n        assert result[0].posted_at == \"\"\n\n\nclass TestParseDeshaw:\n    def test_dedupes_repeated_job_ids(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">A</span>'\n                '<span class=\"location\">NYC</span></div>' * 2)\n        result = parse_deshaw(\"deshaw\", page)\n        assert len(result) == 1\n\n    def test_missing_title_or_id_skipped(self):\n        page = '<div data-job-id=\"1\"></div>'  # no title\n        assert parse_deshaw(\"deshaw\", page) == []\n\n    def test_html_entities_unescaped_in_title_and_location(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">R&amp;D Eng'\n                 '</span><span class=\"location\">S&atilde;o Paulo</span></div>')\n        [job] = parse_deshaw(\"deshaw\", page)\n        assert job.title == \"R&D Eng\"\n\n\nclass TestAmazonPostedAt:\n    def test_valid_date_string(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_string_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_unknown_month_returns_empty(self):\n        assert _amazon_posted_at(\"Frobtember 1, 2026\") == \"\"\n\n    def test_empty_string(self):\n        assert _amazon_posted_at(\"\") == \"\""
