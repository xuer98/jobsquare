        "title": "tests/test_pipeline.py",
        "content": "import pytest\nfrom pipeline import load_config, run\n\n\ndef test_load_config_applies_defaults(tmp_path):\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(\"sources: []\\n\")\n    cfg = load_config(cfg_path)\n    assert cfg[\"db\"] == \"jobs.db\"\n    assert cfg[\"concurrency\"] == 8\n    assert cfg[\"filters\"] == {}\n\n\n@pytest.mark.asyncio\nasync def test_dry_run_does_not_persist_or_notify(tmp_path, monkeypatch):\n    import pipeline\n    from models import Job\n\n    async def fake_fetch_all(sources, concurrency):\n        return [Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"A\", url=\"u\")]\n    monkeypatch.setattr(pipeline, \"fetch_all\", fake_fetch_all)\n\n    called = []\n    monkeypatch.setattr(pipeline, \"dispatch\", lambda n, c: called.append(True))\n\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(f\"sources: [{{}}]\\ndb: {tmp_path/'j.db'}\\n\")\n    result = await run(cfg_path, dry_run=True)\n\n    assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n    assert not called\n    assert not (tmp_path / \"j.db\").exists()\n\n\n@pytest.mark.asyncio\nasync def test_full_run_persists_and_notifies(tmp_path, monkeypatch):\n    import pipeline\n    from models import Job\n\n    async def fake_fetch_all(sources, concurrency):\n        return [Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"A\", url=\"u\")]\n    monkeypatch.setattr(pipeline, \"fetch_all\", fake_fetch_all)\n    dispatched = {}\n    monkeypatch.setattr(pipeline, \"dispatch\",\n                         lambda n, c: dispatched.update(new=n, changed=c))\n\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(f\"sources: [{{}}]\\ndb: {tmp_path/'j.db'}\\n\")\n    result = await run(cfg_path, dry_run=False)\n\n    assert result == {\"matched\": 1, \"new\": 1, \"changed\": 0}\n    assert len(dispatched[\"new\"]) == 1\n    assert (tmp_path / \"j.db\").exists()\n```\n\n---\n\n",
