        "title": "tests/test_filters.py",
        "content": "from datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\n\ndef _job(title=\"Software Engineer\", dept=\"Eng\", loc=\"Remote - US\", posted_at=\"\"):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=title, url=\"u\",\n               department=dept, location=loc, posted_at=posted_at)\n\n\nclass TestMatch:\n    def test_no_rules_passes(self):\n        assert match(_job()) is True\n\n    def test_include_keyword_matches_whole_word_only(self):\n        assert match(_job(title=\"Senior Engineer\"), include=[\"engineer\"]) is True\n        assert match(_job(title=\"Engineering Manager\"), include=[\"engineer\"]) is False\n\n    def test_include_keyword_case_insensitive(self):\n        assert match(_job(title=\"ENGINEER\"), include=[\"engineer\"]) is True\n\n    def test_exclude_takes_priority_over_include(self):\n        j = _job(title=\"Senior Engineer\", dept=\"Sales\")\n        assert match(j, include=[\"engineer\"], exclude=[\"senior\"]) is False\n\n    def test_locations_is_substring_not_word_boundary(self):\n        assert match(_job(loc=\"San Francisco, CA\"), locations=[\"francisco\"]) is True\n\n    def test_locations_no_match_excludes(self):\n        assert match(_job(loc=\"London, UK\"), locations=[\"new york\"]) is False\n\n    def test_cutoff_drops_confirmed_old_posting(self):\n        old = _job(posted_at=\"2020-01-01T00:00:00Z\")\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(old, cutoff=cutoff) is False\n\n    def test_cutoff_keeps_unparseable_posted_at(self):\n        j = _job(posted_at=\"Posted 3 Days Ago\")  # Workday prose, unparseable\n        cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n        assert match(j, cutoff=cutoff) is True\n\n    def test_cutoff_keeps_recent_posting(self):\n        j = _job(posted_at=datetime.now(timezone.utc).isoformat())\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(j, cutoff=cutoff) is True\n\n\nclass TestFilterJobs:\n    def test_empty_rules_returns_all(self):\n        jobs = [_job(), _job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs\n\n    def test_max_age_days_builds_cutoff(self):\n        old = _job(posted_at=\"2000-01-01T00:00:00Z\")\n        result = filter_jobs([old], {\"max_age_days\": 1})\n        assert result == []\n\n    def test_max_age_days_zero_is_falsy_and_ignored(self):\n        # rules.get(\"max_age_days\") truthiness check: 0 is falsy -> no cutoff applied\n        old = _job(posted_at=\"2000-01-01T00:00:00Z\")\n        result = filter_jobs([old], {\"max_age_days\": 0})\n        assert result == [old]\n```\n\nNote the `max_age_days: 0` case above is a genuine **gap in the implementation, not just tests** — `if max_age:` treats `0` as \"no filter,\" which may or may not be intended. Worth flagging to whoever owns this file.\n\n---\n\n",
