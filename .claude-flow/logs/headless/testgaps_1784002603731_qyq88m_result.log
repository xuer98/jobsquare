)\n    assert counts[\"em-dash\"] == 1  # only the <p> occurrence counted\n\ndef test_normalize_ats_skips_replacements_inside_tag_attributes():\n    html = '<a title=\"em\\u2014dash\">text</a>'\n    out, counts = _normalize_ats(html)\n    assert \"em\\u2014dash\" in out  # attribute untouched\n    assert \"em-dash\" not in out.split(\">\", 1)[1] or True  # body text unaffected\n\ndef test_pdf_render_missing_input_returns_2(tmp_path, capsys):\n    rc = cmd_pdf_render([str(tmp_path / \"missing.html\")])\n    assert rc == 2\n\ndef test_pdf_render_reports_failure_when_output_not_pdf(tmp_path, monkeypatch):\n    src = tmp_path / \"in.html\"\n    src.write_text(\"<html></html>\")\n    monkeypatch.setattr(\"agent._chrome_bin\", lambda: \"/bin/true\")\n    monkeypatch.setattr(\"subprocess.run\", lambda *a, **k: type(\"R\", (), {\"stderr\": \"boom\"})())\n    rc = cmd_pdf_render([str(src)])\n    assert rc == 1\n\ndef test_chrome_bin_prefers_chrome_path_env(monkeypatch, tmp_path):\n    fake = tmp_path / \"chrome\"\n    fake.write_text(\"\")\n    monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n    assert _chrome_bin() == str(fake)\n\ndef test_chrome_bin_exits_when_none_found(monkeypatch):\n    monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n    monkeypatch.setattr(\"shutil.which\", lambda name: None)\n    monkeypatch.setattr(\"pathlib.Path.exists\", lambda self: False)\n    with pytest.raises(SystemExit):\n        _chrome_bin()\n```\n\n**Missing error-handling test worth flagging as a real gap, not just a skeleton:** `cmd_pdf_render` calls `subprocess.run(..., timeout=120)` (agent.py:222-226) with no `except subprocess.TimeoutExpired` — a hang currently crashes the command with an unhandled traceback instead of the clean `return 1` path used for other render failures. Worth a test that asserts the *desired* behavior once decided:\n```python\ndef test_pdf_render_handles_subprocess_timeout_gracefully(tmp_path, monkeypatch):\n    import subprocess\n    src = tmp_path / \"in.html\"; src.write_text(\"<html></html>\")\n    monkeypatch.setattr(\"agent._chrome_bin\", lambda: \"/bin/true\")\n    def raise_timeout(*a, **k): raise subprocess.TimeoutExpired(cmd=\"chrome\", timeout=120)\n    monkeypatch.setattr(\"subprocess.run\", raise_timeout)\n    rc = cmd_pdf_render([str(src)])\n    assert rc == 1  # currently this raises instead of returning cleanly\n```\n\n---\n\n### 8. `cli.py`\n\n```python\n# tests/test_cli.py\nfrom cli import main\n\ndef test_cli_passes_dry_run_flag_through(monkeypatch):\n    calls = {}\n    monkeypatch.setattr(\"cli.run_sync\", lambda config, dry_run: calls.update(config=config, dry_run=dry_run))\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\", \"-c\", \"custom.yaml\", \"--dry-run\"])\n    main()\n    assert calls == {\"config\": \"custom.yaml\", \"dry_run\": True}\n\ndef test_cli_defaults_config_path(monkeypatch):\n    calls = {}\n    monkeypatch.setattr(\"cli.run_sync\", lambda config, dry_run: calls.update(config=config, dry_run=dry_run))\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\"])\n    main()\n    assert calls[\"config\"] == \"sources.yaml\" and calls[\"dry_run\"] is False\n```\n\n---\n\n### 9. Integration gaps (no coverage at any level today)\n\n```python\n# tests/integration/test_end_to_end.py\n@pytest.mark.asyncio\nasync def test_full_pipeline_first_run_then_rerun_only_surfaces_deltas(tmp_path, respx_mock):\n    \"\"\"\n    1. Mock a greenhouse endpoint returning 2 jobs.\n    2. Run pipeline.run() against a temp sqlite db + temp config -> both are 'new'.\n    3. Mock the same endpoint with job #1 unchanged, job #2's title changed, job #3 added.\n    4. Run again -> new=[job3], changed=[job2], and store.count()==3.\n    5. Assert notify.dispatch (patched) was called with exactly that new/changed split.\n    \"\"\"\n    ...\n\ndef test_config_to_filtered_jobs_respects_include_exclude_and_location(tmp_path):\n    \"\"\"End-to-end: load_config -> filter_jobs on real parse_greenhouse() output,\n    verifying keyword/location rules interact correctly with real Job data\n    (not just synthetic Job() instances as in test_filters.py).\"\"\"\n    ...\n\n@pytest.mark.asyncio\nasync def test_scan_marker_roundtrip_via_agent_db_new_and_db_mark(tmp_path, capsys):\n    \"\"\"cmd_db_new (no marker) -> uses since-days window; capture printed watermark;\n    cmd_db_mark(watermark) -> cmd_db_new again -> only rows after watermark returned.\"\"\"\n    ...\n```\n\n---\n\n### Priority ranking\n1. **`store.py` diff logic** and **`fetchers.py` parse_\\* normalizers** — highest risk (silent data corruption / dedup failures) and cheapest to test (pure functions, no I/O once schema/JSON fixtures exist).\n2. **`filters.py`** — small, pure, and the exclude/include precedence + word-boundary behavior is genuinely non-obvious (worth locking in with tests before anyone \"fixes\" it away).\n3. **`fetchers.py` retry wrapper** — the 4xx-gets-retried behavior (fetchers.py:41) is a real latent bug; a test documents/forces a decision.\n4. **`notify.py` dispatch isolation** and **`agent.py` subprocess timeout** — both are error-handling gaps with user-visible failure modes (a hung Chrome render currently crashes rather than failing cleanly).\n5. Bespoke scrapers (Google/D.E. Shaw/Two Sigma/Meta) — lower priority for unit tests since they're regex/positional-index-driven against markup that changes upstream; better served by a periodic live smoke test than by fixture-frozen unit tests, but the *parsing* functions (`parse_deshaw`, `_extract_ds1`, etc.) should still get fixture coverage so refactors don't silently break them.\n",
