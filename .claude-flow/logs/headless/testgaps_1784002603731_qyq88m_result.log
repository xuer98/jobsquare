  "output": "## Test Coverage Analysis — jobsquare\n\n**Current state:** zero test files, zero test framework in `requirements.txt`. All 1,505 lines across 8 modules (`models.py`, `filters.py`, `store.py`, `pipeline.py`, `notify.py`, `fetchers.py`, `agent.py`, `cli.py`) are untested.\n\n### Recommended test infra (add to a new `requirements-dev.txt`)\n```\npytest>=8.0\npytest-asyncio>=0.24\nrespx>=0.21        # mock httpx at the transport layer (fetchers.py, notify.py)\nfreezegun>=1.5     # freeze \"now\" for posted_at/filter cutoff tests\n```\nSuggested layout: `tests/conftest.py` (shared fixtures: `tmp_store`, `job_factory`, `respx_mock`), `tests/test_models.py`, `tests/test_filters.py`, `tests/test_store.py`, `tests/test_notify.py`, `tests/test_fetchers.py`, `tests/test_pipeline.py`, `tests/test_agent.py`, `tests/integration/test_end_to_end.py`.\n\n---\n\n### 1. `models.py`\n\n**Gaps:** `parse_posted_at` epoch/ISO branch logic (models.py:14-37), seconds-vs-ms boundary, malformed input; `Job.content_hash` change detection; `Job.key` stability; `to_row` shape.\n\n```python\n# tests/test_models.py\nimport pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\n@pytest.mark.parametrize(\"raw\", [\"\", None, \"   \"])\ndef test_parse_posted_at_empty_returns_none(raw):\n    assert parse_posted_at(raw) is None\n\ndef test_parse_posted_at_epoch_milliseconds_lever_style():\n    dt = parse_posted_at(\"1643241332430\")\n    assert dt.tzinfo == timezone.utc\n    assert dt.year == 2022\n\ndef test_parse_posted_at_epoch_seconds():\n    dt = parse_posted_at(\"1643241332\")\n    assert dt.year == 2022\n\ndef test_parse_posted_at_boundary_1e12_is_treated_as_ms():\n    # 999_999_999_999 (12 digits) -> seconds; 1_000_000_000_000 -> ms\n    assert parse_posted_at(\"999999999999\").year > 33000  # documents current (odd) behavior\n    assert parse_posted_at(\"1000000000000\").year == 2001\n\ndef test_parse_posted_at_iso_with_z_suffix():\n    dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n    assert dt.tzinfo == timezone.utc\n\ndef test_parse_posted_at_iso_naive_gets_utc_attached():\n    dt = parse_posted_at(\"2024-01-15T10:00:00\")\n    assert dt.tzinfo == timezone.utc\n\ndef test_parse_posted_at_workday_prose_is_unparseable():\n    assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\ndef test_parse_posted_at_garbage_returns_none():\n    assert parse_posted_at(\"not-a-date\") is None\n\ndef test_job_key_is_stable_identity():\n    j = Job(source=\"greenhouse\", company=\"acme\", external_id=\"42\", title=\"X\", url=\"u\")\n    assert j.key == \"greenhouse:acme:42\"\n\ndef test_content_hash_changes_when_title_location_url_department_change():\n    base = dict(source=\"s\", company=\"c\", external_id=\"1\", url=\"u\")\n    j1 = Job(title=\"Engineer\", location=\"NY\", **base)\n    j2 = Job(title=\"Senior Engineer\", location=\"NY\", **base)\n    assert j1.content_hash != j2.content_hash\n\ndef test_content_hash_stable_when_only_posted_at_or_salary_changes():\n    base = dict(source=\"s\", company=\"c\", external_id=\"1\", title=\"Eng\", url=\"u\", location=\"NY\")\n    j1 = Job(posted_at=\"2024-01-01\", **base)\n    j2 = Job(posted_at=\"2024-02-01\", **base)\n    assert j1.content_hash == j2.content_hash  # documents that posted_at isn't part of the hash\n\ndef test_to_row_drops_raw_and_adds_key_and_hash():\n    j = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\", raw={\"secret\": 1})\n    row = j.to_row()\n    assert \"raw\" not in row\n    assert row[\"key\"] == j.key\n    assert row[\"content_hash\"] == j.content_hash\n```\n\n---\n\n### 2. `filters.py`\n\n**Gaps:** word-boundary regex semantics, exclude-vs-include precedence, location substring matching, cutoff with unparseable dates.\n\n```python\n# tests/test_filters.py\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(**kw):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"\", url=\"u\", **kw)\n\ndef test_word_boundary_prevents_substring_match():\n    # \"eng\" must not match \"Engineering\" due to \\b...\\b\n    assert match(_job(title=\"Engineering Manager\"), include=[\"eng\"]) is False\n\ndef test_include_keyword_matches_whole_word():\n    assert match(_job(title=\"Software Engineer\"), include=[\"engineer\"]) is True\n\ndef test_exclude_takes_precedence_over_include():\n    j = _job(title=\"Senior Intern Engineer\")\n    assert match(j, include=[\"engineer\"], exclude=[\"intern\"]) is False\n\ndef test_exclude_is_case_insensitive():\n    assert match(_job(title=\"Sales Manager\"), exclude=[\"MANAGER\"]) is False\n\ndef test_locations_substring_case_insensitive():\n    assert match(_job(location=\"San Francisco, CA\"), locations=[\"san francisco\"]) is True\n    assert match(_job(location=\"Remote - US\"), locations=[\"san francisco\"]) is False\n\ndef test_cutoff_drops_confirmed_stale_posting():\n    cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n    old = _job(posted_at=(cutoff - timedelta(days=10)).isoformat())\n    assert match(old, cutoff=cutoff) is False\n\ndef test_cutoff_keeps_unparseable_posted_at_rather_than_dropping():\n    cutoff = datetime.now(timezone.utc)\n    j = _job(posted_at=\"Posted 3 Days Ago\")  # Workday-style, unparseable\n    assert match(j, cutoff=cutoff) is True\n\ndef test_regex_special_characters_in_keywords_are_escaped():\n    # \"C++\" contains regex metacharacters — must not raise or misbehave\n    assert match(_job(title=\"C++ Developer\"), include=[\"C++\"]) is True\n\ndef test_filter_jobs_applies_max_age_days_as_cutoff():\n    stale = _job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n    fresh = _job(posted_at=datetime.now(timezone.utc).isoformat())\n    result = filter_jobs([stale, fresh], {\"max_age_days\": 7})\n    assert fresh in result and stale not in result\n\ndef test_filter_jobs_empty_rules_returns_all():\n    jobs = [_job(), _job()]\n    assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n### 3. `store.py`\n\n**Gaps:** first-insert vs unchanged vs changed diff paths, `_migrate` additive column, `added_since` exclusivity, meta upsert, duplicate keys within one `diff()` call.\n\n```python\n# tests/test_store.py\nimport pytest\nfrom datetime import datetime, timezone\nfrom models import Job\nfrom store import Store\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\ndef _job(ext_id=\"1\", title=\"T\", **kw):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id, title=title, url=\"u\", **kw)\n\ndef test_diff_first_seen_job_is_new(store):\n    new, changed = store.diff([_job()])\n    assert len(new) == 1 and changed == []\n    assert store.count() == 1\n\ndef test_diff_unchanged_job_is_neither_new_nor_changed(store):\n    store.diff([_job()])\n    new, changed = store.diff([_job()])\n    assert new == [] and changed == []\n\ndef test_diff_changed_content_hash_reports_changed(store):\n    store.diff([_job(title=\"Engineer\")])\n    new, changed = store.diff([_job(title=\"Senior Engineer\")])\n    assert new == [] and len(changed) == 1\n\ndef test_diff_updates_last_seen_on_unchanged_row(store):\n    store.diff([_job()])\n    store.diff([_job()])\n    row = store.conn.execute(\"SELECT first_seen, last_seen FROM jobs\").fetchone()\n    assert row[\"last_seen\"] >= row[\"first_seen\"]\n\ndef test_migrate_adds_salary_range_column_to_legacy_schema(tmp_path):\n    # simulate a pre-salary_range DB created before the column existed\n    import sqlite3\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                     external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n                     employment_type TEXT, posted_at TEXT, content_hash TEXT,\n                     first_seen TEXT, last_seen TEXT)\"\"\")\n    conn.commit(); conn.close()\n    with Store(path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\ndef test_added_since_is_strictly_after_and_ordered(store):\n    ts0 = \"2024-01-01T00:00:00+00:00\"\n    store.diff([_job(ext_id=\"1\")])\n    rows = store.added_since(ts0)\n    assert len(rows) == 1\n    boundary = rows[0][\"first_seen\"]\n    assert store.added_since(boundary) == []  # exclusive on the boundary itself\n\ndef test_get_set_meta_upsert(store):\n    store.set_meta(\"last_scan\", \"a\")\n    store.set_meta(\"last_scan\", \"b\")\n    assert store.get_meta(\"last_scan\") == \"b\"\n\ndef test_get_meta_missing_key_returns_none(store):\n    assert store.get_meta(\"nope\") is None\n\ndef test_diff_duplicate_key_within_same_call(store):\n    # documents current behavior when the same job.key appears twice in one batch\n    dup = _job(ext_id=\"1\")\n    new, changed = store.diff([dup, dup])\n    assert len(new) + len(changed) <= 2  # verify no crash / define expected dedup behavior\n```\n\n---\n\n### 4. `notify.py`\n\n**Gaps:** every notifier's env-var gating (no-op when unset), `dispatch`'s failure isolation, SMS body truncation, HTTP error propagation.\n\n```python\n# tests/test_notify.py\nimport pytest\nimport httpx\nimport respx\nfrom models import Job\nimport notify\n\ndef _job(**kw):\n    return Job(source=\"s\", company=\"Acme\", external_id=\"1\", title=\"Engineer\", url=\"https://x/1\", **kw)\n\ndef test_notify_slack_noop_when_env_unset(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    notify.notify_slack([_job()], [])  # must not raise / must not attempt network\n\ndef test_notify_slack_noop_when_no_jobs(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n    with respx.mock:\n        route = respx.post(\"https://hooks.slack.com/x\")\n        notify.notify_slack([], [])\n        assert not route.called\n\n@respx.mock\ndef test_notify_slack_posts_when_configured_and_jobs_present(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n    route = respx.post(\"https://hooks.slack.com/x\").mock(return_value=httpx.Response(200))\n    notify.notify_slack([_job()], [])\n    assert route.called\n\ndef test_notify_sms_noop_unless_all_four_twilio_vars_set(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n    monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n    notify.notify_sms([_job()], [])  # must not raise\n\n@respx.mock\ndef test_notify_sms_raises_on_twilio_error_response(monkeypatch):\n    for k, v in dict(TWILIO_ACCOUNT_SID=\"sid\", TWILIO_AUTH_TOKEN=\"tok\",\n                      TWILIO_FROM=\"+1\", TWILIO_TO=\"+2\").items():\n        monkeypatch.setenv(k, v)\n    respx.post(url__regex=r\".*Messages\\.json\").mock(return_value=httpx.Response(401))\n    with pytest.raises(httpx.HTTPStatusError):\n        notify.notify_sms([_job()], [])\n\ndef test_sms_body_truncates_after_limit():\n    jobs = [_job(external_id=str(i)) for i in range(12)]\n    body = notify._sms_body(jobs, [], limit=8)\n    assert \"+4 more\" in body\n\ndef test_dispatch_isolates_notifier_failures(monkeypatch, capsys):\n    def boom(new, changed): raise RuntimeError(\"smtp down\")\n    monkeypatch.setattr(notify, \"NOTIFIERS\", [boom, notify.notify_console])\n    notify.dispatch([_job()], [])  # should not raise\n    assert \"notifier boom failed\" in capsys.readouterr().out\n\ndef test_notify_email_noop_when_smtp_host_unset(monkeypatch):\n    monkeypatch.delenv(\"SMTP_HOST\", raising=False)\n    notify.notify_email([_job()], [])  # must not raise / no smtplib.SMTP() call\n```\n\n---\n\n### 5. `fetchers.py` (largest gap — 787 untested lines, 15 ATS integrations)\n\n**Gaps:** retry/backoff behavior including the mis-retry of non-transient 4xx codes, every `parse_*` normalizer's field-fallback logic, pagination stop conditions, and the bespoke scrapers' regex robustness.\n\n```python\n# tests/test_fetchers.py\nimport json\nimport httpx\nimport pytest\nimport respx\nfrom fetchers import (\n    _request, parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n    _amazon_posted_at, parse_amazon, _extract_ds1, _ds1_posted_at, parse_google,\n    parse_deshaw, fetch_workday, fetch_meta, fetch_source, fetch_all, FETCHERS,\n)\n\n# --- retry wrapper -----------------------------------------------------\n@respx.mock\n@pytest.mark.asyncio\nasync def test_request_retries_on_transient_5xx_then_succeeds():\n    route = respx.get(\"https://x/y\").mock(side_effect=[\n        httpx.Response(503), httpx.Response(200, json={\"ok\": True})])\n    async with httpx.AsyncClient() as client:\n        r = await _request(client, \"https://x/y\", retries=3)\n    assert r.status_code == 200 and route.call_count == 2\n\n@respx.mock\n@pytest.mark.asyncio\nasync def test_request_exhausts_retries_and_raises_runtimeerror():\n    respx.get(\"https://x/y\").mock(return_value=httpx.Response(503))\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(RuntimeError):\n            await _request(client, \"https://x/y\", retries=2)\n\n@respx.mock\n@pytest.mark.asyncio\nasync def test_request_retries_non_transient_404_too():\n    # documents current (arguably buggy) behavior: raise_for_status() on a 404\n    # raises HTTPStatusError, which the broad except also catches and retries\n    route = respx.get(\"https://x/y\").mock(return_value=httpx.Response(404))\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(RuntimeError):\n            await _request(client, \"https://x/y\", retries=2)\n    assert route.call_count == 2  # flags wasted retries on a permanent error\n\n# --- parse_* normalizers -------------------------------------------------\ndef test_parse_greenhouse_maps_fields_and_joins_departments():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\", \"absolute_url\": \"u\",\n                       \"location\": {\"name\": \"NY\"},\n                       \"departments\": [{\"name\": \"Platform\"}, {\"name\": \"Core\"}],\n                       \"updated_at\": \"2024-01-01\"}]}\n    jobs = parse_greenhouse(\"acme\", data)\n    assert jobs[0].department == \"Platform, Core\"\n\ndef test_lever_salary_prefers_range_over_description():\n    j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n    assert _lever_salary(j) == \"USD 100,000–150,000\"\n\ndef test_lever_salary_falls_back_to_plain_description():\n    j = {\"salaryDescriptionPlain\": \"Competitive\"}\n    assert _lever_salary(j) == \"Competitive\"\n\ndef test_parse_ashby_skips_unlisted_jobs():\n    data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"}]}\n    assert parse_ashby(\"acme\", data) == []\n\ndef test_amazon_posted_at_parses_us_format():\n    assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\ndef test_amazon_posted_at_handles_malformed_value():\n    assert _amazon_posted_at(\"garbage\") == \"\"\n    assert _amazon_posted_at(\"\") == \"\"\n\ndef test_parse_amazon_falls_back_to_id_icims_when_id_missing():\n    jobs = parse_amazon(\"amazon\", [{\"id_icims\": \"999\", \"title\": \"X\", \"job_path\": \"/p\"}])\n    assert jobs[0].external_id == \"999\"\n\n# --- Google bespoke scraper ----------------------------------------------\ndef test_extract_ds1_parses_embedded_json():\n    html = \"AF_initDataCallback({key: 'ds:1', data:[[[\\\"1\\\",\\\"Title\\\"]]] ,sideChannel:{}})\"\n    data = _extract_ds1(html)\n    assert data == [[\"1\", \"Title\"]]\n\ndef test_extract_ds1_returns_empty_on_missing_blob():\n    assert _extract_ds1(\"<html>no data here</html>\") == []\n\ndef test_extract_ds1_returns_empty_on_malformed_json():\n    html = \"key: 'ds:1', data:[not valid json] ,sideChannel\"\n    assert _extract_ds1(html) == []\n\ndef test_ds1_posted_at_prefers_create_time_index_12():\n    job = [None] * 15\n    job[12] = [1700000000]\n    job[13] = [1800000000]\n    assert \"2023\" in _ds1_posted_at(job)\n\ndef test_parse_google_skips_falsy_entries():\n    assert parse_google(\"google\", [None, [None]]) == []\n\n# --- D.E. Shaw regex scraper ----------------------------------------------\ndef test_parse_deshaw_dedups_repeated_cards():\n    page = ('<div data-job-id=\"123\" class=\"job-display-name\">Eng</div>'\n            '<div data-job-id=\"123\" class=\"job-display-name\">Eng</div>')\n    jobs = parse_deshaw(\"deshaw\", page)\n    assert len(jobs) == 1\n\ndef test_parse_deshaw_missing_location_defaults_empty():\n    page = '<div data-job-id=\"1\" class=\"job-display-name\">Eng</div>'\n    assert parse_deshaw(\"deshaw\", page)[0].location == \"\"\n\n# --- Workday pagination ----------------------------------------------------\n@respx.mock\n@pytest.mark.asyncio\nasync def test_fetch_workday_stops_when_total_reached():\n    respx.post(url__regex=r\".*/jobs\").mock(side_effect=[\n        httpx.Response(200, json={\"jobPostings\": [{\"title\": \"A\", \"bulletFields\": [\"1\"]}], \"total\": 1}),\n    ])\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\", \"page_size\": 20})\n    assert len(jobs) == 1\n\n@respx.mock\n@pytest.mark.asyncio\nasync def test_fetch_workday_stops_on_empty_postings():\n    respx.post(url__regex=r\".*/jobs\").mock(return_value=httpx.Response(200, json={\"jobPostings\": [], \"total\": 0}))\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\"})\n    assert jobs == []\n\n# --- Meta GraphQL quirks ---------------------------------------------------\n@respx.mock\n@pytest.mark.asyncio\nasync def test_fetch_meta_strips_for_loop_protection_prefix_and_raises_on_errors():\n    respx.get(\"https://www.metacareers.com/jobs\").mock(\n      