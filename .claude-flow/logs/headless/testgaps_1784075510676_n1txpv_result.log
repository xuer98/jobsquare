        "title": "1. `models.py` — highest-value target, pure logic, zero I/O",
        "content": "\n**`parse_posted_at`** — untested entirely.\n- Gaps: empty string / `None` → `None`; millisecond epoch (Lever, 13 digits) vs second epoch; negative/malformed numeric strings; ISO-8601 with `Z` suffix; ISO-8601 with explicit offset; naive ISO string (must get UTC attached); garbage string → `None` (currently caught by `except ValueError` — but `TypeError` from non-string weirdness is not caught).\n\n```python\nimport pytest\nfrom datetime import timezone\nfrom models import parse_posted_at\n\nclass TestParsePostedAt:\n    def test_none_and_empty(self):\n        assert parse_posted_at(\"\") is None\n        assert parse_posted_at(None) is None\n\n    def test_millisecond_epoch(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt.tzinfo == timezone.utc\n        assert dt.year == 2022\n\n    def test_second_epoch(self):\n        dt = parse_posted_at(\"1643241332\")\n        assert dt.year == 2022\n\n    def test_iso_with_z_suffix(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00Z\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_naive_gets_utc(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_with_offset_preserved(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00-05:00\")\n        assert dt.utcoffset().total_seconds() == -5 * 3600\n\n    def test_garbage_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_negative_numeric_string(self):\n        # -1 is < 1e12 -> treated as seconds; document/assert actual behavior\n        assert parse_posted_at(\"-1\") is not None\n```\n\n**`Job.key` / `Job.content_hash` / `Job.posted_dt` / `Job.to_row`** — untested.\n\n```python\nfrom models import Job\n\nclass TestJob:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"Engineer\", url=\"https://x\", location=\"SF\",\n                     department=\"Eng\")\n        base.update(overrides)\n        return Job(**base)\n\n    def test_key_is_stable_composite(self):\n        j = self._job()\n        assert j.key == \"greenhouse:acme:1\"\n\n    def test_content_hash_changes_on_title_change(self):\n        a, b = self._job(), self._job(title=\"Senior Engineer\")\n        assert a.content_hash != b.content_hash\n\n    def test_content_hash_stable_for_unrelated_field(self):\n        # posted_at is NOT in the hash blob -> re-fetch with new timestamp\n        # must not register as \"changed\"\n        a, b = self._job(), self._job(posted_at=\"2024-01-01\")\n        assert a.content_hash == b.content_hash\n\n    def test_content_hash_changes_on_location_url_department(self):\n        a = self._job()\n        for field, val in [(\"location\", \"NYC\"), (\"url\", \"https://y\"),\n                            (\"department\", \"Sales\")]:\n            b = self._job(**{field: val})\n            assert a.content_hash != b.content_hash, field\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self):\n        j = self._job(raw={\"secret\": True})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash\n\n    def test_posted_dt_delegates_to_parse_posted_at(self):\n        j = self._job(posted_at=\"1643241332430\")\n        assert j.posted_dt is not None\n```\n\n---\n\n",
