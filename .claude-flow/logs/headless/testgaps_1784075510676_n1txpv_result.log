        "code": "import httpx, pytest, respx\nfrom notify import (notify_slack, notify_webhook, notify_email, notify_sms,\n                     _sms_body, dispatch)\nfrom models import Job\n\ndef _job(**kw):\n    base = dict(source=\"x\", company=\"c\", external_id=\"1\", title=\"Engineer\",\n                url=\"u\", location=\"SF\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestNotifySlack:\n    def test_noop_when_env_var_unset(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with respx.mock:  # nothing mocked -> would error if a request were attempted\n            notify_slack([_job()], [])\n\n    def test_noop_when_no_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack/x\")\n        with respx.mock as m:\n            notify_slack([], [])\n            assert not m.calls\n\n    def test_posts_when_configured_and_new_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack/x\")\n        with respx.mock:\n            route = respx.post(\"https://hooks.slack/x\").mock(return_value=httpx.Response(200))\n            notify_slack([_job()], [])\n            assert route.called\n\nclass TestNotifyWebhook:\n    def test_payload_serializes_jobs_via_to_row(self, monkeypatch):\n        monkeypatch.setenv(\"WEBHOOK_URL\", \"https://hook/x\")\n        with respx.mock:\n            route = respx.post(\"https://hook/x\").mock(return_value=httpx.Response(200))\n            notify_webhook([_job()], [])\n            body = json.loads(route.calls.last.request.content)\n            assert body[\"new\"][0][\"key\"] == \"x:c:1\"\n\nclass TestSmsBody:\n    def test_truncates_over_limit_with_more_count(self):\n        jobs = [_job(external_id=str(i), title=f\"J{i}\") for i in range(10)]\n        body = _sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n\n    def test_ascii_only_no_bullet_or_ellipsis(self):\n        body = _sms_body([_job()], [])\n        assert \"\\u2022\" not in body and \"\\u2026\" not in body\n\nclass TestNotifySms:\n    def test_noop_unless_all_four_twilio_vars_set(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        with respx.mock as m:\n            notify_sms([_job()], [])\n            assert not m.calls\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        for k, v in [(\"TWILIO_ACCOUNT_SID\", \"sid\"), (\"TWILIO_AUTH_TOKEN\", \"tok\"),\n                     (\"TWILIO_FROM\", \"+1\"), (\"TWILIO_TO\", \"+2\")]:\n            monkeypatch.setenv(k, v)\n        with respx.mock:\n            respx.post(url__regex=r\".*Messages\\.json\").mock(\n                return_value=httpx.Response(400, json={\"message\": \"bad\"}))\n            with pytest.raises(httpx.HTTPStatusError):\n                notify_sms([_job()], [])\n\nclass TestDispatch:\n    def test_one_notifier_failure_does_not_block_others(self, monkeypatch, capsys):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://bad\")\n        # respx.mock not configured for slack -> httpx raises inside notify_slack\n        dispatch([_job()], [])  # notify_console must still have printed\n        out = capsys.readouterr().out\n        assert \"NEW listing\" in out\n        assert \"failed\" in out\n\nclass TestNotifyEmail:\n    def test_noop_when_smtp_host_unset(self, monkeypatch):\n        monkeypatch.delenv(\"SMTP_HOST\", raising=False)\n        notify_email([_job()], [])  # must not attempt a connection\n\n    def test_sends_via_smtp(self, monkeypatch):\n        monkeypatch.setenv(\"SMTP_HOST\", \"smtp.test\")\n        monkeypatch.setenv(\"EMAIL_TO\", \"me@x.com\")\n        sent = {}\n        class FakeSMTP:\n            def __init__(self, *a, **k): pass\n            def __enter__(self): return self\n            def __exit__(self, *a): pass\n            def starttls(self): pass\n            def send_message(self, msg): sent[\"msg\"] = msg\n        monkeypatch.setattr(\"notify.smtplib.SMTP\", FakeSMTP)\n        notify_email([_job()], [])\n        assert sent[\"msg\"][\"To\"] == \"me@x.com\""
