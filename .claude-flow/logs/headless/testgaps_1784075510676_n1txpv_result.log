        "code": "import pytest\nfrom datetime import timezone\nfrom models import parse_posted_at\n\nclass TestParsePostedAt:\n    def test_none_and_empty(self):\n        assert parse_posted_at(\"\") is None\n        assert parse_posted_at(None) is None\n\n    def test_millisecond_epoch(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt.tzinfo == timezone.utc\n        assert dt.year == 2022\n\n    def test_second_epoch(self):\n        dt = parse_posted_at(\"1643241332\")\n        assert dt.year == 2022\n\n    def test_iso_with_z_suffix(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00Z\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_naive_gets_utc(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_with_offset_preserved(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00-05:00\")\n        assert dt.utcoffset().total_seconds() == -5 * 3600\n\n    def test_garbage_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_negative_numeric_string(self):\n        # -1 is < 1e12 -> treated as seconds; document/assert actual behavior\n        assert parse_posted_at(\"-1\") is not None"
