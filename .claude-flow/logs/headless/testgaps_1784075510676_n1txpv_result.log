  "output": "No test infrastructure exists yet (no `tests/` directory, and `requirements.txt` only lists `httpx` and `PyYAML` — no pytest). I have enough context now to write the full analysis.\n\n## Test Coverage Analysis — jobsquare\n\n**Current state: zero automated tests.** No `tests/` directory, no test runner in `requirements.txt`. Everything below assumes adding `pytest`, `pytest-asyncio`, and `respx` (httpx-native mocking) as dev dependencies, plus a `tests/` package with a `conftest.py`.\n\n---\n\n### 1. `models.py` — highest-value target, pure logic, zero I/O\n\n**`parse_posted_at`** — untested entirely.\n- Gaps: empty string / `None` → `None`; millisecond epoch (Lever, 13 digits) vs second epoch; negative/malformed numeric strings; ISO-8601 with `Z` suffix; ISO-8601 with explicit offset; naive ISO string (must get UTC attached); garbage string → `None` (currently caught by `except ValueError` — but `TypeError` from non-string weirdness is not caught).\n\n```python\nimport pytest\nfrom datetime import timezone\nfrom models import parse_posted_at\n\nclass TestParsePostedAt:\n    def test_none_and_empty(self):\n        assert parse_posted_at(\"\") is None\n        assert parse_posted_at(None) is None\n\n    def test_millisecond_epoch(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt.tzinfo == timezone.utc\n        assert dt.year == 2022\n\n    def test_second_epoch(self):\n        dt = parse_posted_at(\"1643241332\")\n        assert dt.year == 2022\n\n    def test_iso_with_z_suffix(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00Z\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_naive_gets_utc(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_with_offset_preserved(self):\n        dt = parse_posted_at(\"2024-01-01T00:00:00-05:00\")\n        assert dt.utcoffset().total_seconds() == -5 * 3600\n\n    def test_garbage_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_negative_numeric_string(self):\n        # -1 is < 1e12 -> treated as seconds; document/assert actual behavior\n        assert parse_posted_at(\"-1\") is not None\n```\n\n**`Job.key` / `Job.content_hash` / `Job.posted_dt` / `Job.to_row`** — untested.\n\n```python\nfrom models import Job\n\nclass TestJob:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"Engineer\", url=\"https://x\", location=\"SF\",\n                     department=\"Eng\")\n        base.update(overrides)\n        return Job(**base)\n\n    def test_key_is_stable_composite(self):\n        j = self._job()\n        assert j.key == \"greenhouse:acme:1\"\n\n    def test_content_hash_changes_on_title_change(self):\n        a, b = self._job(), self._job(title=\"Senior Engineer\")\n        assert a.content_hash != b.content_hash\n\n    def test_content_hash_stable_for_unrelated_field(self):\n        # posted_at is NOT in the hash blob -> re-fetch with new timestamp\n        # must not register as \"changed\"\n        a, b = self._job(), self._job(posted_at=\"2024-01-01\")\n        assert a.content_hash == b.content_hash\n\n    def test_content_hash_changes_on_location_url_department(self):\n        a = self._job()\n        for field, val in [(\"location\", \"NYC\"), (\"url\", \"https://y\"),\n                            (\"department\", \"Sales\")]:\n            b = self._job(**{field: val})\n            assert a.content_hash != b.content_hash, field\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self):\n        j = self._job(raw={\"secret\": True})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash\n\n    def test_posted_dt_delegates_to_parse_posted_at(self):\n        j = self._job(posted_at=\"1643241332430\")\n        assert j.posted_dt is not None\n```\n\n---\n\n### 2. `filters.py` — pure logic, currently untested, has subtle edge cases\n\n- Word-boundary regex matching (`\\b`) — e.g. include `\"go\"` should not match `\"mongodb\"` but should match `\"Go Engineer\"`.\n- `exclude` takes priority over `include` when both match.\n- Location filter is substring/case-insensitive, not word-boundary — different semantics from include/exclude, worth pinning down.\n- `cutoff` behavior: jobs with unparseable `posted_at` are **kept**, not dropped (documented intentional behavior — must be pinned by a test so it can't regress silently).\n- Empty rules dict → everything passes.\n- `max_age_days` as a string vs float from YAML.\n\n```python\nfrom datetime import datetime, timedelta, timezone\nfrom filters import match, filter_jobs\nfrom models import Job\n\ndef _job(**kw):\n    base = dict(source=\"x\", company=\"c\", external_id=\"1\", title=\"Backend Engineer\",\n                url=\"u\", location=\"Remote - USA\", department=\"Eng\", posted_at=\"\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestMatch:\n    def test_no_rules_passes(self):\n        assert match(_job()) is True\n\n    def test_include_word_boundary_no_substring_match(self):\n        j = _job(title=\"MongoDB Engineer\")\n        assert match(j, include=[\"go\"]) is False\n\n    def test_include_matches_whole_word(self):\n        j = _job(title=\"Go Engineer\")\n        assert match(j, include=[\"go\"]) is True\n\n    def test_exclude_overrides_include(self):\n        j = _job(title=\"Staff Backend Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"staff\"]) is False\n\n    def test_include_checks_title_department_location(self):\n        j = _job(title=\"X\", department=\"Data Platform\", location=\"Y\")\n        assert match(j, include=[\"platform\"]) is True\n\n    def test_locations_is_case_insensitive_substring(self):\n        j = _job(location=\"Seattle, WA\")\n        assert match(j, locations=[\"seattle\"]) is True\n        assert match(j, locations=[\"Austin\"]) is False\n\n    def test_cutoff_drops_confirmed_old_job(self):\n        old = _job(posted_at=\"2020-01-01T00:00:00Z\")\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(old, cutoff=cutoff) is False\n\n    def test_cutoff_keeps_unparseable_posted_at(self):\n        j = _job(posted_at=\"Posted 3 Days Ago\")  # unparseable prose\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(j, cutoff=cutoff) is True  # intentional: don't nuke unknowns\n\n    def test_cutoff_keeps_recent_job(self):\n        recent = _job(posted_at=datetime.now(timezone.utc).isoformat())\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(recent, cutoff=cutoff) is True\n\nclass TestFilterJobs:\n    def test_max_age_days_as_string_from_yaml(self):\n        old = _job(posted_at=\"2020-01-01T00:00:00Z\")\n        rules = {\"max_age_days\": \"30\"}  # YAML often yields strings\n        assert filter_jobs([old], rules) == []\n\n    def test_empty_rules_returns_all(self):\n        jobs = [_job(), _job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs\n```\n\n---\n\n### 3. `store.py` — SQLite dedup logic, fully untestable-but-untested; use `tmp_path` / in-memory DB\n\nGaps: `diff()` new vs changed vs unchanged classification, `_migrate` additive column backfill, `added_since` boundary (`>` not `>=`), `count`, context-manager close.\n\n```python\nimport pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\ndef _job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\", title=\"Engineer\",\n                url=\"u\", location=\"SF\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestStoreDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_on_second_run_is_neither(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_content_change_is_flagged_changed_not_new(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job(title=\"Staff Engineer\")])\n        assert new == []\n        assert len(changed) == 1\n\n    def test_posted_at_only_change_is_not_flagged(self, store):\n        # posted_at isn't in content_hash -> re-fetch w/ new timestamp is silent\n        store.diff([_job(posted_at=\"2024-01-01\")])\n        new, changed = store.diff([_job(posted_at=\"2024-06-01\")])\n        assert new == [] and changed == []\n\n    def test_last_seen_updates_on_unchanged_rerun(self, store):\n        store.diff([_job()])\n        row_before = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        import time; time.sleep(1.1)\n        store.diff([_job()])\n        row_after = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        assert row_after[\"last_seen\"] != row_before[\"last_seen\"]\n\n    def test_count_reflects_distinct_keys(self, store):\n        store.diff([_job(), _job(external_id=\"2\")])\n        assert store.count() == 2\n\nclass TestStoreMeta:\n    def test_get_meta_missing_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta_roundtrip(self, store):\n        store.set_meta(\"last_scan\", \"2024-01-01T00:00:00\")\n        assert store.get_meta(\"last_scan\") == \"2024-01-01T00:00:00\"\n\n    def test_set_meta_upserts(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\nclass TestAddedSince:\n    def test_strictly_greater_than_excludes_boundary_ts(self, store):\n        store.diff([_job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n        assert store.added_since(ts) == []  # boundary itself excluded\n\n    def test_returns_rows_ordered_by_first_seen(self, store):\n        store.diff([_job(external_id=\"1\")])\n        rows = store.added_since(\"1970-01-01T00:00:00\")\n        assert len(rows) == 1\n\nclass TestMigrate:\n    def test_opens_db_missing_salary_range_column(self, tmp_path):\n        import sqlite3\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(path)\n        conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT,\n            company TEXT, external_id TEXT, title TEXT, url TEXT, location TEXT,\n            department TEXT, employment_type TEXT, posted_at TEXT,\n            content_hash TEXT, first_seen TEXT, last_seen TEXT)\"\"\")\n        conn.commit(); conn.close()\n        with Store(path) as s:  # must not raise\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n```\n\n---\n\n### 4. `fetchers.py` — largest surface, currently zero coverage. Split into parser tests (pure, fast) and fetch-loop tests (need `respx`).\n\n**Untested parsers** (all of them): `parse_greenhouse`, `parse_lever` + `_lever_salary`, `parse_ashby` + `_ashby_salary`, `parse_smartrecruiters`, `parse_recruitee`, `parse_workable`, `_extract_ds1`/`_ds1_posted_at`/`parse_google`, `parse_deshaw`, `parse_twosigma`, `parse_optiver`, `parse_meta`, `parse_microsoft`, `parse_netflix`, `_amazon_posted_at`/`parse_amazon`.\n\nKey edge cases per parser, illustrated for a few representative ones:\n\n```python\nfrom fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       _amazon_posted_at, parse_amazon, _extract_ds1, parse_google,\n                       parse_deshaw, parse_meta)\n\nclass TestParseGreenhouse:\n    def test_missing_location_department_defaults_empty(self):\n        jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1, \"title\": \"E\"}]})\n        assert jobs[0].location == \"\" and jobs[0].department == \"\"\n\n    def test_multi_department_joined(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"E\",\n                           \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Platform\"}]}]}\n        assert parse_greenhouse(\"acme\", data)[0].department == \"Eng, Platform\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_jobs_key_raises_or_defaults(self):\n        # data.get(\"jobs\", []) -> should not raise\n        assert parse_greenhouse(\"acme\", {}) == []\n\n\nclass TestLeverSalary:\n    def test_min_max_formats_with_commas(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_falls_back_to_plain_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n    def test_partial_range_missing_max_falls_back(self):\n        j = {\"salaryRange\": {\"min\": 100000}, \"salaryDescriptionPlain\": \"DOE\"}\n        assert _lever_salary(j) == \"DOE\"\n\n\nclass TestParseAshby:\n    def test_unlisted_job_is_skipped(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"}]}\n        assert parse_ashby(\"acme\", data) == []\n\n    def test_id_falls_back_to_jobid(self):\n        data = {\"jobs\": [{\"jobId\": \"abc\", \"title\": \"E\"}]}\n        assert parse_ashby(\"acme\", data)[0].external_id == \"abc\"\n\n\nclass TestAmazonPostedAt:\n    def test_valid_date_string(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_string_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_empty_string(self):\n        assert _amazon_posted_at(\"\") == \"\"\n\n    def test_unknown_month_returns_empty(self):\n        assert _amazon_posted_at(\"Blorptober 1, 2026\") == \"\"\n\n\nclass TestParseAmazon:\n    def test_id_falls_back_to_id_icims(self):\n        jobs = parse_amazon(\"amazon\", [{\"id_icims\": \"999\", \"title\": \"E\",\n                                         \"job_path\": \"/x\"}])\n        assert jobs[0].external_id == \"999\"\n\n    def test_title_is_stripped(self):\n        jobs = parse_amazon(\"amazon\", [{\"id\": \"1\", \"title\": \"  Engineer  \",\n                                         \"job_path\": \"/x\"}])\n        assert jobs[0].title == \"Engineer\"\n\n    def test_missing_job_path_yields_empty_url(self):\n        jobs = parse_amazon(\"amazon\", [{\"id\": \"1\", \"title\": \"E\"}])\n        assert jobs[0].url == \"\"\n\n\nclass TestGoogleDs1Extraction:\n    def test_extracts_data_array_from_callback(self):\n        html = \"AF_initDataCallback({key: 'ds:1', data:[[[\\\"1\\\",\\\"Title\\\"]]], sideChannel:{}});\"\n        assert _extract_ds1(html) == [[\"1\", \"Title\"]]\n\n    def test_missing_ds1_key_returns_empty(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_malformed_json_returns_empty(self):\n        html = \"key: 'ds:1', data:[[not valid json]], sideChannel:{}\"\n        assert _extract_ds1(html) == []\n\n    def test_fallback_pattern_when_sidechannel_missing(self):\n        html = \"key: 'ds:1', data:[[[\\\"1\\\",\\\"T\\\"]]]});\"\n        assert _extract_ds1(html) == [[\"1\", \"T\"]]\n\n\nclass TestParseDeshaw:\n    def test_dedupes_repeated_job_id(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">A</span>'\n                '</div>' * 2)\n        assert len(parse_deshaw(\"deshaw\", page)) == 1\n\n    def test_missing_title_skips_card(self):\n        page = '<div data-job-id=\"1\"></div>'\n        assert