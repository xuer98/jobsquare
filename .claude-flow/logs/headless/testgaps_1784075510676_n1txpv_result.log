      {
        "title": "3. `store.py` — SQLite dedup logic, fully untestable-but-untested; use `tmp_path` / in-memory DB",
        "content": "\nGaps: `diff()` new vs changed vs unchanged classification, `_migrate` additive column backfill, `added_since` boundary (`>` not `>=`), `count`, context-manager close.\n\n```python\nimport pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\ndef _job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\", title=\"Engineer\",\n                url=\"u\", location=\"SF\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestStoreDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_on_second_run_is_neither(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_content_change_is_flagged_changed_not_new(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job(title=\"Staff Engineer\")])\n        assert new == []\n        assert len(changed) == 1\n\n    def test_posted_at_only_change_is_not_flagged(self, store):\n        # posted_at isn't in content_hash -> re-fetch w/ new timestamp is silent\n        store.diff([_job(posted_at=\"2024-01-01\")])\n        new, changed = store.diff([_job(posted_at=\"2024-06-01\")])\n        assert new == [] and changed == []\n\n    def test_last_seen_updates_on_unchanged_rerun(self, store):\n        store.diff([_job()])\n        row_before = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        import time; time.sleep(1.1)\n        store.diff([_job()])\n        row_after = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        assert row_after[\"last_seen\"] != row_before[\"last_seen\"]\n\n    def test_count_reflects_distinct_keys(self, store):\n        store.diff([_job(), _job(external_id=\"2\")])\n        assert store.count() == 2\n\nclass TestStoreMeta:\n    def test_get_meta_missing_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta_roundtrip(self, store):\n        store.set_meta(\"last_scan\", \"2024-01-01T00:00:00\")\n        assert store.get_meta(\"last_scan\") == \"2024-01-01T00:00:00\"\n\n    def test_set_meta_upserts(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\nclass TestAddedSince:\n    def test_strictly_greater_than_excludes_boundary_ts(self, store):\n        store.diff([_job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n        assert store.added_since(ts) == []  # boundary itself excluded\n\n    def test_returns_rows_ordered_by_first_seen(self, store):\n        store.diff([_job(external_id=\"1\")])\n        rows = store.added_since(\"1970-01-01T00:00:00\")\n        assert len(rows) == 1\n\nclass TestMigrate:\n    def test_opens_db_missing_salary_range_column(self, tmp_path):\n        import sqlite3\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(path)\n        conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT,\n            company TEXT, external_id TEXT, title TEXT, url TEXT, location TEXT,\n            department TEXT, employment_type TEXT, posted_at TEXT,\n            content_hash TEXT, first_seen TEXT, last_seen TEXT)\"\"\")\n        conn.commit(); conn.close()\n        with Store(path) as s:  # must not raise\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "4. `fetchers.py` — largest surface, currently zero coverage. Split into parser tests (pure, fast) and fetch-loop tests (need `respx`).",
        "content": "\n**Untested parsers** (all of them): `parse_greenhouse`, `parse_lever` + `_lever_salary`, `parse_ashby` + `_ashby_salary`, `parse_smartrecruiters`, `parse_recruitee`, `parse_workable`, `_extract_ds1`/`_ds1_posted_at`/`parse_google`, `parse_deshaw`, `parse_twosigma`, `parse_optiver`, `parse_meta`, `parse_microsoft`, `parse_netflix`, `_amazon_posted_at`/`parse_amazon`.\n\nKey edge cases per parser, illustrated for a few representative ones:\n\n```python\nfrom fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       _amazon_posted_at, parse_amazon, _extract_ds1, parse_google,\n                       parse_deshaw, parse_meta)\n\nclass TestParseGreenhouse:\n    def test_missing_location_department_defaults_empty(self):\n        jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1, \"title\": \"E\"}]})\n        assert jobs[0].location == \"\" and jobs[0].department == \"\"\n\n    def test_multi_department_joined(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"E\",\n                           \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Platform\"}]}]}\n        assert parse_greenhouse(\"acme\", data)[0].department == \"Eng, Platform\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_jobs_key_raises_or_defaults(self):\n        # data.get(\"jobs\", []) -> should not raise\n        assert parse_greenhouse(\"acme\", {}) == []\n\n\nclass TestLeverSalary:\n    def test_min_max_formats_with_commas(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_falls_back_to_plain_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n    def test_partial_range_missing_max_falls_back(self):\n        j = {\"salaryRange\": {\"min\": 100000}, \"salaryDescriptionPlain\": \"DOE\"}\n        assert _lever_salary(j) == \"DOE\"\n\n\nclass TestParseAshby:\n    def test_unlisted_job_is_skipped(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"}]}\n        assert parse_ashby(\"acme\", data) == []\n\n    def test_id_falls_back_to_jobid(self):\n        data = {\"jobs\": [{\"jobId\": \"abc\", \"title\": \"E\"}]}\n        assert parse_ashby(\"acme\", data)[0].external_id == \"abc\"\n\n\nclass TestAmazonPostedAt:\n    def test_valid_date_string(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_string_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_empty_string(self):\n        assert _amazon_posted_at(\"\") == \"\"\n\n    def test_unknown_month_returns_empty(self):\n        assert _amazon_posted_at(\"Blorptober 1, 2026\") == \"\"\n\n\nclass TestParseAmazon:\n    def test_id_falls_back_to_id_icims(self):\n        jobs = parse_amazon(\"amazon\", [{\"id_icims\": \"999\", \"title\": \"E\",\n                                         \"job_path\": \"/x\"}])\n        assert jobs[0].external_id == \"999\"\n\n    def test_title_is_stripped(self):\n        jobs = parse_amazon(\"amazon\", [{\"id\": \"1\", \"title\": \"  Engineer  \",\n                                         \"job_path\": \"/x\"}])\n        assert jobs[0].title == \"Engineer\"\n\n    def test_missing_job_path_yields_empty_url(self):\n        jobs = parse_amazon(\"amazon\", [{\"id\": \"1\", \"title\": \"E\"}])\n        assert jobs[0].url == \"\"\n\n\nclass TestGoogleDs1Extraction:\n    def test_extracts_data_array_from_callback(self):\n        html = \"AF_initDataCallback({key: 'ds:1', data:[[[\\\"1\\\",\\\"Title\\\"]]], sideChannel:{}});\"\n        assert _extract_ds1(html) == [[\"1\", \"Title\"]]\n\n    def test_missing_ds1_key_returns_empty(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_malformed_json_returns_empty(self):\n        html = \"key: 'ds:1', data:[[not valid json]], sideChannel:{}\"\n        assert _extract_ds1(html) == []\n\n    def test_fallback_pattern_when_sidechannel_missing(self):\n        html = \"key: 'ds:1', data:[[[\\\"1\\\",\\\"T\\\"]]]});\"\n        assert _extract_ds1(html) == [[\"1\", \"T\"]]\n\n\nclass TestParseDeshaw:\n    def test_dedupes_repeated_job_id(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">A</span>'\n                '</div>' * 2)\n        assert len(parse_deshaw(\"deshaw\", page)) == 1\n\n    def test_missing_title_skips_card(self):\n        page = '<div data-job-id=\"1\"></div>'\n        assert parse_deshaw(\"deshaw\", page) == []\n\n    def test_html_entities_unescaped_in_title(self):\n        page = '<div data-job-id=\"1\"><span class=\"job-display-name\">R&amp;D</span></div>'\n        assert parse_deshaw(\"deshaw\", page)[0].title == \"R&D\"\n\n\nclass TestParseMeta:\n    def test_dedupes_by_id(self):\n        results = [{\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"1\", \"title\": \"A dup\"}]\n        assert len(parse_meta(\"meta\", results)) == 1\n\n    def test_missing_id_is_skipped(self):\n        assert parse_meta(\"meta\", [{\"title\": \"No ID\"}]) == []\n```\n\n**`_request` retry wrapper** — untested, and the highest-risk piece of logic in the file (backoff, retryable-status detection, non-retryable errors, exhaustion). Use `respx` + monkeypatch `asyncio.sleep`.\n\n```python\nimport httpx, pytest, respx\nfrom fetchers import _request, _get_json, fetch_source, fetch_all, FETCHERS\n\n@pytest.mark.asyncio\nclass TestRequestRetry:\n    async def test_success_first_try_no_sleep(self, monkeypatch):\n        async def no_sleep(_): raise AssertionError(\"should not sleep\")\n        monkeypatch.setattr(\"fetchers.asyncio.sleep\", no_sleep)\n        with respx.mock:\n            respx.get(\"https://x/\").mock(return_value=httpx.Response(200, json={}))\n            async with httpx.AsyncClient() as c:\n                r = await _request(c, \"https://x/\")\n                assert r.status_code == 200\n\n    async def test_retries_on_503_then_succeeds(self, monkeypatch):\n        monkeypatch.setattr(\"fetchers.asyncio.sleep\", lambda *_: _AwaitableNone())\n        with respx.mock:\n            route = respx.get(\"https://x/\")\n            route.side_effect = [httpx.Response(503), httpx.Response(200, json={})]\n            async with httpx.AsyncClient() as c:\n                r = await _request(c, \"https://x/\")\n                assert r.status_code == 200\n\n    async def test_exhausts_retries_raises_runtimeerror(self, monkeypatch):\n        monkeypatch.setattr(\"fetchers.asyncio.sleep\", lambda *_: _AwaitableNone())\n        with respx.mock:\n            respx.get(\"https://x/\").mock(return_value=httpx.Response(500))\n            async with httpx.AsyncClient() as c:\n                with pytest.raises(RuntimeError):\n                    await _request(c, \"https://x/\", retries=2)\n\n    async def test_non_retryable_400_raises_immediately_without_retry(self, monkeypatch):\n        calls = []\n        monkeypatch.setattr(\"fetchers.asyncio.sleep\",\n                             lambda *_: calls.append(1) or _AwaitableNone())\n        with respx.mock:\n            respx.get(\"https://x/\").mock(return_value=httpx.Response(400))\n            async with httpx.AsyncClient() as c:\n                with pytest.raises(RuntimeError):\n                    await _request(c, \"https://x/\")\n            assert calls == []  # 400 isn't in the retryable set -> raise_for_status fires once\n```\n(Helper `_AwaitableNone` needed since `monkeypatch` on an async function needs an awaitable stub — use `AsyncMock` from `unittest.mock` in practice.)\n\n**Fetch loops with pagination** (`fetch_twosigma`, `fetch_optiver`, `fetch_google`, `fetch_microsoft`, `fetch_netflix`, `fetch_amazon`, `fetch_workday`) — completely untested. Each shares the same risky pattern: dedup-by-`seen`-set + stop-on-empty-fresh. Gaps:\n- Stops correctly when a page returns no *new* IDs (even if the page itself is non-empty — duplicate page bug).\n- Respects `max_pages` cap when the server never returns empty (infinite-loop protection).\n- `fetch_workday`'s `offset >= total` and `offset > 5000` safety cap.\n\n```python\n@pytest.mark.asyncio\nclass TestFetchOptiverPagination:\n    async def test_stops_on_empty_items(self):\n        with respx.mock:\n            respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n                return_value=httpx.Response(200, json={\"items\": []}))\n            jobs = await FETCHERS[\"optiver\"](httpx.AsyncClient(), {\"company\": \"optiver\"})\n            assert jobs == []\n\n    async def test_stops_when_page_has_no_new_ids(self):\n        # server keeps re-serving the same last page past the end\n        page = {\"items\": [{\"href\": \"/join-us/jobs/a\", \"title\": \"A\"}]}\n        with respx.mock:\n            respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n                return_value=httpx.Response(200, json=page))\n            jobs = await FETCHERS[\"optiver\"](httpx.AsyncClient(), {\"company\": \"optiver\"})\n            assert len(jobs) == 1  # first page's job only; loop breaks on 2nd page dup\n\n    async def test_respects_max_pages_cap(self):\n        counter = {\"n\": 0}\n        def responder(request):\n            counter[\"n\"] += 1\n            return httpx.Response(200, json={\"items\": [\n                {\"href\": f\"/join-us/jobs/{counter['n']}\", \"title\": \"X\"}]})\n        with respx.mock:\n            respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(side_effect=responder)\n            jobs = await FETCHERS[\"optiver\"](httpx.AsyncClient(),\n                                              {\"company\": \"optiver\", \"max_pages\": 3})\n            assert counter[\"n\"] == 3\n\n\n@pytest.mark.asyncio\nclass TestFetchWorkday:\n    async def test_stops_when_offset_reaches_total(self):\n        with respx.mock:\n            respx.post(url__regex=r\".*/jobs$\").mock(\n                return_value=httpx.Response(200, json={\n                    \"jobPostings\": [{\"title\": \"E\", \"externalPath\": \"/e-1\"}],\n                    \"total\": 1}))\n            jobs = await FETCHERS[\"workday\"](httpx.AsyncClient(),\n                {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\"})\n            assert len(jobs) == 1\n\n    async def test_safety_cap_at_5000_offset(self):\n        # server lies about `total`, would loop forever without the >5000 cap\n        with respx.mock:\n            respx.post(url__regex=r\".*/jobs$\").mock(\n                return_value=httpx.Response(200, json={\n                    \"jobPostings\": [{\"title\": \"E\", \"externalPath\": \"/e-1\"}],\n                    \"total\": 999999}))\n            jobs = await FETCHERS[\"workday\"](httpx.AsyncClient(),\n                {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\", \"page_size\": 1000})\n            assert len(jobs) <= 6  # ceil(5000/1000)+1 iterations, not infinite\n```\n\n**`fetch_source` / `fetch_all`** — untested.\n\n```python\n@pytest.mark.asyncio\nclass TestFetchSource:\n    async def test_unknown_ats_raises_valueerror(self):\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            await fetch_source(httpx.AsyncClient(), {\"ats\": \"bogus\"})\n\n@pytest.mark.asyncio\nclass TestFetchAll:\n    async def test_one_source_failure_does_not_abort_others(self, capsys):\n        with respx.mock:\n            respx.get(url__regex=r\".*greenhouse.*\").mock(\n                side_effect=httpx.ConnectError(\"boom\"))\n            respx.get(url__regex=r\".*lever.*\").mock(\n                return_value=httpx.Response(200, json=[]))\n            jobs = await fetch_all([\n                {\"ats\": \"greenhouse\", \"company\": \"a\"},\n                {\"ats\": \"lever\", \"company\": \"b\"},\n            ])\n            assert jobs == []  # both empty, but no exception raised\n            assert \"failed\" in capsys.readouterr().out\n\n    async def test_concurrency_semaphore_limits_in_flight(self):\n        # spawn N sources with a mocked fetcher that records max concurrent calls\n        ...  # needs a manual semaphore-probe fetcher injected via FETCHERS monkeypatch\n```\n\n**`fetch_meta`** — untested and the riskiest fetcher (token scraping + `for (;;);` JSON prefix stripping + rotated `doc_id` error surfacing).\n\n```python\n@pytest.mark.asyncio\nclass TestFetchMeta:\n    async def test_strips_for_loop_prefix(self):\n        page_html = '[\"LSD\",[],{\"token\":\"tok123\"}] \"__spin_r\":5 \"__spin_b\":\"b\" \"__spin_t\":1'\n        gql_body = 'for (;;);' + json.dumps({\"data\": {\n            \"job_search_with_featured_jobs_v2\": {\"all_jobs\": [{\"id\": \"1\", \"title\": \"E\"}]}}})\n        with respx.mock:\n            respx.get(\"https://www.metacareers.com/jobs\").mock(\n                return_value=httpx.Response(200, text=page_html))\n            respx.post(\"https://www.metacareers.com/graphql\").mock(\n                return_value=httpx.Response(200, text=gql_body))\n            jobs = await fetch_meta(httpx.AsyncClient(), {\"company\": \"meta\"})\n            assert len(jobs) == 1\n\n    async def test_graphql_error_raises_with_rotated_doc_id_hint(self):\n        page_html = '[\"LSD\",[],{\"token\":\"tok123\"}]'\n        gql_body = json.dumps({\"errors\": [{\"message\": \"Unsupported query\"}]})\n        with respx.mock:\n            respx.get(\"https://www.metacareers.com/jobs\").mock(\n                return_value=httpx.Response(200, text=page_html))\n            respx.post(\"https://www.metacareers.com/graphql\").mock(\n                return_value=httpx.Response(200, text=gql_body))\n            with pytest.raises(RuntimeError, match=\"graphql\"):\n                await fetch_meta(httpx.AsyncClient(), {\"company\": \"meta\"})\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "5. `notify.py` — untested; all activation gates depend on env vars, easy to unit test with `monkeypatch.setenv` / `delenv` + `respx`/mock `httpx.post`",
        "content": "\n```python\nimport httpx, pytest, respx\nfrom notify import (notify_slack, notify_webhook, notify_email, notify_sms,\n                     _sms_body, dispatch)\nfrom models import Job\n\ndef _job(**kw):\n    base = dict(source=\"x\", company=\"c\", external_id=\"1\", title=\"Engineer\",\n                url=\"u\", location=\"SF\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestNotifySlack:\n    def test_noop_when_env_var_unset(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with respx.mock:  # nothing mocked -> would error if a request were attempted\n            notify_slack([_job()], [])\n\n    def test_noop_when_no_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack/x\")\n        with respx.mock as m:\n            notify_slack([], [])\n            assert not m.calls\n\n    def test_posts_when_configured_and_new_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack/x\")\n        with respx.mock:\n            route = respx.post(\"https://hooks.slack/x\").mock(return_value=httpx.Response(200))\n            notify_slack([_job()], [])\n            assert route.called\n\nclass TestNotifyWebhook:\n    def test_payload_serializes_jobs_via_to_row(self, monkeypatch):\n        monkeypatch.setenv(\"WEBHOOK_URL\", \"https://hook/x\")\n        with respx.mock:\n            route = respx.post(\"https://hook/x\").mock(return_value=httpx.Response(200))\n            notify_webhook([_job()], [])\n            body = json.loads(route.calls.last.request.content)\n            assert body[\"new\"][0][\"key\"] == \"x:c:1\"\n\nclass TestSmsBody:\n    def test_truncates_over_limit_with_more_count(self):\n        jobs = [_job(external_id=str(i), title=f\"J{i}\") for i in range(10)]\n        body = _sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n\n    def test_ascii_only_no_bullet_or_ellipsis(self):\n        body = _sms_body([_job()], [])\n        assert \"\\u2022\" not in body and \"\\u2026\" not in body\n\nclass TestNotifySms:\n    def test_noop_unless_all_four_twilio_vars_set(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        with respx.mock as m:\n            notify_sms([_job()], [])\n            assert not m.calls\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        for k, v in [(\"TWILIO_ACCOUNT_SID\", \"sid\"), (\"TWILIO_AUTH_TOKEN\", \"tok\"),\n                     (\"TWILIO_FROM\", \"+1\"), (\"TWILIO_TO\", \"+2\")]:\n            monkeypatch.setenv(k, v)\n        with respx.mock:\n            respx.post(url__regex=r\".*Messages\\.json\").mock(\n                return_value=httpx.Response(400, json={\"message\": \"bad\"}))\n            with pytest.raises(httpx.HTTPStatusError):\n                notify_sms([_job()], [])\n\nclass TestDispatch:\n    def test_one_notifier_failure_does_not_block_others(self, monkeypatch, capsys):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://bad\")\n        # respx.mock not configured for slack -> httpx raises inside notify_slack\n        dispatch([_job()], [])  # notify_console must still have printed\n        out = capsys.readouterr().out\n        assert \"NEW listing\" in out\n        assert \"failed\" in out\n\nclass TestNotifyEmail:\n    def test_noop_when_smtp_host_unset(self, monkeypatch):\n        monkeypatch.delenv(\"SMTP_HOST\", raising=False)\n        notify_email([_job()], [])  # must not attempt a connection\n\n    def test_sends_via_smtp(self, monkeypatch):\n        monkeypatch.setenv(\"SMTP_HOST\", \"smtp.test\")\n        monkeypatch.setenv(\"EMAIL_TO\", \"me@x.com\")\n        sent = {}\n        class FakeSMTP:\n            def __init__(self, *a, **k): pass\n            def __enter__(self): return self\n            def __exit__(self, *a): pass\n            def starttls(self): pass\n            def send_message(self, msg): sent[\"msg\"] = msg\n        monkeypatch.setattr(\"notify.smtplib.SMTP\", FakeSMTP)\n        notify_email([_job()], [])\n        assert sent[\"msg\"][\"To\"] == \"me@x.com\"\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "6. `pipeline.py` — orchestration, untested; needs a fake `Store`/fetcher/config fixture",
        "content": "\n```python\nimport pytest\nfrom pipeline import load_config, run\n\nclass TestLoadConfig:\n    def test_defaults_filled_in(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"sources: []\\n\")\n        cfg = load_config(p)\n        assert cfg == {\"sources\": [], \"filters\": {}, \"db\": \"jobs.db\", \"concurrency\": 8}\n\n    def test_missing_file_raises(self):\n        with pytest.raises(FileNotFoundError):\n            load_config(\"/no/such/file.yaml\")\n\n    def test_empty_yaml_file(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"\")\n        with pytest.raises(AttributeError):  # cfg.setdefault on None -> current bug risk\n            load_config(p)\n\n@pytest.mark.asyncio\nclass TestRun:\n    async def test_dry_run_does_not_touch_store(self, tmp_path, monkeypatch):\n        cfg_path = tmp_path / \"c.yaml\"\n        cfg_path.write_text(f\"sources: []\\ndb: {tmp_path/'x.db'}\\n\")\n        result = await run(cfg_path, dry_run=True)\n        assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n        assert not (tmp_path / \"x.db\").exists()\n\n    async def test_full_run_persists_and_dispatches(self, tmp_path, monkeypatch):\n        # monkeypatch fetch_all to return canned jobs, notify.dispatch to a spy\n        ...\n```\nNote `test_empty_yaml_file` documents a real gap: `yaml.safe_load(\"\")` returns `None`, and `cfg.setdefault` on `None` raises `AttributeError` — worth confirming intended behavior (should probably default to `{}`).\n\n---\n\n",
