s\": [{\"jobId\": \"abc\", \"title\": \"E\"}]}\n        assert parse_ashby(\"acme\", data)[0].external_id == \"abc\"\n\n\nclass TestAmazonPostedAt:\n    def test_valid_date_string(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_string_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_empty_string(self):\n        assert _amazon_posted_at(\"\") == \"\"\n\n    def test_unknown_month_returns_empty(self):\n        assert _amazon_posted_at(\"Blorptober 1, 2026\") == \"\"\n\n\nclass TestParseAmazon:\n    def test_id_falls_back_to_id_icims(self):\n        jobs = parse_amazon(\"amazon\", [{\"id_icims\": \"999\", \"title\": \"E\",\n                                         \"job_path\": \"/x\"}])\n        assert jobs[0].external_id == \"999\"\n\n    def test_title_is_stripped(self):\n        jobs = parse_amazon(\"amazon\", [{\"id\": \"1\", \"title\": \"  Engineer  \",\n                                         \"job_path\": \"/x\"}])\n        assert jobs[0].title == \"Engineer\"\n\n    def test_missing_job_path_yields_empty_url(self):\n        jobs = parse_amazon(\"amazon\", [{\"id\": \"1\", \"title\": \"E\"}])\n        assert jobs[0].url == \"\"\n\n\nclass TestGoogleDs1Extraction:\n    def test_extracts_data_array_from_callback(self):\n        html = \"AF_initDataCallback({key: 'ds:1', data:[[[\\\"1\\\",\\\"Title\\\"]]], sideChannel:{}});\"\n        assert _extract_ds1(html) == [[\"1\", \"Title\"]]\n\n    def test_missing_ds1_key_returns_empty(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_malformed_json_returns_empty(self):\n        html = \"key: 'ds:1', data:[[not valid json]], sideChannel:{}\"\n        assert _extract_ds1(html) == []\n\n    def test_fallback_pattern_when_sidechannel_missing(self):\n        html = \"key: 'ds:1', data:[[[\\\"1\\\",\\\"T\\\"]]]});\"\n        assert _extract_ds1(html) == [[\"1\", \"T\"]]\n