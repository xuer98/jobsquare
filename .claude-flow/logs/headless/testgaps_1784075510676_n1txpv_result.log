        "code": "from datetime import datetime, timedelta, timezone\nfrom filters import match, filter_jobs\nfrom models import Job\n\ndef _job(**kw):\n    base = dict(source=\"x\", company=\"c\", external_id=\"1\", title=\"Backend Engineer\",\n                url=\"u\", location=\"Remote - USA\", department=\"Eng\", posted_at=\"\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestMatch:\n    def test_no_rules_passes(self):\n        assert match(_job()) is True\n\n    def test_include_word_boundary_no_substring_match(self):\n        j = _job(title=\"MongoDB Engineer\")\n        assert match(j, include=[\"go\"]) is False\n\n    def test_include_matches_whole_word(self):\n        j = _job(title=\"Go Engineer\")\n        assert match(j, include=[\"go\"]) is True\n\n    def test_exclude_overrides_include(self):\n        j = _job(title=\"Staff Backend Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"staff\"]) is False\n\n    def test_include_checks_title_department_location(self):\n        j = _job(title=\"X\", department=\"Data Platform\", location=\"Y\")\n        assert match(j, include=[\"platform\"]) is True\n\n    def test_locations_is_case_insensitive_substring(self):\n        j = _job(location=\"Seattle, WA\")\n        assert match(j, locations=[\"seattle\"]) is True\n        assert match(j, locations=[\"Austin\"]) is False\n\n    def test_cutoff_drops_confirmed_old_job(self):\n        old = _job(posted_at=\"2020-01-01T00:00:00Z\")\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(old, cutoff=cutoff) is False\n\n    def test_cutoff_keeps_unparseable_posted_at(self):\n        j = _job(posted_at=\"Posted 3 Days Ago\")  # unparseable prose\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(j, cutoff=cutoff) is True  # intentional: don't nuke unknowns\n\n    def test_cutoff_keeps_recent_job(self):\n        recent = _job(posted_at=datetime.now(timezone.utc).isoformat())\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(recent, cutoff=cutoff) is True\n\nclass TestFilterJobs:\n    def test_max_age_days_as_string_from_yaml(self):\n        old = _job(posted_at=\"2020-01-01T00:00:00Z\")\n        rules = {\"max_age_days\": \"30\"}  # YAML often yields strings\n        assert filter_jobs([old], rules) == []\n\n    def test_empty_rules_returns_all(self):\n        jobs = [_job(), _job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs"
