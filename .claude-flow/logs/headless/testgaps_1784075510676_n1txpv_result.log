etattr(\"fetchers.asyncio.sleep\", lambda *_: _AwaitableNone())\n        with respx.mock:\n            respx.get(\"https://x/\").mock(return_value=httpx.Response(500))\n            async with httpx.AsyncClient() as c:\n                with pytest.raises(RuntimeError):\n                    await _request(c, \"https://x/\", retries=2)\n\n    async def test_non_retryable_400_raises_immediately_without_retry(self, monkeypatch):\n        calls = []\n        monkeypatch.setattr(\"fetchers.asyncio.sleep\",\n                             lambda *_: calls.append(1) or _AwaitableNone())\n        with respx.mock:\n            respx.get(\"https://x/\").mock(return_value=httpx.Response(400))\n            async with httpx.AsyncClient() as c:\n                with pytest.raises(RuntimeError):\n                    await _request(c, \"https://x/\")\n            assert calls == []  # 400 isn't in the retryable set -> raise_for_status fires once\n```\n(Helper `_AwaitableNone` needed since `monkeypatch` on an async function needs an awaitable stub — use `AsyncMock` from `unittest.mock` in practice.)\n\n**Fetch loops with pagination** (`fetch_twosigma`, `fetch_optiver`, `fetch_google`, `fetch_microsoft`, `fetch_netflix`, `fetch_amazon`, `fetch_workday`) — completely untested. Each shares the same risky pattern: dedup-by-`seen`-set + stop-on-empty-fresh. Gaps:\n- Stops correctly when a page returns no *new* IDs (even if the page itself is non-empty — duplicate page bug).\n- Respects `max_pages` cap when the server never returns empty (infinite-loop protection).\n- `fetch_workday`'s `offset >= total` and `offset > 5000` safety cap.\n\n```python\n@pytest.mark.asyncio\nclass TestFetchOptiverPagination:\n    async def test_stops_on_empty_items(self):\n        with respx.mock:\n            respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n                return_value=httpx.Response(200, json={\"items\": []}))\n            jobs = await FETCHERS[\"optiver\"](httpx.AsyncClient(), {\"company\": \"optiver\"})\n            assert jobs == []\n\n    async def test_stops_when_page_has_no_new_ids(self):\n        # server keeps re-serving the same last page past the end\n        page = {\"items\": [{\"href\": \"/join-us/jobs/a\", \"title\": \"A\"}]}\n        with respx.mock:\n            respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n                return_value=httpx.Response(200, json=page))\n            jobs = await FETCHERS[\"optiver\"](httpx.AsyncClient(), {\"company\": \"optiver\"})\n            assert len(jobs) == 1  # first page's job only; loop breaks on 2nd page dup\n\n    async def test_respects_max_pages_cap(self):\n        counter = {\"n\": 0}\n        def responder(request):\n            counter[\"n\"] += 1\n            return httpx.Response(200, json={\"items\": [\n                {\"href\": f\"/join-us/jobs/{counter['n']}\", \"title\": \"X\"}]})\n        with respx.mock:\n            respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(side_effect=responder)\n            jobs = await FETCHERS[\"optiver\"](httpx.AsyncClient(),\n                                              {\"company\": \"optiver\", \"max_pages\": 3})\n            assert counter[\"n\"] == 3\n\n\n@pytest.mark.asyncio\nclass TestFetchWorkday:\n    async def test_stops_when_offset_reaches_total(self):\n        with respx.mock:\n            respx.post(url__regex=r\".*/jobs$\").mock(\n                return_value=httpx.Response(200, json={\n                    \"jobPostings\": [{\"title\": \"E\", \"externalPath\": \"/e-1\"}],\n                    \"total\": 1}))\n            jobs = await FETCHERS[\"workday\"](httpx.AsyncClient(),\n                {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\"})\n            assert len(jobs) == 1\n\n    async def test_safety_cap_at_5000_offset(self):\n        # server lies about `total`, would loop forever without the >5000 cap\n        with respx.mock:\n            respx.post(url__regex=r\".*/jobs$\").mock(\n                return_value=httpx.Response(200, json={\n                    \"jobPostings\": [{\"title\": \"E\", \"externalPath\": \"/e-1\"}],\n                    \"total\": 999999}))\n            jobs = await FETCHERS[\"workday\"](httpx.AsyncClient(),\n                {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\", \"page_size\": 1000})\n            assert len(jobs) <= 6  # ceil(5000/1000)+1 iterations, not infinite\n```\n\n**`fetch_source` / `fetch_all`** — untested.\n\n```python\n@pytest.mark.asyncio\nclass TestFetchSource:\n    async def test_unknown_ats_raises_valueerror(self):\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            await fetch_source(httpx.AsyncClient(), {\"ats\": \"bogus\"})\n\n@pytest.mark.asyncio\nclass TestFetchAll:\n    async def test_one_source_failure_does_not_abort_others(self, capsys):\n        with respx.mock:\n            respx.get(url__regex=r\".*greenhouse.*\").mock(\n                side_effect=httpx.ConnectError(\"boom\"))\n            respx.get(url__regex=r\".*lever.*\").mock(\n                return_value=httpx.Response(200, json=[]))\n            jobs = await fetch_all([\n                {\"ats\": \"greenhouse\", \"company\": \"a\"},\n                {\"ats\": \"lever\", \"company\": \"b\"},\n            ])\n            assert jobs == []  # both empty, but no exception raised\n            assert \"failed\" in capsys.readouterr().out\n\n    async def test_concurrency_semaphore_limits_in_flight(self):\n        # spawn N sources with a mocked fetcher that records max concurrent calls\n        ...  # needs a manual semaphore-probe fetcher injected via FETCHERS monkeypatch\n```\n\n**`fetch_meta`** — untested and the riskiest fetcher (token scraping + `for (;;);` JSON prefix stripping + rotated `doc_id` error surfacing).\n\n```python\n@pytest.mark.asyncio\nclass TestFetchMeta:\n    async def test_strips_for_loop_prefix(self):\n        page_html = '[\"LSD\",[],{\"token\":\"tok123\"}] \"__spin_r\":5 \"__spin_b\":\"b\" \"__spin_t\":1'\n        gql_body = 'for (;;);' + json.dumps({\"data\": {\n            \"job_search_with_featured_jobs_v2\": {\"all_jobs\": [{\"id\": \"1\", \"title\": \"E\"}]}}})\n        with respx.mock:\n            respx.get(\"https://www.metacareers.com/jobs\").mock(\n                return_value=httpx.Response(200, text=page_html))\n            respx.post(\"https://www.metacareers.com/graphql\").mock(\n                return_value=httpx.Response(200, text=gql_body))\n            jobs = await fetch_meta(httpx.AsyncClient(), {\"company\": \"meta\"})\n            assert len(jobs) == 1\n\n    async def test_graphql_error_raises_with_rotated_doc_id_hint(self):\n        page_html = '[\"LSD\",[],{\"token\":\"tok123\"}]'\n        gql_body = json.dumps({\"errors\": [{\"message\": \"Unsupported query\"}]})\n        with respx.mock:\n            respx.get(\"https://www.metacareers.com/jobs\").mock(\n                return_value=httpx.Response(200, text=page_html))\n            respx.post(\"https://www.metacareers.com/graphql\").mock(\n                return_value=httpx.Response(200, text=gql_body))\n            with pytest.raises(RuntimeError, match=\"graphql\"):\n                await fetch_meta(httpx.AsyncClient(), {\"company\": \"meta\"})\n```\n\n---\n\n### 5. `notify.py` — untested; all activation gates depend on env vars, easy to unit test with `monkeypatch.setenv` / `delenv` + `respx`/mock `httpx.post`\n\n```python\nimport httpx, pytest, respx\nfrom notify import (notify_slack, notify_webhook, notify_email, notify_sms,\n                     _sms_body, dispatch)\nfrom models import Job\n\ndef _job(**kw):\n    base = dict(source=\"x\", company=\"c\", external_id=\"1\", title=\"Engineer\",\n                url=\"u\", location=\"SF\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestNotifySlack:\n    def test_noop_when_env_var_unset(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with respx.mock:  # nothing mocked -> would error if a request were attempted\n            notify_slack([_job()], [])\n\n    def test_noop_when_no_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack/x\")\n        with respx.mock as m:\n            notify_slack([], [])\n            assert not m.calls\n\n    def test_posts_when_configured_and_new_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack/x\")\n        with respx.mock:\n            route = respx.post(\"https://hooks.slack/x\").mock(return_value=httpx.Response(200))\n            notify_slack([_job()], [])\n            assert route.called\n\nclass TestNotifyWebhook:\n    def test_payload_serializes_jobs_via_to_row(self, monkeypatch):\n        monkeypatch.setenv(\"WEBHOOK_URL\", \"https://hook/x\")\n        with respx.mock:\n            route = respx.post(\"https://hook/x\").mock(return_value=httpx.Response(200))\n            notify_webhook([_job()], [])\n            body = json.loads(route.calls.last.request.content)\n            assert body[\"new\"][0][\"key\"] == \"x:c:1\"\n\nclass TestSmsBody:\n    def test_truncates_over_limit_with_more_count(self):\n        jobs = [_job(external_id=str(i), title=f\"J{i}\") for i in range(10)]\n        body = _sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n\n    def test_ascii_only_no_bullet_or_ellipsis(self):\n        body = _sms_body([_job()], [])\n        assert \"\\u2022\" not in body and \"\\u2026\" not in body\n\nclass TestNotifySms:\n    def test_noop_unless_all_four_twilio_vars_set(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        with respx.mock as m:\n            notify_sms([_job()], [])\n            assert not m.calls\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        for k, v in [(\"TWILIO_ACCOUNT_SID\", \"sid\"), (\"TWILIO_AUTH_TOKEN\", \"tok\"),\n                     (\"TWILIO_FROM\", \"+1\"), (\"TWILIO_TO\", \"+2\")]:\n            monkeypatch.setenv(k, v)\n        with respx.mock:\n            respx.post(url__regex=r\".*Messages\\.json\").mock(\n                return_value=httpx.Response(400, json={\"message\": \"bad\"}))\n            with pytest.raises(httpx.HTTPStatusError):\n                notify_sms([_job()], [])\n\nclass TestDispatch:\n    def test_one_notifier_failure_does_not_block_others(self, monkeypatch, capsys):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://bad\")\n        # respx.mock not configured for slack -> httpx raises inside notify_slack\n        dispatch([_job()], [])  # notify_console must still have printed\n        out = capsys.readouterr().out\n        assert \"NEW listing\" in out\n        assert \"failed\" in out\n\nclass TestNotifyEmail:\n    def test_noop_when_smtp_host_unset(self, monkeypatch):\n        monkeypatch.delenv(\"SMTP_HOST\", raising=False)\n        notify_email([_job()], [])  # must not attempt a connection\n\n    def test_sends_via_smtp(self, monkeypatch):\n        monkeypatch.setenv(\"SMTP_HOST\", \"smtp.test\")\n        monkeypatch.setenv(\"EMAIL_TO\", \"me@x.com\")\n        sent = {}\n        class FakeSMTP:\n            def __init__(self, *a, **k): pass\n            def __enter__(self): return self\n            def __exit__(self, *a): pass\n            def starttls(self): pass\n            def send_message(self, msg): sent[\"msg\"] = msg\n        monkeypatch.setattr(\"notify.smtplib.SMTP\", FakeSMTP)\n        notify_email([_job()], [])\n        assert sent[\"msg\"][\"To\"] == \"me@x.com\"\n```\n\n---\n\n### 6. `pipeline.py` — orchestration, untested; needs a fake `Store`/fetcher/config fixture\n\n```python\nimport pytest\nfrom pipeline import load_config, run\n\nclass TestLoadConfig:\n    def test_defaults_filled_in(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"sources: []\\n\")\n        cfg = load_config(p)\n        assert cfg == {\"sources\": [], \"filters\": {}, \"db\": \"jobs.db\", \"concurrency\": 8}\n\n    def test_missing_file_raises(self):\n        with pytest.raises(FileNotFoundError):\n            load_config(\"/no/such/file.yaml\")\n\n    def test_empty_yaml_file(self, tmp_path):\n        p = tmp_path / \"c.yaml\"\n        p.write_text(\"\")\n        with pytest.raises(AttributeError):  # cfg.setdefault on None -> current bug risk\n            load_config(p)\n\n@pytest.mark.asyncio\nclass TestRun:\n    async def test_dry_run_does_not_touch_store(self, tmp_path, monkeypatch):\n        cfg_path = tmp_path / \"c.yaml\"\n        cfg_path.write_text(f\"sources: []\\ndb: {tmp_path/'x.db'}\\n\")\n        result = await run(cfg_path, dry_run=True)\n        assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n        assert not (tmp_path / \"x.db\").exists()\n\n    async def test_full_run_persists_and_dispatches(self, tmp_path, monkeypatch):\n        # monkeypatch fetch_all to return canned jobs, notify.dispatch to a spy\n        ...\n```\nNote `test_empty_yaml_file` documents a real gap: `yaml.safe_load(\"\")` returns `None`, and `cfg.setdefault` on `None` raises `AttributeError` — worth confirming intended behavior (should probably default to `{}`).\n\n---\n\n### 7. `agent.py` — CLI/data-helper layer, untested\n\n**`_normalize_ats`** (ATS character normalization) — pure and high-value:\n```python\nfrom agent import _normalize_ats\n\nclass TestNormalizeAts:\n    def test_em_dash_and_smart_quotes_replaced(self):\n        html = \"<p>It\\u2019s \\u201Cgreat\\u201D \\u2014 really</p>\"\n        out, counts = _normalize_ats(html)\n        assert \"\\u2019\" not in out and \"\\u201C\" not in out and \"\\u2014\" not in out\n        assert counts[\"em-dash\"] == 1\n\n    def test_does_not_touch_style_or_script_blocks(self):\n        html = '<style>body{content:\"\\u2014\"}</style><p>\\u2014</p>'\n        out, counts = _normalize_ats(html)\n        assert \"\\u2014\" in out.split(\"</style>\")[0]  # untouched inside style\n        assert counts[\"em-dash\"] == 1  # only the <p> one counted\n\n    def test_does_not_touch_tag_attributes(self):\n        html = '<a title=\"\\u2014\">x</a>'\n        out, counts = _normalize_ats(html)\n        assert 'title=\"\\u2014\"' in out  # inside a tag -> untouched\n        assert \"em-dash\" not in counts\n\n    def test_zero_width_chars_stripped(self):\n        out, counts = _normalize_ats(\"a\\u200bb\")\n        assert out == \"ab\"\n```\n\n**`cmd_db_new` / `cmd_db_mark`** — integration-ish, use a real temp `Store`:\n```python\nclass TestDbNewMark:\n    def test_first_run_uses_since_days_window(self, tmp_path, capsys):\n        # no marker set -> since = now - since_days\n        ...\n    def test_truncation_respects_group_boundaries(self, tmp_path, capsys):\n        # two jobs sharing first_seen must not be split across the limit\n        ...\n    def test_db_mark_rejects_non_iso_watermark(self, capsys):\n        rc = cmd_db_mark([\"not-a-timestamp\"])\n        assert rc == 2\n    def test_db_mark_requires_watermark_or_now(self, capsys):\n        rc = cmd_db_mark([])\n        assert rc == 2\n```\n\n**`_chrome_bin`** — untested; environment-dependent, needs `monkeypatch` on `shutil.which` and `Path.exists`.\n\n**`cmd_pdf_render`** — needs a real/fake Chrome binary or a `subprocess.run` monkeypatch; test the \"no such input file\" and \"render produced non-PDF output\" failure paths without invoking real Chrome:\n```python\nclass TestPdfRenderErrors:\n    def test_missing_input_file_returns_2(self, capsys):\n        rc = cmd_pdf_render([\"/no/such/file.html\"])\n        assert rc == 2\n\n    def test_render_failure_when_output_not_pdf(self, tmp_path, monkeypatch):\n        src = tmp_path / \"in.html\"; src.write_text(\"<html></html>\")\n        monkeypatch.setattr(\"agent.subprocess.run\",\n                             lambda *a, **k: type(\"R\", (), {\"stderr\": \"boom\", \"returncode\": 1})())\n        monkeypatch.setattr(\"agent._chrome_bin\", lambda: \"/bin/true\")\n        rc = cmd_pdf_render([str(src)])\n        assert rc == 1\n```\n\n**`main()` argv routing** — untested (mode-word vs flag splitting, `-i`/`--interactive` handling):\n```python\nclass TestMainRouting:\n    def test_help_flag_short_circuits(self, capsys):\n        assert main.__wrapped__ if False else None  # invoke via sys.argv monkeypatch\n    def test_bare_invocation_is_interactive(self, monkeypatch):\n        ...\n    def test_flag_after_mode_words_splits_correctly(self, monkeypatch):\n        # agent.py scan --foo bar -> mode_words=[\"scan\"], extra=[\"--foo\",\"bar\"]\n        ...\n```\n\n---\n\n### 8. Integration test gaps (cross-module)\n\nNone currently exist. Highest-value additions:\n\n1. **End-to-end pipeline run against mocked fetchers**: fetch → filter → store.diff → notify, using `respx` for one real ATS shape (e.g. greenhouse) and asserting the DB row count and notifier console output together.\n2. **Re-run idempotency**: run the pipeline twice against identical fetch data; second run must report `new=0, changed=0` and not duplicate rows.\n3. **Schema migration integration**: open a pre-`salary_range` DB fixture through the full `pipeline.run` path, not just `Store.__init__` directly.\n4. **`agent.py db-new` → `db-mark` cycle** against a real pipeline-populated `Store`, verifying the watermark advances only on `db-mark` and that a second `db-new` before marking returns the same window.\n5. **Config-driven multi-ATS fetch** (`sources.yaml`-shaped fixture with 2-3 different `ats` types) through `fetch_all`, confirming per-source failure isolation end-to-end (one ATS 500s, others succeed, final job list only contains the successes).\n\n---\n\n### Missing error-handling tests (cross-cutting)\n\n- `fetch_all`: swallowed exceptions currently print to stdout with no structured signal — no test pins that a failing source doesn't corrupt the result list or crash the gather.\n- `notify.dispatch`: no test confirms a notifier exception doesn't stop later notifiers (order-dependent: `notify_sms` is last, so a slack failure must not skip SMS).\n- `_amazon_posted_at`: catches `ValueError`/`KeyError` but not e.g. a `None` input (`value.replace` would raise `AttributeError` — worth a test asserting current crash-or-not behavior).\n- `load_config`: no test for a YAML file that fails to parse (`yaml.YAMLError`) or an empty file (`AttributeError` risk noted above).\n- `Store.__init__`: no test for an unwritable path / permission error.\n- `agent._chrome_bin`: no test for \"no Chrome found anywhere\" (`sys.exit` path).\n\n---\n\n### Suggested setup to unblock all of this\n\n```\n# requirements-dev.txt\npytest>=8.0\npytest-asyncio>=0.24\nrespx>=0.21\n```\n\n```ini\n# pytest.ini\n[pytest]\nasyncio_mode = auto\n```\n\nPriority order if implementing incrementally: **models.py → filters.py → store.py → notify.py → fetchers.py parsers → fetchers.py pagination/retry loops → pipeline.py → agent.py**. The first four are pure-logic and zero-dependency; they'd catch the most regressions per line of test code written.\n",
