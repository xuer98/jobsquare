        "code": "# tests/test_models.py\nimport pytest\nfrom datetime import datetime, timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_and_none_return_none(self):\n        assert parse_posted_at(\"\") is None\n\n    def test_lever_milliseconds_epoch(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt == datetime.fromtimestamp(1643241332.430, tz=timezone.utc)\n\n    def test_seconds_epoch_under_1e12_boundary(self):\n        dt = parse_posted_at(\"1643241332\")  # 10 digits, should NOT be treated as ms\n        assert dt.year == 2022\n\n    def test_iso8601_with_z_suffix(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00Z\")\n        assert dt.tzinfo is not None\n\n    def test_iso8601_naive_gets_utc_attached(self):\n        dt = parse_posted_at(\"2024-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_unparseable_prose_returns_none(self):\n        # Workday sends \"Posted 3 Days Ago\" — must not raise\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_negative_numeric_string(self):\n        dt = parse_posted_at(\"-100\")\n        assert dt is not None\n\n    def test_extreme_numeric_string_does_not_raise(self):\n        # GAP/BUG: currently raises OverflowError — should return None\n        assert parse_posted_at(\"99999999999999999999\") is None\n\nclass TestJob:\n    def _job(self, **kw):\n        defaults = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                         title=\"Engineer\", url=\"https://x/1\")\n        return Job(**{**defaults, **kw})\n\n    def test_key_format(self):\n        assert self._job().key == \"greenhouse:acme:1\"\n\n    def test_content_hash_changes_on_title(self):\n        a, b = self._job(), self._job(title=\"Senior Engineer\")\n        assert a.content_hash != b.content_hash\n\n    def test_content_hash_stable_on_salary_only_change(self):\n        # documents current (possibly unintended) behavior\n        a = self._job(salary_range=\"100k\")\n        b = self._job(salary_range=\"200k\")\n        assert a.content_hash == b.content_hash\n\n    def test_posted_dt_delegates_to_parser(self):\n        j = self._job(posted_at=\"1700000000\")\n        assert j.posted_dt is not None\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self):\n        row = self._job(raw={\"secret\": 1}).to_row()\n        assert \"raw\" not in row\n        assert \"key\" in row and \"content_hash\" in row"
