        "content": "import pytest\nfrom unittest.mock import AsyncMock, patch\nimport pipeline\n\ndef test_load_config_defaults(tmp_path):\n    p = tmp_path / \"s.yaml\"\n    p.write_text(\"sources: []\\n\")\n    cfg = pipeline.load_config(p)\n    assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\ndef test_load_config_empty_file_raises_or_is_handled(tmp_path):\n    # GAP/BUG: yaml.safe_load('') -> None -> cfg.setdefault raises AttributeError\n    p = tmp_path / \"empty.yaml\"\n    p.write_text(\"\")\n    with pytest.raises(AttributeError):\n        pipeline.load_config(p)   # once fixed, assert it returns defaults instead\n\n@pytest.mark.asyncio\nasync def test_dry_run_skips_store_and_dispatch(tmp_path):\n    cfg_path = tmp_path / \"s.yaml\"\n    cfg_path.write_text(f\"sources: []\\ndb: {tmp_path/'jobs.db'}\\n\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n         patch(\"pipeline.dispatch\") as mock_dispatch:\n        result = await pipeline.run(cfg_path, dry_run=True)\n    assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n    mock_dispatch.assert_not_called()\n\n@pytest.mark.asyncio\nasync def test_run_persists_and_dispatches(tmp_path):\n    # fetch_all -> filter_jobs -> Store.diff -> dispatch, full wiring\n    ...\n\ndef test_run_sync_wraps_asyncio_run(tmp_path):\n    with patch(\"pipeline.run\", new=AsyncMock(return_value={\"matched\": 0, \"new\": 0, \"changed\": 0})):\n        assert pipeline.run_sync(tmp_path / \"s.yaml\") == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n```\n\n",
        "level": 1
