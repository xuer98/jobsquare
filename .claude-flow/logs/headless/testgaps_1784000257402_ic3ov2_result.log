class TestParseMicrosoftNetflix:\n    def test_microsoft_posted_ts_conversion(self):\n        j = [{\"id\": \"1\", \"name\": \"Eng\", \"postedTs\": 1700000000}]\n        assert parse_microsoft(\"microsoft\", j)[0].posted_at != \"\"\n\n    def test_microsoft_missing_posted_ts(self):\n        j = [{\"id\": \"1\", \"name\": \"Eng\"}]\n        assert parse_microsoft(\"microsoft\", j)[0].posted_at == \"\"\n\n    def test_netflix_location_comma_spacing(self):\n        j = [{\"id\": \"1\", \"name\": \"Eng\", \"locations\": [\"NYC,NY,US\"]}]\n        assert parse_netflix(\"netflix\", j)[0].location == \"NYC, NY, US\"\n\n    def test_netflix_t_create_falls_back_to_t_update(self):\n        j = [{\"id\": \"1\", \"name\": \"Eng\", \"t_update\": 1700000000}]\n        assert parse_netflix(\"netflix\", j)[0].posted_at != \"\"\n\n# --- pagination fetchers: mock transport, verify loop termination + max_pages cap ---\nclass TestFetchPagination:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_fetch_microsoft_stops_when_no_fresh_ids(self):\n        respx.get(\"https://apply.careers.microsoft.com/api/pcsx/search\").mock(\n            return_value=httpx.Response(200, json={\"data\": {\"positions\": []}}))\n        from fetchers import fetch_microsoft\n        async with httpx.AsyncClient() as c:\n            jobs = await fetch_microsoft(c, {\"company\": \"microsoft\", \"max_pages\": 3})\n        assert jobs == []\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_fetch_workday_respects_safety_cap(self):\n        # total keeps growing forever -> must stop at offset > 5000, not hang\n        ...\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_fetch_meta_strips_for_semicolon_prefix_and_raises_on_graphql_error(self):\n        respx.get(\"https://www.metacareers.com/jobs\").mock(\n            return_value=httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok\"}] \"__spin_r\":1'))\n        respx.post(\"https://www.metacareers.com/graphql\").mock(\n            return_value=httpx.Response(200, text='for (;;);{\"errors\":[{\"message\":\"doc_id stale\"}]}'))\n        async with httpx.AsyncClient() as c:\n            with pytest.raises(RuntimeError, match=\"doc_id stale\"):\n                await fetch_meta(c, {\"company\": \"meta\"})\n\n# --- registry + top-level orchestration ---\nclass TestFetchSourceAndAll:\n    @pytest.mark.asyncio\n    async def test_fetch_source_unknown_ats_raises(self):\n        async with httpx.AsyncClient() as c:\n            with pytest.raises(ValueError, match=\"unknown ATS\"):\n                await fetch_source(c, {\"ats\": \"bogus\"})\n\n    @pytest.mark.asyncio\n    async def test_fetch_all_empty_sources(self):\n        assert await fetch_all([]) == []\n\n    @pytest.mark.asyncio\n    async def test_fetch_all_one_source_failure_does_not_kill_others(self, capsys):\n        # patch FETCHERS so one raises, one returns jobs — assert both attempted,\n        # failure logged (not raised), other source's jobs still returned\n        ...\n\n    @pytest.mark.asyncio\n    async def test_fetch_all_does_not_close_injected_client(self):\n        async with httpx.AsyncClient() as c:\n            await fetch_all([], client=c)\n            assert not c.is_closed\n```\n\n### `agent.py`\n\n```python\n# tests/test_agent.py\nimport json\nimport pytest\nfrom datetime import datetime, timezone, timedelta\nfrom unittest.mock import patch\nimport agent\nfrom store import Store\nfrom models import Job\n\nclass TestDbNew:\n    def test_first_run_uses_since_days_window(self, tmp_path, capsys):\n        cfg = tmp_path / \"s.yaml\"\n        db = tmp_path / \"j.db\"\n        cfg.write_text(f\"sources: []\\ndb: {db}\\n\")\n        agent.cmd_db_new([\"-c\", str(cfg), \"--since-days\", \"1\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n\n    def test_truncation_respects_group_boundaries(self, tmp_path, capsys):\n        # rows sharing an identical first_seen timestamp must not be split\n        # across the --limit boundary\n        ...\n\n    def test_never_advances_marker(self, tmp_path):\n        # calling db-new twice in a row must return the same \"new\" set\n        ...\n\nclass TestDbMark:\n    def test_now_flag_sets_current_timestamp(self, tmp_path):\n        cfg = tmp_path / \"s.yaml\"\n        cfg.write_text(f\"sources: []\\ndb: {tmp_path/'j.db'}\\n\")\n        assert agent.cmd_db_mark([\"--now\", \"-c\", str(cfg)]) == 0\n\n    def test_invalid_watermark_returns_2(self, tmp_path, capsys):\n        cfg = tmp_path / \"s.yaml\"\n        cfg.write_text(f\"sources: []\\ndb: {tmp_path/'j.db'}\\n\")\n        rc = agent.cmd_db_mark([\"not-a-date\", \"-c\", str(cfg)])\n        assert rc == 2\n        assert \"not an ISO timestamp\" in capsys.readouterr().err\n\n    def test_neither_watermark_nor_now_returns_2(self, tmp_path):\n        cfg = tmp_path / \"s.yaml\"\n        cfg.write_text(f\"sources: []\\ndb: {tmp_path/'j.db'}\\n\")\n        assert agent.cmd_db_mark([\"-c\", str(cfg)]) == 2\n\nclass TestNormalizeAts:\n    def test_replaces_smart_quotes_and_dashes_in_body_text(self):\n        html = \"<p>“Quoted” — text\\u2026</p>\"\n        out, counts = agent._normalize_ats(html)\n        assert '\"' in out and \"-\" in out and \"...\" in out\n\n    def test_does_not_touch_style_or_script_blocks(self):\n        html = '<style>.x::before{content:\"\\u2014\"}</style><p>a\\u2014b</p>'\n        out, _ = agent._normalize_ats(html)\n        assert \"\\u2014\" in out.split(\"</style>\")[0]  # untouched inside <style>\n        assert \"\\u2014\" not in out.split(\"</style>\")[1]  # replaced in body\n\n    def test_no_replacements_needed_yields_empty_counts(self):\n        _, counts = agent._normalize_ats(\"<p>plain ascii</p>\")\n        assert counts == {}\n\nclass TestPdfRender:\n    def test_missing_input_file_returns_2(self, tmp_path, capsys):\n        rc = agent.cmd_pdf_render([str(tmp_path / \"missing.html\")])\n        assert rc == 2\n\n    def test_render_failure_when_output_not_valid_pdf(self, tmp_path):\n        src = tmp_path / \"in.html\"\n        src.write_text(\"<html></html>\")\n        with patch(\"agent._chrome_bin\", return_value=\"/bin/true\"):  # produces no PDF\n            rc = agent.cmd_pdf_render([str(src)])\n        assert rc == 1\n\n    def test_inserts_page_css_before_head_close_tag(self):\n        html = \"<html><head></head><body>x</body></html>\"\n        # exercise the </head> injection branch directly if refactored to be testable\n\nclass TestChromeBin:\n    def test_chrome_path_env_var_used_when_exists(self, tmp_path, monkeypatch):\n        fake = tmp_path / \"chrome\"\n        fake.write_text(\"\")\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert agent._chrome_bin() == str(fake)\n\n    def test_exits_when_nothing_found(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        with patch(\"shutil.which\", return_value=None), \\\n             patch(\"pathlib.Path.exists\", return_value=False):\n            with pytest.raises(SystemExit):\n                agent._chrome_bin()\n\nclass TestMainArgvParsing:\n    def test_bare_invocation_is_interactive(self):\n        with patch(\"agent.run_claude\") as rc:\n            agent.main()\n            rc.assert_called_once_with([], True, [])\n\n    def test_mode_words_stop_at_first_flag(self):\n        with patch(\"agent.run_claude\") as rc:\n            agent.main.__wrapped__ if False else None\n            import sys\n            with patch.object(sys, \"argv\", [\"agent.py\", \"scan\", \"--extra\", \"val\"]):\n                agent.main()\n            rc.assert_called_once_with([\"scan\"], False, [\"--extra\", \"val\"])\n```\n\n---\n\n## 3. Integration test gaps (cross-module)\n\nNone of these exist today — they're the highest-value additions since every module is currently only reachable via manual runs against live ATS APIs:\n\n```python\n# tests/test_integration.py\n@pytest.mark.asyncio\nasync def test_full_pipeline_first_and_second_run(tmp_path):\n    \"\"\"fetch_all (mocked via respx) -> filter -> Store.diff -> dispatch,\n    run twice: run 1 reports all as new, run 2 (unchanged upstream) reports 0 new/0 changed,\n    run 3 with one job's title changed reports 1 changed.\"\"\"\n\n@pytest.mark.asyncio\nasync def test_cli_dry_run_does_not_touch_db(tmp_path):\n    \"\"\"invoke cli.main() with --dry-run via monkeypatched sys.argv; assert no jobs.db created\"\"\"\n\ndef test_agent_db_new_then_db_mark_round_trip(tmp_path):\n    \"\"\"Seed a real Store with jobs, run cmd_db_new, feed its watermark into\n    cmd_db_mark, then run cmd_db_new again and assert the previously-dumped\n    rows are no longer returned.\"\"\"\n\n@pytest.mark.asyncio\nasync def test_notify_dispatch_is_called_with_store_diff_output(tmp_path):\n    \"\"\"Verify pipeline.run() wires Store.diff's (new, changed) directly into\n    notify.dispatch — a signature drift between the two would only surface here.\"\"\"\n```\n\n---\n\n## Summary\n\n| Module | Current coverage | Priority gaps |\n|---|---|---|\n| `models.py` | 0% | `parse_posted_at` overflow crash, content_hash field scope |\n| `filters.py` | 0% | regex boundary/escaping, cutoff tri-state logic |\n| `pipeline.py` | 0% | empty-YAML crash, dry_run wiring |\n| `store.py` | 0% | migration path, duplicate-key-in-batch, diff semantics |\n| `notify.py` | 0% | env-var gating per channel, dispatch isolation |\n| `fetchers.py` | 0% | retry-on-4xx bug, every `parse_*`, all pagination loops |\n| `agent.py` | 0% | truncation-at-group-boundary logic, chrome discovery, argv parsing |\n\nRecommend starting with `models.py`/`filters.py`/`store.py` (pure logic, no mocking needed) and the two flagged bugs (`parse_posted_at` overflow, `load_config` empty-file crash) before tackling `fetchers.py`'s large parser surface with `respx`.\n",
