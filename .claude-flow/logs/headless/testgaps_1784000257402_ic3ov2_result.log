        "title": "tests/test_filters.py",
        "content": "import pytest\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(title=\"Backend Engineer\", dept=\"Eng\", loc=\"Remote - US\", posted_at=\"\"):\n    return Job(source=\"x\", company=\"c\", external_id=\"1\", title=title,\n               url=\"u\", department=dept, location=loc, posted_at=posted_at)\n\nclass TestMatch:\n    def test_no_filters_passes(self):\n        assert match(_job()) is True\n\n    def test_include_keyword_hit_and_miss(self):\n        assert match(_job(title=\"Backend Engineer\"), include=[\"backend\"]) is True\n        assert match(_job(title=\"Frontend Engineer\"), include=[\"backend\"]) is False\n\n    def test_exclude_takes_priority_over_include(self):\n        j = _job(title=\"Senior Backend Engineer Intern\")\n        assert match(j, include=[\"backend\"], exclude=[\"intern\"]) is False\n\n    def test_word_boundary_prevents_substring_false_positive(self):\n        # \"eng\" should not match \"engineering\" via naive substring, but should via \\b at word start\n        j = _job(title=\"Engineering Manager\")\n        assert match(j, exclude=[\"eng\"]) is True  # \"eng\" is not a whole word here — must NOT exclude\n        # NOTE: verify actual intended semantics; this asserts current \\b behavior\n\n    def test_regex_special_chars_in_keyword_are_escaped(self):\n        j = _job(title=\"C++ Developer\")\n        assert match(j, include=[\"C++\"]) is True  # must not raise re.error\n\n    def test_locations_substring_case_insensitive(self):\n        assert match(_job(loc=\"Seattle, WA\"), locations=[\"seattle\"]) is True\n        assert match(_job(loc=\"Austin, TX\"), locations=[\"seattle\"]) is False\n\n    def test_cutoff_drops_old_confirmed_dates(self):\n        old = (datetime.now(timezone.utc) - timedelta(days=30)).isoformat()\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(_job(posted_at=old), cutoff=cutoff) is False\n\n    def test_cutoff_keeps_unparseable_dates(self):\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(_job(posted_at=\"Posted 3 Days Ago\"), cutoff=cutoff) is True\n\n    def test_empty_include_list_is_treated_as_no_filter(self):\n        assert match(_job(), include=[]) is True\n\nclass TestFilterJobs:\n    def test_max_age_days_filters_list(self):\n        old = _job(posted_at=(datetime.now(timezone.utc) - timedelta(days=10)).isoformat())\n        new = _job(posted_at=datetime.now(timezone.utc).isoformat())\n        out = filter_jobs([old, new], {\"max_age_days\": 5})\n        assert out == [new]\n\n    def test_no_rules_returns_all(self):\n        jobs = [_job(), _job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs\n\n    def test_max_age_days_as_float_string(self):\n        # rules typically come from YAML — could be \"3.5\"\n        out = filter_jobs([_job()], {\"max_age_days\": \"3.5\"})\n        assert isinstance(out, list)\n```\n\n",
