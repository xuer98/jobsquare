        "title": "`store.py`",
        "content": "\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_store.py",
        "content": "import sqlite3\nimport pytest\nfrom store import Store\nfrom models import Job\n\ndef _job(external_id=\"1\", title=\"Engineer\", **kw):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=external_id,\n               title=title, url=\"u\", **kw)\n\nclass TestDiff:\n    def test_new_job_is_inserted_and_returned_as_new(self, tmp_path):\n        with Store(tmp_path / \"t.db\") as s:\n            new, changed = s.diff([_job()])\n            assert len(new) == 1 and changed == []\n            assert s.count() == 1\n\n    def test_unchanged_job_on_second_run_is_neither(self, tmp_path):\n        db = tmp_path / \"t.db\"\n        with Store(db) as s:\n            s.diff([_job()])\n        with Store(db) as s:\n            new, changed = s.diff([_job()])\n            assert new == [] and changed == []\n\n    def test_changed_content_hash_flags_changed(self, tmp_path):\n        db = tmp_path / \"t.db\"\n        with Store(db) as s:\n            s.diff([_job(title=\"Engineer\")])\n        with Store(db) as s:\n            new, changed = s.diff([_job(title=\"Senior Engineer\")])\n            assert new == [] and len(changed) == 1\n\n    def test_duplicate_keys_within_single_batch(self, tmp_path):\n        # GAP: two Job objects with the same key in one fetch batch —\n        # verify no IntegrityError and diff() behaves sanely\n        with Store(tmp_path / \"t.db\") as s:\n            new, changed = s.diff([_job(title=\"A\"), _job(title=\"B\")])\n            assert len(new) + len(changed) >= 1  # document actual behavior\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, tmp_path):\n        with Store(tmp_path / \"t.db\") as s:\n            assert s.get_meta(\"last_scan\") is None\n\n    def test_set_meta_then_get_roundtrip(self, tmp_path):\n        with Store(tmp_path / \"t.db\") as s:\n            s.set_meta(\"last_scan\", \"2026-01-01T00:00:00+00:00\")\n            assert s.get_meta(\"last_scan\") == \"2026-01-01T00:00:00+00:00\"\n\n    def test_set_meta_upserts_on_conflict(self, tmp_path):\n        with Store(tmp_path / \"t.db\") as s:\n            s.set_meta(\"k\", \"v1\")\n            s.set_meta(\"k\", \"v2\")\n            assert s.get_meta(\"k\") == \"v2\"\n\nclass TestMigration:\n    def test_old_schema_without_salary_range_gets_migrated(self, tmp_path):\n        db = tmp_path / \"old.db\"\n        conn = sqlite3.connect(db)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n              external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n              employment_type TEXT, posted_at TEXT, content_hash TEXT,\n              first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        with Store(db) as s:\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\nclass TestAddedSince:\n    def test_ordering_and_strict_greater_than(self, tmp_path):\n        ...\n\ndef test_context_manager_closes_connection(tmp_path):\n    s = Store(tmp_path / \"t.db\")\n    with s:\n        pass\n    with pytest.raises(sqlite3.ProgrammingError):\n        s.conn.execute(\"SELECT 1\")\n```\n\n",
        "level": 1
      },
      {
        "title": "`notify.py`",
        "content": "\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_notify.py",
        "content": "import pytest\nfrom unittest.mock import patch, MagicMock\nimport notify\nfrom models import Job\n\ndef _job(**kw):\n    return Job(source=\"x\", company=\"acme\", external_id=\"1\", title=\"Engineer\",\n               url=\"https://x/1\", **kw)\n\nclass TestNotifyConsole:\n    def test_prints_no_fresh_listings_when_empty(self, capsys):\n        notify.notify_console([], [])\n        assert \"No fresh listings\" in capsys.readouterr().out\n\n    def test_prints_new_and_changed_sections(self, capsys):\n        notify.notify_console([_job()], [_job(external_id=\"2\")])\n        out = capsys.readouterr().out\n        assert \"NEW\" in out and \"UPDATED\" in out\n\nclass TestNotifySlack:\n    def test_noop_without_env_var(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with patch(\"httpx.post\") as p:\n            notify.notify_slack([_job()], [])\n            p.assert_not_called()\n\n    def test_noop_with_no_jobs_even_if_url_set(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n        with patch(\"httpx.post\") as p:\n            notify.notify_slack([], [])\n            p.assert_not_called()\n\n    def test_posts_when_url_and_jobs_present(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks/x\")\n        with patch(\"httpx.post\") as p:\n            notify.notify_slack([_job(salary_range=\"100k\")], [])\n            p.assert_called_once()\n            assert \"100k\" in p.call_args.kwargs[\"json\"][\"text\"]\n\nclass TestNotifySms:\n    def test_noop_unless_all_four_env_vars_set(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        with patch(\"httpx.post\") as p:\n            notify.notify_sms([_job()], [])\n            p.assert_not_called()\n\n    def test_body_truncates_at_limit(self):\n        jobs = [_job(external_id=str(i), title=f\"Role {i}\") for i in range(12)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+4 more\" in body\n\n    def test_body_is_ascii_only(self):\n        # regression guard: non-GSM chars force costly UCS-2 SMS segments\n        body = notify._sms_body([_job(title=\"Café Role\")], [])\n        # documents current behavior — title chars pass through unescaped;\n        # decide whether non-ASCII should be stripped/transliterated\n        assert isinstance(body, str)\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.setenv(\"TWILIO_AUTH_TOKEN\", \"tok\")\n        monkeypatch.setenv(\"TWILIO_FROM\", \"+1\")\n        monkeypatch.setenv(\"TWILIO_TO\", \"+2\")\n        resp = MagicMock()\n        resp.raise_for_status.side_effect = Exception(\"boom\")\n        with patch(\"httpx.post\", return_value=resp):\n            with pytest.raises(Exception):\n                notify.notify_sms([_job()], [])\n\nclass TestDispatch:\n    def test_one_notifier_failure_does_not_stop_others(self, capsys):\n        calls = []\n        def bad(new, changed): raise RuntimeError(\"fail\")\n        def good(new, changed): calls.append(1)\n        with patch.object(notify, \"NOTIFIERS\", [bad, good]):\n            notify.dispatch([_job()], [])\n        assert calls == [1]\n        assert \"notifier bad failed\" in capsys.readouterr().out\n```\n\n",
        "level": 1
      },
      {
        "title": "`fetchers.py` — largest surface, biggest gap",
        "content": "\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_fetchers.py",
        "content": "import pytest\nimport httpx\nimport respx\nfrom fetchers import (\n    parse_greenhouse, parse_lever, parse_ashby, parse_smartrecruiters,\n    parse_recruitee, parse_workable, parse_google, _extract_ds1, _ds1_posted_at,\n    parse_deshaw, parse_twosigma, parse_optiver, parse_meta, parse_microsoft,\n    parse_netflix, parse_amazon, _amazon_posted_at, fetch_source, fetch_all,\n    _request, fetch_workday, fetch_meta,\n)\n\n",
        "level": 1
      },
      {
        "title": "--- retry wrapper ---",
        "content": "class TestRequest:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_success_first_try(self):\n        respx.get(\"https://x/\").mock(return_value=httpx.Response(200, json={}))\n        async with httpx.AsyncClient() as c:\n            r = await _request(c, \"https://x/\")\n            assert r.status_code == 200\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_retries_on_503_then_succeeds(self):\n        route = respx.get(\"https://x/\")\n        route.side_effect = [httpx.Response(503), httpx.Response(200, json={})]\n        async with httpx.AsyncClient() as c:\n            r = await _request(c, \"https://x/\", retries=3)\n            assert r.status_code == 200\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_exhausts_retries_raises_runtime_error(self):\n        respx.get(\"https://x/\").mock(return_value=httpx.Response(503))\n        async with httpx.AsyncClient() as c:\n            with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n                await _request(c, \"https://x/\", retries=2)\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_404_is_retried_same_as_5xx(self):\n        # GAP/BUG: documents current (arguably wrong) behavior — a 404 gets\n        # retried `retries` times instead of failing fast on the first attempt\n        route = respx.get(\"https://x/\").mock(return_value=httpx.Response(404))\n        async with httpx.AsyncClient() as c:\n            with pytest.raises(RuntimeError):\n                await _request(c, \"https://x/\", retries=2)\n        assert route.call_count == 2  # once fixed to fail-fast, this should be 1\n\n",
        "level": 1
      },
      {
        "title": "--- parsers: one class per ATS, each covering happy path + missing/null fields ---",
        "content": "class TestParseGreenhouse:\n    def test_basic_mapping(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\", \"absolute_url\": \"u\",\n                           \"location\": {\"name\": \"NYC\"},\n                           \"departments\": [{\"name\": \"Platform\"}],\n                           \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].location == \"NYC\" and jobs[0].department == \"Platform\"\n\n    def test_missing_location_object(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].location == \"\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_jobs_key(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\nclass TestParseLever:\n    def test_salary_range_with_min_and_max(self):\n        j = [{\"id\": \"1\", \"text\": \"Eng\", \"hostedUrl\": \"u\",\n              \"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}]\n        assert \"100,000\" in parse_lever(\"acme\", j)[0].salary_range\n\n    def test_salary_falls_back_to_description(self):\n        j = [{\"id\": \"1\", \"text\": \"Eng\", \"hostedUrl\": \"u\",\n              \"salaryDescriptionPlain\": \"Competitive\"}]\n        assert parse_lever(\"acme\", j)[0].salary_range == \"Competitive\"\n\n    def test_no_salary_info_at_all(self):\n        j = [{\"id\": \"1\", \"text\": \"Eng\", \"hostedUrl\": \"u\"}]\n        assert parse_lever(\"acme\", j)[0].salary_range == \"\"\n\nclass TestParseAshby:\n    def test_unlisted_jobs_filtered_out(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False}, {\"id\": \"2\", \"isListed\": True, \"title\": \"Eng\"}]}\n        jobs = parse_ashby(\"acme\", data)\n        assert len(jobs) == 1 and jobs[0].external_id == \"2\"\n\n    def test_id_falls_back_to_jobId(self):\n        data = {\"jobs\": [{\"jobId\": \"42\", \"isListed\": True}]}\n        assert parse_ashby(\"acme\", data)[0].external_id == \"42\"\n\nclass TestGoogleDs1:\n    def test_extract_ds1_happy_path(self):\n        html = \"key: 'ds:1', ... data:[[[\\\"id1\\\",\\\"title\\\"]]], sideChannel:{}\"\n        assert _extract_ds1(html) == [[\"id1\", \"title\"]]\n\n    def test_extract_ds1_returns_empty_on_no_match(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_extract_ds1_returns_empty_on_malformed_json(self):\n        html = \"key: 'ds:1', data:[not valid json], sideChannel:{}\"\n        assert _extract_ds1(html) == []\n\n    def test_ds1_posted_at_prefers_create_over_update(self):\n        job = [None] * 15\n        job[12] = [1700000000, 0]\n        job[13] = [1800000000, 0]\n        assert _ds1_posted_at(job)[:4] == \"2023\"\n\n    def test_ds1_posted_at_missing_all_indices(self):\n        assert _ds1_posted_at([None] * 5) == \"\"\n\n    def test_parse_google_skips_falsy_first_element(self):\n        assert parse_google(\"google\", [[None, \"title\"]]) == []\n\nclass TestParseDeshaw:\n    def test_dedups_by_job_id(self):\n        page = ('data-job-id=\"1\"><span class=\"job-display-name\">Eng</span>'\n                '<span class=\"location\">NYC</span>'\n                'data-job-id=\"1\"><span class=\"job-display-name\">Eng</span>')\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert len(jobs) == 1\n\n    def test_missing_title_or_id_skipped(self):\n        page = 'data-job-id=\"1\">no title span here'\n        assert parse_deshaw(\"deshaw\", page) == []\n\nclass TestParseTwosigma:\n    def test_dedups_triple_rendered_cards(self):\n        anchor = ('href=\"https://careers.twosigma.com/careers/JobDetail/x/99\">Eng</a>' * 3)\n        jobs = parse_twosigma(\"twosigma\", anchor)\n        assert len(jobs) == 1\n\nclass TestParseOptiver:\n    def test_external_id_strips_prefix(self):\n        j = [{\"href\": \"/join-us/jobs/eng-role\", \"title\": \"Eng\"}]\n        assert parse_optiver(\"optiver\", j)[0].external_id == \"eng-role\"\n\n    def test_relative_vs_absolute_href(self):\n        j = [{\"href\": \"/join-us/jobs/x\", \"title\": \"T\"}]\n        assert parse_optiver(\"optiver\", j)[0].url.startswith(\"https://www.optiver.com\")\n        j2 = [{\"href\": \"https://external/x\", \"title\": \"T\"}]\n        assert parse_optiver(\"optiver\", j2)[0].url == \"https://external/x\"\n\nclass TestParseMeta:\n    def test_dedups_by_id_and_skips_blank(self):\n        results = [{\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"\", \"title\": \"B\"}]\n        assert len(parse_meta(\"meta\", results)) == 1\n\nclass TestAmazonPostedAt:\n    def test_valid_us_date(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_unknown_month_returns_empty(self):\n        assert _amazon_posted_at(\"Foo 1, 2026\") == \"\"\n\nclass TestParseAmazon:\n    def test_id_falls_back_to_icims(self):\n        j = [{\"id_icims\": \"999\", \"title\": \"Eng\", \"job_path\": \"/x\"}]\n        assert parse_amazon(\"amazon\", j)[0].external_id == \"999\"\n\nclass TestParseMicrosoftNetflix:\n    def test_microsoft_posted_ts_conversion(self):\n        j = [{\"id\": \"1\", \"name\": \"Eng\", \"postedTs\": 1700000000}]\n        assert parse_microsoft(\"microsoft\", j)[0].posted_at != \"\"\n\n    def test_microsoft_missing_posted_ts(self):\n        j = [{\"id\": \"1\", \"name\": \"Eng\"}]\n        assert parse_microsoft(\"microsoft\", j)[0].posted_at == \"\"\n\n    def test_netflix_location_comma_spacing(self):\n        j = [{\"id\": \"1\", \"name\": \"Eng\", \"locations\": [\"NYC,NY,US\"]}]\n        assert parse_netflix(\"netflix\", j)[0].location == \"NYC, NY, US\"\n\n    def test_netflix_t_create_falls_back_to_t_update(self):\n        j = [{\"id\": \"1\", \"name\": \"Eng\", \"t_update\": 1700000000}]\n        assert parse_netflix(\"netflix\", j)[0].posted_at != \"\"\n\n",
        "level": 1
