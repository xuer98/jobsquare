        "code": "# tests/test_fetchers.py\nimport pytest\nimport httpx\nimport respx\nfrom fetchers import (\n    parse_greenhouse, parse_lever, parse_ashby, parse_smartrecruiters,\n    parse_recruitee, parse_workable, parse_google, _extract_ds1, _ds1_posted_at,\n    parse_deshaw, parse_twosigma, parse_optiver, parse_meta, parse_microsoft,\n    parse_netflix, parse_amazon, _amazon_posted_at, fetch_source, fetch_all,\n    _request, fetch_workday, fetch_meta,\n)\n\n# --- retry wrapper ---\nclass TestRequest:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_success_first_try(self):\n        respx.get(\"https://x/\").mock(return_value=httpx.Response(200, json={}))\n        async with httpx.AsyncClient() as c:\n            r = await _request(c, \"https://x/\")\n            assert r.status_code == 200\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_retries_on_503_then_succeeds(self):\n        route = respx.get(\"https://x/\")\n        route.side_effect = [httpx.Response(503), httpx.Response(200, json={})]\n        async with httpx.AsyncClient() as c:\n            r = await _request(c, \"https://x/\", retries=3)\n            assert r.status_code == 200\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_exhausts_retries_raises_runtime_error(self):\n        respx.get(\"https://x/\").mock(return_value=httpx.Response(503))\n        async with httpx.AsyncClient() as c:\n            with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n                await _request(c, \"https://x/\", retries=2)\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_404_is_retried_same_as_5xx(self):\n        # GAP/BUG: documents current (arguably wrong) behavior — a 404 gets\n        # retried `retries` times instead of failing fast on the first attempt\n        route = respx.get(\"https://x/\").mock(return_value=httpx.Response(404))\n        async with httpx.AsyncClient() as c:\n            with pytest.raises(RuntimeError):\n                await _request(c, \"https://x/\", retries=2)\n        assert route.call_count == 2  # once fixed to fail-fast, this should be 1\n\n# --- parsers: one class per ATS, each covering happy path + missing/null fields ---\nclass TestParseGreenhouse:\n    def test_basic_mapping(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\", \"absolute_url\": \"u\",\n                           \"location\": {\"name\": \"NYC\"},\n                           \"departments\": [{\"name\": \"Platform\"}],\n                           \"updated_at\": \"2024-01-01T00:00:00Z\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].location == \"NYC\" and jobs[0].department == \"Platform\"\n\n    def test_missing_location_object(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].location == \"\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_jobs_key(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\nclass TestParseLever:\n    def test_salary_range_with_min_and_max(self):\n        j = [{\"id\": \"1\", \"text\": \"Eng\", \"hostedUrl\": \"u\",\n              \"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}]\n        assert \"100,000\" in parse_lever(\"acme\", j)[0].salary_range\n\n    def test_salary_falls_back_to_description(self):\n        j = [{\"id\": \"1\", \"text\": \"Eng\", \"hostedUrl\": \"u\",\n              \"salaryDescriptionPlain\": \"Competitive\"}]\n        assert parse_lever(\"acme\", j)[0].salary_range == \"Competitive\"\n\n    def test_no_salary_info_at_all(self):\n        j = [{\"id\": \"1\", \"text\": \"Eng\", \"hostedUrl\": \"u\"}]\n        assert parse_lever(\"acme\", j)[0].salary_range == \"\"\n\nclass TestParseAshby:\n    def test_unlisted_jobs_filtered_out(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False}, {\"id\": \"2\", \"isListed\": True, \"title\": \"Eng\"}]}\n        jobs = parse_ashby(\"acme\", data)\n        assert len(jobs) == 1 and jobs[0].external_id == \"2\"\n\n    def test_id_falls_back_to_jobId(self):\n        data = {\"jobs\": [{\"jobId\": \"42\", \"isListed\": True}]}\n        assert parse_ashby(\"acme\", data)[0].external_id == \"42\"\n\nclass TestGoogleDs1:\n    def test_extract_ds1_happy_path(self):\n        html = \"key: 'ds:1', ... data:[[[\\\"id1\\\",\\\"title\\\"]]], sideChannel:{}\"\n        assert _extract_ds1(html) == [[\"id1\", \"title\"]]\n\n    def test_extract_ds1_returns_empty_on_no_match(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_extract_ds1_returns_empty_on_malformed_json(self):\n        html = \"key: 'ds:1', data:[not valid json], sideChannel:{}\"\n        assert _extract_ds1(html) == []\n\n    def test_ds1_posted_at_prefers_create_over_update(self):\n        job = [None] * 15\n        job[12] = [1700000000, 0]\n        job[13] = [1800000000, 0]\n        assert _ds1_posted_at(job)[:4] == \"2023\"\n\n    def test_ds1_posted_at_missing_all_indices(self):\n        assert _ds1_posted_at([None] * 5) == \"\"\n\n    def test_parse_google_skips_falsy_first_element(self):\n        assert parse_google(\"google\", [[None, \"title\"]]) == []\n\nclass TestParseDeshaw:\n    def test_dedups_by_job_id(self):\n        page = ('data-job-id=\"1\"><span class=\"job-display-name\">Eng</span>'\n                '<span class=\"location\">NYC</span>'\n                'data-job-id=\"1\"><span class=\"job-display-name\">Eng</span>')\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert len(jobs) == 1\n\n    def test_missing_title_or_id_skipped(self):\n        page = 'data-job-id=\"1\">no title span here'\n        assert parse_deshaw(\"deshaw\", page) == []\n\nclass TestParseTwosigma:\n    def test_dedups_triple_rendered_cards(self):\n        anchor = ('href=\"https://careers.twosigma.com/careers/JobDetail/x/99\">Eng</a>' * 3)\n        jobs = parse_twosigma(\"twosigma\", anchor)\n        assert len(jobs) == 1\n\nclass TestParseOptiver:\n    def test_external_id_strips_prefix(self):\n        j = [{\"href\": \"/join-us/jobs/eng-role\", \"title\": \"Eng\"}]\n        assert parse_optiver(\"optiver\", j)[0].external_id == \"eng-role\"\n\n    def test_relative_vs_absolute_href(self):\n        j = [{\"href\": \"/join-us/jobs/x\", \"title\": \"T\"}]\n        assert parse_optiver(\"optiver\", j)[0].url.startswith(\"https://www.optiver.com\")\n        j2 = [{\"href\": \"https://external/x\", \"title\": \"T\"}]\n        assert parse_optiver(\"optiver\", j2)[0].url == \"https://external/x\"\n\nclass TestParseMeta:\n    def test_dedups_by_id_and_skips_blank(self):\n        results = [{\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"\", \"title\": \"B\"}]\n        assert len(parse_meta(\"meta\", results)) == 1\n\nclass TestAmazonPostedAt:\n    def test_valid_us_date(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_unknown_month_returns_empty(self):\n        assert _amazon_posted_at(\"Foo 1, 2026\") == \"\"\n\nclass TestParseAmazon:\n    def test_id_falls_back_to_icims(self):\n        j = [{\"id_icims\": \"999\", \"title\": \"Eng\", \"job_path\": \"/x\"}]\n        assert parse_amazon(\"amazon\", j)[0].external_id == \"999\"\n\nclass TestParseMicrosoftNetflix:\n    def test_microsoft_posted_ts_conversion(self):\n        j = [{\"id\": \"1\", \"name\": \"Eng\", \"postedTs\": 1700000000}]\n        assert parse_microsoft(\"microsoft\", j)[0].posted_at != \"\"\n\n    def test_microsoft_missing_posted_ts(self):\n        j = [{\"id\": \"1\", \"name\": \"Eng\"}]\n        assert parse_microsoft(\"microsoft\", j)[0].posted_at == \"\"\n\n    def test_netflix_location_comma_spacing(self):\n        j = [{\"id\": \"1\", \"name\": \"Eng\", \"locations\": [\"NYC,NY,US\"]}]\n        assert parse_netflix(\"netflix\", j)[0].location == \"NYC, NY, US\"\n\n    def test_netflix_t_create_falls_back_to_t_update(self):\n        j = [{\"id\": \"1\", \"name\": \"Eng\", \"t_update\": 1700000000}]\n        assert parse_netflix(\"netflix\", j)[0].posted_at != \"\"\n\n# --- pagination fetchers: mock transport, verify loop termination + max_pages cap ---\nclass TestFetchPagination:\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_fetch_microsoft_stops_when_no_fresh_ids(self):\n        respx.get(\"https://apply.careers.microsoft.com/api/pcsx/search\").mock(\n            return_value=httpx.Response(200, json={\"data\": {\"positions\": []}}))\n        from fetchers import fetch_microsoft\n        async with httpx.AsyncClient() as c:\n            jobs = await fetch_microsoft(c, {\"company\": \"microsoft\", \"max_pages\": 3})\n        assert jobs == []\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_fetch_workday_respects_safety_cap(self):\n        # total keeps growing forever -> must stop at offset > 5000, not hang\n        ...\n\n    @pytest.mark.asyncio\n    @respx.mock\n    async def test_fetch_meta_strips_for_semicolon_prefix_and_raises_on_graphql_error(self):\n        respx.get(\"https://www.metacareers.com/jobs\").mock(\n            return_value=httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok\"}] \"__spin_r\":1'))\n        respx.post(\"https://www.metacareers.com/graphql\").mock(\n            return_value=httpx.Response(200, text='for (;;);{\"errors\":[{\"message\":\"doc_id stale\"}]}'))\n        async with httpx.AsyncClient() as c:\n            with pytest.raises(RuntimeError, match=\"doc_id stale\"):\n                await fetch_meta(c, {\"company\": \"meta\"})\n\n# --- registry + top-level orchestration ---\nclass TestFetchSourceAndAll:\n    @pytest.mark.asyncio\n    async def test_fetch_source_unknown_ats_raises(self):\n        async with httpx.AsyncClient() as c:\n            with pytest.raises(ValueError, match=\"unknown ATS\"):\n                await fetch_source(c, {\"ats\": \"bogus\"})\n\n    @pytest.mark.asyncio\n    async def test_fetch_all_empty_sources(self):\n        assert await fetch_all([]) == []\n\n    @pytest.mark.asyncio\n    async def test_fetch_all_one_source_failure_does_not_kill_others(self, capsys):\n        # patch FETCHERS so one raises, one returns jobs — assert both attempted,\n        # failure logged (not raised), other source's jobs still returned\n        ...\n\n    @pytest.mark.asyncio\n    async def test_fetch_all_does_not_close_injected_client(self):\n        async with httpx.AsyncClient() as c:\n            await fetch_all([], client=c)\n            assert not c.is_closed"
