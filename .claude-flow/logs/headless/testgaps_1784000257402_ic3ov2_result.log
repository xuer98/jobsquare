        "code": "# tests/test_store.py\nimport sqlite3\nimport pytest\nfrom store import Store\nfrom models import Job\n\ndef _job(external_id=\"1\", title=\"Engineer\", **kw):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=external_id,\n               title=title, url=\"u\", **kw)\n\nclass TestDiff:\n    def test_new_job_is_inserted_and_returned_as_new(self, tmp_path):\n        with Store(tmp_path / \"t.db\") as s:\n            new, changed = s.diff([_job()])\n            assert len(new) == 1 and changed == []\n            assert s.count() == 1\n\n    def test_unchanged_job_on_second_run_is_neither(self, tmp_path):\n        db = tmp_path / \"t.db\"\n        with Store(db) as s:\n            s.diff([_job()])\n        with Store(db) as s:\n            new, changed = s.diff([_job()])\n            assert new == [] and changed == []\n\n    def test_changed_content_hash_flags_changed(self, tmp_path):\n        db = tmp_path / \"t.db\"\n        with Store(db) as s:\n            s.diff([_job(title=\"Engineer\")])\n        with Store(db) as s:\n            new, changed = s.diff([_job(title=\"Senior Engineer\")])\n            assert new == [] and len(changed) == 1\n\n    def test_duplicate_keys_within_single_batch(self, tmp_path):\n        # GAP: two Job objects with the same key in one fetch batch —\n        # verify no IntegrityError and diff() behaves sanely\n        with Store(tmp_path / \"t.db\") as s:\n            new, changed = s.diff([_job(title=\"A\"), _job(title=\"B\")])\n            assert len(new) + len(changed) >= 1  # document actual behavior\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, tmp_path):\n        with Store(tmp_path / \"t.db\") as s:\n            assert s.get_meta(\"last_scan\") is None\n\n    def test_set_meta_then_get_roundtrip(self, tmp_path):\n        with Store(tmp_path / \"t.db\") as s:\n            s.set_meta(\"last_scan\", \"2026-01-01T00:00:00+00:00\")\n            assert s.get_meta(\"last_scan\") == \"2026-01-01T00:00:00+00:00\"\n\n    def test_set_meta_upserts_on_conflict(self, tmp_path):\n        with Store(tmp_path / \"t.db\") as s:\n            s.set_meta(\"k\", \"v1\")\n            s.set_meta(\"k\", \"v2\")\n            assert s.get_meta(\"k\") == \"v2\"\n\nclass TestMigration:\n    def test_old_schema_without_salary_range_gets_migrated(self, tmp_path):\n        db = tmp_path / \"old.db\"\n        conn = sqlite3.connect(db)\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n              external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n              employment_type TEXT, posted_at TEXT, content_hash TEXT,\n              first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        with Store(db) as s:\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\nclass TestAddedSince:\n    def test_ordering_and_strict_greater_than(self, tmp_path):\n        ...\n\ndef test_context_manager_closes_connection(tmp_path):\n    s = Store(tmp_path / \"t.db\")\n    with s:\n        pass\n    with pytest.raises(sqlite3.ProgrammingError):\n        s.conn.execute(\"SELECT 1\")"
