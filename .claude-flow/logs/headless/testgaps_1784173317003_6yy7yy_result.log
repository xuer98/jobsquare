        "code": "# tests/test_store.py\nimport pytest\nimport sqlite3\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef store():\n    s = Store(\":memory:\")\n    yield s\n    s.close()\n\ndef _job(ext_id=\"1\", title=\"Engineer\", **kw):\n    return Job(source=\"x\", company=\"acme\", external_id=ext_id, title=title,\n               url=f\"https://x/{ext_id}\", **kw)\n\nclass TestMigration:\n    def test_adds_salary_range_to_legacy_schema(self, tmp_path):\n        db = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(db)\n        conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT,\n            company TEXT, external_id TEXT, title TEXT, url TEXT, location TEXT,\n            department TEXT, employment_type TEXT, posted_at TEXT,\n            content_hash TEXT, first_seen TEXT, last_seen TEXT)\"\"\")\n        conn.commit(); conn.close()\n        s = Store(db)  # must not raise\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n        s.close()\n\nclass TestDiff:\n    def test_new_job_is_inserted_and_returned_as_new(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n        assert store.count() == 1\n\n    def test_unchanged_job_updates_last_seen_only(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_changed_content_moves_to_changed_bucket(self, store):\n        store.diff([_job(title=\"Engineer\")])\n        new, changed = store.diff([_job(title=\"Sr Engineer\")])\n        assert new == [] and len(changed) == 1\n\n    def test_duplicate_key_within_same_batch(self, store):\n        # two Job objects with identical key in one diff() call\n        new, changed = store.diff([_job(), _job()])\n        # second occurrence should see the first's insert — assert no crash,\n        # and document actual behavior (currently both land in `new`)\n        assert store.count() == 1\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_roundtrip(self, store):\n        store.set_meta(\"k\", \"v1\")\n        assert store.get_meta(\"k\") == \"v1\"\n\n    def test_set_meta_upserts(self, store):\n        store.set_meta(\"k\", \"v1\")\n        store.set_meta(\"k\", \"v2\")\n        assert store.get_meta(\"k\") == \"v2\"\n\nclass TestNextSeq:\n    def test_starts_at_one(self, store):\n        assert store.next_seq(\"counter\") == 1\n\n    def test_increments_sequentially(self, store):\n        assert [store.next_seq(\"counter\") for _ in range(3)] == [1, 2, 3]\n\n    def test_independent_counters(self, store):\n        store.next_seq(\"a\")\n        assert store.next_seq(\"b\") == 1\n\nclass TestAddedSince:\n    def test_excludes_rows_at_exact_timestamp(self, store):\n        # `>` is strict — a row with first_seen == ts must NOT be returned\n        ...\n\n    def test_orders_by_first_seen_then_company_then_title(self, store):\n        ...\n\n    def test_empty_store_returns_empty(self, store):\n        assert store.added_since(\"2000-01-01T00:00:00+00:00\") == []"
