tle=f\"Job {i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n        assert body.count(\"\\n- \") == 8\n\n    def test_ascii_only_no_bullets_or_ellipsis(self):\n        body = notify._sms_body([_job()], [])\n        assert \"\\u2022\" not in body and \"\\u2026\" not in body\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, monkeypatch):\n        called = []\n        def bad(new, changed): raise RuntimeError(\"boom\")\n        def good(new, changed): called.append(\"good\")\n        monkeypatch.setattr(notify, \"NOTIFIERS\", [bad, good])\n        notify.dispatch([_job()], [])\n        assert called == [\"good\"]\n\nclass TestNotifyEmail:\n    def test_noop_without_smtp_host(self, monkeypatch): ...\n    def test_sends_via_smtp_with_auth(self, monkeypatch): ...  # mock smtplib.SMTP\n\nclass TestNotifyWebhook:\n    def test_noop_without_url(self, monkeypatch): ...\n    def test_payload_serializes_jobs_via_to_row(self, monkeypatch): ...\n```\n\n---\n\n",
