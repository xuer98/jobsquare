        "code": "# tests/test_parsers.py\nfrom fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n    parse_smartrecruiters, parse_recruitee, parse_workable, parse_google,\n    _extract_ds1, _ds1_posted_at, parse_deshaw, parse_twosigma, parse_apple,\n    _apple_hydration, _apple_posted_at, parse_eightfold, parse_bytedance,\n    _bd_location, parse_microsoft, parse_netflix, parse_amazon, _amazon_posted_at,\n    parse_meta)\n\nclass TestParseGreenhouse:\n    def test_happy_path(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\", \"absolute_url\": \"u\",\n                           \"location\": {\"name\": \"SF\"}, \"departments\": [{\"name\": \"Eng\"}],\n                           \"updated_at\": \"2024-01-01\"}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].location == \"SF\" and jobs[0].department == \"Eng\"\n\n    def test_missing_location_defaults_empty(self):\n        jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1, \"title\": \"Eng\"}]})\n        assert jobs[0].location == \"\"\n\n    def test_no_jobs_key_returns_empty(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\nclass TestLeverSalary:\n    def test_min_and_max_formats_with_commas(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_missing_range_falls_back_to_plain_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\nclass TestParseAshby:\n    def test_unlisted_jobs_filtered_out(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"},\n                          {\"id\": \"2\", \"isListed\": True, \"title\": \"Visible\"}]}\n        jobs = parse_ashby(\"acme\", data)\n        assert len(jobs) == 1 and jobs[0].title == \"Visible\"\n\nclass TestParseWorkable:\n    def test_location_as_dict(self):\n        j = {\"location\": {\"location_str\": \"NYC\"}, \"shortcode\": \"x\", \"title\": \"t\"}\n        assert parse_workable(\"acme\", {\"jobs\": [j]})[0].location == \"NYC\"\n\n    def test_location_as_flat_fields(self):\n        j = {\"city\": \"NYC\", \"state\": \"NY\", \"country\": \"US\", \"id\": \"1\", \"title\": \"t\"}\n        assert parse_workable(\"acme\", {\"jobs\": [j]})[0].location == \"NYC, NY, US\"\n\nclass TestGoogleDs1:\n    def test_extract_ds1_primary_pattern(self):\n        html = \"AF_initDataCallback({key: 'ds:1', data:[[['j1']]] , sideChannel:{}})\"\n        assert _extract_ds1(html) == [['j1']]\n\n    def test_extract_ds1_fallback_pattern_when_sidechannel_missing(self):\n        html = \"key: 'ds:1', data:[[['j1']]] });\"\n        assert _extract_ds1(html) != []  # or == [] documenting current fallback shape\n\n    def test_extract_ds1_malformed_json_returns_empty(self):\n        html = \"key: 'ds:1', data:[not json] , sideChannel:{}\"\n        assert _extract_ds1(html) == []\n\n    def test_extract_ds1_no_match_returns_empty(self):\n        assert _extract_ds1(\"<html></html>\") == []\n\n    def test_ds1_posted_at_prefers_create_over_update_time(self):\n        job = [None] * 15\n        job[12] = [1700000000, 0]\n        job[13] = [1800000000, 0]\n        assert \"2023\" in _ds1_posted_at(job)  # create-time year, not update-time\n\n    def test_ds1_posted_at_missing_all_indices(self):\n        assert _ds1_posted_at([None] * 5) == \"\"\n\nclass TestParseGoogle:\n    def test_skips_entries_with_falsy_id(self):\n        assert parse_google(\"google\", [None, [\"\"], [\"1\", \"Title\"]]) == \\\n            parse_google(\"google\", [[\"1\", \"Title\"]])\n\nclass TestApplePostedAt:\n    def test_truncates_nanoseconds_to_microseconds(self):\n        v = _apple_posted_at(\"2024-01-01T00:00:03.812668311Z\")\n        assert v == \"2024-01-01T00:00:03.812668+00:00\"\n\n    def test_no_fractional_seconds(self):\n        assert _apple_posted_at(\"2024-01-01T00:00:03Z\") == \"2024-01-01T00:00:03+00:00\"\n\n    def test_empty_value(self):\n        assert _apple_posted_at(\"\") == \"\"\n\nclass TestAppleHydration:\n    def test_handles_escaped_quotes_in_json_string(self):\n        # the manual quote-scanner must not stop at an escaped \\\" inside the blob\n        html = 'window.__staticRouterHydrationData = JSON.parse(\"{\\\\\"a\\\\\":\\\\\"say \\\\\\\\\\\\\"hi\\\\\\\\\\\\\"\\\\\"}\")'\n        result = _apple_hydration(html)\n        assert result == {\"a\": 'say \"hi\"'}\n\n    def test_marker_missing_returns_none(self):\n        assert _apple_hydration(\"<html></html>\") is None\n\nclass TestParseDeshaw:\n    def test_dedups_by_job_id(self):\n        page = ('data-job-id=\"1\" class=\"job-display-name\">Eng<' * 1)\n        # construct two cards sharing id=\"1\" -> only one Job out\n        ...\n\nclass TestParseTwoSigma:\n    def test_dedups_triple_rendered_cards(self):\n        # each role renders 3x in the page per the module comment\n        ...\n\nclass TestBdLocation:\n    def test_walks_parent_chain_city_state_country(self):\n        city = {\"en_name\": \"SF\", \"parent\": {\"en_name\": \"CA\", \"parent\": {\"en_name\": \"US\"}}}\n        assert _bd_location(city) == \"SF, CA, US\"\n\n    def test_none_returns_empty(self):\n        assert _bd_location(None) == \"\"\n\nclass TestAmazonPostedAt:\n    def test_valid_date(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_unknown_month_returns_empty(self):\n        assert _amazon_posted_at(\"Undecimber 1, 2026\") == \"\"\n\nclass TestParseMeta:\n    def test_dedups_by_id(self):\n        results = [{\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"1\", \"title\": \"A dup\"}]\n        assert len(parse_meta(\"meta\", results)) == 1\n\n    def test_skips_missing_id(self):\n        assert parse_meta(\"meta\", [{\"title\": \"no id\"}]) == []"
