      {
        "title": "fetchers.py (1146 lines, largest untested surface — retry logic, ~20 pure parsers, ~14 async paginated fetchers)",
        "content": "\n**Retry wrapper `_request`** — the core resilience primitive, no coverage at all:\n\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_fetchers_request.py",
        "content": "import httpx, pytest\nfrom fetchers import _request\n\n@pytest.mark.asyncio\nasync def test_request_retries_on_5xx_then_succeeds(monkeypatch):\n    calls = {\"n\": 0}\n    async def handler(request):\n        calls[\"n\"] += 1\n        if calls[\"n\"] < 3:\n            return httpx.Response(503)\n        return httpx.Response(200, json={\"ok\": True})\n    monkeypatch.setattr(\"fetchers.asyncio.sleep\", _fake_sleep)  # avoid real backoff delay\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        r = await _request(c, \"https://x.test\", retries=4)\n    assert r.status_code == 200 and calls[\"n\"] == 3\n\n@pytest.mark.asyncio\nasync def test_request_exhausts_retries_raises_runtimeerror(monkeypatch):\n    monkeypatch.setattr(\"fetchers.asyncio.sleep\", _fake_sleep)\n    async def handler(request): return httpx.Response(500)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(c, \"https://x.test\", retries=2)\n\n@pytest.mark.asyncio\nasync def test_request_404_is_also_retried_not_short_circuited(monkeypatch):\n    # NOTE: current code funnels raise_for_status()'s HTTPStatusError through\n    # the same except clause as the explicit retryable list, so a plain 404\n    # also gets retried `retries` times before failing — lock in (or fix) this.\n    calls = {\"n\": 0}\n    async def handler(request):\n        calls[\"n\"] += 1\n        return httpx.Response(404)\n    monkeypatch.setattr(\"fetchers.asyncio.sleep\", _fake_sleep)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        with pytest.raises(RuntimeError):\n            await _request(c, \"https://x.test\", retries=3)\n    assert calls[\"n\"] == 3\n\n@pytest.mark.asyncio\nasync def test_request_transport_error_retried(monkeypatch):\n    async def handler(request): raise httpx.ConnectError(\"boom\")\n    monkeypatch.setattr(\"fetchers.asyncio.sleep\", _fake_sleep)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        with pytest.raises(RuntimeError):\n            await _request(c, \"https://x.test\", retries=2)\n```\n\nI flagged `test_request_404_is_also_retried_not_short_circuited` because it looks like unintended behavior (permanent 4xx errors get retried the same as transient 5xx), which wastes ~30s of backoff per dead source per run — worth confirming with you before writing it as a \"locked-in\" test vs. filing it as a bug.\n\n**`_balanced_json`:**\n\n```python\ndef test_balanced_json_handles_nested_and_escaped_quotes():\n    text = '{\"a\": {\"b\": 1}, \"c\": \"a \\\\\"quoted\\\\\" } brace\"}'\n    assert _balanced_json(text, 0) == text\n\ndef test_balanced_json_unterminated_returns_none():\n    assert _balanced_json('{\"a\": 1', 0) is None\n```\n\n**Pure `parse_*` functions** — one representative pattern per fetcher family (fixture-driven, no I/O). Apply the same shape to the other ~15 parsers (ashby, smartrecruiters, recruitee, workable, google/`_ds1_posted_at`, deshaw, twosigma, optiver, apple/`_apple_hydration`/`_apple_posted_at`, eightfold, bytedance/`_bd_location`, phenom, microsoft, netflix, amazon/`_amazon_posted_at`):\n\n```python\ndef test_parse_greenhouse_missing_optional_fields():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\"}]}   # no location/departments\n    jobs = parse_greenhouse(\"acme\", data)\n    assert jobs[0].location == \"\" and jobs[0].department == \"\"\n\ndef test_lever_salary_min_max_formatted():\n    j = {\"salaryRange\": {\"min\": 120000, \"max\": 150000, \"currency\": \"USD\"}}\n    assert _lever_salary(j) == \"USD 120,000–150,000\"\n\ndef test_lever_salary_falls_back_to_description():\n    assert _lever_salary({\"salaryDescriptionPlain\": \"DOE\"}) == \"DOE\"\n\ndef test_lever_salary_empty_when_nothing_present():\n    assert _lever_salary({}) == \"\"\n\ndef test_parse_ashby_filters_unlisted():\n    data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False}, {\"id\": \"2\", \"title\": \"Eng\"}]}\n    jobs = parse_ashby(\"acme\", data)\n    assert [j.external_id for j in jobs] == [\"2\"]\n\ndef test_amazon_posted_at_valid_and_invalid():\n    assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n    assert _amazon_posted_at(\"garbage\") == \"\"\n    assert _amazon_posted_at(\"\") == \"\"\n\ndef test_apple_posted_at_trims_nanoseconds():\n    assert _apple_posted_at(\"2024-01-01T00:00:03.812668311Z\") == \"2024-01-01T00:00:03.812668+00:00\"\n    assert _apple_posted_at(\"\") == \"\"\n\ndef test_ds1_posted_at_prefers_create_over_update():\n    job = [None]*13 + [[1700000000]]  # index 12\n    assert _ds1_posted_at(job) != \"\"\n\ndef test_bd_location_walks_parent_chain():\n    city = {\"en_name\": \"SF\", \"parent\": {\"en_name\": \"CA\", \"parent\": {\"en_name\": \"US\"}}}\n    assert _bd_location(city) == \"SF, CA, US\"\n\ndef test_bd_location_none_returns_empty():\n    assert _bd_location(None) == \"\"\n```\n\n**Async paginated fetchers** — none have tests; each has distinct stop conditions (empty page / no-fresh-ids / max_pages cap / `total`-vs-`offset` safety cap) that are exactly where off-by-one and infinite-loop bugs hide:\n\n```python\n@pytest.mark.asyncio\nasync def test_fetch_workday_stops_at_total():\n    pages = [\n        {\"jobPostings\": [{\"bulletFields\": [\"R1\"], \"title\": \"A\", \"externalPath\": \"/a\"}], \"total\": 1},\n    ]\n    async def handler(request):\n        return httpx.Response(200, json=pages[0])\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        jobs = await fetch_workday(c, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\", \"page_size\": 20})\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\nasync def test_fetch_workday_safety_cap_at_5000_offset():\n    # server claims total=999999 and always returns one posting -> loop must\n    # bail via the `offset > 5000` cap, not spin forever\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_ashby_falls_back_to_html_on_404():\n    async def handler(request):\n        if \"posting-api\" in str(request.url):\n            return httpx.Response(404)\n        return httpx.Response(200, text='window.__appData= {\"jobBoard\":{\"jobPostings\":[]}}')\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        jobs = await fetch_ashby(c, {\"company\": \"acme\"})\n    assert jobs == []\n\n@pytest.mark.asyncio\nasync def test_fetch_ashby_raises_on_non_404_non_200():\n    async def handler(request): return httpx.Response(500)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        with pytest.raises(httpx.HTTPStatusError):\n            await fetch_ashby(c, {\"company\": \"acme\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_strips_for_semicolon_prefix_and_parses(monkeypatch):\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_raises_on_graphql_errors():\n    # response body: {\"errors\": [{\"message\": \"...\"}]} -> RuntimeError,\n    # this is the doc_id-rotation failure mode called out in memory\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_bytedance_stops_when_count_reached():\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_source_unknown_ats_raises_valueerror():\n    with pytest.raises(ValueError, match=\"unknown ATS\"):\n        await fetch_source(None, {\"ats\": \"nope\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_all_isolates_one_source_failure(monkeypatch):\n    async def bad(client, source): raise RuntimeError(\"dead\")\n    async def good(client, source): return [Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")]\n    monkeypatch.setattr(\"fetchers.FETCHERS\", {\"bad\": bad, \"good\": good})\n    jobs = await fetch_all([{\"ats\": \"bad\", \"company\": \"c1\"}, {\"ats\": \"good\", \"company\": \"c2\"}])\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\nasync def test_fetch_all_respects_concurrency_semaphore():\n    # spin N sources whose handler records max-in-flight count; assert it\n    # never exceeds `concurrency`\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_all_closes_owned_client_but_not_injected_client():\n    injected = httpx.AsyncClient()\n    await fetch_all([], client=injected)\n    assert not injected.is_closed\n    await injected.aclose()\n```\n\n**Integration gap:** every `fetch_*` function is currently exercised only against live third-party endpoints (implicitly, by running the real pipeline). None have a mocked-transport regression test, so ATS-side breakage (schema/doc_id/pagination-key changes — the exact failure mode noted in memory for [[Meta careers fetcher]] and [[Microsoft careers URL migration]]) is invisible until the next scan run fails silently and logs `\"! {ats}:{company} failed\"`. Fixture-based parser tests plus MockTransport pagination tests would catch regressions in the normalization logic even when you can't tell if the live API itself changed.\n\n---\n\n",
        "level": 1
      },
      {
        "title": "agent.py",
        "content": "\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_agent.py",
        "content": "from agent import cmd_db_new, cmd_db_mark, cmd_report_num, _normalize_ats, _amazon_posted_at\n\ndef test_db_new_first_run_uses_since_days_window(store, capsys, monkeypatch):\n    monkeypatch.setattr(\"agent._store\", lambda cfg: store)\n    ... # no marker set -> `first_run: true`, since = now - 7d\n\ndef test_db_new_respects_existing_marker(store, monkeypatch):\n    store.set_meta(\"last_scan\", \"2024-01-01T00:00:00+00:00\")\n    ...\n\ndef test_db_new_posted_days_keeps_undated_by_default():\n    # job with posted_at=\"\" should be counted in undated_kept, not dropped\n    ...\n\ndef test_db_new_dated_only_drops_undated():\n    ...\n\ndef test_db_new_truncates_at_group_boundary_not_mid_group():\n    # two first_seen groups where the first alone exceeds --limit:\n    # per the `if jobs and len(jobs)+len(g) > limit` guard, the first group\n    # is included whole even if it exceeds limit; only the SECOND group triggers\n    # truncation. Assert watermark == first group's timestamp in that case.\n    ...\n\ndef test_db_mark_now_sets_current_timestamp(store, monkeypatch):\n    ...\n\ndef test_db_mark_rejects_non_iso_watermark(capsys):\n    rc = cmd_db_mark([\"not-a-date\"])\n    assert rc == 2\n    assert \"not an ISO timestamp\" in capsys.readouterr().err\n\ndef test_db_mark_requires_watermark_or_now(capsys):\n    rc = cmd_db_mark([])\n    assert rc == 2\n\ndef test_report_num_zero_padded(store, capsys, monkeypatch):\n    monkeypatch.setattr(\"agent._store\", lambda cfg: store)\n    cmd_report_num([])\n    assert capsys.readouterr().out.strip() == \"001\"\n\ndef test_normalize_ats_skips_style_and_script_blocks():\n    html = \"<style>content: '\\u2014';</style><p>em\\u2014dash</p>\"\n    out, counts = _normalize_ats(html)\n    assert \"\\u2014\" in out.split(\"</style>\")[0]     # untouched inside <style>\n    assert \"em-dash\" in out\n    assert counts[\"em-dash\"] == 1\n\ndef test_normalize_ats_replaces_all_mapped_chars():\n    html = \"<p>\\u2018quote\\u2019 \\u2026 \\u2192 \\u2022 item</p>\"\n    out, counts = _normalize_ats(html)\n    assert \"'\" in out and \"...\" in out and \" to \" in out and \"|\" in out\n\ndef test_normalize_ats_ignores_tag_attributes():\n    html = '<a title=\"em\\u2014dash\">text</a>'\n    out, counts = _normalize_ats(html)\n    # only text nodes get fixed, not attribute values inside <...>\n    assert \"em\\u2014dash\" in out  # attribute left untouched\n```\n\nFor `cmd_pdf_render` and `_chrome_bin` (subprocess + filesystem side effects): mock `subprocess.run` and `shutil.which`/`Path.exists` rather than invoking real Chrome.\n\n```python\ndef test_pdf_render_missing_input_returns_2(tmp_path, capsys):\n    rc = cmd_pdf_render([str(tmp_path / \"nope.html\")])\n    assert rc == 2\n\ndef test_pdf_render_failure_prints_stderr_tail(tmp_path, monkeypatch):\n    src = tmp_path / \"in.html\"; src.write_text(\"<html></html>\")\n    monkeypatch.setattr(\"agent._chrome_bin\", lambda: \"/bin/false\")\n    monkeypatch.setattr(\"agent.subprocess.run\", lambda *a, **k: type(\"R\", (), {\"stdout\":\"\",\"stderr\":\"boom\",\"returncode\":1})())\n    rc = cmd_pdf_render([str(src)])\n    assert rc == 1\n\ndef test_chrome_bin_prefers_env_var(tmp_path, monkeypatch):\n    fake = tmp_path / \"chrome\"; fake.touch()\n    monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n    assert _chrome_bin() == str(fake)\n\ndef test_chrome_bin_exits_when_none_found(monkeypatch):\n    monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n    monkeypatch.setattr(\"agent.shutil.which\", lambda name: None)\n    monkeypatch.setattr(\"agent.Path.exists\", lambda self: False)\n    with pytest.raises(SystemExit):\n        _chrome_bin()\n```\n\n`main()`'s argv-routing/flag-splitting logic (`mode_words` vs `extra`, interactive detection) is also untested:\n\n```python\ndef test_main_splits_mode_words_at_first_flag(monkeypatch):\n    captured = {}\n    monkeypatch.setattr(\"agent.run_claude\", lambda mw, i, e: captured.update(mw=mw, i=i, e=e))\n    import sys\n    monkeypatch.setattr(sys, \"argv\", [\"agent.py\", \"scan\", \"--dry-run\"])\n    main()\n    assert captured[\"mw\"] == [\"scan\"] and captured[\"e\"] == [\"--dry-run\"]\n```\n\n---\n\n",
