  "output": "## Test coverage analysis — jobsquare\n\n**Current state: zero tests.** No `tests/` directory, no `pytest` in `requirements.txt`, no CI config. Every function below is untested. `httpx` already supports `httpx.MockTransport`, so most of this needs no new dependency beyond `pytest` + `pytest-asyncio`.\n\nSuggested setup:\n```\n# requirements-dev.txt (new)\npytest>=8.0\npytest-asyncio>=0.24\n```\n```python\n# tests/conftest.py\nimport pytest, httpx\n\n@pytest.fixture\ndef store(tmp_path):\n    from store import Store\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\ndef mock_client(handler):\n    return httpx.AsyncClient(transport=httpx.MockTransport(handler))\n```\n\n---\n\n### models.py — `parse_posted_at`, `Job`\n\nPure functions, highest ROI, zero mocking needed.\n\n```python\n# tests/test_models.py\nimport pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\n@pytest.mark.parametrize(\"value,expected_none\", [\n    (\"\", True),\n    (None, True),           # falsy check on `value` — confirm no TypeError on None\n    (\"not a date\", True),\n    (\"Posted 3 Days Ago\", True),   # Workday prose is never parsed — silently None\n])\ndef test_parse_posted_at_unparseable(value, expected_none):\n    assert (parse_posted_at(value) is None) == expected_none\n\ndef test_parse_posted_at_epoch_seconds():\n    dt = parse_posted_at(\"1700000000\")\n    assert dt.tzinfo == timezone.utc\n\ndef test_parse_posted_at_epoch_milliseconds_boundary():\n    # 999999999999 (12 digits) -> seconds; 1000000000000 (13 digits) -> ms\n    assert parse_posted_at(\"999999999999\").year > 33000  # treated as seconds\n    assert parse_posted_at(\"1700000000000\").year == 2023  # treated as ms\n\ndef test_parse_posted_at_negative_epoch():\n    assert parse_posted_at(\"-100\") is not None\n\ndef test_parse_posted_at_iso_with_z():\n    dt = parse_posted_at(\"2024-01-01T00:00:00Z\")\n    assert dt.tzinfo == timezone.utc\n\ndef test_parse_posted_at_iso_naive_gets_utc():\n    dt = parse_posted_at(\"2024-01-01T00:00:00\")\n    assert dt.tzinfo == timezone.utc\n\ndef test_job_key_stable_across_edits():\n    j1 = Job(source=\"lever\", company=\"acme\", external_id=\"1\", title=\"A\", url=\"u\")\n    j2 = Job(source=\"lever\", company=\"acme\", external_id=\"1\", title=\"B\", url=\"v\")\n    assert j1.key == j2.key\n\ndef test_job_content_hash_changes_on_material_fields():\n    base = Job(source=\"lever\", company=\"acme\", external_id=\"1\", title=\"A\", url=\"u\", location=\"SF\")\n    changed = Job(source=\"lever\", company=\"acme\", external_id=\"1\", title=\"B\", url=\"u\", location=\"SF\")\n    assert base.content_hash != changed.content_hash\n\ndef test_job_to_row_excludes_raw_includes_key_and_hash():\n    j = Job(source=\"lever\", company=\"acme\", external_id=\"1\", title=\"A\", url=\"u\", raw={\"x\": 1})\n    row = j.to_row()\n    assert \"raw\" not in row\n    assert row[\"key\"] == j.key and row[\"content_hash\"] == j.content_hash\n```\n\n---\n\n### filters.py — `match`, `filter_jobs`\n\n```python\n# tests/test_filters.py\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef job(**kw):\n    return Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"Software Engineer\",\n                location=\"Remote - US\", department=\"Eng\", **kw)\n\ndef test_exclude_takes_precedence_over_include():\n    j = job()\n    assert not match(j, include=[\"engineer\"], exclude=[\"software\"])\n\ndef test_include_word_boundary_no_partial_match():\n    j = job(title=\"Sales Engineering Manager\")\n    # \"eng\" must NOT match \"Engineering\" — \\b enforces whole-word\n    assert not match(j, include=[\"eng\"])\n\ndef test_case_insensitive_matching():\n    j = job()\n    assert match(j, include=[\"SOFTWARE\"])\n\ndef test_empty_include_exclude_matches_everything():\n    assert match(job(), include=[], exclude=[])\n\ndef test_location_substring_case_insensitive():\n    j = job(location=\"San Francisco, CA\")\n    assert match(j, locations=[\"san francisco\"])\n    assert not match(j, locations=[\"new york\"])\n\ndef test_cutoff_keeps_unparseable_posted_at():\n    j = job(posted_at=\"Posted 3 Days Ago\")  # unparseable -> keep, per code comment\n    cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n    assert match(j, cutoff=cutoff)\n\ndef test_cutoff_drops_older_confirmed_dates():\n    old = job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n    cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n    assert not match(old, cutoff=cutoff)\n\ndef test_cutoff_boundary_equal_is_kept():\n    now = datetime.now(timezone.utc)\n    j = job(posted_at=now.isoformat())\n    assert match(j, cutoff=now)  # `dt < cutoff` is strict, equal should pass\n\ndef test_filter_jobs_max_age_days_builds_cutoff():\n    stale = job(posted_at=(datetime.now(timezone.utc) - timedelta(days=10)).isoformat())\n    fresh = job(posted_at=datetime.now(timezone.utc).isoformat())\n    out = filter_jobs([stale, fresh], {\"max_age_days\": 5})\n    assert out == [fresh]\n\ndef test_filter_jobs_missing_rules_keys_defaults_safely():\n    assert filter_jobs([job()], {}) == [job()]\n```\n\n---\n\n### store.py — `Store` (SQLite dedup core; highest-risk module — no tests currently guard the diff/migration/concurrency logic)\n\n```python\n# tests/test_store.py\nimport sqlite3, threading\nfrom models import Job\nfrom store import Store\n\ndef make_job(ext=\"1\", title=\"A\", loc=\"SF\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext, title=title,\n               url=\"https://x\", location=loc)\n\ndef test_diff_new_job_inserted_and_returned(store):\n    new, changed = store.diff([make_job()])\n    assert len(new) == 1 and changed == []\n    assert store.count() == 1\n\ndef test_diff_unchanged_job_not_flagged_new_or_changed(store):\n    j = make_job()\n    store.diff([j])\n    new, changed = store.diff([j])\n    assert new == [] and changed == []\n\ndef test_diff_changed_content_flagged_and_updated(store):\n    store.diff([make_job(title=\"Old Title\")])\n    new, changed = store.diff([make_job(title=\"New Title\")])\n    assert new == [] and len(changed) == 1\n    row = store.conn.execute(\"SELECT title FROM jobs WHERE key=?\", (changed[0].key,)).fetchone()\n    assert row[\"title\"] == \"New Title\"\n\ndef test_diff_duplicate_key_within_same_batch():\n    # two entries sharing a key in one call — second should see the first's\n    # uncommitted insert via the same connection and be treated as changed, not new\n    store_jobs = [make_job(title=\"A\"), make_job(title=\"B\")]\n    ...  # assert on new/changed counts; document actual behavior\n\ndef test_migrate_adds_salary_range_to_legacy_db(tmp_path):\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.executescript(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n        external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n        employment_type TEXT, posted_at TEXT, content_hash TEXT,\n        first_seen TEXT, last_seen TEXT);\"\"\")\n    conn.commit(); conn.close()\n    with Store(path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\ndef test_get_meta_missing_key_returns_none(store):\n    assert store.get_meta(\"nope\") is None\n\ndef test_set_meta_is_upsert(store):\n    store.set_meta(\"k\", \"v1\")\n    store.set_meta(\"k\", \"v2\")\n    assert store.get_meta(\"k\") == \"v2\"\n\ndef test_next_seq_increments_from_one(store):\n    assert store.next_seq(\"report_seq\") == 1\n    assert store.next_seq(\"report_seq\") == 2\n\ndef test_next_seq_concurrent_workers_no_lost_updates(tmp_path):\n    # regression guard for the parallel-worker report-id collision risk\n    with Store(tmp_path / \"c.db\") as s:\n        results = []\n        def claim():\n            results.append(s.next_seq(\"report_seq\"))\n        threads = [threading.Thread(target=claim) for _ in range(20)]\n        [t.start() for t in threads]; [t.join() for t in threads]\n        assert sorted(results) == list(range(1, 21))  # no duplicates/gaps\n\ndef test_added_since_excludes_equal_timestamp(store):\n    store.diff([make_job()])\n    ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n    assert store.added_since(ts) == []          # strict >\n    assert len(store.added_since(\"2000-01-01T00:00:00+00:00\")) == 1\n\ndef test_added_since_ordering(store):\n    store.diff([make_job(ext=\"2\", title=\"Z\"), make_job(ext=\"1\", title=\"A\")])\n    rows = store.added_since(\"2000-01-01T00:00:00+00:00\")\n    assert [r[\"title\"] for r in rows] == [\"A\", \"Z\"]  # ordered by first_seen, company, title\n\ndef test_count_empty_db_is_zero(store):\n    assert store.count() == 0\n\ndef test_context_manager_closes_connection(tmp_path):\n    with Store(tmp_path / \"x.db\") as s:\n        pass\n    with pytest.raises(sqlite3.ProgrammingError):\n        s.conn.execute(\"SELECT 1\")\n```\n\nThe concurrent `next_seq` test directly targets the known risk in memory ([[jobsquare-parallel-worker-collisions]]) — worth prioritizing.\n\n---\n\n### pipeline.py — `load_config`, `run`, `run_sync`\n\n```python\n# tests/test_pipeline.py\nimport pytest\nfrom pipeline import load_config, run, run_sync\n\ndef test_load_config_applies_defaults(tmp_path):\n    p = tmp_path / \"c.yaml\"\n    p.write_text(\"sources: []\\n\")\n    cfg = load_config(p)\n    assert cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8 and cfg[\"filters\"] == {}\n\ndef test_load_config_missing_file_raises(tmp_path):\n    with pytest.raises(FileNotFoundError):\n        load_config(tmp_path / \"nope.yaml\")\n\ndef test_load_config_invalid_yaml_raises(tmp_path):\n    p = tmp_path / \"bad.yaml\"\n    p.write_text(\"sources: [unterminated\")\n    import yaml\n    with pytest.raises(yaml.YAMLError):\n        load_config(p)\n\n@pytest.mark.asyncio\nasync def test_run_dry_run_does_not_persist(tmp_path, monkeypatch):\n    cfg = tmp_path / \"c.yaml\"\n    cfg.write_text(f\"sources: []\\ndb: {tmp_path / 'x.db'}\\n\")\n    monkeypatch.setattr(\"pipeline.fetch_all\", _fake_fetch_all([...]))\n    result = await run(cfg, dry_run=True)\n    assert result == {\"matched\": ..., \"new\": 0, \"changed\": 0}\n    assert not (tmp_path / \"x.db\").exists() or Store(tmp_path/'x.db').count() == 0\n\n@pytest.mark.asyncio\nasync def test_run_persists_and_dispatches(tmp_path, monkeypatch):\n    # monkeypatch fetch_all/dispatch, assert Store.diff got called with filtered jobs\n    ...\n\ndef test_run_sync_wraps_asyncio_run(monkeypatch):\n    called = {}\n    async def fake_run(path, dry_run=False):\n        called[\"args\"] = (path, dry_run)\n        return {\"matched\": 0, \"new\": 0, \"changed\": 0}\n    monkeypatch.setattr(\"pipeline.run\", fake_run)\n    run_sync(\"cfg.yaml\", dry_run=True)\n    assert called[\"args\"] == (\"cfg.yaml\", True)\n```\n\n**Testability gap:** `run()` builds its own `httpx.AsyncClient` indirectly via `fetch_all` and takes no injectable client, so a true integration test needs `monkeypatch` on `fetchers.fetch_all` rather than dependency injection at the `pipeline` layer. Worth threading a `client` param through if integration tests become a priority.\n\n---\n\n### notify.py — `dispatch` + 5 notifiers (all env-gated side effects, currently 100% untested)\n\n```python\n# tests/test_notify.py\nimport httpx, pytest\nfrom models import Job\nfrom notify import notify_console, notify_slack, notify_webhook, notify_email, notify_sms, _sms_body, dispatch, NOTIFIERS\n\ndef j(title=\"A\"): return Job(source=\"x\", company=\"c\", external_id=\"1\", title=title, url=\"u\")\n\ndef test_notify_console_no_jobs_prints_message(capsys):\n    notify_console([], [])\n    assert \"No fresh listings\" in capsys.readouterr().out\n\ndef test_notify_slack_noop_without_env(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append((a, k)))\n    notify_slack([j()], [])\n    assert calls == []\n\ndef test_notify_slack_posts_when_configured(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda url, json, timeout: calls.append(json))\n    notify_slack([j()], [])\n    assert \"1 new job(s)\" in calls[0][\"text\"]\n\ndef test_notify_slack_noop_when_no_jobs(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify_slack([], [])\n    assert calls == []\n\ndef test_notify_webhook_payload_serializes_jobs(monkeypatch):\n    monkeypatch.setenv(\"WEBHOOK_URL\", \"https://x.test/hook\")\n    captured = {}\n    monkeypatch.setattr(httpx, \"post\", lambda url, content, headers, timeout: captured.update(body=content))\n    notify_webhook([j()], [])\n    assert '\"new\"' in captured[\"body\"]\n\ndef test_notify_email_requires_host_and_to(monkeypatch):\n    monkeypatch.delenv(\"SMTP_HOST\", raising=False)\n    monkeypatch.delenv(\"EMAIL_TO\", raising=False)\n    notify_email([j()], [])  # should not raise / not attempt SMTP\n\ndef test_notify_email_sends_via_smtp(monkeypatch):\n    monkeypatch.setenv(\"SMTP_HOST\", \"smtp.test\")\n    monkeypatch.setenv(\"EMAIL_TO\", \"a@b.com\")\n    sent = []\n    class FakeSMTP:\n        def __init__(self, *a, **k): pass\n        def __enter__(self): return self\n        def __exit__(self, *a): pass\n        def starttls(self): pass\n        def send_message(self, msg): sent.append(msg)\n    monkeypatch.setattr(\"notify.smtplib.SMTP\", FakeSMTP)\n    notify_email([j()], [])\n    assert len(sent) == 1\n\ndef test_notify_email_logs_in_when_smtp_user_set(monkeypatch):\n    # assert .login() called only when SMTP_USER present, not otherwise\n    ...\n\ndef test_sms_body_ascii_only_and_truncates(monkeypatch):\n    jobs = [j(title=f\"Role {i}\") for i in range(12)]\n    body = _sms_body(jobs, [], limit=8)\n    assert \"+4 more\" in body\n    assert all(ord(c) < 128 for c in body)\n\ndef test_notify_sms_requires_all_four_env_vars(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n    monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify_sms([j()], [])\n    assert calls == []\n\ndef test_notify_sms_raises_on_twilio_failure(monkeypatch):\n    for k, v in [(\"TWILIO_ACCOUNT_SID\",\"s\"),(\"TWILIO_AUTH_TOKEN\",\"t\"),\n                 (\"TWILIO_FROM\",\"+1\"),(\"TWILIO_TO\",\"+2\")]:\n        monkeypatch.setenv(k, v)\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: httpx.Response(400, request=httpx.Request(\"POST\",\"https://x\")))\n    with pytest.raises(httpx.HTTPStatusError):\n        notify_sms([j()], [])\n\ndef test_dispatch_continues_after_one_notifier_fails(monkeypatch, capsys):\n    def boom(new, changed): raise RuntimeError(\"smtp down\")\n    monkeypatch.setattr(\"notify.NOTIFIERS\", [boom, notify_console])\n    dispatch([j()], [])\n    out = capsys.readouterr().out\n    assert \"notifier boom failed\" in out and \"NEW listing\" in out\n```\n\n---\n\n### fetchers.py (1146 lines, largest untested surface — retry logic, ~20 pure parsers, ~14 async paginated fetchers)\n\n**Retry wrapper `_request`** — the core resilience primitive, no coverage at all:\n\n```python\n# tests/test_fetchers_request.py\nimport httpx, pytest\nfrom fetchers import _request\n\n@pytest.mark.asyncio\nasync def test_request_retries_on_5xx_then_succeeds(monkeypatch):\n    calls = {\"n\": 0}\n    async def handler(request):\n        calls[\"n\"] += 1\n        if calls[\"n\"] < 3:\n            return httpx.Response(503)\n        return httpx.Response(200, json={\"ok\": True})\n    monkeypatch.setattr(\"fetchers.asyncio.sleep\", _fake_sleep)  # avoid real backoff delay\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        r = await _request(c, \"https://x.test\", retries=4)\n    assert r.status_code == 200 and calls[\"n\"] == 3\n\n@pytest.mark.asyncio\nasync def test_request_exhausts_retries_raises_runtimeerror(monkeypatch):\n    monkeypatch.setattr(\"fetchers.asyncio.sleep\", _fake_sleep)\n    async def handler(request): return httpx.Response(500)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(c, \"https://x.test\", retries=2)\n\n@pytest.mark.asyncio\nasync def test_request_404_is_also_retried_not_short_circuited(monkeypatch):\n    # NOTE: current code funnels raise_for_status()'s HTTPStatusError through\n    # the same except clause as the explicit retryable list, so a plain 404\n    # also gets retried `retries` times before failing — lock in (or fix) this.\n    calls = {\"n\": 0}\n    async def handler(request):\n        calls[\"n\"] += 1\n        return httpx.Response(404)\n    monkeypatch.setattr(\"fetchers.asyncio.sleep\", _fake_sleep)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        with pytest.raises(RuntimeError):\n            await _request(c, \"https://x.test\", retries=3)\n    assert calls[\"n\"] == 3\n\n@pytest.mark.asyncio\nasync def test_request_transport_error_retried(monkeypatch):\n    async def handler(request): raise httpx.ConnectError(\"boom\")\n    monkeypatch.setattr(\"fetchers.asyncio.sleep\", _fake_sleep)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        with pytest.raises(RuntimeError):\n            await _request(c, \"https://x.test\", retries=2)\n```\n\nI flagged `test_request_404_is_also_retried_not_short_circuited` because it looks like unintended behavior (permanent 4xx errors get retried the same as transient 5xx), which wastes ~30s of backoff per dead source per run — worth confirming with you before writing it as a \"locked-in\" test vs. filing it as a bug.\n\n**`_balanced_json`:**\n\n```python\ndef test_balanced_json_handles_nested_and_escaped_quotes():\n    text = '{\"a\": {\"b\": 1}, \"c\": \"a \\\\\"quoted\\\\\" } brace\"}'\n    assert _balanced_json(text, 0) == text\n\ndef test_balanced_json_unterminated_returns_none():\n    assert _balanced_json('{\"a\": 1', 0) is None\n```\n\n**Pure `parse_*` functions** — one representative pattern per fetcher family (fixture-driven, no I/O). Apply the same shape to the other ~15 parsers (ashby, smartrecruiters, recruitee, workable, google/`_ds1_posted_at`, deshaw, twosigma, optiver, apple/`_apple_hydration`/`_apple_posted_at`, eightfold, bytedance/`_bd_location`, phenom, microsoft, netflix, amazon/`_amazon_posted_at`):\n\n```python\ndef test_parse_greenhouse_missing_optional_fields():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\"}]}   # no location/departments\n    jobs = parse_greenhouse(\"acme\", data)\n    assert jobs[0].location == \"\" and jobs[0].department == \"\"\n\ndef test_lever_salary_min_max_formatted():\n    j = {\"salaryRange\": {\"min\": 120000, \"max\": 150000, \"currency\": \"USD\"}}\n    assert _lever_salary(j) == \"USD 120,000–150,000\"\n\ndef test_lever_salary_falls_back_to_description():\n    assert _lever_salary({\"salaryDescriptionPlain\": \"DOE\"}) == \"DOE\"\n\ndef test_lever_salary_empty_when_nothing_present():\n    assert _lever_salary({}) == \"\"\n\ndef test_parse_ashby_filters_unlisted():\n    data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False}, {\"id\": \"2\", \"title\": \"Eng\"}]}\n    jobs = parse_ashby(\"acme\", data)\n    assert [j.external_id for j in jobs] == [\"2\"]\n\ndef test_amazon_posted_at_valid_and_invalid():\n    assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n    assert _amazon_posted_at(\"garbage\") == \"\"\n    assert _amazon_posted_at(\"\") == \"\"\n\ndef test_apple_posted_at_trims_nanoseconds():\n    assert _apple_posted_at(\"2024-01-01T00:00:03.812668311Z\") == \"2024-01-01T00:00:03.812668+00:00\"\n    assert _apple_posted_at(\"\") == \"\"\n\ndef test_ds1_posted_at_prefers_create_over_update():\n    job = [None]*13 + [[1700000000]]  # index 12\n    assert _ds1_posted_at(job) != \"\"\n\ndef test_bd_location_walks_parent_chain():\n    city = {\"en_name\": \"SF\", \"parent\": {\"en_name\": \"CA\", \"parent\": {\"en_name\": \"US\"}}}\n    assert _bd_location(city) == \"SF, CA, US\"\n\ndef test_bd_location_none_returns_empty():\n    assert _bd_location(None) == \"\"\n```\n\n**Async paginated fetchers** — none have tests; each has distinct stop conditions (empty page / no-fresh-ids / max_pages cap / `total`-vs-`offset` safety cap) that are exactly where off-by-one and infinite-loop bugs hide:\n\n```python\n@pytest.mark.asyncio\nasync def test_fetch_workday_stops_at_total():\n    pages = [\n        {\"jobPostings\": [{\"bulletFields\": [\"R1\"], \"title\": \"A\", \"externalPath\": \"/a\"}], \"total\": 1},\n    ]\n    async def handler(request):\n        return httpx.Response(200, json=pages[0])\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        jobs = await fetch_workday(c, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\", \"page_size\": 20})\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\nasync def test_fetch_workday_safety_cap_at_5000_offset():\n    # server claims total=999999 and always returns one posting -> loop must\n    # bail via the `offset > 5000` cap, not spin forever\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_ashby_falls_back_to_html_on_404():\n    async def handler(request):\n        if \"posting-api\" in str(request.url):\n            return httpx.Response(404)\n        return httpx.Response(200, text='window.__appData= {\"jobBoard\":{\"jobPostings\":[]}}')\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        jobs = await fetch_ashby(c, {\"company\": \"acme\"})\n    assert jobs == []\n\n@pytest.mark.asyncio\nasync def test_fetch_ashby_raises_on_non_404_non_200():\n    async def handler(request): return httpx.Response(500)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        with pytest.raises(httpx.HTTPStatusError):\n            await fetch_ashby(c, {\"company\": \"acme\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_strips_for_semicolon_prefix_and_parses(monkeypatch):\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_raises_on_graphql_errors():\n    # response body: {\"errors\": [{\"message\": \"...\"}]} -> RuntimeError,\n    # this is the doc_id-rotation failure mode called out in memory\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_bytedance_stops_when_count_reached():\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_source_unknown_ats_raises_valueerror():\n    with pytest.raises(ValueError, match=\"unknown ATS\"):\n        await fetch_source(None, {\"ats\": \"nope\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_all_isolates_one_source_failure(monkeypatch):\n    async def bad(client, source): raise RuntimeError(\"dead\")\n    async def good(client, source): return [Job(source=\"x\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")]\n    monkeypatch.setattr(\"fetchers.FETCHERS\", {\"bad\": bad, \"good\": good})\n    jobs = await fetch_all([{\"ats\": \"bad\", \"company\": \"c1\"}, {\"ats\": \"good\", \"company\": \"c2\"}])\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\nasync def test_fetch_all_respects_concurrency_semaphore():\n    # spin N sources whose handler records max-in-flight count; assert it\n    # never exceeds `concurrency`\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_all_closes_owned_client_but_not_injected_client():\n    injected = httpx.AsyncClient()\n    await fetch_all([], client=injected)\n    assert not injected.is_closed\n    await injected.aclose()\n```\n\n**Integration gap:** every `fetch_*` function is currently exercised only against live third-party endpoints (implicitly, by running the real pipeline). None have a mocked-transport regression test, so ATS-side breakage (schema/doc_id/pagination-key changes — the exact failure mode noted in memory for [[Meta careers fetcher]] and [[Microsoft careers URL migration]]) is invisible until the next scan run fails silently and logs `\"! {ats}:{company} failed\"`. Fixture-based parser tests plus MockTransport pagination tests would catch regressions in the normalization logic even when you can't tell if the live API itself changed.\n\n---\n\n### agent.py\n\n```python\n# tests/test_agent.py\nfrom agent import cmd_db_new, cmd_db_mark, cmd_report_num, _normalize_ats, _amazon_posted_at\n\ndef test_db_new_first_run_uses_since_days_window(store, capsys, monkeypatch):\n    monkeypatch.setattr(\"agent._store\", lambda cfg: store)\n    ... # no marker set -> `first_run: true`, since = now - 7d\n\ndef test_db_new_respects_existing_marker(store, monkeypatch):\n    store.set_meta(\"last_scan\", \"2024-01-01T00:00:00+00:00\")\n    ...\n\ndef test_db_new_posted_days_keeps_undated_by_default():\n    # job with posted_at=\"\" should be counted in undated_kept, not dropped\n    ...\n\ndef test_db_new_dated_only_drops_undated():\n    ...\n\ndef test_db_new_truncates_at_group_boundary_not_mid_group():\n    # two first_seen groups where the first alone exceeds --limit:\n    # per the `if jobs and len(jobs)+len(g) > limit` guard, the first group\n    # is included whole even if it exceeds limit; only the SECOND group triggers\n    # truncation. Assert watermark == first group's timestamp in that case.\n    ...\n\ndef test_db_mark_now_sets_current_timestamp(store, monkeypatch):\n    ...\n\ndef test_db_mark_rejects_non_iso_watermark(capsys):\n    rc = cmd_db_mark([\"not-a-date\"])\n    assert rc == 2\n    assert \"not an ISO timestamp\" in capsys.readouterr().err\n\ndef test_db_mark_requires_watermark_or_now(capsys):\n    rc = cmd_db_mark([])\n    assert rc == 2\n\ndef test_report_num_zero_padded(store, capsys, monkeypatch):\n    monkeypatch.setattr(\"agent._store\", lambda cfg: store)\n    cmd_report_num([])\n    assert capsys.readouterr().out.strip() == \"001\"\n\ndef test_normalize_ats_skips_style_and_script_blocks():\n    html = \"<style>content: '\\u2014';</style><p>em\\u2014dash</p>\"\n    out, counts = _normalize_ats(html)\n    assert \"\\u2014\" in out.split(\"</style>\")[0]     # untouched inside <style>\n    assert \"em-dash\" in out\n    assert counts[\"em-dash\"] == 1\n\ndef test_normalize_ats_replaces_all_mapped_chars():\n    html = \"<p>\\u2018quote\\u2019 \\u2026 \\u2192 \\u2022 item</p>\"\n    out, counts = _normalize_ats(html)\n    assert \"'\" in out and \"...\" in out and \" to \" in out and \"|\" in out\n\ndef test_normalize_ats_ignores_tag_attributes():\n    html = '<a title=\"em\\u2014dash\">text</a>'\n    out, counts = _normalize_ats(html)\n    # only text nodes get fixed, not attribute values inside <...>\n    assert \"em\\u2014dash\" in out  # attribute left untouched\n```\n\nFor `cmd_pdf_render` and `_chrome_bin` (subprocess + filesystem side effects): mock `subprocess.run` and `shutil.which`/`Path.exists` rather than invoking real Chrome.\n\n```python\ndef test_pdf_render_missing_input_returns_2(tmp_path, capsys):\n    rc = cmd_pdf_render([str(tmp_path / \"nope.html\")])\n    assert rc == 2\n\ndef test_pdf_render_failure_prints_stderr_tail(tmp_path, monkeypatch):\n    src = tmp_path / \"in.html\"; src.write_text(\"<html></html>\")\n    monkeypatch.setattr(\"agent._chrome_bin\", lambda: \"/bin/false\")\n    monkeypatch.setattr(\"agent.subprocess.run\", lambda *a, **k: type(\"R\", (), {\"stdout\":\"\",\"stderr\":\"boom\",\"returncode\":1})())\n    rc = cmd_pdf_render([str(src)])\n    assert rc == 1\n\ndef test_chrome_bin_prefers_env_var(tmp_path, monkeypatch):\n    fake = tmp_path / \"chrome\"; fake.touch()\n    monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n    assert _chrome_bin() == str(fake)\n\ndef test_chrome_bin_exits_when_none_found(monkeypatch):\n    monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n    monkeypatch.setattr(\"agent.shutil.which\", lambda name: None)\n    monkeypatch.setattr(\"agent.Path.exists\", lambda self: False)\n    with pytest.raises(SystemExit):\n        _chrome_bin()\n```\n\n`main()`'s argv-routing/flag-splitting logic (`mode_words` vs `extra`, interactive detection) is also untested:\n\n```python\ndef test_main_splits_mode_words_at_first_flag(monkeypatch):\n    captured = {}\n    monkeypatch.setattr(\"agent.run_claude\", lambda mw, i, e: captured.update(mw=mw, i=i, e=e))\n    import sys\n    monkeypatch.setattr(sys, \"argv\", [\"agent.py\", \"scan\", \"--dry-run\"])\n    main()\n    assert captured[\"mw\"] == [\"scan\"] and captured[\"e\"] == [\"--dry-run\"]\n```\n\n---\n\n### cli.py\n\n```python\n# tests/test_cli.py\ndef test_main_defaults(monkeypatch):\n    captured = {}\n    monkeypatch.setattr(\"cli.run_sync\", lambda cfg, dry_run: captured.update(cfg=cfg, dry_run=dry_run))\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\"])\n    main()\n    assert captured == {\"cfg\": \"sources.yaml\", \"dry_run\": False}\n\ndef test_main_passes_dry_run_and_config(monkeypatch):\n    captured = {}\n    monkeypatch.setattr(\"cli.run_sync\", lambda cfg, dry_run: captured.update(cfg=cfg, dry_run=dry_run))\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\", \"-c\", \"other.yaml\", \"--dry-run\"])\n    main()\n    assert captured == {\"cfg\": \"other.yaml\", \"dry_run\": True}\n```\n\n---\n\n## Priority ranking\n\n1. **store.py** — the dedup/diff logic is the correctness backbone of the whole tool; a bug here means silent duplicate notifications or lost jobs. Zero coverage today.\n2. **fetchers.py `_request` + `parse_*`** — pure, fast, highest bug-surface (20 besp