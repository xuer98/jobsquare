        "code": "# tests/test_store.py\nimport sqlite3, threading\nfrom models import Job\nfrom store import Store\n\ndef make_job(ext=\"1\", title=\"A\", loc=\"SF\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext, title=title,\n               url=\"https://x\", location=loc)\n\ndef test_diff_new_job_inserted_and_returned(store):\n    new, changed = store.diff([make_job()])\n    assert len(new) == 1 and changed == []\n    assert store.count() == 1\n\ndef test_diff_unchanged_job_not_flagged_new_or_changed(store):\n    j = make_job()\n    store.diff([j])\n    new, changed = store.diff([j])\n    assert new == [] and changed == []\n\ndef test_diff_changed_content_flagged_and_updated(store):\n    store.diff([make_job(title=\"Old Title\")])\n    new, changed = store.diff([make_job(title=\"New Title\")])\n    assert new == [] and len(changed) == 1\n    row = store.conn.execute(\"SELECT title FROM jobs WHERE key=?\", (changed[0].key,)).fetchone()\n    assert row[\"title\"] == \"New Title\"\n\ndef test_diff_duplicate_key_within_same_batch():\n    # two entries sharing a key in one call — second should see the first's\n    # uncommitted insert via the same connection and be treated as changed, not new\n    store_jobs = [make_job(title=\"A\"), make_job(title=\"B\")]\n    ...  # assert on new/changed counts; document actual behavior\n\ndef test_migrate_adds_salary_range_to_legacy_db(tmp_path):\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.executescript(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n        external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n        employment_type TEXT, posted_at TEXT, content_hash TEXT,\n        first_seen TEXT, last_seen TEXT);\"\"\")\n    conn.commit(); conn.close()\n    with Store(path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\ndef test_get_meta_missing_key_returns_none(store):\n    assert store.get_meta(\"nope\") is None\n\ndef test_set_meta_is_upsert(store):\n    store.set_meta(\"k\", \"v1\")\n    store.set_meta(\"k\", \"v2\")\n    assert store.get_meta(\"k\") == \"v2\"\n\ndef test_next_seq_increments_from_one(store):\n    assert store.next_seq(\"report_seq\") == 1\n    assert store.next_seq(\"report_seq\") == 2\n\ndef test_next_seq_concurrent_workers_no_lost_updates(tmp_path):\n    # regression guard for the parallel-worker report-id collision risk\n    with Store(tmp_path / \"c.db\") as s:\n        results = []\n        def claim():\n            results.append(s.next_seq(\"report_seq\"))\n        threads = [threading.Thread(target=claim) for _ in range(20)]\n        [t.start() for t in threads]; [t.join() for t in threads]\n        assert sorted(results) == list(range(1, 21))  # no duplicates/gaps\n\ndef test_added_since_excludes_equal_timestamp(store):\n    store.diff([make_job()])\n    ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n    assert store.added_since(ts) == []          # strict >\n    assert len(store.added_since(\"2000-01-01T00:00:00+00:00\")) == 1\n\ndef test_added_since_ordering(store):\n    store.diff([make_job(ext=\"2\", title=\"Z\"), make_job(ext=\"1\", title=\"A\")])\n    rows = store.added_since(\"2000-01-01T00:00:00+00:00\")\n    assert [r[\"title\"] for r in rows] == [\"A\", \"Z\"]  # ordered by first_seen, company, title\n\ndef test_count_empty_db_is_zero(store):\n    assert store.count() == 0\n\ndef test_context_manager_closes_connection(tmp_path):\n    with Store(tmp_path / \"x.db\") as s:\n        pass\n    with pytest.raises(sqlite3.ProgrammingError):\n        s.conn.execute(\"SELECT 1\")"
