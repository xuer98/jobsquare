tpx.ConnectError(\"boom\")\n    monkeypatch.setattr(\"fetchers.asyncio.sleep\", _fake_sleep)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as c:\n        with pytest.raises(RuntimeError):\n            await _request(c, \"https://x.test\", retries=2)"
