        "code": "# tests/test_agent.py\nfrom agent import cmd_db_new, cmd_db_mark, cmd_report_num, _normalize_ats, _amazon_posted_at\n\ndef test_db_new_first_run_uses_since_days_window(store, capsys, monkeypatch):\n    monkeypatch.setattr(\"agent._store\", lambda cfg: store)\n    ... # no marker set -> `first_run: true`, since = now - 7d\n\ndef test_db_new_respects_existing_marker(store, monkeypatch):\n    store.set_meta(\"last_scan\", \"2024-01-01T00:00:00+00:00\")\n    ...\n\ndef test_db_new_posted_days_keeps_undated_by_default():\n    # job with posted_at=\"\" should be counted in undated_kept, not dropped\n    ...\n\ndef test_db_new_dated_only_drops_undated():\n    ...\n\ndef test_db_new_truncates_at_group_boundary_not_mid_group():\n    # two first_seen groups where the first alone exceeds --limit:\n    # per the `if jobs and len(jobs)+len(g) > limit` guard, the first group\n    # is included whole even if it exceeds limit; only the SECOND group triggers\n    # truncation. Assert watermark == first group's timestamp in that case.\n    ...\n\ndef test_db_mark_now_sets_current_timestamp(store, monkeypatch):\n    ...\n\ndef test_db_mark_rejects_non_iso_watermark(capsys):\n    rc = cmd_db_mark([\"not-a-date\"])\n    assert rc == 2\n    assert \"not an ISO timestamp\" in capsys.readouterr().err\n\ndef test_db_mark_requires_watermark_or_now(capsys):\n    rc = cmd_db_mark([])\n    assert rc == 2\n\ndef test_report_num_zero_padded(store, capsys, monkeypatch):\n    monkeypatch.setattr(\"agent._store\", lambda cfg: store)\n    cmd_report_num([])\n    assert capsys.readouterr().out.strip() == \"001\"\n\ndef test_normalize_ats_skips_style_and_script_blocks():\n    html = \"<style>content: '\\u2014';</style><p>em\\u2014dash</p>\"\n    out, counts = _normalize_ats(html)\n    assert \"\\u2014\" in out.split(\"</style>\")[0]     # untouched inside <style>\n    assert \"em-dash\" in out\n    assert counts[\"em-dash\"] == 1\n\ndef test_normalize_ats_replaces_all_mapped_chars():\n    html = \"<p>\\u2018quote\\u2019 \\u2026 \\u2192 \\u2022 item</p>\"\n    out, counts = _normalize_ats(html)\n    assert \"'\" in out and \"...\" in out and \" to \" in out and \"|\" in out\n\ndef test_normalize_ats_ignores_tag_attributes():\n    html = '<a title=\"em\\u2014dash\">text</a>'\n    out, counts = _normalize_ats(html)\n    # only text nodes get fixed, not attribute values inside <...>\n    assert \"em\\u2014dash\" in out  # attribute left untouched"
