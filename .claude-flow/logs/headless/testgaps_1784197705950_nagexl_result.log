        "content": "import pytest\nfrom pipeline import load_config, run, run_sync\n\ndef test_load_config_applies_defaults(tmp_path):\n    p = tmp_path / \"c.yaml\"\n    p.write_text(\"sources: []\\n\")\n    cfg = load_config(p)\n    assert cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8 and cfg[\"filters\"] == {}\n\ndef test_load_config_missing_file_raises(tmp_path):\n    with pytest.raises(FileNotFoundError):\n        load_config(tmp_path / \"nope.yaml\")\n\ndef test_load_config_invalid_yaml_raises(tmp_path):\n    p = tmp_path / \"bad.yaml\"\n    p.write_text(\"sources: [unterminated\")\n    import yaml\n    with pytest.raises(yaml.YAMLError):\n        load_config(p)\n\n@pytest.mark.asyncio\nasync def test_run_dry_run_does_not_persist(tmp_path, monkeypatch):\n    cfg = tmp_path / \"c.yaml\"\n    cfg.write_text(f\"sources: []\\ndb: {tmp_path / 'x.db'}\\n\")\n    monkeypatch.setattr(\"pipeline.fetch_all\", _fake_fetch_all([...]))\n    result = await run(cfg, dry_run=True)\n    assert result == {\"matched\": ..., \"new\": 0, \"changed\": 0}\n    assert not (tmp_path / \"x.db\").exists() or Store(tmp_path/'x.db').count() == 0\n\n@pytest.mark.asyncio\nasync def test_run_persists_and_dispatches(tmp_path, monkeypatch):\n    # monkeypatch fetch_all/dispatch, assert Store.diff got called with filtered jobs\n    ...\n\ndef test_run_sync_wraps_asyncio_run(monkeypatch):\n    called = {}\n    async def fake_run(path, dry_run=False):\n        called[\"args\"] = (path, dry_run)\n        return {\"matched\": 0, \"new\": 0, \"changed\": 0}\n    monkeypatch.setattr(\"pipeline.run\", fake_run)\n    run_sync(\"cfg.yaml\", dry_run=True)\n    assert called[\"args\"] == (\"cfg.yaml\", True)\n```\n\n**Testability gap:** `run()` builds its own `httpx.AsyncClient` indirectly via `fetch_all` and takes no injectable client, so a true integration test needs `monkeypatch` on `fetchers.fetch_all` rather than dependency injection at the `pipeline` layer. Worth threading a `client` param through if integration tests become a priority.\n\n---\n\n",
