        "title": "tests/test_notify.py",
        "content": "import httpx, pytest\nfrom models import Job\nfrom notify import notify_console, notify_slack, notify_webhook, notify_email, notify_sms, _sms_body, dispatch, NOTIFIERS\n\ndef j(title=\"A\"): return Job(source=\"x\", company=\"c\", external_id=\"1\", title=title, url=\"u\")\n\ndef test_notify_console_no_jobs_prints_message(capsys):\n    notify_console([], [])\n    assert \"No fresh listings\" in capsys.readouterr().out\n\ndef test_notify_slack_noop_without_env(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append((a, k)))\n    notify_slack([j()], [])\n    assert calls == []\n\ndef test_notify_slack_posts_when_configured(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda url, json, timeout: calls.append(json))\n    notify_slack([j()], [])\n    assert \"1 new job(s)\" in calls[0][\"text\"]\n\ndef test_notify_slack_noop_when_no_jobs(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify_slack([], [])\n    assert calls == []\n\ndef test_notify_webhook_payload_serializes_jobs(monkeypatch):\n    monkeypatch.setenv(\"WEBHOOK_URL\", \"https://x.test/hook\")\n    captured = {}\n    monkeypatch.setattr(httpx, \"post\", lambda url, content, headers, timeout: captured.update(body=content))\n    notify_webhook([j()], [])\n    assert '\"new\"' in captured[\"body\"]\n\ndef test_notify_email_requires_host_and_to(monkeypatch):\n    monkeypatch.delenv(\"SMTP_HOST\", raising=False)\n    monkeypatch.delenv(\"EMAIL_TO\", raising=False)\n    notify_email([j()], [])  # should not raise / not attempt SMTP\n\ndef test_notify_email_sends_via_smtp(monkeypatch):\n    monkeypatch.setenv(\"SMTP_HOST\", \"smtp.test\")\n    monkeypatch.setenv(\"EMAIL_TO\", \"a@b.com\")\n    sent = []\n    class FakeSMTP:\n        def __init__(self, *a, **k): pass\n        def __enter__(self): return self\n        def __exit__(self, *a): pass\n        def starttls(self): pass\n        def send_message(self, msg): sent.append(msg)\n    monkeypatch.setattr(\"notify.smtplib.SMTP\", FakeSMTP)\n    notify_email([j()], [])\n    assert len(sent) == 1\n\ndef test_notify_email_logs_in_when_smtp_user_set(monkeypatch):\n    # assert .login() called only when SMTP_USER present, not otherwise\n    ...\n\ndef test_sms_body_ascii_only_and_truncates(monkeypatch):\n    jobs = [j(title=f\"Role {i}\") for i in range(12)]\n    body = _sms_body(jobs, [], limit=8)\n    assert \"+4 more\" in body\n    assert all(ord(c) < 128 for c in body)\n\ndef test_notify_sms_requires_all_four_env_vars(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n    monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n    calls = []\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: calls.append(1))\n    notify_sms([j()], [])\n    assert calls == []\n\ndef test_notify_sms_raises_on_twilio_failure(monkeypatch):\n    for k, v in [(\"TWILIO_ACCOUNT_SID\",\"s\"),(\"TWILIO_AUTH_TOKEN\",\"t\"),\n                 (\"TWILIO_FROM\",\"+1\"),(\"TWILIO_TO\",\"+2\")]:\n        monkeypatch.setenv(k, v)\n    monkeypatch.setattr(httpx, \"post\", lambda *a, **k: httpx.Response(400, request=httpx.Request(\"POST\",\"https://x\")))\n    with pytest.raises(httpx.HTTPStatusError):\n        notify_sms([j()], [])\n\ndef test_dispatch_continues_after_one_notifier_fails(monkeypatch, capsys):\n    def boom(new, changed): raise RuntimeError(\"smtp down\")\n    monkeypatch.setattr(\"notify.NOTIFIERS\", [boom, notify_console])\n    dispatch([j()], [])\n    out = capsys.readouterr().out\n    assert \"notifier boom failed\" in out and \"NEW listing\" in out\n```\n\n---\n\n",
