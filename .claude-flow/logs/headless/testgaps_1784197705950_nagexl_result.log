        "content": "def test_main_defaults(monkeypatch):\n    captured = {}\n    monkeypatch.setattr(\"cli.run_sync\", lambda cfg, dry_run: captured.update(cfg=cfg, dry_run=dry_run))\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\"])\n    main()\n    assert captured == {\"cfg\": \"sources.yaml\", \"dry_run\": False}\n\ndef test_main_passes_dry_run_and_config(monkeypatch):\n    captured = {}\n    monkeypatch.setattr(\"cli.run_sync\", lambda cfg, dry_run: captured.update(cfg=cfg, dry_run=dry_run))\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\", \"-c\", \"other.yaml\", \"--dry-run\"])\n    main()\n    assert captured == {\"cfg\": \"other.yaml\", \"dry_run\": True}\n```\n\n---\n\n",
