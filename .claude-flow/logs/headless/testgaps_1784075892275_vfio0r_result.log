        "content": "import pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_and_none(self):\n        assert parse_posted_at(\"\") is None\n        assert parse_posted_at(None) is None\n\n    def test_epoch_milliseconds(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt.tzinfo == timezone.utc\n        assert dt.year == 2022\n\n    def test_epoch_seconds(self):\n        dt = parse_posted_at(\"1643241332\")\n        assert dt.year == 2022\n\n    def test_negative_epoch(self):\n        assert parse_posted_at(\"-100\") is not None\n\n    def test_iso_with_trailing_z(self):\n        dt = parse_posted_at(\"2026-01-01T00:00:00Z\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_naive_gets_utc(self):\n        dt = parse_posted_at(\"2026-01-01T00:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_unparseable_prose_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_garbage_returns_none(self):\n        assert parse_posted_at(\"not-a-date\") is None\n\n\nclass TestJob:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"SWE\", url=\"https://x/1\", location=\"NY\")\n        base.update(overrides)\n        return Job(**base)\n\n    def test_key_is_stable_identity(self):\n        j = self._job()\n        assert j.key == \"greenhouse:acme:1\"\n\n    def test_content_hash_changes_on_title_change(self):\n        j1, j2 = self._job(), self._job(title=\"Sr SWE\")\n        assert j1.content_hash != j2.content_hash\n\n    def test_content_hash_stable_when_salary_or_posted_at_changes(self):\n        j1 = self._job(salary_range=\"100k\", posted_at=\"2026-01-01\")\n        j2 = self._job(salary_range=\"200k\", posted_at=\"2026-02-01\")\n        assert j1.content_hash == j2.content_hash  # documents current (surprising) behavior\n\n    def test_to_row_excludes_raw_includes_key_and_hash(self):\n        row = self._job(raw={\"secret\": 1}).to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] and row[\"content_hash\"]\n\n    def test_posted_dt_property_delegates(self):\n        assert self._job(posted_at=\"\").posted_dt is None\n```\n\n---\n\n",
