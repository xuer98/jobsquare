e_miss_excludes_job(self):\n        assert match(make_job(title=\"Designer\"), include=[\"engineer\"]) is False\n\n    def test_locations_substring_case_insensitive(self):\n        assert match(make_job(location=\"San Francisco, CA\"), locations=[\"san francisco\"]) is True\n\n    def test_locations_no_match(self):\n        assert match(make_job(location=\"London\"), locations=[\"New York\"]) is False\n\n    def test_cutoff_drops_old_confirmed_date(self):\n        old = make_job(posted_at=\"2020-01-01T00:00:00Z\")\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(old, cutoff=cutoff) is False\n\n    def test_cutoff_keeps_unparseable_date(self):\n        j = make_job(posted_at=\"Posted 3 Days Ago\")  # Workday-style prose\n        cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n        assert match(j, cutoff=cutoff) is True\n\n    def test_cutoff_keeps_recent_job(self):\n        recent = make_job(posted_at=datetime.now(timezone.utc).isoformat())\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(recent, cutoff=cutoff) is True\n\n\nclass TestFilterJobs:\n    def test_empty_rules_passthrough(self):\n        jobs = [make_job(), make_job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs\n\n    def test_max_age_days_as_string_from_yaml(self):\n        old = make_job(posted_at=\"2020-01-01T00:00:00Z\")\n        assert filter_jobs([old], {\"max_age_days\": \"30\"}) == []\n\n    def test_combines_include_exclude_locations(self):\n        jobs = [\n            make_job(external_id=\"1\", title=\"Backend Engineer\", location=\"NY\"),\n            make_job(external_id=\"2\", title=\"Backend Manager\", location=\"NY\"),\n            make_job(external_id=\"3\", title=\"Backend Engineer\", location=\"London\"),\n        ]\n        rules = {\"include_keywords\": [\"engineer\"], \"exclude_keywords\": [\"manager\"],\n                 \"locations\": [\"NY\"]}\n        result = filter_jobs(jobs, rules)\n        assert [j.external_id for j in result] == [\"1\"]\n```\n\n---\n\n### 3. `store.py` — untested entirely, highest-risk gap (stateful SQLite dedup logic)\n\n**Gaps:** `diff()` three-way branch (new/changed/unchanged), migration path, `added_since()` ordering, `meta` upsert semantics.\n\nEdge cases not covered:\n- Same job appearing twice in one `diff()` call (duplicate `external_id` within a single fetch)\n- `_migrate()` actually adding `salary_range` to a pre-existing DB missing that column\n- `added_since()` boundary is **strict** `>` — a row with `first_seen == ts` should be excluded, easy off-by-one to regress\n- `content_hash` unchanged → only `last_seen` updated, `title`/`url` etc. not rewritten (currently untested — if content_hash didn't change but something else did, e.g. corrupted `raw`... not applicable since raw isn't stored, but worth confirming `last_seen` bump works)\n- `count()` on empty DB\n- Context manager (`__enter__`/`__exit__`) actually closes connection\n- Concurrent runs / re-opening the same `path` file\n\n```python\n# test_store.py\nimport sqlite3\nimport tempfile\nfrom pathlib import Path\nimport pytest\nfrom store import Store\nfrom models import Job\n\n@pytest.fixture\ndef tmp_db_path(tmp_path):\n    return tmp_path / \"jobs.db\"\n\ndef make_job(ext_id=\"1\", title=\"SWE\", **kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=ext_id,\n                title=title, url=\"u\", location=\"NY\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestDiff:\n    def test_new_job_is_new(self, tmp_db_path):\n        with Store(tmp_db_path) as store:\n            new, changed = store.diff([make_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_on_second_run(self, tmp_db_path):\n        with Store(tmp_db_path) as store:\n            store.diff([make_job()])\n            new, changed = store.diff([make_job()])\n        assert new == [] and changed == []\n\n    def test_changed_title_detected(self, tmp_db_path):\n        with Store(tmp_db_path) as store:\n            store.diff([make_job(title=\"SWE\")])\n            new, changed = store.diff([make_job(title=\"Sr SWE\")])\n        assert new == [] and len(changed) == 1\n\n    def test_salary_only_change_not_flagged_changed(self, tmp_db_path):\n        # documents the content_hash asymmetry from models.py\n        with Store(tmp_db_path) as store:\n            store.diff([make_job(salary_range=\"100k\")])\n            new, changed = store.diff([make_job(salary_range=\"200k\")])\n        assert new == [] and changed == []\n\n    def test_duplicate_external_id_within_one_batch(self, tmp_db_path):\n        with Store(tmp_db_path) as store:\n            new, changed = store.diff([make_job(), make_job()])\n        assert store.count() == 1  # second insert should not crash on PK conflict\n\n    def test_last_seen_bumped_on_unchanged(self, tmp_db_path, freezer=None):\n        with Store(tmp_db_path) as store:\n            store.diff([make_job()])\n            row1 = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n            store.diff([make_job()])\n            row2 = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        assert row2[\"last_seen\"] >= row1[\"last_seen\"]\n\n\nclass TestMigration:\n    def test_adds_salary_range_to_legacy_db(self, tmp_db_path):\n        conn = sqlite3.connect(str(tmp_db_path))\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        with Store(tmp_db_path) as store:\n            cols = {r[\"name\"] for r in store.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\n\nclass TestMeta:\n    def test_get_meta_missing_key_returns_none(self, tmp_db_path):\n        with Store(tmp_db_path) as store:\n            assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_meta(self, tmp_db_path):\n        with Store(tmp_db_path) as store:\n            store.set_meta(\"last_scan\", \"2026-01-01T00:00:00+00:00\")\n            assert store.get_meta(\"last_scan\") == \"2026-01-01T00:00:00+00:00\"\n\n    def test_set_meta_upserts(self, tmp_db_path):\n        with Store(tmp_db_path) as store:\n            store.set_meta(\"k\", \"v1\")\n            store.set_meta(\"k\", \"v2\")\n            assert store.get_meta(\"k\") == \"v2\"\n\n\nclass TestAddedSince:\n    def test_strict_greater_than_excludes_boundary(self, tmp_db_path):\n        with Store(tmp_db_path) as store:\n            store.diff([make_job()])\n            ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[\"first_seen\"]\n            assert store.added_since(ts) == []          # boundary excluded\n            assert len(store.added_since(\"2000-01-01T00:00:00\")) == 1\n\n    def test_ordering_is_first_seen_then_company_then_title(self, tmp_db_path):\n        ...  # insert rows with controlled first_seen via monkeypatched now, assert order\n\nclass TestCount:\n    def test_empty_db_count_zero(self, tmp_db_path):\n        with Store(tmp_db_path) as store:\n            assert store.count() == 0\n```\n\n---\n\n### 4. `pipeline.py` — untested entirely (integration surface)\n\n**Gaps:** `load_config` defaults, `run()`'s dry-run short-circuit (skips Store + dispatch), full happy path.\n\n```python\n# test_pipeline.py\nimport pytest\nfrom unittest.mock import AsyncMock, patch\nimport pipeline\n\ndef test_load_config_applies_defaults(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(\"sources: []\\n\")\n    cfg = pipeline.load_config(cfg_file)\n    assert cfg[\"filters\"] == {} and cfg[\"db\"] == \"jobs.db\" and cfg[\"concurrency\"] == 8\n\ndef test_load_config_preserves_explicit_values(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(\"sources: []\\ndb: custom.db\\nconcurrency: 3\\n\")\n    cfg = pipeline.load_config(cfg_file)\n    assert cfg[\"db\"] == \"custom.db\" and cfg[\"concurrency\"] == 3\n\n@pytest.mark.asyncio\nasync def test_dry_run_never_touches_store_or_notify(tmp_path):\n    cfg_file = tmp_path / \"sources.yaml\"\n    cfg_file.write_text(\"sources: []\\n\")\n    with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n         patch(\"pipeline.Store\") as store_cls, \\\n         patch(\"pipeline.dispatch\") as dispatch_fn:\n        result = await pipeline.run(cfg_file, dry_run=True)\n    store_cls.assert_not_called()\n    dispatch_fn.assert_not_called()\n    assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n\n@pytest.mark.asyncio\nasync def test_run_wires_fetch_filter_diff_dispatch(tmp_path, ...):\n    # integration-style: real filters.py + real Store on tmp db, fake fetch_all\n    ...\n\n@pytest.mark.asyncio\nasync def test_run_sync_wraps_asyncio_run(tmp_path, monkeypatch):\n    called = {}\n    async def fake_run(path, dry_run=False):\n        called[\"ok\"] = True\n        return {}\n    monkeypatch.setattr(pipeline, \"run\", fake_run)\n    pipeline.run_sync(tmp_path / \"x.yaml\", dry_run=False)\n    assert called[\"ok\"]\n```\n\nMissing config error handling: `load_config` on a **missing file** or **malformed YAML** raises unhandled `FileNotFoundError`/`yaml.YAMLError` straight through — no test proves the CLI surfaces this cleanly (see `cli.py` gap below too).\n\n---\n\n### 5. `notify.py` — untested entirely, and the one module with real production-incident risk (SMS/email/webhook side effects)\n\n**Gaps:** every notifier's env-var gating, the `dispatch()` per-notifier exception isolation (a broken notifier must not block the others), `_sms_body` truncation.\n\nEdge cases not covered:\n- Each notifier no-ops when its env var(s) unset — must be tested per-notifier, not just spot-checked\n- Each notifier no-ops when both `new` and `changed` are empty, **even if configured** (currently silent — worth asserting no HTTP call happens)\n- `dispatch()`: one notifier raising must not prevent the rest from running (this is the most important behavior in the file and has zero coverage)\n- `_sms_body` truncation at `limit=8` and the \"+N more\" line\n- `notify_sms` calls `resp.raise_for_status()` — a 4xx from Twilio must propagate as an exception that `dispatch` catches (not crash the whole run)\n- Partial Twilio env vars (3 of 4 set) → no-op, not a partial/crashing send\n\n```python\n# test_notify.py\nimport json\nimport pytest\nimport httpx\nimport respx\nfrom unittest.mock import patch, MagicMock\nimport notify\nfrom models import Job\n\ndef make_job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"SWE\", url=\"https://x/1\", location=\"NY\", salary_range=\"150k\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestNotifyConsole:\n    def test_prints_no_fresh_listings_when_empty(self, capsys):\n        notify.notify_console([], [])\n        assert \"No fresh listings\" in capsys.readouterr().out\n\n    def test_prints_new_and_changed_sections(self, capsys):\n        notify.notify_console([make_job()], [make_job(external_id=\"2\")])\n        out = capsys.readouterr().out\n        assert \"NEW listing\" in out and \"UPDATED listing\" in out\n\n\nclass TestNotifySlack:\n    def test_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with patch(\"httpx.post\") as post:\n            notify.notify_slack([make_job()], [])\n        post.assert_not_called()\n\n    def test_noop_when_no_jobs_even_if_configured(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack/x\")\n        with patch(\"httpx.post\") as post:\n            notify.notify_slack([], [])\n        post.assert_not_called()\n\n    @respx.mock\n    def test_posts_when_configured_and_new_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack/x\")\n        route = respx.post(\"https://hooks.slack/x\").mock(return_value=httpx.Response(200))\n        notify.notify_slack([make_job()], [])\n        assert route.called\n\n\nclass TestNotifySms:\n    def test_noop_when_partial_twilio_env(self, monkeypatch):\n        monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n        monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n        with patch(\"httpx.post\") as post:\n            notify.notify_sms([make_job()], [])\n        post.assert_not_called()\n\n    @respx.mock\n    def test_raises_on_twilio_4xx(self, monkeypatch):\n        for k, v in dict(TWILIO_ACCOUNT_SID=\"sid\", TWILIO_AUTH_TOKEN=\"tok\",\n                          TWILIO_FROM=\"+1\", TWILIO_TO=\"+2\").items():\n            monkeypatch.setenv(k, v)\n        respx.post(url__regex=r\".*Messages\\.json\").mock(\n            return_value=httpx.Response(400, json={\"message\": \"bad\"}))\n        with pytest.raises(httpx.HTTPStatusError):\n            notify.notify_sms([make_job()], [])\n\n    def test_sms_body_truncates_at_limit(self):\n        jobs = [make_job(external_id=str(i), title=f\"Job{i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n        assert body.count(\"- Job\") == 8\n\n\nclass TestDispatch:\n    def test_one_notifier_failing_does_not_block_others(self, capsys):\n        calls = []\n        def ok(new, changed): calls.append(\"ok\")\n        def boom(new, changed): raise RuntimeError(\"smtp down\")\n        with patch.object(notify, \"NOTIFIERS\", [boom, ok]):\n            notify.dispatch([make_job()], [])\n        assert calls == [\"ok\"]\n        assert \"notifier boom failed\" in capsys.readouterr().out\n```\n\nAlso missing: `notify_email` (SMTP interaction — needs `smtplib.SMTP` mocked) and `notify_webhook` (JSON payload shape / `default=str` fallback for non-serializable fields) have no skeleton coverage beyond the pattern above; same gating tests apply.\n\n---\n\n### 6. `fetchers.py` (787 lines) — the largest, riskiest, and completely untested module\n\nThis is where the actual bugs will hide — 15 ATS integrations, each with bespoke, defensive parsing of untrusted upstream payloads. **The module docstring literally states the HTTP client is injectable \"so the parsing logic is unit-testable against mocked transports without touching the network\"** — that intent has never been acted on.\n\n**Priority gaps, by risk:**\n\n**a) `_request` retry/backoff logic — zero coverage, easy to break silently**\n```python\n# test_fetchers_request.py\nimport httpx, pytest, respx\nfrom fetchers import _request\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_retries_on_500_then_succeeds():\n    route = respx.get(\"https://x/jobs\").mock(side_effect=[\n        httpx.Response(500), httpx.Response(200, json={\"ok\": True})])\n    async with httpx.AsyncClient() as client:\n        r = await _request(client, \"https://x/jobs\", retries=3)\n    assert r.status_code == 200 and route.call_count == 2\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_exhausts_retries_and_raises_runtime_error():\n    respx.get(\"https://x/jobs\").mock(return_value=httpx.Response(503))\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(client, \"https://x/jobs\", retries=2)\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_non_retryable_4xx_raises_immediately_without_retry():\n    route = respx.get(\"https://x/jobs\").mock(return_value=httpx.Response(404))\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(RuntimeError):\n            await _request(client, \"https://x/jobs\", retries=5)\n    assert route.call_count == 1   # 404 isn't in the retryable set — should not retry 5x\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_transport_error_retried(monkeypatch):\n    # simulate httpx.ConnectError then success\n    ...\n```\n\n**b) `parse_*` functions — each needs its own minimal-payload + malformed-payload test, no network needed**\n\nPattern to apply to *every* parser (`parse_greenhouse`, `parse_lever`, `parse_ashby`, `parse_smartrecruiters`, `parse_recruitee`, `parse_workable`, `parse_google`, `parse_deshaw`, `parse_twosigma`, `parse_optiver`, `parse_workday` (inline in `fetch_workday`), `parse_meta`, `parse_microsoft`, `parse_netflix`, `parse_amazon`):\n\n```python\n# test_fetchers_parsers.py\nfrom fetchers import parse_greenhouse, parse_lever, _lever_salary, parse_ashby, \\\n    parse_amazon, _amazon_posted_at, parse_google, _extract_ds1, _ds1_posted_at, \\\n    parse_deshaw, parse_twosigma, parse_meta, parse_microsoft, parse_netflix\n\nclass TestParseGreenhouse:\n    def test_minimal_job(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\", \"absolute_url\": \"u\",\n                           \"location\": {\"name\": \"NY\"}, \"departments\": [{\"name\": \"Eng\"}],\n                           \"updated_at\": \"2026-01-01T00:00:00Z\"}]}\n        [job] = parse_greenhouse(\"acme\", data)\n        assert job.external_id == \"1\" and job.department == \"Eng\"\n\n    def test_missing_optional_fields_defaults_empty(self):\n        data = {\"jobs\": [{\"id\": 2}]}   # no title/location/url/departments\n        [job] = parse_greenhouse(\"acme\", data)\n        assert job.title == \"\" and job.location == \"\" and job.department == \"\"\n\n    def test_empty_jobs_list(self):\n        assert parse_greenhouse(\"acme\", {\"jobs\": []}) == []\n\n    def test_missing_jobs_key(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\n    def test_missing_id_raises_keyerror(self):\n        # documents current behavior: a job with no \"id\" crashes the whole batch\n        with pytest.raises(KeyError):\n            parse_greenhouse(\"acme\", {\"jobs\": [{\"title\": \"SWE\"}]})\n\n\nclass TestLeverSalary:\n    def test_min_max_present(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_falls_back_to_description(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_data_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n    def test_float_values_format(self):\n        j = {\"salaryRange\": {\"min\": 100000.0, \"max\": 150000.0}}\n        assert \"100,000\" in _lever_salary(j)\n\n\nclass TestAmazonPostedAt:\n    def test_valid_date_string(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_single_digit_day(self):\n        assert _amazon_posted_at(\"March 1, 2026\") == \"2026-03-01T00:00:00+00:00\"\n\n    def test_malformed_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_empty_string(self):\n        assert _amazon_posted_at(\"\") == \"\"\n\n    def test_unknown_month_returns_empty(self):\n        assert _amazon_posted_at(\"Frobtober 1, 2026\") == \"\"\n\n\nclass TestGoogleDs1:\n    def test_extract_ds1_happy_path(self):\n        html = \"AF_initDataCallback({key: 'ds:1', ..., data:[[{\\\"a\\\":1}]], sideChannel:{}})\"\n        # craft valid json matching regex; assert list returned\n\n    def test_extract_ds1_missing_key_returns_empty(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_extract_ds1_malformed_json_returns_empty(self):\n        html = \"key: 'ds:1', data:[not valid json], sideChannel\"\n        assert _extract_ds1(html) == []\n\n    def test_ds1_posted_at_prefers_index_12(self):\n        job = [None]*13 + [[1700000000]]\n        assert _ds1_posted_at(job) != \"\"\n\n    def test_ds1_posted_at_missing_all_indices(self):\n        assert _ds1_posted_at([None]*10) == \"\"\n\n    def test_parse_google_skips_falsy_entries(self):\n        from fetchers import parse_google\n        assert parse_google(\"google\", [None, [None]]) == []\n\n\nclass TestParseDeshaw:\n    def test_dedups_by_job_id(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">SWE</span>'\n                '<span class=\"location\">NY</span></div>'\n                '<div data-job-id=\"1\"><span class=\"job-display-name\">SWE</span></div>')\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert len(jobs) == 1\n\n    def test_missing_title_skips_card(self):\n        page = '<div data-job-id=\"1\"></div>'\n        assert parse_deshaw(\"deshaw\", page) == []\n\n    def test_html_entities_unescaped_in_title(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">'\n                'R&amp;D Engineer</span></div>')\n        [job] = parse_deshaw(\"deshaw\", page)\n        assert job.title == \"R&D Engineer\"\n\n\nclass TestParseMeta:\n    def test_dedups_by_id(self):\n        results = [{\"id\": \"1\", \"title\": \"SWE\"}, {\"id\": \"1\", \"title\": \"SWE dup\"}]\n        assert len(parse_meta(\"meta\", results)) == 1\n\n    def test_missing_id_skipped(self):\n        assert parse_meta(\"meta\", [{\"title\": \"no id\"}]) == []\n\n    def test_locations_and_teams_joined(self):\n        [job] = parse_meta(\"meta\", [{\"id\": \"1\", \"locations\": [\"NY\", \"SF\"],\n                                      \"teams\": [\"Infra\"]}])\n        assert job.location == \"NY; SF\"\n```\n\n*(Same pattern applies to `parse_ashby` (`isListed=False` skip), `parse_smartrecruiters`/`parse_recruitee`/`parse_workable` (location dict-vs-string branching), `parse_microsoft`/`parse_netflix` (missing `postedTs`/`t_create`), `parse_twosigma` (triple-render dedup), `parse_optiver` (slug extraction) — each has a distinct defensive branch with zero coverage.)*\n\n**c) Pagination loop logic — `fetch_twosigma`, `fetch_optiver`, `fetch_workday`, `fetch_google`, `fetch_microsoft`, `fetch_netflix`, `fetch_amazon` all share a \"stop when no fresh IDs\" pattern with subtly different implementations — needs per-function tests with `respx` mocking 2-3 pages:**\n\n```python\n# test_fetchers_pagination.py\nimport httpx, pytest, respx\nfrom fetchers import fetch_amazon\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_amazon_stops_when_no_fresh_ids():\n    respx.get(\"https://www.amazon.jobs/en/search.json\").mock(side_effect=[\n        httpx.Response(200, json={\"jobs\": [{\"id\": \"1\", \"title\": \"A\", \"job_path\": \"/a\"}]}),\n        httpx.Response(200, json={\"jobs\": []}),\n    ])\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_amazon(client, {\"company\": \"amazon\", \"max_pages\": 5})\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_amazon_respects_max_pages_safety_cap():\n    route = respx.get(\"https://www.amazon.jobs/en/search.json\").mock(\n        return_value=httpx.Response(200, json={\"jobs\": [\n            {\"id\": \"dup\", \"title\": \"A\", \"job_path\": \"/a\"}]}))  # always same id -> never \"fresh\" after p1\n    async with httpx.AsyncClient() as client:\n        await fetch_amazon(client, {\"company\": \"amazon\", \"max_pages\": 3})\n    assert route.call_count <= 3\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_workday_stops_at_total():\n    respx.post(url__regex=r\".*/wday/cxs/.*\").mock(return_value=httpx.Response(\n        200, json={\"jobPostings\": [], \"total\": 0}))\n    async with httpx.AsyncClient() as client:\n        jobs = await fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\"})\n    assert jobs == []\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_workday_offset_safety_cap_5000():\n    # postings never empty and total huge -> loop must still terminate at offset > 5000\n    ...\n```\n\n**d) `fetch_meta` — token scraping regex is the single most fragile piece in the whole codebase (per its own comment about doc_id rotation) and has zero test coverage for the failure mode it explicitly anticipates:**\n\n```python\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_meta_raises_readable_error_on_graphql_error(monkeypatch):\n    respx.get(\"https://www.metacareers.com/jobs\").mock(\n        return_value=httpx.Response(200, text='[\"LSD\",[],{\"token\":\"tok\"}]\"__spin_r\":1'))\n    respx.post(\"https://www.metacareers.com/graphql\").mock(\n        return_value=httpx.Response(200, text='for (;;);{\"errors\":[{\"message\":\"doc_id stale\"}]}'))\n    from fetchers import fetch_meta\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(RuntimeError, match=\"doc_id stale\"):\n            await fetch_meta(client, {\"company\": \"meta\"})\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_meta_strips_for_loop_prefix_and_parses():\n    ...\n\n@pytest.mark.asyncio\n@respx.mock\nasync def test_fetch_meta_missing_tokens_still_sends_request_with_empty_strings():\n    # scraping page without the expected tokens shouldn't crash the regex helper\n    ...\n```\n\n**e) `fetch_source` / `fetch_all` — dispatch + isolation, currently untested**\n\n```python\n# test_fetchers_dispatch.py\nimport pytest\nfrom fetchers import fetch_source, fetch_all\n\n@pytest.mark.asyncio\nasync def test_fetch_source_unknown_ats_raises_value_error():\n    with pytest.raises(ValueError, match=\"unknown ATS\"):\n        await fetch_source(None, {\"ats\": \"bogus\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_all_one_source_failing_does_not_kill_others(monkeypatch, capsys):\n    async def boom(client, source): raise RuntimeError(\"network down\")\n    async def ok(client, source): return [object()]\n    monkeypatch.setitem(__import__(\"fetchers\").FETCHERS, \"greenhouse\", boom)\n    monkeypatch.setitem(__import__(\"fetchers\").FETCHERS, \"lever\", ok)\n    jobs = await fetch_all([{\"ats\": \"greenhouse\", \"company\": \"x\"},\n                             {\"ats\": \"lever\", \"company\": \"y\"}])\n    assert len(jobs) == 1\n    assert \"greenhouse:x failed\" in capsys.readouterr().out\n\n@pytest.mark.asyncio\nasync def test_fetch_all_respects_concurrency_semaphore():\n    # spawn N sources with a fetcher that records concurrent-in-flight count,\n    # assert peak concurrency <= configured value\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_all_closes_owned_client_but_not_injected_one():\n    ...\n```\n\n---\n\n### 7. `agent.py` — the deterministic (non-LLM) helpers are untested; these are the highest-value target since they're pure/local and don't need Claude Code itself\n\n**Gaps:**\n- `cmd_db_new`: first-run window vs marker-based window, `--limit` truncation **at group boundaries only** (the trickiest logic in the file — a `groupby` on `first_seen` that must never split a same-timestamp batch), `truncated` flag correctness\n- `cmd_db_mark`: `--now` vs explicit watermark vs neither (exit code 2), invalid ISO string rejected\n- `_normalize_ats`: must not touch text inside `<style>`/`<script>` tags or inside tag attributes — only body text between tags; needs an explicit adversarial test since the regex splitting is subtle\n- `_chrome_bin`: `CHROME_PATH` env var precedence, `PATH` lookup, hardcoded macOS app paths, `sys.exit` when none found\n- `cmd_pdf_render`: input file missing (exit 2), Chrome producing non-PDF output (exit 1)\n- `main()` argv routing: `-h`/`--help`, subcommands, bare invocation (interactive), mode-words-until-first-flag splitting\n\n```python\n# test_agent.py\nimport json\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nimport agent\nfrom store import Store\nfrom models import Job\n\ndef _make_config(tmp_path, db_path):\n    cfg = tmp_path / \"sources.yaml\"\n    cfg.write_text(f\"db: {db_path}\\nsources: []\\n\")\n    return cfg\n\nclass TestDbNew:\n    def test_first_run_uses_since_days_window(self, tmp_path, capsys):\n        db = tmp_path / \"jobs.db\"\n        cfg = _make_config(tmp_path, db)\n        with Store(db) as store:\n            store.diff([Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                             title=\"SWE\", url=\"u\")])\n        agent.cmd_db_new([\"-c\", str(cfg), \"--since-days\", \"1\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True and out[\"count\"] == 1\n\n    def test_marker_based_window_excludes_older_rows(self, tmp_path, capsys):\n        db = tmp_path / \"jobs.db\"\n        cfg = _make_config(tmp_path, db)\n        with Store(db) as store:\n            store.diff([Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                             title=\"SWE\", url=\"u\")])\n            future = (datetime.now(timezone.utc) + timedelta(seconds=1)).isoformat(\n                timespec=\"seconds\")\n            store.set_meta(\"last_scan\", future)\n        agent.cmd_db_new([\"-c\", str(cfg)])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is False and out[\"count\"] == 0\n\n    def test_limit_truncates_at_group_boundary_not_mid_group(self, tmp_path, capsys):\n        # two jobs inserted in the SAME diff() call share first_seen; with\n        # limit=1 they must either both be included or both excluded, never split\n        db = tmp_path / \"jobs.db\"\n        cfg = _make_config(tmp_path, db)\n        with Store(db) as store:\n            store.diff([\n                Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\", title=\"A\", url=\"u\"),\n                Job(source=\"greenhouse\", company=\"acme\", external_id=\"2\", title=\"B\", url=\"u\"),\n            ])\n        agent.cmd_db_new([\"-c\", str(cfg), \"--limit\", \"1\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"count\"] == 0 and out[\"truncated\"] is True  # can't fit the group of 2\n\n    def test_watermark_is_last_included_group_ts_not_since(self, tmp_path, capsys):\n        ...\n\n\nclass TestDbMark:\n    def test_now_flag_sets_current_time(self, tmp_path, capsys):\n        db = tmp_path / \"jobs.db\"\n        cfg = _make_config(tmp_path, db)\n        rc = agent.cmd_db_mark([\"--now\", \"-c\", str(cfg)])\n        assert rc == 0\n        with Store(db) as store:\n            assert store.get_meta(\"last_scan\") is not None\n\n    def test_invalid_watermark_returns_exit_2(self, tmp_path, capsys):\n        cfg = _make_config(tmp_path, tmp_path / \"jobs.db\")\n        rc = agent.cmd_db_mark([\"not-a-date\", \"-c\", str(cfg)])\n        assert rc == 2\n\n    def test_no_args_returns_exit_2(self, tmp_path):\n        cfg = _make_config(tmp_path, tmp_path / \"jobs.db\")\n        assert agent.cmd_db_mark([\"-c\", str(cfg)]) == 2\n\n\nclass TestNormalizeAts:\n    def test_replaces_smart_quotes_in_body_text(self):\n        html, counts = agent._normalize_ats(\"<p>He said \\u201chi\\u201d</p>\")\n        assert '\"hi\"' in html and counts.get(\"smart-double-quote\") == 2\n\n    def test_does_not_touch_style_block(self):\n        html, counts = agent._normalize_ats(\n            \"<style>.x::before{content:'\\u2014'}</style><p>a\\u2014b</p>\")\n        assert \"\\u2014\" in html.split(\"</style>\")[0]   # untouched inside style\n        assert \"-\" in html.split(\"</style>\")[1]         # replaced in body\n\n    def test_does_not_touch_tag_attributes(self):\n        html, _ = agent._normalize_ats('<a title=\"em\\u2014dash\">x</a>')\n        assert 'title=\"em\\u2014dash\"' in html\n\n    def test_empty_html_no_crash(self):\n        html, counts = agent._normalize_ats(\"\")\n        assert html == \"\" and counts == {}\n\n\nclass TestChromeBin:\n    def test_chrome_path_env_takes_precedence(self, monkeypatch, tmp_path):\n        fake = tmp_path / \"chrome\"\n        fake.write_text(\"\")\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert agent._chrome_bin() == str(fake)\n\n    def test_exits_when_nothing_found(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        monkeypatch.setattr(agent.shutil, \"which\", lambda name: None)\n        monkeypatch.setattr(agent.Path, \"exists\", lambda self: False)\n        with pytest.raises(SystemExit):\n            agent._chrome_bin()\n\n\nclass TestPdfRenderInputValidation:\n    def test_missing_input_file_returns_2(self, tmp_path, capsys):\n        rc = agent.cmd_pdf_render([str(tmp_path / \"nope.html\")])\n        assert rc == 2\n\n\nclass TestMainRouting:\n    def test_help_flag_prints_docstring_and_exits_0(self, capsys):\n        assert agent.main.__wrapped__ if False else True  # placeholder for argv patching\n    def test_db_new_subcommand_dispatches(self, monkeypatch):\n        called = {}\n        monkeypatch.setattr(agent, \"cmd_db_new\", lambda argv: called.setdefault(\"argv\", argv) or 0)\n        monkeypatch.setattr(\"sys.argv\", [\"agent.py\", \"db-new\", \"-c\", \"x.yaml\"])\n        assert agent.main() == 0\n        assert called[\"argv\"] == [\"-c\", \"x.yaml\"]\n\n    def test_mode_words_split_at_first_flag(self, monkeypatch):\n        captured = {}\n        monkeypatch.setattr(agent, \"run_claude\",\n            lambda mode_words, interactive, extra: captured.update(\n                mode_words=mode_words, extra=extra) or 0)\n        monkeypatch.setattr(\"sys.argv\", [\"agent.py\", \"scan\", \"--foo\", \"bar\"])\n        agent.main()\n        assert captured[\"mode_words\"] == [\"scan\"]\n        assert captured[\"extra\"] == [\"--foo\", \"bar\"]\n```\n\n---\n\n### 8. `cli.py` — untested entirely\n\nSmall but the actual user-facing entrypoint. Missing:\n- `main()` wires `--config`/`--dry-run` through to `run_sync` correctly\n- Default config path is `sources.yaml`\n- A `load_config` failure (missing file) propagates as an unhandled traceback to the CLI user rather than a clean error message — **this is a real UX gap worth flagging**, not just a test gap\n\n```python\n# test_cli.py\nfrom unittest.mock import patch\nimport cli\n\ndef test_main_passes_config_and_dry_run(monkeypatch):\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\", \"-c\", \"my.yaml\", \"--dry-run\"])\n    with patch(\"cli.run_sync\") as run_sync:\n        cli.main()\n    run_sync.assert_called_once_with(\"my.yaml\", dry_run=True)\n\ndef test_main_default_config_path(monkeypatch):\n    monkeypatch.setattr(\"sys.argv\", [\"cli.py\"])\n    with patch(\"cli.run_sync\") as run_sync:\n        cli.main()\n    run_sync.assert_called_once_with(\"sources.yaml\", dry_run=False)\n```\n\n---\n\n### Integration test gaps (no unit test substitutes for these)\n\n1. **End-to-end pipeline run against a real (or respx-mocked) HTTP layer + real SQLite tmp file** — fetch → filter → diff → dispatch, asserting the DB state and printed summary after two consecutive runs (first run all \"new\", second run mostly \"unchanged\", one \"changed\").\n2. **`agent.py db-new` → `db-mark` → `db-new` cycle** — proves the watermark handoff described in the module docstring (marker must NOT advance until `db-mark` runs, and must resume from the *previous dump's* watermark, not `--now`, to avoid skipping mid-analysis rows).\n3. **`pdf-render` end-to-end** with a real headless Chrome invocation (skip in CI if Chrome unavailable) — the ATS-normalization + Chrome subprocess call + PDF-magic-bytes check is only meaningfully tested together.\n4. **Cross-module: `models.Job.content_hash` asymmetry × `store.diff()` \"changed\" detection** — worth one explicit integration test proving a `salary_range`-only update from a fetcher is silently dropped (currently by design, but undocumented as a test, so a future refactor could accidentally start flooding notifications on every salary re-scrape, or vice versa quietly stop noticing real changes).\n5. **Config loading**: `sources.yaml` → `load_config` → `fetch_all` with an ATS type not in `FETCHERS` — confirm the per-source try/except in `fetch_all` (not `fetch_source`'s raise) is what actually protects the pipeline run, since `fetch_source` itself raises on unknown ATS.\n\n---\n\n### Summary\n\n| Module | Lines | Public surface untested | Priority |\n|---|---|---|---|\n| `fetchers.py` | 787 | 15 parsers, 8 fetch functions, retry wrapper, dispatch | **Highest** — most complex, most external-input-dependent |\n| `agent.py` | 289 | db-new/db-mark watermark logic, ATS text normalization, Chrome discovery | **High** — subtle group-boundary bug risk |\n| `store.py` | 121 | diff/migrate/added_since | **High** — stateful dedup correctness |\n| `notify.py` | 109 | 5 notifiers + dispatch isolation | **Medium-high** — real side effects (SMS/email cost money/spam) |\n| `models.py` | 75 | parse_posted_at, content_hash | **Medium** — small but foundational, many callers |\n| `filters.py` | 54 | match/filter_jobs | **Medium** |\n| `pipeline.py` | 52 | run/load_config | **Medium** — thin but is the integration seam |\n| `cli.py` | 18 | main | **Low** |\n\nNo test infrastructure exists — `pytest`/`pytest-asyncio`/`respx` need to be added to `requirements.txt` (or a new `requirements-dev.txt`) before any of this can run. Want me to scaffold the actual test files and add the dev dependencies?\n",
