        "content": "import json\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nfrom unittest.mock import patch\nfrom store import Store\nfrom models import Job\nimport agent\n\nclass TestCmdDbNew:\n    @pytest.fixture\n    def db_with_jobs(self, tmp_path, monkeypatch):\n        db_path = tmp_path / \"jobs.db\"\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(f\"db: {db_path}\\n\")\n        with Store(db_path) as s:\n            s.diff([Job(source=\"gh\", company=\"c\", external_id=\"1\", title=\"A\", url=\"u\")])\n        return cfg_path\n\n    def test_first_run_uses_since_days_window(self, db_with_jobs, capsys):\n        agent.cmd_db_new([\"-c\", str(db_with_jobs), \"--since-days\", \"7\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n        assert out[\"count\"] == 1\n\n    def test_truncation_never_splits_a_first_seen_group(self, tmp_path, capsys):\n        db_path = tmp_path / \"jobs.db\"\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(f\"db: {db_path}\\n\")\n        with Store(db_path) as s:\n            # two jobs in the SAME diff() call share one first_seen timestamp\n            s.diff([Job(source=\"gh\", company=\"c\", external_id=str(i), title=\"A\", url=\"u\")\n                     for i in range(3)])\n        agent.cmd_db_new([\"-c\", str(cfg_path), \"--limit\", \"2\"])\n        out = json.loads(capsys.readouterr().out)\n        # limit=2 but the group of 3 shares one first_seen -> group is atomic:\n        # either all 3 included (if jobs list was empty) or all excluded\n        assert out[\"count\"] in (0, 3)\n\n    def test_dated_only_drops_undated_rows(self, db_with_jobs, capsys):\n        agent.cmd_db_new([\"-c\", str(db_with_jobs), \"--dated-only\"])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"undated_dropped\"] >= 1\n        assert out[\"count\"] == 0  # the fixture job has no posted_at\n\n\nclass TestCmdDbMark:\n    def test_now_flag_sets_current_timestamp(self, tmp_path, capsys):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(f\"db: {tmp_path/'jobs.db'}\\n\")\n        rc = agent.cmd_db_mark([\"--now\", \"-c\", str(cfg_path)])\n        assert rc == 0\n\n    def test_invalid_watermark_returns_exit_code_2(self, tmp_path, capsys):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(f\"db: {tmp_path/'jobs.db'}\\n\")\n        rc = agent.cmd_db_mark([\"not-a-timestamp\", \"-c\", str(cfg_path)])\n        assert rc == 2\n\n    def test_neither_watermark_nor_now_returns_exit_code_2(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(f\"db: {tmp_path/'jobs.db'}\\n\")\n        assert agent.cmd_db_mark([\"-c\", str(cfg_path)]) == 2\n\n\nclass TestNormalizeAts:\n    def test_replaces_em_dash_in_body_text(self):\n        html, counts = agent._normalize_ats(\"<p>foo\\u2014bar</p>\")\n        assert \"foo-bar\" in html\n        assert counts[\"em-dash\"] == 1\n\n    def test_does_not_modify_content_inside_script_tag(self):\n        html, counts = agent._normalize_ats(\n            \"<script>var x = 'a\\u2014b';</script><p>c\\u2014d</p>\")\n        assert \"a\\u2014b\" in html  # untouched inside script\n        assert \"c-d\" in html       # touched in body\n        assert counts[\"em-dash\"] == 1\n\n    def test_does_not_modify_tag_attributes(self):\n        html, counts = agent._normalize_ats('<a title=\"x\\u2014y\">z\\u2014w</a>')\n        assert 'title=\"x\\u2014y\"' in html  # attribute untouched\n        assert \"z-w\" in html\n\n    def test_no_special_chars_returns_empty_counts(self):\n        html, counts = agent._normalize_ats(\"<p>plain text</p>\")\n        assert counts == {}\n\n\nclass TestChromeBin:\n    def test_prefers_chrome_path_env_var_when_valid(self, monkeypatch, tmp_path):\n        fake = tmp_path / \"chrome\"\n        fake.write_text(\"\")\n        monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n        assert agent._chrome_bin() == str(fake)\n\n    def test_exits_when_nothing_found(self, monkeypatch):\n        monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n        with patch(\"agent.shutil.which\", return_value=None), \\\n             patch(\"agent.Path.exists\", return_value=False):\n            with pytest.raises(SystemExit):\n                agent._chrome_bin()\n\n\nclass TestCmdPdfRender:\n    def test_missing_input_file_returns_exit_code_2(self, tmp_path, capsys):\n        rc = agent.cmd_pdf_render([str(tmp_path / \"nope.html\")])\n        assert rc == 2\n```\n\n---\n\n",
