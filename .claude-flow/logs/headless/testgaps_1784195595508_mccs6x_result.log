        "code": "# tests/test_filters.py\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(title=\"Software Engineer\", dept=\"\", loc=\"Remote\", posted_at=\"\"):\n    return Job(source=\"s\", company=\"c\", external_id=\"1\", title=title,\n               url=\"u\", department=dept, location=loc, posted_at=posted_at)\n\nclass TestMatch:\n    def test_word_boundary_avoids_substring_false_positive(self):\n        # \"AI\" should not match inside \"Maintain\"\n        assert match(_job(title=\"Maintain the pipeline\"), include=[\"AI\"]) is False\n\n    def test_include_keyword_matches_whole_word_case_insensitive(self):\n        assert match(_job(title=\"Machine Learning AI Engineer\"), include=[\"ai\"]) is True\n\n    def test_exclude_takes_priority_over_include(self):\n        j = _job(title=\"Staff Engineer\", dept=\"Sales\")\n        assert match(j, include=[\"Engineer\"], exclude=[\"Sales\"]) is False\n\n    def test_location_substring_case_insensitive(self):\n        assert match(_job(loc=\"San Francisco, CA\"), locations=[\"san francisco\"]) is True\n\n    def test_location_no_match(self):\n        assert match(_job(loc=\"London\"), locations=[\"New York\"]) is False\n\n    def test_cutoff_drops_confirmed_old_posting(self):\n        old = _job(posted_at=(datetime.now(timezone.utc) - timedelta(days=30)).isoformat())\n        cutoff = datetime.now(timezone.utc) - timedelta(days=7)\n        assert match(old, cutoff=cutoff) is False\n\n    def test_cutoff_keeps_unparseable_date_instead_of_dropping(self):\n        j = _job(posted_at=\"Posted 3 Days Ago\")  # Workday prose, unparseable\n        cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n        assert match(j, cutoff=cutoff) is True\n\n    def test_no_rules_matches_everything(self):\n        assert match(_job()) is True\n\n\nclass TestFilterJobs:\n    def test_max_age_days_accepts_float_string(self):\n        fresh = _job(posted_at=datetime.now(timezone.utc).isoformat())\n        stale = _job(posted_at=(datetime.now(timezone.utc) - timedelta(days=10)).isoformat())\n        out = filter_jobs([fresh, stale], {\"max_age_days\": \"3.5\"})\n        assert out == [fresh]\n\n    def test_empty_rules_returns_all_jobs(self):\n        jobs = [_job(), _job(external_id=\"2\")]\n        assert filter_jobs(jobs, {}) == jobs"
