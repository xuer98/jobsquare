        "title": "tests/test_store.py",
        "content": "import sqlite3\nimport pytest\nfrom models import Job\nfrom store import Store\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"test.db\")\n    yield s\n    s.close()\n\ndef _job(ext_id=\"1\", title=\"Engineer\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id,\n               title=title, url=\"https://x\", location=\"NYC\")\n\nclass TestDiff:\n    def test_first_seen_job_is_new(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_reported_neither_new_nor_changed(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_content_change_reported_as_changed(self, store):\n        store.diff([_job(title=\"Engineer I\")])\n        new, changed = store.diff([_job(title=\"Engineer II\")])\n        assert new == [] and len(changed) == 1\n\n    def test_unchanged_job_still_bumps_last_seen(self, store):\n        store.diff([_job()])\n        store.diff([_job()])\n        row = store.conn.execute(\"SELECT last_seen, first_seen FROM jobs\").fetchone()\n        assert row[\"last_seen\"] >= row[\"first_seen\"]\n\n\nclass TestMigration:\n    def test_migrate_adds_salary_range_to_legacy_db(self, tmp_path):\n        path = tmp_path / \"legacy.db\"\n        conn = sqlite3.connect(path)\n        conn.execute(\"\"\"CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT,\n            company TEXT, external_id TEXT, title TEXT, url TEXT, location TEXT,\n            department TEXT, employment_type TEXT, posted_at TEXT,\n            content_hash TEXT, first_seen TEXT, last_seen TEXT)\"\"\")  # no salary_range\n        conn.commit(); conn.close()\n\n        s = Store(path)  # should not raise\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n        s.close()\n\n\nclass TestAddedSince:\n    def test_strictly_after_excludes_boundary_timestamp(self, store):\n        store.diff([_job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n        assert store.added_since(ts) == []  # not >=\n\n    def test_ordering_oldest_first(self, store):\n        store.diff([_job(ext_id=\"1\")])\n        store.diff([_job(ext_id=\"2\")])\n        rows = store.added_since(\"2000-01-01T00:00:00\")\n        assert [r[\"external_id\"] for r in rows] == [\"1\", \"2\"]\n\n\nclass TestNextSeq:\n    def test_increments_from_one(self, store):\n        assert store.next_seq(\"report_seq\") == 1\n        assert store.next_seq(\"report_seq\") == 2\n\n    def test_independent_keys_do_not_share_counter(self, store):\n        store.next_seq(\"a\")\n        assert store.next_seq(\"b\") == 1\n\n\ndef test_count_reflects_row_count(store):\n    assert store.count() == 0\n    store.diff([_job()])\n    assert store.count() == 1\n```\n\n---\n\n",
