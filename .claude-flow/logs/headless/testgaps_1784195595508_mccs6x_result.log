        "code": "# tests/test_fetchers_parsers.py\nfrom fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       parse_ashby_page, parse_smartrecruiters, parse_recruitee,\n                       parse_workable, parse_google, _extract_ds1, _ds1_posted_at,\n                       parse_deshaw, parse_twosigma, parse_optiver, parse_apple,\n                       _apple_posted_at, parse_eightfold, parse_bytedance,\n                       _bd_location, parse_phenom, parse_amazon, _amazon_posted_at)\n\nclass TestParseGreenhouse:\n    def test_maps_fields_and_joins_departments(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\", \"absolute_url\": \"u\",\n                           \"location\": {\"name\": \"NYC\"},\n                           \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Platform\"}],\n                           \"updated_at\": \"2026-01-01\"}]}\n        out = parse_greenhouse(\"acme\", data)\n        assert len(out) == 1\n        assert out[0].department == \"Eng, Platform\"\n\n    def test_missing_location_defaults_empty(self):\n        out = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1, \"title\": \"Eng\"}]})\n        assert out[0].location == \"\"\n\n    def test_no_jobs_key_returns_empty_list(self):\n        assert parse_greenhouse(\"acme\", {}) == []\n\n\nclass TestLeverSalary:\n    def test_formats_min_max_with_currency_and_commas(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_falls_back_to_description_when_no_range(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_data_returns_empty_string(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestParseAshby:\n    def test_skips_unlisted_jobs(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"isListed\": False, \"title\": \"Hidden\"},\n                          {\"id\": \"2\", \"isListed\": True, \"title\": \"Visible\"}]}\n        out = parse_ashby(\"co\", data)\n        assert len(out) == 1 and out[0].title == \"Visible\"\n\n    def test_external_id_falls_back_to_jobId(self):\n        out = parse_ashby(\"co\", {\"jobs\": [{\"jobId\": \"j1\", \"title\": \"T\"}]})\n        assert out[0].external_id == \"j1\"\n\n\nclass TestExtractDs1AndPostedAt:\n    def test_extracts_valid_blob(self):\n        html = \"key: 'ds:1', ... data:[[[1,\\\"Job\\\"]]] , sideChannel:{}\"\n        assert _extract_ds1(html) == [[1, \"Job\"]]\n\n    def test_missing_key_returns_empty_list(self):\n        assert _extract_ds1(\"<html>no data here</html>\") == []\n\n    def test_malformed_json_returns_empty_list(self):\n        html = \"key: 'ds:1', data:[not valid json] , sideChannel:{}\"\n        assert _extract_ds1(html) == []\n\n    def test_ds1_posted_at_prefers_create_over_update_time(self):\n        job = [None] * 15\n        job[12] = [1700000000, 0]   # create\n        job[13] = [1800000000, 0]   # update\n        assert \"2023\" in _ds1_posted_at(job) or _ds1_posted_at(job) != \"\"\n\n    def test_ds1_posted_at_falls_back_when_create_missing(self):\n        job = [None] * 15\n        job[13] = [1700000000, 0]\n        assert _ds1_posted_at(job) != \"\"\n\n    def test_ds1_posted_at_no_timestamps_returns_empty(self):\n        assert _ds1_posted_at([None] * 15) == \"\"\n\n\nclass TestParseDeshaw:\n    def test_dedups_by_job_id(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">A</span>'\n                 '</div><div data-job-id=\"1\"><span class=\"job-display-name\">A</span></div>')\n        out = parse_deshaw(\"deshaw\", page)\n        assert len(out) == 1\n\n    def test_unescapes_html_entities_in_title(self):\n        page = '<div data-job-id=\"1\"><span class=\"job-display-name\">R&amp;D Eng</span></div>'\n        out = parse_deshaw(\"deshaw\", page)\n        assert out[0].title == \"R&D Eng\"\n\n\nclass TestParseTwosigma:\n    def test_dedups_role_rendered_three_times(self):\n        page = ('href=\"https://careers.twosigma.com/careers/JobDetail/x/1\">Eng</a>' * 3)\n        out = parse_twosigma(\"twosigma\", page)\n        assert len(out) == 1\n\n\nclass TestParseOptiver:\n    def test_strips_join_us_jobs_prefix_for_external_id(self):\n        j = {\"href\": \"/join-us/jobs/eng/nyc/software-engineer\", \"title\": \"SWE\"}\n        out = parse_optiver(\"optiver\", [j])\n        assert out[0].external_id == \"eng/nyc/software-engineer\"\n\n\nclass TestApplePostedAt:\n    def test_trims_nanosecond_precision_to_microseconds(self):\n        assert _apple_posted_at(\"2026-01-15T10:00:03.812668311Z\") == \\\n            \"2026-01-15T10:00:03.812668+00:00\"\n\n    def test_empty_value_returns_empty_string(self):\n        assert _apple_posted_at(\"\") == \"\"\n\n\nclass TestBdLocation:\n    def test_walks_parent_chain_city_state_country(self):\n        city = {\"en_name\": \"Seattle\",\n                \"parent\": {\"en_name\": \"WA\", \"parent\": {\"en_name\": \"USA\", \"parent\": None}}}\n        assert _bd_location(city) == \"Seattle, WA, USA\"\n\n    def test_none_returns_empty_string(self):\n        assert _bd_location(None) == \"\"\n\n\nclass TestAmazonPostedAt:\n    def test_parses_us_format_date(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_date_returns_empty_string(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_unknown_month_returns_empty_string(self):\n        assert _amazon_posted_at(\"Frobtember 1, 2026\") == \"\"\n\n\nclass TestParsePhenom:\n    def test_job_seq_no_fallback_when_job_id_missing(self):\n        out = parse_phenom(\"co\", [{\"jobSeqNo\": \"seq-1\", \"title\": \"T\"}])\n        assert out[0].external_id == \"seq-1\""
