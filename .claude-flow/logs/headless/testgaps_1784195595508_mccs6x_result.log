        "code": "# tests/test_models.py\nimport pytest\nfrom datetime import timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_returns_none(self):\n        assert parse_posted_at(\"\") is None\n\n    @pytest.mark.parametrize(\"value,expected_epoch\", [\n        (\"1643241332430\", 1643241332),   # lever ms epoch\n        (\"1643241332\", 1643241332),      # plain seconds epoch\n        (\"-1\", -1),                      # negative epoch edge case\n    ])\n    def test_epoch_variants(self, value, expected_epoch):\n        dt = parse_posted_at(value)\n        assert dt.tzinfo == timezone.utc\n        assert int(dt.timestamp()) == expected_epoch\n\n    def test_iso_without_offset_assumes_utc(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso_z_suffix(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00Z\")\n        assert dt is not None and dt.tzinfo == timezone.utc\n\n    def test_unparseable_prose_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None  # Workday format\n\n    def test_whitespace_only_returns_none(self):\n        assert parse_posted_at(\"   \") is None\n\n\nclass TestJobIdentity:\n    def _job(self, **overrides):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                     title=\"Engineer\", url=\"https://x\", location=\"NYC\",\n                     department=\"Eng\")\n        return Job(**{**base, **overrides})\n\n    def test_key_format(self):\n        assert self._job().key == \"greenhouse:acme:1\"\n\n    def test_content_hash_stable_across_posted_at_and_salary(self):\n        a = self._job(posted_at=\"2026-01-01\", salary_range=\"100k\")\n        b = self._job(posted_at=\"2026-06-01\", salary_range=\"200k\")\n        assert a.content_hash == b.content_hash\n\n    @pytest.mark.parametrize(\"field,value\", [\n        (\"title\", \"Senior Engineer\"), (\"location\", \"SF\"),\n        (\"url\", \"https://y\"), (\"department\", \"Sales\"),\n    ])\n    def test_content_hash_changes_on_material_fields(self, field, value):\n        a = self._job()\n        b = self._job(**{field: value})\n        assert a.content_hash != b.content_hash\n\n    def test_to_row_excludes_raw_includes_computed_fields(self):\n        j = self._job(raw={\"secret\": \"data\"})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash"
