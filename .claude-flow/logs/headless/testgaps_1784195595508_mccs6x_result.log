        "title": "tests/test_notify.py",
        "content": "import pytest\nfrom unittest.mock import patch, MagicMock\nfrom models import Job\nimport notify\n\ndef _job(title=\"Eng\", company=\"acme\"):\n    return Job(source=\"s\", company=company, external_id=\"1\", title=title, url=\"u\")\n\nclass TestDispatchErrorIsolation:\n    def test_one_notifier_failing_does_not_block_others(self, capsys):\n        calls = []\n        def ok(new, changed): calls.append(\"ok\")\n        def boom(new, changed): raise RuntimeError(\"smtp down\")\n        with patch.object(notify, \"NOTIFIERS\", [boom, ok]):\n            notify.dispatch([_job()], [])\n        assert calls == [\"ok\"]\n        assert \"boom\" in capsys.readouterr().out or \"failed\" in capsys.readouterr().out\n\n\nclass TestSlackNotifier:\n    def test_noop_when_env_var_unset(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_slack([_job()], [])\n            post.assert_not_called()\n\n    def test_noop_when_no_jobs_even_with_url_set(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_slack([], [])\n            post.assert_not_called()\n\n    def test_posts_payload_with_job_details(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_slack([_job(title=\"Staff Eng\")], [])\n            _, kwargs = post.call_args\n            assert \"Staff Eng\" in kwargs[\"json\"][\"text\"]\n\n\nclass TestSmsBody:\n    def test_truncates_at_limit_and_shows_remainder_count(self):\n        jobs = [_job(title=f\"Role {i}\") for i in range(10)]\n        body = notify._sms_body(jobs, [], limit=8)\n        assert body.count(\"Role\") == 8\n        assert \"+2 more\" in body\n\n    def test_ascii_only_no_smart_punctuation(self):\n        body = notify._sms_body([_job()], [])\n        assert \"•\" not in body and \"…\" not in body\n\n\nclass TestSmsNotifier:\n    @pytest.mark.parametrize(\"missing_var\", [\n        \"TWILIO_ACCOUNT_SID\", \"TWILIO_AUTH_TOKEN\", \"TWILIO_FROM\", \"TWILIO_TO\"])\n    def test_noop_if_any_required_env_var_missing(self, monkeypatch, missing_var):\n        env = {\"TWILIO_ACCOUNT_SID\": \"sid\", \"TWILIO_AUTH_TOKEN\": \"tok\",\n               \"TWILIO_FROM\": \"+1\", \"TWILIO_TO\": \"+2\"}\n        env.pop(missing_var)\n        for k, v in env.items():\n            monkeypatch.setenv(k, v)\n        monkeypatch.delenv(missing_var, raising=False)\n        with patch(\"notify.httpx.post\") as post:\n            notify.notify_sms([_job()], [])\n            post.assert_not_called()\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        for k, v in {\"TWILIO_ACCOUNT_SID\": \"sid\", \"TWILIO_AUTH_TOKEN\": \"tok\",\n                     \"TWILIO_FROM\": \"+1\", \"TWILIO_TO\": \"+2\"}.items():\n            monkeypatch.setenv(k, v)\n        resp = MagicMock()\n        resp.raise_for_status.side_effect = Exception(\"401 unauthorized\")\n        with patch(\"notify.httpx.post\", return_value=resp):\n            with pytest.raises(Exception):\n                notify.notify_sms([_job()], [])\n\n\nclass TestEmailNotifier:\n    def test_noop_when_smtp_host_unset(self, monkeypatch):\n        monkeypatch.delenv(\"SMTP_HOST\", raising=False)\n        with patch(\"notify.smtplib.SMTP\") as smtp:\n            notify.notify_email([_job()], [])\n            smtp.assert_not_called()\n```\n\n---\n\n",
