        "title": "`notify.py`",
        "content": "\n**Gaps:**\n- `notify_console`: new-only, changed-only, both, neither branches\n- `notify_slack`/`notify_webhook`/`notify_email`/`notify_sms`: **early-return guards are untested** (missing env var → no HTTP call at all; empty new+changed → no call even with env set)\n- `notify_email`: SMTP interaction entirely unmocked/untested (`starttls`, conditional `login`)\n- `notify_sms`: `_sms_body` truncation logic (`limit` boundary, `+N more` line), `raise_for_status()` propagating Twilio errors\n- `dispatch()`: **critical gap** — one notifier raising must not prevent others from running (currently only implicitly relied upon, never verified)\n\n```python\nimport os\nimport pytest\nfrom unittest.mock import patch, MagicMock\nfrom models import Job\nimport notify\n\ndef _job(title=\"T\", company=\"C\", salary=\"\"):\n    return Job(source=\"s\", company=company, external_id=\"1\", title=title,\n               url=\"https://x\", salary_range=salary)\n\ndef test_notify_console_none(capsys):\n    notify.notify_console([], [])\n    assert \"No fresh listings\" in capsys.readouterr().out\n\ndef test_notify_console_new_and_changed(capsys):\n    notify.notify_console([_job(title=\"New\")], [_job(title=\"Changed\")])\n    out = capsys.readouterr().out\n    assert \"NEW listing\" in out and \"UPDATED listing\" in out\n\ndef test_notify_slack_noop_without_env(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    with patch(\"httpx.post\") as mock_post:\n        notify.notify_slack([_job()], [])\n        mock_post.assert_not_called()\n\ndef test_notify_slack_noop_when_empty_even_with_env(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack/x\")\n    with patch(\"httpx.post\") as mock_post:\n        notify.notify_slack([], [])\n        mock_post.assert_not_called()\n\ndef test_notify_slack_posts_payload(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack/x\")\n    with patch(\"httpx.post\") as mock_post:\n        notify.notify_slack([_job(salary=\"$100k\")], [])\n        _, kwargs = mock_post.call_args\n        assert \"$100k\" in kwargs[\"json\"][\"text\"]\n\ndef test_notify_email_noop_without_smtp_host(monkeypatch):\n    monkeypatch.delenv(\"SMTP_HOST\", raising=False)\n    with patch(\"smtplib.SMTP\") as mock_smtp:\n        notify.notify_email([_job()], [])\n        mock_smtp.assert_not_called()\n\ndef test_notify_email_logs_in_only_when_user_set(monkeypatch):\n    monkeypatch.setenv(\"SMTP_HOST\", \"smtp.x\"); monkeypatch.setenv(\"EMAIL_TO\", \"a@b.com\")\n    monkeypatch.delenv(\"SMTP_USER\", raising=False)\n    mock_conn = MagicMock()\n    with patch(\"smtplib.SMTP\") as mock_smtp:\n        mock_smtp.return_value.__enter__.return_value = mock_conn\n        notify.notify_email([_job()], [])\n        mock_conn.login.assert_not_called()\n\n@pytest.mark.parametrize(\"n_jobs,limit,expect_more_line\", [(5, 8, False), (10, 8, True)])\ndef test_sms_body_truncation(n_jobs, limit, expect_more_line):\n    jobs = [_job(title=f\"J{i}\") for i in range(n_jobs)]\n    body = notify._sms_body(jobs, [], limit=limit)\n    assert (\"more\" in body) == expect_more_line\n\ndef test_notify_sms_noop_missing_any_twilio_var(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"x\")\n    monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)\n    with patch(\"httpx.post\") as mock_post:\n        notify.notify_sms([_job()], [])\n        mock_post.assert_not_called()\n\ndef test_notify_sms_raises_on_http_error(monkeypatch):\n    for k, v in {\"TWILIO_ACCOUNT_SID\": \"sid\", \"TWILIO_AUTH_TOKEN\": \"tok\",\n                 \"TWILIO_FROM\": \"+1\", \"TWILIO_TO\": \"+2\"}.items():\n        monkeypatch.setenv(k, v)\n    with patch(\"httpx.post\") as mock_post:\n        mock_post.return_value.raise_for_status.side_effect = Exception(\"boom\")\n        with pytest.raises(Exception):\n            notify.notify_sms([_job()], [])\n\ndef test_dispatch_isolates_notifier_failures(capsys):\n    failing = MagicMock(side_effect=RuntimeError(\"boom\"), __name__=\"failing\")\n    ok = MagicMock(__name__=\"ok\")\n    with patch(\"notify.NOTIFIERS\", [failing, ok]):\n        notify.dispatch([], [])\n    ok.assert_called_once()\n    assert \"failing failed\" in capsys.readouterr().out\n```\n\n---\n\n",
