        "code": "import pytest\nfrom datetime import datetime, timezone\nfrom models import Job, parse_posted_at\n\n@pytest.mark.parametrize(\"value,expected\", [\n    (\"1643241332430\", datetime(2022, 1, 26, 22, 55, 32, tzinfo=timezone.utc)),  # ms epoch\n    (\"1643241332\", datetime(2022, 1, 26, 22, 55, 32, tzinfo=timezone.utc)),      # sec epoch\n    (\"2022-01-26T22:55:32Z\", datetime(2022, 1, 26, 22, 55, 32, tzinfo=timezone.utc)),\n    (\"2022-01-26T22:55:32+00:00\", datetime(2022, 1, 26, 22, 55, 32, tzinfo=timezone.utc)),\n    (\"2022-01-26T22:55:32\", datetime(2022, 1, 26, 22, 55, 32, tzinfo=timezone.utc)),  # naive -> UTC\n    (\"\", None),\n    (\"Posted 3 Days Ago\", None),  # Workday prose - unparseable\n    (\"not-a-date\", None),\n])\ndef test_parse_posted_at(value, expected):\n    assert parse_posted_at(value) == expected\n\ndef test_job_content_hash_ignores_posted_at_and_salary():\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x\", location=\"NYC\")\n    j1 = Job(**base, posted_at=\"2022-01-01\")\n    j2 = Job(**base, posted_at=\"2023-06-01\", salary_range=\"$100k\")\n    assert j1.content_hash == j2.content_hash\n\ndef test_job_content_hash_changes_on_title():\n    j1 = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"A\", url=\"u\")\n    j2 = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"B\", url=\"u\")\n    assert j1.content_hash != j2.content_hash\n\ndef test_job_key_format():\n    j = Job(source=\"lever\", company=\"acme\", external_id=\"123\", title=\"T\", url=\"u\")\n    assert j.key == \"lever:acme:123\"\n\ndef test_to_row_excludes_raw_and_adds_derived_fields():\n    j = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\", raw={\"x\": 1})\n    row = j.to_row()\n    assert \"raw\" not in row\n    assert row[\"key\"] == j.key\n    assert row[\"content_hash\"] == j.content_hash"
