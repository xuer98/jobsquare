        "content": "\n**Gaps:**\n- Fresh DB creates schema (`jobs`, `meta` tables)\n- **Migration path**: opening a pre-existing DB file that lacks `salary_range` column (this is the one genuinely tricky code path — untested entirely)\n- `diff()`: new job inserted; unchanged job (same `content_hash`) only bumps `last_seen`, doesn't go in `changed`; changed job (different hash) goes in `changed` and updates row; mixed batch\n- `get_meta`/`set_meta`: missing key returns `None`; upsert overwrites existing value (`ON CONFLICT`)\n- `added_since`: strict `>` (not `>=`) boundary, ordering by `first_seen, company, title`\n- `count()`\n- context manager (`__enter__`/`__exit__`) closes connection\n\n```python\nimport sqlite3\nimport pytest\nfrom models import Job\nfrom store import Store\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\ndef _job(ext_id=\"1\", title=\"T\", loc=\"\", dept=\"\", url=\"u\"):\n    return Job(source=\"s\", company=\"c\", external_id=ext_id, title=title, url=url,\n               location=loc, department=dept)\n\ndef test_schema_created_fresh(store):\n    tables = {r[0] for r in store.conn.execute(\n        \"SELECT name FROM sqlite_master WHERE type='table'\")}\n    assert {\"jobs\", \"meta\"} <= tables\n\ndef test_migration_adds_salary_range_to_legacy_db(tmp_path):\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.executescript(\"\"\"\n        CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n            external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n            employment_type TEXT, posted_at TEXT, content_hash TEXT,\n            first_seen TEXT, last_seen TEXT);\n    \"\"\")\n    conn.commit(); conn.close()\n    with Store(path) as s:\n        cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n        assert \"salary_range\" in cols\n\ndef test_diff_first_seen_is_new(store):\n    new, changed = store.diff([_job()])\n    assert len(new) == 1 and changed == []\n\ndef test_diff_unchanged_job_not_in_changed(store):\n    store.diff([_job(title=\"T\")])\n    new, changed = store.diff([_job(title=\"T\")])\n    assert new == [] and changed == []\n\ndef test_diff_content_change_detected(store):\n    store.diff([_job(title=\"Old Title\")])\n    new, changed = store.diff([_job(title=\"New Title\")])\n    assert new == [] and len(changed) == 1\n\ndef test_diff_updates_last_seen_on_unchanged(store):\n    store.diff([_job()])\n    store.diff([_job()])\n    row = store.conn.execute(\"SELECT first_seen, last_seen FROM jobs\").fetchone()\n    # first_seen must not move even though last_seen does\n    assert row[\"first_seen\"] is not None\n\ndef test_get_meta_missing_key_returns_none(store):\n    assert store.get_meta(\"nope\") is None\n\ndef test_set_meta_upserts(store):\n    store.set_meta(\"k\", \"v1\")\n    store.set_meta(\"k\", \"v2\")\n    assert store.get_meta(\"k\") == \"v2\"\n\ndef test_added_since_is_strictly_after(store):\n    store.diff([_job(ext_id=\"1\")])\n    ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[0]\n    assert store.added_since(ts) == []  # boundary excluded\n\ndef test_count(store):\n    store.diff([_job(ext_id=\"1\"), _job(ext_id=\"2\")])\n    assert store.count() == 2\n```\n\n---\n\n",
