        "title": "`agent.py`",
        "content": "\n**Gaps:**\n- `cmd_db_new`: first run (no marker) uses `since_days` window; truncation only at `first_seen` group boundaries (the trickiest logic in this file — a naive slice would split a batch mid-timestamp-group); `watermark` output correctness\n- `cmd_db_mark`: `--now`, valid watermark, invalid ISO watermark → exit code 2 + stderr, neither arg → exit code 2\n- `_normalize_ats`: replacements skip `<style>`/`<script>` blocks and tag attributes, only touch text nodes; counts dict accuracy\n- `_chrome_bin`: `CHROME_PATH` env override, `PATH` lookup via `shutil.which`, macOS app bundle fallback, none found → `sys.exit`\n- `cmd_pdf_render`: missing input file → exit 2; Chrome invocation produces non-PDF output → exit 1 with stderr tail printed; temp file cleanup (`tmp.unlink`) even on exception\n- `main()`: mode-word vs flag-passthrough split logic (`words[:i]` / `words[i:]`), `-i`/`--interactive` stripped from mode words but forces interactive\n\n```python\nimport sys\nimport pytest\nfrom unittest.mock import patch\nimport agent\nfrom store import Store\n\ndef test_cmd_db_mark_now(tmp_path, capsys):\n    cfg = tmp_path / \"c.yaml\"\n    cfg.write_text(f\"db: {tmp_path/'j.db'}\\n\")\n    assert agent.cmd_db_mark([\"--now\", \"-c\", str(cfg)]) == 0\n    with Store(tmp_path / \"j.db\") as s:\n        assert s.get_meta(\"last_scan\") is not None\n\ndef test_cmd_db_mark_invalid_watermark_exits_2(tmp_path, capsys):\n    cfg = tmp_path / \"c.yaml\"\n    cfg.write_text(f\"db: {tmp_path/'j.db'}\\n\")\n    assert agent.cmd_db_mark([\"not-a-date\", \"-c\", str(cfg)]) == 2\n    assert \"not an ISO timestamp\" in capsys.readouterr().err\n\ndef test_cmd_db_mark_no_args_exits_2(tmp_path):\n    cfg = tmp_path / \"c.yaml\"\n    cfg.write_text(f\"db: {tmp_path/'j.db'}\\n\")\n    assert agent.cmd_db_mark([\"-c\", str(cfg)]) == 2\n\ndef test_db_new_truncates_only_at_group_boundary(tmp_path, capsys):\n    cfg = tmp_path / \"c.yaml\"\n    db = tmp_path / \"j.db\"\n    cfg.write_text(f\"db: {db}\\n\")\n    from models import Job\n    with Store(db) as s:\n        # two jobs sharing one first_seen timestamp (one pipeline run)\n        s.diff([Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"A\", url=\"u\"),\n                Job(source=\"s\", company=\"c\", external_id=\"2\", title=\"B\", url=\"u\")])\n    agent.cmd_db_new([\"--limit\", \"1\", \"-c\", str(cfg)])  # limit smaller than the group\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"count\"] == 0 or out[\"count\"] == 2  # never 1 - group not split\n    assert out[\"truncated\"] is True\n\ndef test_normalize_ats_skips_style_and_script_blocks():\n    html = \"<style>content: '\\u2014';</style><p>em\\u2014dash</p><script>'\\u2014'</script>\"\n    fixed, counts = agent._normalize_ats(html)\n    assert \"\\u2014\" in fixed  # inside <style>/<script>, untouched\n    assert \"em-dash\" in fixed  # inside <p> text, replaced\n    assert counts.get(\"em-dash\") == 1\n\ndef test_normalize_ats_skips_tag_attributes():\n    html = '<a title=\"caf\\u00e9\\u2014note\">text\\u2014here</a>'\n    fixed, counts = agent._normalize_ats(html)\n    assert 'title=\"caf\\u00e9\\u2014note\"' in fixed  # attribute untouched\n    assert \"text-here\" in fixed\n\ndef test_chrome_bin_prefers_env_var(tmp_path, monkeypatch):\n    fake = tmp_path / \"chrome\"\n    fake.write_text(\"\")\n    monkeypatch.setenv(\"CHROME_PATH\", str(fake))\n    assert agent._chrome_bin() == str(fake)\n\ndef test_chrome_bin_exits_when_nothing_found(monkeypatch):\n    monkeypatch.delenv(\"CHROME_PATH\", raising=False)\n    with patch(\"shutil.which\", return_value=None), \\\n         patch(\"pathlib.Path.exists\", return_value=False):\n        with pytest.raises(SystemExit):\n            agent._chrome_bin()\n\ndef test_cmd_pdf_render_missing_input_exits_2(tmp_path, capsys):\n    rc = agent.cmd_pdf_render([str(tmp_path / \"nope.html\")])\n    assert rc == 2\n\ndef test_main_splits_mode_words_at_first_flag():\n    with patch(\"agent.run_claude\") as mock_run:\n        agent.main.__wrapped__ if False else None\n    # verify argv [\"scan\", \"extra\", \"--foo\"] -> mode_words=[\"scan\",\"extra\"], extra=[\"--foo\"]\n```\n\n---\n\n",
