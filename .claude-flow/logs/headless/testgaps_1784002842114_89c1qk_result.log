        "title": "`fetchers.py` — largest file, largest gap surface (787 lines, 0 tests)",
        "content": "\n**A. Retry/backoff core (`_request`) — completely untested, and it's the trickiest logic in the file:**\n\n```python\nimport httpx\nimport pytest\nfrom fetchers import _request, _get_json\n\n@pytest.mark.asyncio\nasync def test_request_retries_on_429_then_succeeds():\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        if calls[\"n\"] < 3:\n            return httpx.Response(429)\n        return httpx.Response(200, json={\"ok\": True})\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        r = await _request(client, \"https://x\", retries=4)\n    assert r.status_code == 200 and calls[\"n\"] == 3\n\n@pytest.mark.asyncio\nasync def test_request_exhausts_retries_raises_runtimeerror():\n    async def handler(request):\n        return httpx.Response(500)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n            await _request(client, \"https://x\", retries=2)\n\n@pytest.mark.asyncio\nasync def test_request_non_retryable_4xx_raises_immediately():\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        return httpx.Response(404)\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        with pytest.raises(RuntimeError):\n            await _request(client, \"https://x\", retries=4)\n    assert calls[\"n\"] == 1  # 404 isn't in the retryable set -> raise_for_status fires once\n```\n\n**B. Parser normalizers — each has untested edge cases:**\n\n| Function | Untested edge cases |\n|---|---|\n| `parse_lever` / `_lever_salary` | missing `salaryRange`, only `salaryDescriptionPlain`, int vs already-string min/max |\n| `parse_ashby` / `_ashby_salary` | `isListed: False` filtered out; missing `id` falls back to `jobId` |\n| `parse_smartrecruiters` | partial location (city only, no region/country) |\n| `parse_recruitee` | location dict vs flat city/country fallback |\n| `parse_workable` | location as dict vs flat fields |\n| `_extract_ds1` / `parse_google` | primary regex fails → fallback regex; both fail → `[]`; malformed embedded JSON → `[]`; short job arrays (defensive indexing) |\n| `_ds1_posted_at` | prefers idx 12 over 13/14; all empty → `\"\"` |\n| `parse_deshaw` | dedup via `seen`; missing location; missing href fallback URL |\n| `parse_twosigma` | 3x-duplicate-card dedup; missing location match |\n| `_amazon_posted_at` | malformed date string → `\"\"` (currently only implicitly covered) |\n| `parse_meta` | duplicate/missing `id` skipped |\n\n```python\nfrom fetchers import (_lever_salary, parse_ashby, _extract_ds1, parse_google,\n                       _ds1_posted_at, parse_deshaw, _amazon_posted_at, parse_meta)\n\ndef test_lever_salary_falls_back_to_description():\n    assert _lever_salary({\"salaryDescriptionPlain\": \"Competitive\"}) == \"Competitive\"\n\ndef test_lever_salary_formats_range():\n    assert _lever_salary({\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}) \\\n        == \"USD 100,000–150,000\"\n\ndef test_parse_ashby_filters_unlisted():\n    jobs = parse_ashby(\"acme\", {\"jobs\": [{\"id\": \"1\", \"isListed\": False}, {\"id\": \"2\"}]})\n    assert [j.external_id for j in jobs] == [\"2\"]\n\ndef test_extract_ds1_fallback_regex_when_sidechannel_missing():\n    html = \"key: 'ds:1', foo, data:[[[\\\"1\\\",\\\"Title\\\"]]]});\"\n    assert _extract_ds1(html) == [[\"1\", \"Title\"]]\n\ndef test_extract_ds1_malformed_json_returns_empty():\n    html = \"key: 'ds:1', data:[not valid json], sideChannel\"\n    assert _extract_ds1(html) == []\n\ndef test_ds1_posted_at_prefers_create_over_update_time():\n    job = [None] * 15\n    job[12] = [1700000000]\n    job[13] = [1800000000]\n    assert \"2023\" in _ds1_posted_at(job)\n\ndef test_parse_deshaw_dedups_repeated_cards():\n    page = ('<div data-job-id=\"1\" class=\"job-display-name\">Eng<'\n            '<div data-job-id=\"1\" class=\"job-display-name\">Eng<')\n    jobs = parse_deshaw(\"deshaw\", page)\n    assert len(jobs) == 1\n\n@pytest.mark.parametrize(\"value,expect_empty\", [\n    (\"June 26, 2026\", False),\n    (\"garbage\", True),\n    (\"\", True),\n])\ndef test_amazon_posted_at(value, expect_empty):\n    result = _amazon_posted_at(value)\n    assert (result == \"\") == expect_empty\n\ndef test_parse_meta_skips_duplicate_and_missing_ids():\n    jobs = parse_meta(\"meta\", [{\"id\": \"1\", \"title\": \"A\"}, {\"id\": \"1\", \"title\": \"A dup\"},\n                                {\"title\": \"no id\"}])\n    assert len(jobs) == 1\n```\n\n**C. Paginated fetchers — no test drives the pagination stop conditions, which is where real bugs hide:**\n\n```python\nimport httpx, pytest\nfrom fetchers import fetch_workday, fetch_google, fetch_amazon\n\n@pytest.mark.asyncio\nasync def test_fetch_workday_stops_when_offset_reaches_total():\n    def handler(request):\n        body = request.read()\n        offset = int(__import__(\"json\").loads(body)[\"offset\"])\n        if offset >= 20:\n            return httpx.Response(200, json={\"jobPostings\": [], \"total\": 20})\n        return httpx.Response(200, json={\n            \"jobPostings\": [{\"title\": f\"J{offset}\", \"externalPath\": \"/p\",\n                              \"bulletFields\": [str(offset)]}],\n            \"total\": 20})\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        jobs = await fetch_workday(client, {\"host\": \"h\", \"tenant\": \"t\", \"site\": \"s\",\n                                             \"page_size\": 20})\n    assert len(jobs) == 1\n\n@pytest.mark.asyncio\nasync def test_fetch_workday_safety_cap_at_5000_offset():\n    # total never reported correctly -> must stop via the offset > 5000 safety cap,\n    # not loop forever\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_google_stops_on_first_empty_page():\n    calls = {\"n\": 0}\n    def handler(request):\n        calls[\"n\"] += 1\n        if calls[\"n\"] == 1:\n            return httpx.Response(200, text=\"key: 'ds:1', data:[[['1','T']]], sideChannel\")\n        return httpx.Response(200, text=\"key: 'ds:1', data:[[]], sideChannel\")\n    async with httpx.AsyncClient(transport=httpx.MockTransport(handler)) as client:\n        jobs = await fetch_google(client, {\"company\": \"google\", \"max_pages\": 5})\n    assert len(jobs) == 1 and calls[\"n\"] == 2\n\n@pytest.mark.asyncio\nasync def test_fetch_amazon_dedups_across_pages():\n    # server returns overlapping ids on page boundary -> `seen` set must prevent dupes\n    ...\n```\n\n**D. `fetch_source` / `fetch_all` — orchestration untested:**\n\n```python\nimport httpx, pytest\nfrom fetchers import fetch_source, fetch_all\n\n@pytest.mark.asyncio\nasync def test_fetch_source_unknown_ats_raises_valueerror():\n    async with httpx.AsyncClient() as client:\n        with pytest.raises(ValueError, match=\"unknown ATS\"):\n            await fetch_source(client, {\"ats\": \"bogus\"})\n\n@pytest.mark.asyncio\nasync def test_fetch_all_isolates_per_source_failures(capsys):\n    async def ok(client, source): return [object()]\n    async def boom(client, source): raise RuntimeError(\"network down\")\n    with patch.dict(\"fetchers.FETCHERS\", {\"ok\": ok, \"boom\": boom}):\n        jobs = await fetch_all([{\"ats\": \"ok\", \"company\": \"a\"},\n                                 {\"ats\": \"boom\", \"company\": \"b\"}])\n    assert len(jobs) == 1\n    assert \"failed\" in capsys.readouterr().out\n\n@pytest.mark.asyncio\nasync def test_fetch_all_closes_only_owned_client():\n    external_client = httpx.AsyncClient()\n    await fetch_all([], client=external_client)\n    assert not external_client.is_closed\n    await external_client.aclose()\n```\n\n---\n\n",
