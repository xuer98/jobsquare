      {
        "title": "tests/test_pipeline.py",
        "content": "import pytest\nfrom unittest.mock import AsyncMock, patch\nfrom models import Job\nimport pipeline\n\ndef test_load_config_applies_defaults(tmp_path):\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(\"sources: []\\n\")\n    cfg = pipeline.load_config(cfg_path)\n    assert cfg[\"db\"] == \"jobs.db\"\n    assert cfg[\"concurrency\"] == 8\n    assert cfg[\"filters\"] == {}\n\n@pytest.mark.asyncio\nasync def test_dry_run_does_not_touch_store_or_notify(tmp_path, monkeypatch):\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(f\"sources: []\\nfilters: {{}}\\ndb: {tmp_path/'j.db'}\\n\")\n    job = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")\n    with patch(\"pipeline.fetch_all\", AsyncMock(return_value=[job])), \\\n         patch(\"pipeline.dispatch\") as mock_dispatch:\n        result = await pipeline.run(cfg_path, dry_run=True)\n    assert result == {\"matched\": 1, \"new\": 0, \"changed\": 0}\n    mock_dispatch.assert_not_called()\n\n@pytest.mark.asyncio\nasync def test_run_persists_and_dispatches(tmp_path):\n    cfg_path = tmp_path / \"sources.yaml\"\n    cfg_path.write_text(f\"sources: []\\nfilters: {{}}\\ndb: {tmp_path/'j.db'}\\n\")\n    job = Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")\n    with patch(\"pipeline.fetch_all\", AsyncMock(return_value=[job])), \\\n         patch(\"pipeline.dispatch\") as mock_dispatch:\n        result = await pipeline.run(cfg_path)\n    assert result == {\"matched\": 1, \"new\": 1, \"changed\": 0}\n    mock_dispatch.assert_called_once()\n```\n\nThis end-to-end path (config → fetch → filter → dedup → notify) has no integration test at all today — every stage is tested in isolation above but nothing proves they wire together correctly.\n\n---\n\n",
