        "code": "# tests/test_store.py\nimport pytest\nfrom models import Job\nfrom store import Store\n\n@pytest.fixture\ndef store(tmp_path):\n    s = Store(tmp_path / \"test.db\")\n    yield s\n    s.close()\n\ndef _job(ext_id=\"1\", title=\"Engineer\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=ext_id,\n               title=title, url=\"https://x/1\")\n\ndef test_diff_new_job_is_inserted_and_reported_new(store):\n    new, changed = store.diff([_job()])\n    assert len(new) == 1 and changed == []\n    assert store.count() == 1\n\ndef test_diff_unchanged_job_is_neither_new_nor_changed(store):\n    store.diff([_job()])\n    new, changed = store.diff([_job()])\n    assert new == [] and changed == []\n\ndef test_diff_content_change_reported_as_changed_not_new(store):\n    store.diff([_job(title=\"Engineer\")])\n    new, changed = store.diff([_job(title=\"Senior Engineer\")])\n    assert new == [] and len(changed) == 1\n\ndef test_diff_updates_last_seen_without_touching_first_seen(store):\n    store.diff([_job()])\n    row1 = store.added_since(\"1970-01-01T00:00:00+00:00\")[0]\n    store.diff([_job()])  # unchanged re-see\n    row2 = store.conn.execute(\"SELECT * FROM jobs WHERE key=?\", (row1[\"key\"],)).fetchone()\n    assert row2[\"first_seen\"] == row1[\"first_seen\"]\n    assert row2[\"last_seen\"] >= row1[\"last_seen\"]\n\ndef test_added_since_excludes_boundary_timestamp(store):\n    store.diff([_job()])\n    ts = store.added_since(\"1970-01-01T00:00:00+00:00\")[0][\"first_seen\"]\n    assert store.added_since(ts) == []   # strictly greater-than, not >=\n\ndef test_meta_get_set_roundtrip_and_missing_key(store):\n    assert store.get_meta(\"nope\") is None\n    store.set_meta(\"last_scan\", \"2026-01-01T00:00:00+00:00\")\n    assert store.get_meta(\"last_scan\") == \"2026-01-01T00:00:00+00:00\"\n\ndef test_meta_upsert_overwrites(store):\n    store.set_meta(\"k\", \"a\")\n    store.set_meta(\"k\", \"b\")\n    assert store.get_meta(\"k\") == \"b\"\n\ndef test_next_seq_increments_and_persists(store):\n    assert store.next_seq(\"report_seq\") == 1\n    assert store.next_seq(\"report_seq\") == 2\n\ndef test_migrate_adds_salary_range_to_legacy_schema(tmp_path):\n    import sqlite3\n    path = tmp_path / \"legacy.db\"\n    conn = sqlite3.connect(path)\n    conn.executescript(\"\"\"\n        CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n            external_id TEXT, title TEXT, url TEXT, location TEXT, department TEXT,\n            employment_type TEXT, posted_at TEXT, first_seen TEXT, last_seen TEXT);\n        CREATE TABLE meta (k TEXT PRIMARY KEY, v TEXT);\n    \"\"\")\n    conn.close()\n    s = Store(path)  # should not raise\n    assert \"salary_range\" in {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n    s.close()\n\ndef test_context_manager_closes_connection(tmp_path):\n    with Store(tmp_path / \"x.db\") as s:\n        pass\n    with pytest.raises(Exception):\n        s.conn.execute(\"SELECT 1\")"
