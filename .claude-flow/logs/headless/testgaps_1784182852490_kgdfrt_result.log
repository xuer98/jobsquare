        "title": "tests/test_notify.py",
        "content": "import pytest\nfrom models import Job\nfrom notify import _sms_body, notify_slack, notify_webhook, notify_sms, dispatch\n\ndef _job(title=\"Engineer\", company=\"acme\"):\n    return Job(source=\"s\", company=company, external_id=\"1\", title=title, url=\"u\")\n\ndef test_sms_body_truncates_at_limit_and_shows_remainder_count():\n    jobs = [_job(title=f\"J{i}\") for i in range(12)]\n    body = _sms_body(jobs, [], limit=8)\n    assert body.count(\"\\n- \") == 8\n    assert \"+4 more\" in body\n\ndef test_sms_body_is_ascii_only():\n    body = _sms_body([_job(title=\"Café • Engineer\")], [])\n    body.encode(\"ascii\")  # must not raise UnicodeEncodeError\n\ndef test_notify_slack_noop_when_webhook_url_unset(monkeypatch):\n    monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n    # should return without attempting an HTTP call\n    notify_slack([_job()], [])  # no network call = no exception, no mock needed\n\ndef test_notify_slack_noop_when_no_jobs(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n    notify_slack([], [])  # must not POST with empty payload\n\ndef test_notify_slack_posts_when_configured(monkeypatch):\n    monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.com/x\")\n    calls = []\n    monkeypatch.setattr(\"notify.httpx.post\", lambda url, **kw: calls.append((url, kw)))\n    notify_slack([_job()], [])\n    assert len(calls) == 1\n\ndef test_notify_sms_requires_all_four_twilio_vars(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n    monkeypatch.delenv(\"TWILIO_AUTH_TOKEN\", raising=False)  # missing one\n    notify_sms([_job()], [])  # must be a no-op, not a KeyError\n\ndef test_notify_sms_raises_on_http_error(monkeypatch):\n    monkeypatch.setenv(\"TWILIO_ACCOUNT_SID\", \"sid\")\n    monkeypatch.setenv(\"TWILIO_AUTH_TOKEN\", \"tok\")\n    monkeypatch.setenv(\"TWILIO_FROM\", \"+1\")\n    monkeypatch.setenv(\"TWILIO_TO\", \"+2\")\n    class FakeResp:\n        def raise_for_status(self): raise Exception(\"bad creds\")\n    monkeypatch.setattr(\"notify.httpx.post\", lambda *a, **kw: FakeResp())\n    with pytest.raises(Exception):\n        notify_sms([_job()], [])\n\ndef test_dispatch_isolates_notifier_failures(monkeypatch, capsys):\n    def boom(new, changed): raise RuntimeError(\"smtp down\")\n    monkeypatch.setattr(\"notify.NOTIFIERS\", [boom, lambda n, c: print(\"second ran\")])\n    dispatch([_job()], [])\n    assert \"second ran\" in capsys.readouterr().out  # one failure doesn't block the rest\n```\n\n`dispatch`'s try/except-per-notifier is the single most important behavior in this file (it's what keeps a bad SMTP config from blocking Slack/console) and it currently has zero coverage.\n\n---\n\n",
