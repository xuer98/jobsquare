        "language": "python",
        "code": "# tests/test_filters.py\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(**kw):\n    d = dict(source=\"s\", company=\"c\", external_id=\"1\", title=\"Staff Engineer\",\n              url=\"u\", location=\"Remote - US\", department=\"Platform\")\n    d.update(kw)\n    return Job(**d)\n\ndef test_include_keyword_word_boundary_no_substring_match():\n    # \"eng\" should NOT match \"Engineer\" — \\b enforces whole-word\n    assert match(_job(), include=[\"eng\"]) is False\n    assert match(_job(), include=[\"Engineer\"]) is True\n\ndef test_exclude_wins_over_include():\n    j = _job(title=\"Senior Staff Engineer - Intern Program\")\n    assert match(j, include=[\"Engineer\"], exclude=[\"Intern\"]) is False\n\ndef test_locations_is_substring_case_insensitive():\n    assert match(_job(location=\"Remote - US\"), locations=[\"us\"]) is True\n    assert match(_job(location=\"Berlin, Germany\"), locations=[\"us\"]) is False\n\ndef test_cutoff_keeps_unparseable_dates():\n    j = _job(posted_at=\"garbage\")\n    cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n    assert match(j, cutoff=cutoff) is True   # can't confirm stale -> kept\n\ndef test_cutoff_drops_confirmed_stale():\n    old = (datetime.now(timezone.utc) - timedelta(days=30)).isoformat()\n    j = _job(posted_at=old)\n    cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n    assert match(j, cutoff=cutoff) is False\n\ndef test_filter_jobs_max_age_days_builds_cutoff():\n    stale = _job(external_id=\"1\", posted_at=(datetime.now(timezone.utc) - timedelta(days=10)).isoformat())\n    fresh = _job(external_id=\"2\", posted_at=datetime.now(timezone.utc).isoformat())\n    out = filter_jobs([stale, fresh], {\"max_age_days\": 5})\n    assert [j.external_id for j in out] == [\"2\"]\n\ndef test_filter_jobs_empty_rules_is_passthrough():\n    jobs = [_job(external_id=\"1\"), _job(external_id=\"2\")]\n    assert filter_jobs(jobs, {}) == jobs\n\ndef test_empty_include_list_is_not_a_filter():\n    # rules.get(\"include_keywords\") == [] is falsy -> matches everything, not nothing\n    assert match(_job(), include=[]) is True"
