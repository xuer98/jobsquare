      {
        "title": "6. `fetchers.py` — the largest gap by volume (~20 untested parsers + retry/pagination logic)",
        "content": "\n**Retry wrapper `_request`** — the backbone of every fetcher, zero coverage:\n\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_fetchers_request.py",
        "content": "import httpx, pytest\nfrom fetchers import _request\n\n@pytest.mark.asyncio\nasync def test_request_retries_on_503_then_succeeds():\n    calls = {\"n\": 0}\n    def handler(req):\n        calls[\"n\"] += 1\n        if calls[\"n\"] < 3:\n            return httpx.Response(503)\n        return httpx.Response(200, json={\"ok\": True})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    r = await _request(client, \"https://x/test\", retries=4)\n    assert r.status_code == 200 and calls[\"n\"] == 3\n\n@pytest.mark.asyncio\nasync def test_request_raises_after_exhausting_retries():\n    client = httpx.AsyncClient(transport=httpx.MockTransport(lambda r: httpx.Response(500)))\n    with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n        await _request(client, \"https://x/test\", retries=2)\n\n@pytest.mark.asyncio\nasync def test_request_does_not_retry_on_404():\n    calls = {\"n\": 0}\n    def handler(req):\n        calls[\"n\"] += 1\n        return httpx.Response(404)\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    with pytest.raises(RuntimeError):\n        await _request(client, \"https://x/test\", retries=4)\n    assert calls[\"n\"] == 1  # 404 isn't in the retryable set -> fails fast\n```\n\n**Parsers** — every `parse_*` function is pure and directly testable with fixture dicts; none currently are. Representative template, then the parsers with genuinely tricky logic:\n\n```python\n",
        "level": 1
      },
      {
        "title": "tests/test_fetchers_parsers.py",
        "content": "from fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       _amazon_posted_at, parse_amazon, _apple_posted_at,\n                       _apple_hydration, _extract_ds1, parse_google, _ds1_posted_at,\n                       _bd_location, parse_bytedance)\n\ndef test_parse_greenhouse_handles_missing_optional_fields():\n    data = {\"jobs\": [{\"id\": 1, \"title\": \"SWE\"}]}  # no location/departments/url\n    jobs = parse_greenhouse(\"acme\", data)\n    assert jobs[0].location == \"\" and jobs[0].department == \"\"\n\ndef test_lever_salary_prefers_range_over_description():\n    j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"},\n         \"salaryDescriptionPlain\": \"fallback text\"}\n    assert _lever_salary(j) == \"USD 100,000–150,000\"\n\ndef test_lever_salary_falls_back_when_range_missing():\n    assert _lever_salary({\"salaryDescriptionPlain\": \"DOE\"}) == \"DOE\"\n    assert _lever_salary({}) == \"\"\n\ndef test_parse_ashby_skips_unlisted_jobs():\n    data = {\"jobs\": [{\"id\": \"1\", \"title\": \"Visible\", \"isListed\": True},\n                      {\"id\": \"2\", \"title\": \"Hidden\", \"isListed\": False}]}\n    jobs = parse_ashby(\"acme\", data)\n    assert [j.external_id for j in jobs] == [\"1\"]\n\ndef test_amazon_posted_at_parses_us_format():\n    assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\ndef test_amazon_posted_at_handles_garbage():\n    assert _amazon_posted_at(\"not a date\") == \"\"\n    assert _amazon_posted_at(\"\") == \"\"\n\ndef test_apple_posted_at_truncates_nanoseconds_to_microseconds():\n    # raw value has 9 fractional digits; fromisoformat only accepts up to 6\n    result = _apple_posted_at(\"2026-01-15T10:00:03.812668311Z\")\n    from datetime import datetime\n    datetime.fromisoformat(result)  # must not raise\n\ndef test_apple_posted_at_handles_no_fraction():\n    assert _apple_posted_at(\"2026-01-15T10:00:03Z\") == \"2026-01-15T10:00:03+00:00\"\n\ndef test_apple_hydration_returns_none_on_missing_marker():\n    assert _apple_hydration(\"<html>no data here</html>\") is None\n\ndef test_extract_ds1_handles_malformed_json_gracefully():\n    html = \"key: 'ds:1', data:[not valid json here], sideChannel\"\n    assert _extract_ds1(html) == []  # must not raise\n\ndef test_ds1_posted_at_prefers_create_time_over_update():\n    job = [None]*13 + [[1700000000]]  # index 12 = create time\n    result = _ds1_posted_at(job)\n    assert \"2023\" in result or \"2024\" in result  # sanity check on epoch decode\n\ndef test_ds1_posted_at_returns_empty_when_all_indices_missing():\n    assert _ds1_posted_at([1, 2]) == \"\"\n\ndef test_bd_location_walks_parent_chain():\n    city = {\"en_name\": \"Shenzhen\", \"parent\": {\"en_name\": \"Guangdong\",\n             \"parent\": {\"en_name\": \"China\", \"parent\": None}}}\n    assert _bd_location(city) == \"Shenzhen, Guangdong, China\"\n\ndef test_bd_location_handles_none():\n    assert _bd_location(None) == \"\"\n\ndef test_parse_google_skips_entries_with_falsy_first_element():\n    jobs_raw = [[None, \"title\"], [\"123\", \"Real Job\"]]\n    jobs = parse_google(\"google\", jobs_raw)\n    assert len(jobs) == 1 and jobs[0].external_id == \"123\"\n```\n\n**Pagination loop-termination logic** — every paginated fetcher (`fetch_twosigma`, `fetch_optiver`, `fetch_apple`, `fetch_eightfold`, `fetch_google`, `fetch_microsoft`, `fetch_netflix`, `fetch_amazon`, `fetch_bytedance`, `fetch_workday`) shares the same \"stop when a page returns nothing new\" pattern — none are tested for the boundary cases that pattern is fragile to:\n\n```python\n",
        "level": 1
      },
      {
        "title": "tests/test_fetchers_pagination.py",
        "content": "import httpx, pytest\nfrom fetchers import fetch_optiver\n\n@pytest.mark.asyncio\nasync def test_fetch_optiver_stops_at_max_pages_not_infinite_loop():\n    # server always returns the SAME items -> \"fresh\" would be empty every time\n    # after page 1, so this also exercises the empty-first-page case\n    def handler(req):\n        return httpx.Response(200, json={\"items\": []})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetch_optiver(client, {\"company\": \"optiver\", \"max_pages\": 3})\n    assert jobs == []\n\n@pytest.mark.asyncio\nasync def test_fetch_optiver_dedupes_across_pages_by_external_id():\n    calls = {\"n\": 0}\n    def handler(req):\n        calls[\"n\"] += 1\n        if calls[\"n\"] == 1:\n            return httpx.Response(200, json={\"items\": [{\"href\": \"/join-us/jobs/a\", \"title\": \"A\"}]})\n        return httpx.Response(200, json={\"items\": []})\n    client = httpx.AsyncClient(transport=httpx.MockTransport(handler))\n    jobs = await fetch_optiver(client, {\"company\": \"optiver\"})\n    assert len(jobs) == 1\n```\n\n**`fetch_all`** — the concurrency/error-isolation contract has no test:\n\n```python\n@pytest.mark.asyncio\nasync def test_fetch_all_isolates_per_source_failures(monkeypatch):\n    from fetchers import fetch_all\n    async def ok(client, source): return [object()]\n    async def fail(client, source): raise RuntimeError(\"boom\")\n    monkeypatch.setitem(__import__(\"fetchers\").FETCHERS, \"ok_ats\", ok)\n    monkeypatch.setitem(__import__(\"fetchers\").FETCHERS, \"fail_ats\", fail)\n    jobs = await fetch_all([{\"ats\": \"ok_ats\"}, {\"ats\": \"fail_ats\"}])\n    assert len(jobs) == 1  # one source failing doesn't drop the other's results\n\ndef test_fetch_source_raises_on_unknown_ats():\n    import asyncio\n    from fetchers import fetch_source\n    with pytest.raises(ValueError, match=\"unknown ATS\"):\n        asyncio.run(fetch_source(None, {\"ats\": \"not-a-real-ats\"}))\n```\n\n**Meta's GraphQL error surfacing** is a distinctive gap: `fetch_meta` strips a `for (;;);` XSSI prefix and raises `RuntimeError` on a `data.get(\"errors\")` response (this is literally the failure mode the memory note [[meta-careers-fetcher]] says to watch for when the doc_id rotates) — currently untested:\n\n```python\n@pytest.mark.asyncio\nasync def test_fetch_meta_strips_xssi_prefix_and_parses(monkeypatch):\n    # mock _get_text for the page scrape, then the graphql POST\n    ...\n\n@pytest.mark.asyncio\nasync def test_fetch_meta_raises_readable_error_on_graphql_errors(monkeypatch):\n    # simulate {\"errors\":[{\"message\":\"...\"}]}  -> assert RuntimeError message\n    # is exactly what you'd need to diagnose a rotated doc_id\n    ...\n```\n\n---\n\n",
        "level": 1
