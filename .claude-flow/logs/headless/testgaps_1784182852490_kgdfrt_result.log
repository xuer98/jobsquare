      {
        "title": "7. `agent.py` — CLI subcommands, entirely untested",
        "content": "\n**`_normalize_ats`** is pure and high-value (ATS-safe PDF rendering — a subtle bug here silently corrupts every generated CV/cover letter):\n\n```python\n",
        "level": 3
      },
      {
        "title": "tests/test_agent_normalize.py",
        "content": "from agent import _normalize_ats\n\ndef test_normalize_ats_replaces_smart_quotes_and_dashes():\n    html = \"<p>“Hello” — world…</p>\"\n    out, counts = _normalize_ats(html)\n    assert '\"Hello\" - world...' in out\n    assert counts[\"smart-double-quote\"] == 2\n\ndef test_normalize_ats_does_not_touch_style_block():\n    html = \"<style>.x{content:'\\u2014'}</style><p>\\u2014</p>\"\n    out, counts = _normalize_ats(html)\n    assert \"\\u2014\" in out.split(\"</style>\")[0]   # untouched inside <style>\n    assert counts[\"em-dash\"] == 1                  # only the <p> one counted\n\ndef test_normalize_ats_does_not_touch_script_block():\n    html = \"<script>var x='\\u2022';</script><p>\\u2022</p>\"\n    out, counts = _normalize_ats(html)\n    assert counts[\"bullet\"] == 1\n\ndef test_normalize_ats_does_not_touch_tag_attributes():\n    html = '<a title=\"em—dash\">text\\u2014here</a>'\n    out, counts = _normalize_ats(html)\n    assert 'title=\"em—dash\"' in out       # attribute value untouched\n    assert \"text-here\" in out             # body text fixed\n    assert counts[\"em-dash\"] == 1\n\ndef test_normalize_ats_no_replacements_needed_gives_empty_counts():\n    out, counts = _normalize_ats(\"<p>plain ascii text</p>\")\n    assert counts == {}\n```\n\n**`cmd_db_new` / `cmd_db_mark`** — the posted-date filtering and group-boundary truncation logic is intricate and completely untested:\n\n```python\n",
        "level": 1
      },
      {
        "title": "tests/test_agent_db_new.py",
        "content": "import json, pytest\nfrom store import Store\nfrom models import Job\nfrom agent import cmd_db_new, cmd_db_mark\n\n@pytest.fixture\ndef sources_yaml(tmp_path):\n    db = tmp_path / \"jobs.db\"\n    cfg = tmp_path / \"sources.yaml\"\n    cfg.write_text(f\"sources: []\\ndb: {db}\\n\")\n    return cfg, db\n\ndef test_db_new_first_run_uses_since_days_window(sources_yaml, capsys):\n    cfg, db = sources_yaml\n    with Store(db) as s:\n        s.diff([Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\")])\n    cmd_db_new([\"-c\", str(cfg), \"--since-days\", \"7\"])\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"first_run\"] is True and out[\"count\"] == 1\n\ndef test_db_new_dated_only_drops_undated_rows(sources_yaml, capsys):\n    cfg, db = sources_yaml\n    with Store(db) as s:\n        s.diff([Job(source=\"s\", company=\"c\", external_id=\"1\", title=\"T\", url=\"u\", posted_at=\"\")])\n    cmd_db_new([\"-c\", str(cfg), \"--dated-only\"])\n    out = json.loads(capsys.readouterr().out)\n    assert out[\"count\"] == 0 and out[\"undated_dropped\"] == 1\n\ndef test_db_new_truncates_at_group_boundary_not_mid_group(sources_yaml, capsys):\n    # two jobs sharing one first_seen timestamp must never be split by --limit\n    ...\n\ndef test_db_mark_rejects_non_iso_watermark(sources_yaml, capsys):\n    cfg, db = sources_yaml\n    rc = cmd_db_mark([str(cfg).replace(\"sources.yaml\", \"not-a-date\"), \"-c\", str(cfg)])\n    # actually: watermark is positional, adjust call accordingly\n    assert rc == 2\n\ndef test_db_mark_requires_watermark_or_now(sources_yaml):\n    cfg, _ = sources_yaml\n    rc = cmd_db_mark([\"-c\", str(cfg)])\n    assert rc == 2\n\ndef test_db_mark_now_sets_current_timestamp(sources_yaml):\n    cfg, db = sources_yaml\n    rc = cmd_db_mark([\"--now\", \"-c\", str(cfg)])\n    assert rc == 0\n    with Store(db) as s:\n        assert s.get_meta(\"last_scan\") is not None\n```\n\n**`cmd_pdf_render`** touches the filesystem and shells out to Chrome — needs `subprocess.run` mocked for the failure path (no Chrome found / render produces non-PDF output), which is currently the only error path in the file with zero coverage:\n\n```python\ndef test_pdf_render_missing_input_file_returns_2(tmp_path, capsys):\n    from agent import cmd_pdf_render\n    rc = cmd_pdf_render([str(tmp_path / \"nope.html\")])\n    assert rc == 2\n\ndef test_pdf_render_reports_failure_when_output_is_not_pdf(tmp_path, monkeypatch, capsys):\n    from agent import cmd_pdf_render\n    src = tmp_path / \"in.html\"\n    src.write_text(\"<html></html>\")\n    monkeypatch.setattr(\"agent._chrome_bin\", lambda: \"/bin/true\")\n    monkeypatch.setattr(\"agent.subprocess.run\",\n        lambda *a, **kw: type(\"R\", (), {\"stderr\": \"chrome crashed\", \"returncode\": 1})())\n    rc = cmd_pdf_render([str(src)])\n    assert rc == 1\n```\n\n**`main()` argument routing** — the mode-word/flag-splitting logic (`-i`/`--interactive` stripped out, mode words end at first `-`-prefixed token) has no test proving `agent.py scan --dry-run` routes `[\"scan\"]` as mode words and `[\"--dry-run\"]` as passthrough:\n\n```python\ndef test_main_splits_mode_words_from_flags(monkeypatch):\n    captured = {}\n    monkeypatch.setattr(\"agent.run_claude\", lambda mode, interactive, extra: captured.update(\n        mode=mode, interactive=interactive, extra=extra) or 0)\n    import agent\n    agent.main.__wrapped__ if False else None  # (invoke via sys.argv patch instead)\n```\n(This one is easiest tested by patching `sys.argv` and asserting on `run_claude`'s captured args — worth writing once the harness above exists.)\n\n---\n\n",
        "level": 1
