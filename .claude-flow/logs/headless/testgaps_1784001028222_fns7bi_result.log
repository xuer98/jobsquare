        "code": "import pytest\nfrom datetime import datetime, timezone\nfrom models import Job, parse_posted_at\n\nclass TestParsePostedAt:\n    def test_empty_returns_none(self):\n        assert parse_posted_at(\"\") is None\n\n    def test_millisecond_epoch_lever(self):\n        dt = parse_posted_at(\"1643241332430\")\n        assert dt == datetime.fromtimestamp(1643241332, tz=timezone.utc)\n\n    def test_second_epoch(self):\n        dt = parse_posted_at(\"1643241332\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_iso8601_with_z_suffix(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00Z\")\n        assert dt == datetime(2026, 1, 15, 10, 0, tzinfo=timezone.utc)\n\n    def test_naive_iso_defaults_to_utc(self):\n        dt = parse_posted_at(\"2026-01-15T10:00:00\")\n        assert dt.tzinfo == timezone.utc\n\n    def test_unparseable_string_returns_none(self):\n        assert parse_posted_at(\"Posted 3 Days Ago\") is None\n\n    def test_negative_numeric_string(self):\n        # lstrip(\"-\").isdigit() path — currently treated as epoch; confirm behavior\n        assert parse_posted_at(\"-5\") is not None  # documents actual behavior\n\n\nclass TestJobIdentity:\n    def _job(self, **kw):\n        base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                    title=\"Engineer\", url=\"https://x/1\")\n        base.update(kw)\n        return Job(**base)\n\n    def test_key_is_stable_and_composed(self):\n        j = self._job()\n        assert j.key == \"greenhouse:acme:1\"\n\n    def test_content_hash_changes_with_title(self):\n        a, b = self._job(), self._job(title=\"Senior Engineer\")\n        assert a.content_hash != b.content_hash\n\n    def test_content_hash_stable_across_calls(self):\n        j = self._job()\n        assert j.content_hash == j.content_hash\n\n    def test_content_hash_ignores_department_order_regression_guard(self):\n        # documents current join-based hash: any field change -> new hash\n        a = self._job(department=\"Eng\")\n        b = self._job(department=\"Sales\")\n        assert a.content_hash != b.content_hash\n\n    def test_to_row_drops_raw_and_adds_key_and_hash(self):\n        j = self._job(raw={\"secret\": True})\n        row = j.to_row()\n        assert \"raw\" not in row\n        assert row[\"key\"] == j.key\n        assert row[\"content_hash\"] == j.content_hash"
