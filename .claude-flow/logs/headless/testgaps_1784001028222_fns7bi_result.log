      {
        "title": "2. `filters.py`",
        "content": "\n**Untested:** `_compile`, `match`, `filter_jobs` — entirely.\n\nGaps:\n- Word-boundary regex matching (`\\b`) — substrings shouldn't match, e.g. `\"eng\"` filter shouldn't match `\"engineering\"`... actually it should via `\\b` on partial word boundary — needs verification either way.\n- Case-insensitivity.\n- Exclude takes priority over include.\n- Empty/`None` include/exclude/locations lists (should not filter anything).\n- `cutoff` with unparseable `posted_at` — job is **kept**, not dropped (explicit design decision in comment).\n- `locations` matching is substring/case-insensitive, not exact.\n- `filter_jobs` with `max_age_days` fractional value.\n\n```python\nimport pytest\nfrom datetime import datetime, timedelta, timezone\nfrom models import Job\nfrom filters import match, filter_jobs\n\ndef _job(title=\"Software Engineer\", department=\"Eng\", location=\"Remote, USA\", posted_at=\"\"):\n    return Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n               title=title, url=\"https://x/1\", department=department,\n               location=location, posted_at=posted_at)\n\nclass TestMatch:\n    def test_no_filters_passes(self):\n        assert match(_job()) is True\n\n    def test_include_keyword_hit(self):\n        assert match(_job(title=\"Backend Engineer\"), include=[\"engineer\"]) is True\n\n    def test_include_keyword_miss(self):\n        assert match(_job(title=\"Product Manager\"), include=[\"engineer\"]) is False\n\n    def test_include_respects_word_boundary(self):\n        # \"eng\" should not match \"engineering\" as a whole-word filter\n        assert match(_job(title=\"Engineering Manager\"), include=[\"eng\"]) is False\n\n    def test_exclude_beats_include(self):\n        j = _job(title=\"Senior Staff Engineer\")\n        assert match(j, include=[\"engineer\"], exclude=[\"senior\"]) is False\n\n    def test_case_insensitive(self):\n        assert match(_job(title=\"ENGINEER\"), include=[\"engineer\"]) is True\n\n    def test_location_substring_match(self):\n        assert match(_job(location=\"San Francisco, CA\"), locations=[\"francisco\"]) is True\n\n    def test_location_no_match(self):\n        assert match(_job(location=\"London, UK\"), locations=[\"new york\"]) is False\n\n    def test_cutoff_drops_old_parseable_job(self):\n        old = _job(posted_at=\"2020-01-01T00:00:00Z\")\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(old, cutoff=cutoff) is False\n\n    def test_cutoff_keeps_unparseable_posted_at(self):\n        j = _job(posted_at=\"Posted 3 Days Ago\")  # Workday-style, unparseable\n        cutoff = datetime.now(timezone.utc) - timedelta(days=1)\n        assert match(j, cutoff=cutoff) is True\n\n    def test_cutoff_keeps_recent_job(self):\n        recent = _job(posted_at=datetime.now(timezone.utc).isoformat())\n        cutoff = datetime.now(timezone.utc) - timedelta(days=30)\n        assert match(recent, cutoff=cutoff) is True\n\n\nclass TestFilterJobs:\n    def test_max_age_days_applies_cutoff(self):\n        jobs = [_job(posted_at=\"2020-01-01T00:00:00Z\"),\n                _job(posted_at=datetime.now(timezone.utc).isoformat())]\n        out = filter_jobs(jobs, {\"max_age_days\": 7})\n        assert len(out) == 1\n\n    def test_empty_rules_returns_all(self):\n        jobs = [_job(), _job(title=\"Other\")]\n        assert filter_jobs(jobs, {}) == jobs\n\n    def test_combines_include_exclude_and_location(self):\n        jobs = [_job(title=\"Backend Engineer\", location=\"NYC\"),\n                _job(title=\"Backend Engineer\", location=\"London\")]\n        out = filter_jobs(jobs, {\"include_keywords\": [\"engineer\"], \"locations\": [\"nyc\"]})\n        assert len(out) == 1\n```\n\n---\n\n",
        "level": 2
      },
      {
        "title": "3. `store.py`",
        "content": "\n**Untested:** entirely — schema creation, migration, diff (new/changed/unchanged), meta get/set, `added_since`, `count`.\n\nGaps:\n- Fresh DB creates schema correctly (use `:memory:` or `tmp_path`).\n- `_migrate`: opening a DB created *before* `salary_range` existed should add the column without error (need to simulate an old-schema DB).\n- `diff`: same job twice → second call returns empty new/changed, `last_seen` updates.\n- `diff`: job with same key but changed `content_hash` → goes to `changed`, not `new`.\n- `diff`: unchanged job → neither list, but `last_seen` still bumped.\n- `get_meta`/`set_meta`: missing key returns `None`; upsert overwrites existing value (`ON CONFLICT`).\n- `added_since`: ordering (`first_seen, company, title`), strict `>` boundary (row exactly at `ts` excluded).\n- `count` on empty vs populated store.\n- Context manager (`__enter__`/`__exit__`) actually closes the connection.\n\n```python\nimport pytest\nimport sqlite3\nfrom models import Job\nfrom store import Store\n\ndef _job(external_id=\"1\", title=\"Engineer\", **kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=external_id,\n                title=title, url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\n@pytest.fixture\ndef store(tmp_path):\n    with Store(tmp_path / \"test.db\") as s:\n        yield s\n\nclass TestDiff:\n    def test_new_job_recorded_as_new(self, store):\n        new, changed = store.diff([_job()])\n        assert len(new) == 1 and changed == []\n\n    def test_unchanged_job_returns_empty_both_lists(self, store):\n        store.diff([_job()])\n        new, changed = store.diff([_job()])\n        assert new == [] and changed == []\n\n    def test_content_change_recorded_as_changed_not_new(self, store):\n        store.diff([_job(title=\"Engineer\")])\n        new, changed = store.diff([_job(title=\"Senior Engineer\")])\n        assert new == [] and len(changed) == 1\n\n    def test_last_seen_bumped_on_unchanged_rerun(self, store):\n        store.diff([_job()])\n        row_before = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        import time; time.sleep(1.1)\n        store.diff([_job()])\n        row_after = store.conn.execute(\"SELECT last_seen FROM jobs\").fetchone()\n        assert row_after[\"last_seen\"] != row_before[\"last_seen\"]\n\n\nclass TestMeta:\n    def test_get_missing_key_returns_none(self, store):\n        assert store.get_meta(\"nope\") is None\n\n    def test_set_then_get_roundtrips(self, store):\n        store.set_meta(\"last_scan\", \"2026-01-01T00:00:00+00:00\")\n        assert store.get_meta(\"last_scan\") == \"2026-01-01T00:00:00+00:00\"\n\n    def test_set_overwrites_existing(self, store):\n        store.set_meta(\"last_scan\", \"a\")\n        store.set_meta(\"last_scan\", \"b\")\n        assert store.get_meta(\"last_scan\") == \"b\"\n\n\nclass TestAddedSince:\n    def test_excludes_rows_at_exact_boundary(self, store):\n        store.diff([_job()])\n        ts = store.conn.execute(\"SELECT first_seen FROM jobs\").fetchone()[\"first_seen\"]\n        assert store.added_since(ts) == []\n\n    def test_orders_by_first_seen_company_title(self, store):\n        store.diff([_job(external_id=\"1\", company=\"b\", title=\"X\"),\n                    _job(external_id=\"2\", company=\"a\", title=\"Y\")])\n        rows = store.added_since(\"2000-01-01T00:00:00+00:00\")\n        assert [r[\"company\"] for r in rows] == [\"a\", \"b\"]\n\n\nclass TestMigration:\n    def test_opens_pre_salary_range_db_without_error(self, tmp_path):\n        path = tmp_path / \"old.db\"\n        conn = sqlite3.connect(str(path))\n        conn.executescript(\"\"\"\n            CREATE TABLE jobs (key TEXT PRIMARY KEY, source TEXT, company TEXT,\n                external_id TEXT, title TEXT, url TEXT, location TEXT,\n                department TEXT, employment_type TEXT, posted_at TEXT,\n                content_hash TEXT, first_seen TEXT, last_seen TEXT);\n        \"\"\")\n        conn.commit(); conn.close()\n        with Store(path) as s:\n            cols = {r[\"name\"] for r in s.conn.execute(\"PRAGMA table_info(jobs)\")}\n            assert \"salary_range\" in cols\n\n\nclass TestCount:\n    def test_empty_store_is_zero(self, store):\n        assert store.count() == 0\n\n    def test_count_reflects_inserts(self, store):\n        store.diff([_job(external_id=\"1\"), _job(external_id=\"2\")])\n        assert store.count() == 2\n```\n\n---\n\n",
        "level": 2
      },
      {
        "title": "4. `notify.py`",
        "content": "\n**Untested:** entirely. This is high-value — silent notifier failures currently only `print` and continue, so bugs here are invisible in production.\n\nGaps:\n- Each `notify_*` function's env-var gating (missing var → no-op, no network call).\n- `notify_slack`/`notify_webhook`/`notify_sms`: no-op when `new` and `changed` are both empty, *even if* env vars are set (avoid spamming empty runs).\n- `notify_sms`: requires **all four** Twilio vars; missing any one → no-op. `_sms_body` truncation at `limit=8` and the `+N more` line. ASCII-only body (ensures no UCS-2 segment cost).\n- `notify_email`: SMTP call sequence (`starttls`, conditional `login` only if `SMTP_USER` set).\n- `dispatch`: one notifier raising doesn't stop the others (`try/except` per notifier).\n- `notify_sms` calls `resp.raise_for_status()` — a 4xx from Twilio should propagate up to `dispatch`'s catch, not raise out of `dispatch` itself.\n\n```python\nimport os\nimport pytest\nimport httpx\nfrom unittest.mock import MagicMock, patch\nfrom models import Job\nfrom notify import (notify_slack, notify_webhook, notify_sms, notify_email,\n                     _sms_body, dispatch, NOTIFIERS)\n\ndef _job(**kw):\n    base = dict(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                title=\"Engineer\", url=\"https://x/1\")\n    base.update(kw)\n    return Job(**base)\n\nclass TestNotifySlack:\n    def test_noop_without_webhook_url(self, monkeypatch):\n        monkeypatch.delenv(\"SLACK_WEBHOOK_URL\", raising=False)\n        with patch(\"notify.httpx.post\") as post:\n            notify_slack([_job()], [])\n            post.assert_not_called()\n\n    def test_noop_when_nothing_new_or_changed(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        with patch(\"notify.httpx.post\") as post:\n            notify_slack([], [])\n            post.assert_not_called()\n\n    def test_posts_when_configured_and_new_jobs(self, monkeypatch):\n        monkeypatch.setenv(\"SLACK_WEBHOOK_URL\", \"https://hooks.slack.test/x\")\n        with patch(\"notify.httpx.post\") as post:\n            notify_slack([_job()], [])\n            post.assert_called_once()\n\n\nclass TestNotifySms:\n    @pytest.mark.parametrize(\"missing\", [\"TWILIO_ACCOUNT_SID\", \"TWILIO_AUTH_TOKEN\",\n                                          \"TWILIO_FROM\", \"TWILIO_TO\"])\n    def test_noop_if_any_var_missing(self, monkeypatch, missing):\n        vars = {\"TWILIO_ACCOUNT_SID\": \"sid\", \"TWILIO_AUTH_TOKEN\": \"tok\",\n                 \"TWILIO_FROM\": \"+1\", \"TWILIO_TO\": \"+2\"}\n        vars.pop(missing)\n        for k, v in vars.items():\n            monkeypatch.setenv(k, v)\n        monkeypatch.delenv(missing, raising=False)\n        with patch(\"notify.httpx.post\") as post:\n            notify_sms([_job()], [])\n            post.assert_not_called()\n\n    def test_raises_on_twilio_error_response(self, monkeypatch):\n        for k, v in {\"TWILIO_ACCOUNT_SID\": \"sid\", \"TWILIO_AUTH_TOKEN\": \"tok\",\n                      \"TWILIO_FROM\": \"+1\", \"TWILIO_TO\": \"+2\"}.items():\n            monkeypatch.setenv(k, v)\n        fake_resp = MagicMock()\n        fake_resp.raise_for_status.side_effect = httpx.HTTPStatusError(\n            \"bad\", request=MagicMock(), response=MagicMock(status_code=400))\n        with patch(\"notify.httpx.post\", return_value=fake_resp):\n            with pytest.raises(httpx.HTTPStatusError):\n                notify_sms([_job()], [])\n\n\nclass TestSmsBody:\n    def test_truncates_at_limit_with_more_suffix(self):\n        jobs = [_job(external_id=str(i), title=f\"J{i}\") for i in range(10)]\n        body = _sms_body(jobs, [], limit=8)\n        assert \"+2 more\" in body\n        assert body.count(\"\\n- \") == 8\n\n    def test_body_is_ascii_only(self):\n        body = _sms_body([_job(title=\"Café Engineer\")], [])\n        # non-ASCII chars like é are allowed in title, but no bullet/ellipsis chars\n        assert \"•\" not in body and \"…\" not in body\n\n\nclass TestDispatch:\n    def test_one_notifier_failure_does_not_block_others(self, capsys):\n        calls = []\n        def boom(new, changed): raise RuntimeError(\"nope\")\n        def ok(new, changed): calls.append(\"ok\")\n        with patch(\"notify.NOTIFIERS\", [boom, ok]):\n            dispatch([_job()], [])\n        assert calls == [\"ok\"]\n        assert \"notifier boom failed\" in capsys.readouterr().out\n```\n\n---\n\n",
        "level": 2
      },
      {
        "title": "5. `pipeline.py`",
        "content": "\n**Untested:** `load_config` defaults, `run` orchestration, `dry_run` short-circuit, `run_sync`.\n\nGaps:\n- `load_config` fills in defaults (`sources=[]`, `filters={}`, `db=\"jobs.db\"`, `concurrency=8`) when absent from YAML.\n- `run` in `dry_run=True` mode never touches `Store` or `dispatch` (currently only verifiable by mocking — worth locking in as a regression test since it's a stated safety property: \"without persisting dedup state\").\n- `run` wires `fetch_all` → `filter_jobs` → `Store.diff` → `dispatch` in the right order with the right args.\n- Return dict shape (`matched`/`new`/`changed`) in both dry-run and normal paths.\n\n```python\nimport pytest\nfrom unittest.mock import AsyncMock, patch, MagicMock\nfrom pipeline import load_config, run\n\nclass TestLoadConfig:\n    def test_fills_defaults(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(\"sources: []\\n\")\n        cfg = load_config(cfg_path)\n        assert cfg[\"db\"] == \"jobs.db\"\n        assert cfg[\"concurrency\"] == 8\n        assert cfg[\"filters\"] == {}\n\n    def test_preserves_explicit_values(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(\"sources: []\\ndb: custom.db\\nconcurrency: 3\\n\")\n        cfg = load_config(cfg_path)\n        assert cfg[\"db\"] == \"custom.db\"\n        assert cfg[\"concurrency\"] == 3\n\n\nclass TestRun:\n    @pytest.mark.asyncio\n    async def test_dry_run_never_touches_store_or_dispatch(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(\"sources: []\\n\")\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n             patch(\"pipeline.Store\") as store_cls, \\\n             patch(\"pipeline.dispatch\") as dispatch_fn:\n            result = await run(cfg_path, dry_run=True)\n        store_cls.assert_not_called()\n        dispatch_fn.assert_not_called()\n        assert result == {\"matched\": 0, \"new\": 0, \"changed\": 0}\n\n    @pytest.mark.asyncio\n    async def test_normal_run_calls_diff_and_dispatch(self, tmp_path):\n        cfg_path = tmp_path / \"sources.yaml\"\n        cfg_path.write_text(\"sources: []\\n\")\n        mock_store = MagicMock()\n        mock_store.diff.return_value = ([], [])\n        mock_store.count.return_value = 0\n        mock_store.__enter__.return_value = mock_store\n        with patch(\"pipeline.fetch_all\", new=AsyncMock(return_value=[])), \\\n             patch(\"pipeline.Store\", return_value=mock_store), \\\n             patch(\"pipeline.dispatch\") as dispatch_fn:\n            await run(cfg_path, dry_run=False)\n        mock_store.diff.assert_called_once()\n        dispatch_fn.assert_called_once()\n```\n\n---\n\n",
        "level": 2
      },
      {
        "title": "6. `fetchers.py` (largest gap — ~30 untested functions)",
        "content": "\n",
        "level": 2
      },
      {
        "title": "6a. Retry/transport layer (`_request`, `_get_json`, `_get_text`)",
        "content": "Highest-risk untested code: silent retry-exhaustion swallows the real error into a generic `RuntimeError`.\n\nGaps:\n- Retries on 429/500/502/503/504, does **not** retry on 404/400.\n- Exhausts `retries` then raises `RuntimeError` wrapping the last exception.\n- Succeeds on the Nth attempt after transient failures.\n- `httpx.TransportError` (e.g. connect timeout) also retried.\n\n```python\nimport pytest\nimport httpx\nimport respx\nfrom fetchers import _request, _get_json\n\n@pytest.mark.asyncio\nclass TestRequest:\n    async def test_retries_on_503_then_succeeds(self):\n        route = respx.get(\"https://x.test/j\").mock(side_effect=[\n            httpx.Response(503), httpx.Response(200, json={\"ok\": True})])\n        async with httpx.AsyncClient() as client:\n            with respx.mock:\n                respx.get(\"https://x.test/j\").mock(side_effect=[\n                    httpx.Response(503), httpx.Response(200, json={\"ok\": True})])\n                r = await _request(client, \"https://x.test/j\", retries=3)\n        assert r.status_code == 200\n\n    async def test_does_not_retry_404(self):\n        async with httpx.AsyncClient() as client:\n            with respx.mock:\n                respx.get(\"https://x.test/j\").mock(return_value=httpx.Response(404))\n                with pytest.raises(RuntimeError):\n                    await _request(client, \"https://x.test/j\", retries=3)\n                assert respx.calls.call_count == 1\n\n    async def test_exhausts_retries_and_raises_runtime_error(self):\n        async with httpx.AsyncClient() as client:\n            with respx.mock:\n                respx.get(\"https://x.test/j\").mock(return_value=httpx.Response(500))\n                with pytest.raises(RuntimeError, match=\"failed to fetch\"):\n                    await _request(client, \"https://x.test/j\", retries=2)\n                assert respx.calls.call_count == 2\n```\n\n",
        "level": 3
      },
      {
        "title": "6b. `parse_*` normalizers (pure functions — cheapest, highest-value tests to write first)",
        "content": "\nEach parser has edge cases currently unguarded:\n\n| Parser | Untested edge cases |\n|---|---|\n| `parse_greenhouse` | missing `location`/`departments` keys, multiple departments joined |\n| `parse_lever` | `_lever_salary` with only `salaryDescriptionPlain`, with numeric min/max needing `,` formatting, with neither |\n| `parse_ashby` | `isListed: False` filtered out; `id` vs `jobId` fallback; both compensation field variants |\n| `parse_smartrecruiters` | partial location (city only, no region/country) |\n| `parse_recruitee` | flat string location vs assembled city/country |\n| `parse_workable` | dict location vs flat city/state/country; `shortcode` vs `id` fallback |\n| `parse_google` | `_extract_ds1` no match → `[]`; malformed JSON → `[]`; `_ds1_posted_at` index-out-of-range guarded fallback across indices 12/13/14; job with falsy `j[0]` skipped |\n| `parse_deshaw` | duplicate `data-job-id` deduped; missing `href` falls back to `/careers/{id}`; HTML entity unescaping in title |\n| `parse_twosigma` | triple-rendered card dedup; location lookup bounded to next anchor (doesn't leak into next card) |\n| `parse_optiver` | `href` prefix stripping (`join-us/jobs/`) for external_id |\n| `parse_microsoft` | missing `postedTs` → empty `posted_at`; `standardizedLocations` vs `locations` fallback |\n| `parse_netflix` | comma-packed location gets spaced (`\"City,State\"` → `\"City, State\"`); `t_create` vs `t_update` fallback |\n| `parse_amazon` / `_amazon_posted_at` | malformed date string → `\"\"` (not a crash); `id` vs `id_icims` fallback |\n| `parse_meta` | duplicate ids deduped; missing `id` skipped |\n| `parse_workday` (inline in `fetch_workday`) | `bulletFields[0]` vs `externalPath` fallback for `req_id` |\n\n```python\nfrom fetchers import (parse_greenhouse, parse_lever, _lever_salary, parse_ashby,\n                       parse_google, _extract_ds1, _ds1_posted_at, parse_deshaw,\n                       parse_twosigma, parse_optiver, parse_microsoft, parse_netflix,\n                       parse_amazon, _amazon_posted_at, parse_meta)\n\nclass TestParseGreenhouse:\n    def test_missing_location_defaults_empty(self):\n        jobs = parse_greenhouse(\"acme\", {\"jobs\": [{\"id\": 1, \"title\": \"Eng\"}]})\n        assert jobs[0].location == \"\"\n\n    def test_multiple_departments_joined(self):\n        data = {\"jobs\": [{\"id\": 1, \"title\": \"Eng\",\n                          \"departments\": [{\"name\": \"Eng\"}, {\"name\": \"Platform\"}]}]}\n        jobs = parse_greenhouse(\"acme\", data)\n        assert jobs[0].department == \"Eng, Platform\"\n\n\nclass TestLeverSalary:\n    def test_formats_min_max_with_commas(self):\n        j = {\"salaryRange\": {\"min\": 100000, \"max\": 150000, \"currency\": \"USD\"}}\n        assert _lever_salary(j) == \"USD 100,000–150,000\"\n\n    def test_falls_back_to_description_plain(self):\n        j = {\"salaryDescriptionPlain\": \"Competitive\"}\n        assert _lever_salary(j) == \"Competitive\"\n\n    def test_no_salary_info_returns_empty(self):\n        assert _lever_salary({}) == \"\"\n\n\nclass TestAshby:\n    def test_unlisted_jobs_filtered_out(self):\n        data = {\"jobs\": [{\"id\": \"1\", \"title\": \"Hidden\", \"isListed\": False},\n                         {\"id\": \"2\", \"title\": \"Visible\", \"isListed\": True}]}\n        jobs = parse_ashby(\"acme\", data)\n        assert len(jobs) == 1 and jobs[0].external_id == \"2\"\n\n    def test_id_falls_back_to_jobid(self):\n        data = {\"jobs\": [{\"jobId\": \"42\", \"title\": \"Eng\", \"isListed\": True}]}\n        assert parse_ashby(\"acme\", data)[0].external_id == \"42\"\n\n\nclass TestGoogleDs1:\n    def test_extract_returns_empty_on_no_match(self):\n        assert _extract_ds1(\"<html>nothing here</html>\") == []\n\n    def test_extract_returns_empty_on_malformed_json(self):\n        html = \"key: 'ds:1', ..., data:[not valid json, sideChannel:{}})\"\n        assert _extract_ds1(html) == []\n\n    def test_ds1_posted_at_falls_back_across_indices(self):\n        job = [None] * 15\n        job[13] = [1700000000, 0]\n        assert _ds1_posted_at(job) != \"\"\n\n    def test_ds1_posted_at_missing_returns_empty(self):\n        assert _ds1_posted_at([None] * 5) == \"\"\n\n    def test_parse_google_skips_falsy_first_element(self):\n        assert parse_google(\"google\", [None, [\"\"], [\"123\", \"Title\"]]) == \\\n            parse_google(\"google\", [[\"123\", \"Title\"]])\n\n\nclass TestDeshaw:\n    def test_dedupes_repeated_job_ids(self):\n        page = ('<div data-job-id=\"1\"><span class=\"job-display-name\">Eng</span></div>'\n                '<div data-job-id=\"1\"><span class=\"job-display-name\">Eng</span></div>')\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert len(jobs) == 1\n\n    def test_missing_href_falls_back_to_id_path(self):\n        page = '<div data-job-id=\"7\"><span class=\"job-display-name\">Eng</span></div>'\n        jobs = parse_deshaw(\"deshaw\", page)\n        assert jobs[0].url == \"https://www.deshaw.com/careers/7\"\n\n    def test_unescapes_html_entities_in_title(self):\n        page = ('<div data-job-id=\"1\">'\n                '<span class=\"job-display-name\">R&amp;D Engineer</span></div>')\n        assert parse_deshaw(\"deshaw\", page)[0].title == \"R&D Engineer\"\n\n\nclass TestAmazonPostedAt:\n    def test_valid_date_string(self):\n        assert _amazon_posted_at(\"June 26, 2026\") == \"2026-06-26T00:00:00+00:00\"\n\n    def test_malformed_date_returns_empty(self):\n        assert _amazon_posted_at(\"not a date\") == \"\"\n\n    def test_empty_string_returns_empty(self):\n        assert _amazon_posted_at(\"\") == \"\"\n\n\nclass TestParseMeta:\n    def test_dedupes_by_id(self):\n        results = [{\"id\": \"1\", \"title\": \"Eng\"}, {\"id\": \"1\", \"title\": \"Eng\"}]\n        assert len(parse_meta(\"meta\", results)) == 1\n\n    def test_skips_entries_without_id(self):\n        assert parse_meta(\"meta\", [{\"title\": \"No ID\"}]) == []\n```\n\n",
        "level": 3
      },
      {
        "title": "6c. Paginated `fetch_*` functions (async, need `respx` or injected `httpx.MockTransport`)",
        "content": "\nGaps common to all of `fetch_twosigma`/`fetch_optiver`/`fetch_google`/`fetch_microsoft`/`fetch_netflix`/`fetch_amazon`/`fetch_workday`:\n- Stops pagination when a page returns no *fresh* items (dedup against `seen`).\n- Respects `max_pages` safety cap even if the server keeps returning data.\n- `fetch_workday`'s extra stop conditions: `offset >= total` and the `offset > 5000` hard cap.\n- Empty first page → empty result, no crash.\n\n```python\nimport respx\nimport httpx\nimport pytest\nfrom fetchers import fetch_optiver, fetch_workday\n\n@pytest.mark.asyncio\nclass TestFetchOptiver:\n    async def test_stops_when_page_has_no_fresh_items(self):\n        with respx.mock:\n            respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n                side_effect=[\n                    httpx.Response(200, json={\"items\": [\n                        {\"href\": \"/join-us/jobs/eng-1\", \"title\": \"Eng\"}]}),\n                    httpx.Response(200, json={\"items\": []}),\n                ])\n            async with httpx.AsyncClient() as client:\n                jobs = await fetch_optiver(client, {\"company\": \"optiver\"})\n        assert len(jobs) == 1\n\n    async def test_respects_max_pages_cap(self):\n        with respx.mock:\n            route = respx.get(\"https://www.optiver.com/en/api/v1/jobs\").mock(\n                return_value=httpx.Response(200, json={\"items\": [\n                    {\"href\": f\"/join-us/jobs/e-{__import__('random').random()}\",\n                     \"title\": \"Eng\"}]}))\n            async with httpx.AsyncClient() as client:\n                await fetch_optiver(client, {\"company\": \"optiver\", \"max_pages\": 2})\n        assert route.call_count == 2\n\n\n@pytest.mark.asyncio\nclass TestFetchWorkday:\n    async def test_stops_when_offset_reaches_total(self):\n        with respx.mock:\n            respx.post(\"https://acme.wd5.myworkdayjobs.com/wday/cxs/acme/site/jobs\").mock(\n                return_value=httpx.Response(200, json={\n                    \"jobPostings\": [{\"title\": \"Eng\", \"externalPath\": \"/job/1\"}],\n                    \"total\": 1}))\n            async with httpx.AsyncClient() as client:\n                jobs = await fetch_workday(client, {\n                    \"host\": \"acme.wd5.myworkdayjobs.com\", \"tenant\": \"acme\", \"site\": \"site\"})\n        assert len(jobs) == 1\n\n    async def test_req_id_falls_back_to_external_path(self):\n        with respx.mock:\n            respx.post(\"https://acme.wd5.myworkdayjobs.com/wday/cxs/acme/site/jobs\").mock(\n                return_value=httpx.Response(200, json={\n                    \"jobPostings\": [{\"title\": \"Eng\", \"externalPath\": \"/job/9\"}],  # no bulletFields\n                    \"total\": 1}))\n            async with httpx.AsyncClient() as client:\n                jobs = await fetch_workday(client, {\n                    \"host\": \"acme.wd5.myworkdayjobs.com\", \"tenant\": \"acme\", \"site\": \"site\"})\n        assert jobs[0].external_id == \"/job/9\"\n```\n\n",
        "level": 3
