        "title": "7. `agent.py`",
        "content": "\n**Untested:** `cmd_db_new`, `cmd_db_mark`, `_normalize_ats`, `cmd_pdf_render`, `_chrome_bin`, `main` arg-routing.\n\nGaps:\n- `cmd_db_new`: first-run window (`since_days`) when no marker exists; truncation only at `first_seen` group boundaries (never splits a timestamp group even if it exceeds `limit`); `watermark` output equals the last *complete* group's timestamp, not `since`.\n- `cmd_db_mark`: `--now` sets current time; explicit watermark validated as ISO, rejects garbage with exit code 2; requires one of `watermark`/`--now`.\n- `_normalize_ats`: replacements skip `<style>`/`<script>` blocks and skip inside tag attributes (only applies to text nodes); counts dict tallies per rule.\n- `cmd_pdf_render`: missing input file → exit code 2; injects `@page` CSS before `</head>` if present, else prepends; cleans up temp `.ats.html` file even on subprocess failure (`finally`); detects failed render via missing `%PDF` magic bytes.\n- `main`: routing between `db-new`/`db-mark`/`pdf-render`/mode-words; `-i`/`--interactive` flag detection; mode words stop at first flag.\n\n```python\nimport json\nimport pytest\nfrom datetime import datetime, timezone, timedelta\nfrom agent import cmd_db_new, cmd_db_mark, _normalize_ats, main\nfrom pipeline import load_config\nfrom store import Store\nfrom models import Job\n\nclass TestNormalizeAts:\n    def test_replaces_em_dash_in_text(self):\n        html, counts = _normalize_ats(\"<p>foo—bar</p>\")\n        assert \"foo-bar\" in html and counts[\"em-dash\"] == 1\n\n    def test_does_not_touch_style_block(self):\n        html, counts = _normalize_ats(\"<style>.x{content:'—'}</style><p>a—b</p>\")\n        assert \"—\" in html.split(\"</style>\")[0]\n        assert counts[\"em-dash\"] == 1  # only counted for the <p> occurrence\n\n    def test_does_not_touch_tag_attributes(self):\n        html, counts = _normalize_ats('<a title=\"em—dash\">text</a>')\n        assert 'title=\"em—dash\"' in html\n        assert \"em-dash\" not in counts\n\n\nclass TestDbNewMark(tmp_path_factory=None):\n    pass  # see below for fixture-based version\n\n@pytest.fixture\ndef cfg_path(tmp_path):\n    db_path = tmp_path / \"jobs.db\"\n    cfg = tmp_path / \"sources.yaml\"\n    cfg.write_text(f\"sources: []\\ndb: {db_path}\\n\")\n    return cfg\n\nclass TestDbMark:\n    def test_now_sets_current_iso_timestamp(self, cfg_path, capsys):\n        rc = cmd_db_mark([\"--now\", \"-c\", str(cfg_path)])\n        assert rc == 0\n        with Store(load_config(cfg_path)[\"db\"]) as s:\n            assert s.get_meta(\"last_scan\") is not None\n\n    def test_invalid_watermark_exits_2(self, cfg_path):\n        rc = cmd_db_mark([\"not-a-date\", \"-c\", str(cfg_path)])\n        assert rc == 2\n\n    def test_no_args_exits_2(self, cfg_path):\n        rc = cmd_db_mark([\"-c\", str(cfg_path)])\n        assert rc == 2\n\n\nclass TestDbNew:\n    def test_first_run_uses_since_days_window(self, cfg_path, capsys):\n        with Store(load_config(cfg_path)[\"db\"]) as s:\n            s.diff([Job(source=\"greenhouse\", company=\"acme\", external_id=\"1\",\n                         title=\"Eng\", url=\"https://x/1\")])\n        rc = cmd_db_new([\"--since-days\", \"1\", \"-c\", str(cfg_path)])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"first_run\"] is True\n        assert out[\"count\"] == 1\n\n    def test_never_splits_a_first_seen_group_at_limit(self, cfg_path, capsys):\n        # two jobs inserted in the same store.diff() call share first_seen;\n        # limit=1 should still keep both together, not truncate mid-group\n        with Store(load_config(cfg_path)[\"db\"]) as s:\n            s.diff([Job(source=\"greenhouse\", company=\"acme\", external_id=str(i),\n                        title=\"Eng\", url=f\"https://x/{i}\") for i in range(2)])\n        rc = cmd_db_new([\"--limit\", \"1\", \"-c\", str(cfg_path)])\n        out = json.loads(capsys.readouterr().out)\n        assert out[\"count\"] == 2\n```\n\n---\n\n",
